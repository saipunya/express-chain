<%- include('../partials/header',{title : 'สรุปขั้นตอนการชำระบัญชี'}) %>

<style>
  .movement-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 25px 0;
    font-size: 0.95rem;
    box-shadow: 0 4px 18px rgba(16, 52, 96, 0.1);
    border-radius: 12px;
    overflow: hidden;
  }
  .movement-table thead th {
    background: linear-gradient(135deg, #16697a, #489fb5);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: none;
    padding: 14px;
    font-size: 0.85rem;
    text-align: center;
  }
  .movement-table tbody td {
    background-color: #fff;
    border-bottom: 1px solid #edf2f7;
    padding: 12px 14px;
    vertical-align: middle;
  }
  .movement-table tbody tr:nth-child(even) td {
    background-color: #f8fafc;
  }
  .movement-table tbody tr:hover td {
    background-color: #eef7fb;
  }
  .movement-table .fixed-col {
    position: sticky;
    left: 0;
    background-color: inherit;
    z-index: 1;
  }
  .movement-table .fixed-col + .fixed-col {
    left: 160px;
  }
  .movement-table .badge-step {
    border-radius: 999px;
    padding: 4px 10px;
    font-size: 0.75rem;
  }
  .movement-table .month-cell {
    text-align: center;
    font-weight: 600;
    color: #94a3b8;
    min-width: 72px;
  }
  .movement-table .month-cell.has-activity {
    background-color: #e0f2fe;
    color: #0c4a6e;
  }
  .movement-table .month-cell .dot {
    display: inline-flex;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: #38bdf8;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    color: #fff;
  }
  .movement-table .month-cell .dot::after {
    content: '•';
    line-height: 1;
  }
  @media (max-width: 992px) {
    .movement-table thead th,
    .movement-table tbody td {
      font-size: 0.8rem;
      padding: 10px 8px;
    }
    .movement-table .month-cell {
      min-width: 56px;
    }
  }
  @media (max-width: 768px) {
    .movement-table-wrapper {
      overflow-x: auto;
    }
    .movement-table {
      min-width: 960px;
    }
  }
</style>
<div class="row my-2">
  <div class="col-12 text-center fw-bold">
    <h3>เปรียบเทียบสถานะการชำระบัญชี</h3>
    <p class="text-muted">แสดงเฉพาะสหกรณ์ที่เลิกกิจการและมีการเคลื่อนไหวของขั้นตอนชำระบัญชีหลังวันที่ 1 ต.ค. 2568</p>
  </div>
</div>
<% const fiscalMonths = [
  { label: 'ต.ค.', value: 9 },
  { label: 'พ.ย.', value: 10 },
  { label: 'ธ.ค.', value: 11 },
  { label: 'ม.ค.', value: 0 },
  { label: 'ก.พ.', value: 1 },
  { label: 'มี.ค.', value: 2 },
  { label: 'เม.ย.', value: 3 },
  { label: 'พ.ค.', value: 4 },
  { label: 'มิ.ย.', value: 5 },
  { label: 'ก.ค.', value: 6 },
  { label: 'ส.ค.', value: 7 },
  { label: 'ก.ย.', value: 8 }
]; %>

<div class="movement-table-wrapper">
  <table class="movement-table">
    <thead>
      <tr>
        <th class="text-start">สถาบัน</th>
        <th class="text-start">ขั้นที่เปลี่ยน</th>
        <th class="text-start">วันที่บันทึก</th>
        <% fiscalMonths.forEach(month => { %>
          <th><%= month.label %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="15" class="text-center text-muted py-4">ไม่พบข้อมูลในช่วงวันที่ที่กำหนด</td>
        </tr>
      <% } %>
      <% data.forEach(item => { %>
        <% const activityDate = item.date ? new Date(item.date) : null; %>
        <tr>
          <td class="fixed-col fw-semibold text-dark">
            <%= item.institution_name || '-' %>
          </td>
          <td class="fixed-col">
            <% if (item.current_max_step && item.current_max_step !== '0') { %>
              <span class="badge-step bg-primary-subtle text-primary"><%= item.current_max_step_label || (`ขั้นที่ ${item.current_max_step}`) %></span>
            <% } else { %>
              <span class="text-muted">ยังไม่เริ่ม</span>
            <% } %>
          </td>
          <td>
            <% if (activityDate) { %>
              <%= activityDate.toLocaleDateString('th-TH', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <% fiscalMonths.forEach(month => {
            const hasActivity = activityDate && activityDate.getMonth() === month.value;
          %>
            <td class="month-cell <%= hasActivity ? 'has-activity' : '' %>">
              <% if (hasActivity) { %>
                <span class="dot" title="<%= item.current_max_step_label || '' %>"></span>
              <% } %>
            </td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

 <div class="row text-center mt-2">
  <!-- ย้อนกลับหน้าหลัก /chamra -->
     <a href="/chamra" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
       <i class="bi bi-arrow-left me-2"></i> กลับไปยังหน้าหลัก
     </a>
 </div>

<%- include('../partials/footer') %>
