<!-- include header -->
<%- include('../header.ejs', { title: title }) %>
<style>
  /* campaign-page specific */
  .pcmp-id-chip {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 48px; padding: 5px 10px;
    border-radius: 9px; background: #eff6ff; color: #2563eb;
    font-weight: 800; font-size: .84rem;
  }
  .pcmp-name { font-weight: 700; color: #0f172a; }
  .pcmp-meta { color: #94a3b8; font-size: .8rem; margin-top: 3px; }
  .pcmp-date { font-weight: 500; white-space: nowrap; font-size: .88rem; }

</style>

<% const storesSafe = Array.isArray(stores) ? stores : []; %>
<div class="pad-layout">
<%- include('./_sidebar.ejs', { currentPage: 'campaigns', promotionAdmin, counts: {} }) %>
<div class="pad-main">
  <header class="pad-topbar">
    <div class="pad-topbar-left">
      <button class="pad-sidebar-toggle" id="padToggle" aria-label="Toggle menu"><i class="bi bi-list"></i></button>
      <div>
        <div class="pad-page-title"><i class="bi bi-megaphone me-2 text-primary"></i>Campaigns</div>
        <div class="pad-breadcrumb">Promotion Admin › จัดการแคมเปญ</div>
      </div>
    </div>
    <div class="pad-topbar-right">
      <span class="pad-date-badge"><i class="bi bi-calendar3 me-1"></i><span id="padDateNow"></span></span>
    </div>
  </header>
  <main class="pad-body">
    <%
      const toDateTimeLocal = (raw) => {
        if (!raw) return '';
        const d = new Date(raw);
        if (Number.isNaN(d.getTime())) return '';
        const pad = (n) => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
      };
    %>

    <% if (locals && locals.flash) { %>
      <div class="alert alert-<%= locals.flash.type || 'info' %> pad-flash">
        <%= locals.flash.message %>
      </div>
    <% } %>

    <%
      const nowTs = Date.now();
      const getCampaignTimeState = (campaign) => {
        const startTs = campaign && campaign.start_at ? new Date(campaign.start_at).getTime() : null;
        const endTs = campaign && campaign.end_at ? new Date(campaign.end_at).getTime() : null;
        const active = Boolean(campaign && campaign.active);
        const expired = Number.isFinite(endTs) && endTs < nowTs;
        const upcoming = Number.isFinite(startTs) && startTs > nowTs;
        const usable = active && !expired && !upcoming;
        if (expired) return { key: 'expired', label: 'หมดอายุแล้ว', className: 'ps-expired', detail: 'เกินช่วงเวลาที่กำหนดแล้ว' };
        if (upcoming) return { key: 'scheduled', label: 'ยังไม่เริ่ม', className: 'ps-scheduled', detail: 'รอถึงเวลาเริ่มต้น' };
        if (usable) return { key: 'usable', label: 'ยังใช้ได้', className: 'ps-active', detail: 'อยู่ในช่วงใช้งานปกติ' };
        return { key: 'inactive', label: 'ปิดใช้งาน', className: 'ps-inactive', detail: 'ถูกปิดใช้งานโดยแอดมิน' };
      };
    %>

    <div class="pad-form-card">
      <div class="pad-form-title"><i class="bi bi-plus-circle-fill text-primary"></i> เพิ่มแคมเปญใหม่</div>
        <form method="POST" action="/promotion/admin/campaigns" class="row g-3" autocomplete="off">
          <div class="col-md-3">
            <label class="form-label">สาขา</label>
            <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
              <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
              <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
            <% } else { %>
              <select class="form-select" name="store_id" required>
                <option value="">เลือกสาขา</option>
                <% storesSafe.forEach(s => { %>
                  <option value="<%= s.id %>"><%= s.name %> (<%= s.store_code || '-' %>)</option>
                <% }) %>
              </select>
            <% } %>
          </div>

          <div class="col-md-3">
            <label class="form-label">Campaign Code</label>
            <input type="text" name="campaign_code" class="form-control" maxlength="100" required placeholder="เช่น CMP-STORE01-2026">
          </div>

          <div class="col-md-6">
            <label class="form-label">ชื่อแคมเปญ</label>
            <input type="text" name="name" class="form-control" maxlength="255" required>
          </div>

          <div class="col-md-3">
            <label class="form-label">เริ่มต้น</label>
            <input type="datetime-local" name="start_at" class="form-control">
          </div>

          <div class="col-md-3">
            <label class="form-label">สิ้นสุด</label>
            <input type="datetime-local" name="end_at" class="form-control">
          </div>

          <div class="col-md-2">
            <label class="form-label d-block">สถานะ</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="campaignActive" name="active" value="1" checked>
              <label class="form-check-label" for="campaignActive">เปิดใช้งาน</label>
            </div>
          </div>

          <div class="col-md-12">
            <label class="form-label">รายละเอียด (ถ้ามี)</label>
            <textarea class="form-control" name="description" rows="2" maxlength="2000"></textarea>
          </div>

          <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-primary px-4 fw-bold"><i class="bi bi-check-circle me-1"></i> บันทึกแคมเปญ</button>
          </div>
        </form>
    </div>

    <div class="pad-card">
      <div class="pad-card-head">
        <div>
          <div class="pad-card-title"><i class="bi bi-table me-2 text-primary"></i>รายการแคมเปญทั้งหมด</div>
          <div class="pad-card-subtitle">พร้อมข้อมูลร้าน สถานะ และช่วงเวลา</div>
        </div>
        <% if (Array.isArray(campaigns)) { %><span class="pad-card-badge"><%= campaigns.length %> แคมเปญ</span><% } %>
      </div>
      <div class="table-responsive">
        <table class="table pad-tbl table-hover mb-0">
          <thead>
            <tr>
              <th>ID</th>
              <th>ชื่อแคมเปญ</th>
              <th>สาขา</th>
              <th>สถานะ</th>
              <th>เริ่มต้น</th>
              <th>สิ้นสุด</th>
              <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (Array.isArray(campaigns) && campaigns.length) { %>
                <% campaigns.forEach(c => { %>
                  <% const campaignState = getCampaignTimeState(c); %>
                  <tr>
                    <td><span class="pcmp-id-chip">#<%= c.id %></span></td>
                    <td>
                      <div class="pcmp-name"><%= c.name %></div>
                      <div class="pcmp-meta"><%= c.campaign_code || '' %></div>
                    </td>
                    <td>
                      <% if (c.store_name) { %>
                        <div class="pad-semibold"><%= c.store_name %></div>
                        <span class="pad-store-chip"><%= c.store_code || '-' %></span>
                      <% } else { %><span class="pad-muted">-</span><% } %>
                    </td>
                    <td>
                      <span class="pad-status <%= campaignState.className %>"><%= campaignState.label %></span>
                      <div class="pcmp-meta"><%= campaignState.detail %></div>
                    </td>
                    <td><span class="pcmp-date"><%= c.start_at ? new Date(c.start_at).toLocaleString('th-TH') : '-' %></span></td>
                    <td><span class="pcmp-date"><%= c.end_at ? new Date(c.end_at).toLocaleString('th-TH') : '-' %></span></td>
                    <td>
                      <div class="pad-action-group">
                        <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#editCampaignModal-<%= c.id %>">
                          <i class="bi bi-pencil me-1"></i>Edit
                        </button>
                        <form method="POST" action="/promotion/admin/campaigns/<%= c.id %>/status">
                          <input type="hidden" name="active" value="<%= c.active ? '0' : '1' %>">
                          <button class="btn btn-outline-warning btn-sm w-100"><%= c.active ? 'Deactivate' : 'Activate' %></button>
                        </form>
                        <form method="POST" action="/promotion/admin/campaigns/<%= c.id %>/delete"
                              onsubmit="return confirm('ยืนยันลบแคมเปญนี้ใช่หรือไม่?');">
                          <button class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-trash me-1"></i>Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
              <tr>
                <td colspan="7" class="pad-empty-cell">
                  <span class="pad-empty-icon d-block">📋</span>
                  <span class="pad-empty-text">ยังไม่พบรายการแคมเปญในระบบ</span>
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
</div>
<% if (Array.isArray(campaigns) && campaigns.length) { %>
  <% campaigns.forEach(c => { %>
    <% const campaignStateModal = getCampaignTimeState(c); %>
    <div class="modal fade" id="editCampaignModal-<%= c.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">แก้ไขแคมเปญ #<%= c.id %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form method="POST" action="/promotion/admin/campaigns/<%= c.id %>/update" autocomplete="off">
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">Campaign Code</label>
                  <input type="text" name="campaign_code" class="form-control" maxlength="100" value="<%= c.campaign_code || '' %>" required>
                </div>
                <div class="col-md-8">
                  <label class="form-label">ชื่อแคมเปญ</label>
                  <input type="text" name="name" class="form-control" maxlength="255" value="<%= c.name || '' %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">เริ่มต้น</label>
                  <input type="datetime-local" name="start_at" class="form-control" value="<%= toDateTimeLocal(c.start_at) %>">
                </div>
                <div class="col-md-6">
                  <label class="form-label">สิ้นสุด</label>
                  <input type="datetime-local" name="end_at" class="form-control" value="<%= toDateTimeLocal(c.end_at) %>">
                </div>
                <div class="col-12">
                  <label class="form-label">รายละเอียด</label>
                  <textarea class="form-control" name="description" rows="3" maxlength="2000"><%= c.description || '' %></textarea>
                </div>
                <div class="col-12">
                  <small class="text-muted">
                    สาขา: <%= c.store_name || '-' %> (<%= c.store_code || '-' %>) • สถานะปัจจุบัน: <%= c.active ? 'Active' : 'Inactive' %> • <%= campaignStateModal.label %>
                  </small>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
              <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
<% } %>
<!-- include footer -->
<%- include('../footer.ejs') %>
