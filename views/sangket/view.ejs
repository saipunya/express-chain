<%- include('../partials/header.ejs', { title: title || 'รายละเอียดข้อสังเกต' }) %>
<%
  const categoriesList = (item && item.categories) || [];
  const actions = (item && item.actions) || [];
  const categoryItems = categoriesList.map((cat) => {
    const name = String(cat.name || '').trim();
    const shortName = name.length > 30 ? `${name.slice(0, 30).trimEnd()}…` : name;
    return { id: cat.id, name, shortName };
  });
  const actionTypeLabel = (value) => {
    if (value === 'follow_up') return 'ติดตามผล';
    if (value === 'order') return 'คำสั่ง';
    if (value === 'advice') return 'คำแนะนำ';
    if (value === 'fact_check') return 'ตรวจข้อเท็จจริง';
    if (value === 'close') return 'ปิดเรื่อง';
    return value || '-';
  };
  const severityLabel = {
    serious_order: 'ร้ายแรง / คำสั่ง',
    advice: 'คำแนะนำ',
    fact_check: 'ตรวจข้อเท็จจริง'
  }[item?.severity_case] || '-';
  const statusLabel = item?.status || '-';
  const fmtMoney = (value) => new Intl.NumberFormat('th-TH', { maximumFractionDigits: 2 }).format(Number(value || 0));
%>

<style>
  .sangket-view-page {
    background:
      radial-gradient(circle at top left, rgba(16, 185, 129, 0.08), transparent 30%),
      radial-gradient(circle at top right, rgba(45, 212, 191, 0.06), transparent 28%),
      #f6f8fb;
    min-height: calc(100vh - 120px);
  }
  .view-shell {
    border: 1px solid #e5eef0;
    border-radius: 24px;
    background: rgba(255,255,255,0.95);
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.07);
    overflow: hidden;
  }
  .view-hero {
    background: linear-gradient(135deg, rgba(16,185,129,0.06), rgba(45,212,191,0.03));
    border-bottom: 1px solid #e5eef0;
  }
  .detail-card {
    border: 1px solid #e5edf2;
    border-radius: 18px;
    background: #fff;
    padding: 1rem 1.1rem;
    height: 100%;
  }
  .detail-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    color: #64748b;
    font-weight: 700;
  }
  .detail-value {
    color: #0f172a;
    font-weight: 600;
  }
  .timeline-item {
    border-left: 3px solid #bde8df;
    padding-left: 1rem;
    position: relative;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -7px;
    top: 0.35rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #0f8f7b;
  }
  .action-box {
    border: 1px dashed #cfe8df;
    background: #f7fcfa;
    border-radius: 18px;
  }
  .sangket-view-page .btn-primary {
    background-color: #0f8f7b;
    border-color: #0f8f7b;
  }
  .badge-soft {
    border-radius: 999px;
    padding: 0.35rem 0.7rem;
  }
  .category-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .category-pill {
    max-width: 100%;
    white-space: normal;
    text-align: left;
    line-height: 1.35;
  }
  .mini-note {
    font-size: 0.85rem;
    color: #64748b;
    margin-top: 0.35rem;
  }
</style>

<div class="sangket-view-page py-4">
  <div class="container">
    <div class="view-shell">
      <div class="view-hero p-4 p-lg-5">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
          <div>
            <div class="eyebrow mb-2">Sangket</div>
            <h1 class="h3 fw-bold mb-2"><%= item.cooperative_name %></h1>
            <p class="text-muted mb-0">
              <i class="bi bi-hash me-1"></i><%= item.cooperative_code || '-' %> |
              <%= item.fiscal_year_end || '-' %> | หนังสือ <%= item.audit_office_letter_no || '-' %>
            </p>
          </div>
          <div class="d-flex flex-wrap gap-2 align-items-start">
            <a href="/sangket/edit/<%= item.observation_id %>" class="btn btn-warning rounded-pill">
              <i class="bi bi-pencil-square me-1"></i> แก้ไข
            </a>
            <a href="/sangket" class="btn btn-outline-secondary rounded-pill">
              <i class="bi bi-arrow-left-circle me-1"></i> กลับรายการ
            </a>
          </div>
        </div>
      </div>

      <div class="p-4 p-lg-5">
        <div class="row g-3 mb-4">
          <div class="col-6 col-lg-3">
            <div class="detail-card">
              <div class="detail-label">ประเภท</div>
              <div class="detail-value"><%= item.coop_type === 'group_farmer' ? 'กลุ่มเกษตรกร' : 'สหกรณ์' %></div>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="detail-card">
              <div class="detail-label">กสส.</div>
              <div class="detail-value"><%= item.promotion_group_no || '-' %></div>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="detail-card">
              <div class="detail-label">กรณี</div>
              <div class="detail-value"><%= severityLabel %></div>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="detail-card">
              <div class="detail-label">สถานะ</div>
              <div class="detail-value"><span class="badge text-bg-primary"><%= statusLabel %></span></div>
            </div>
          </div>
        </div>

        <div class="row g-3 mb-4">
          <div class="col-lg-8">
            <div class="detail-card h-100">
              <div class="detail-label mb-2">รายละเอียดข้อสังเกต</div>
              <div class="detail-value" style="white-space: pre-line; line-height: 1.7;"><%= item.observation_text || '-' %></div>
              <hr>
              <div class="row g-3">
                <div class="col-md-4">
                  <div class="detail-label">มูลค่าความเสียหาย</div>
                  <div class="detail-value"><%= item.potential_damage_amount ? fmtMoney(item.potential_damage_amount) + ' บาท' : '-' %></div>
                </div>
                <div class="col-md-4">
                  <div class="detail-label">ลำดับข้อ</div>
                  <div class="detail-value"><%= item.observation_no || '-' %></div>
                </div>
                <div class="col-md-4">
                  <div class="detail-label">กำหนดติดตาม</div>
                  <div class="detail-value"><%= item.due_date || '-' %></div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="detail-card h-100">
              <div class="detail-label mb-2">หมวดข้อสังเกต</div>
              <div class="category-grid mb-3">
                <% if (categoryItems.length) { %>
                  <% categoryItems.forEach((cat) => { %>
                    <span class="badge text-bg-light border badge-soft category-pill" title="<%= cat.name %>">
                      <span class="fw-semibold">#<%= cat.id %></span>
                      <span class="text-muted">-</span>
                      <%= cat.shortName || cat.name || '-' %>
                    </span>
                  <% }) %>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </div>
              <% if (categoryItems.length) { %>
                <div class="mini-note mt-2">หมายเหตุ: hover ที่ป้ายหมวดเพื่อดูชื่อเต็ม</div>
              <% } %>
              <div class="mini-note">ผู้สอบบัญชี: <%= item.auditor_name || '-' %></div>
              <div class="mini-note">หนังสือรับ: <%= item.received_date || '-' %></div>
              <div class="mini-note">วันที่หนังสือ: <%= item.audit_office_letter_date || '-' %></div>
              <div class="mini-note">แหล่งข้อมูล: <%= item.source_sheet || '-' %> แถว <%= item.source_row || '-' %></div>
            </div>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-lg-7">
            <div class="detail-card">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0 fw-bold">ประวัติการติดตามผล</h5>
                <span class="badge text-bg-success"><%= actions.length %> รายการ</span>
              </div>
              <% if (actions.length) { %>
                <div class="d-grid gap-3">
                  <% actions.forEach((action) => { %>
                    <div class="timeline-item">
                      <div class="d-flex justify-content-between gap-3">
                        <div class="fw-semibold"><%= actionTypeLabel(action.action_type) %></div>
                        <div class="text-muted small"><%= action.created_at ? new Date(action.created_at).toLocaleString('th-TH') : '' %></div>
                      </div>
                      <div class="small text-muted">
                        <i class="bi bi-journal-text me-1"></i><%= action.letter_no || '-' %>
                        <% if (action.letter_date) { %> | <%= action.letter_date %><% } %>
                      </div>
                      <div class="mt-1" style="white-space: pre-line;"><%= action.action_detail || '-' %></div>
                      <% if (action.result) { %>
                        <div class="mt-1 text-success" style="white-space: pre-line;"><%= action.result %></div>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="text-muted">ยังไม่มีการบันทึกติดตามผล</div>
              <% } %>
            </div>
          </div>

          <div class="col-lg-5">
            <div class="action-box p-4">
              <h5 class="fw-bold mb-3">เพิ่มหนังสือติดตาม / คำแนะนำ</h5>
              <form method="POST" action="/sangket/view/<%= item.observation_id %>/actions" class="row g-3">
                <div class="col-12">
                  <label class="form-label">ประเภทการติดตาม</label>
                  <select name="action_type" class="form-select">
                    <option value="follow_up">ติดตามผล</option>
                    <option value="order">คำสั่ง</option>
                    <option value="advice">คำแนะนำ</option>
                    <option value="fact_check">ตรวจข้อเท็จจริง</option>
                    <option value="close">ปิดเรื่อง</option>
                  </select>
                </div>
                <div class="col-12">
                  <label class="form-label">เลขหนังสือ</label>
                  <input type="text" name="letter_no" class="form-control">
                </div>
                <div class="col-12">
                  <label class="form-label">วันที่หนังสือ</label>
                  <input type="text" name="letter_date" class="form-control" placeholder="เช่น 30 เม.ย. 69">
                </div>
                <div class="col-12">
                  <label class="form-label">รายละเอียด</label>
                  <textarea name="action_detail" class="form-control" rows="4"></textarea>
                </div>
                <div class="col-12">
                  <label class="form-label">ผลลัพธ์</label>
                  <textarea name="result" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12 d-grid">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send-check me-1"></i> บันทึกการติดตามผล
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
