      <div class="row g-3 align-items-stretch">
        <div class="col-12 col-xl-5">
          <div class="main-institution-chart-card">
            <div class="main-chart-head">
              <div>
                <h3 class="main-chart-title">
                  <i class="bi bi-bar-chart-line"></i>
                  กราฟจำนวนสถาบัน
                </h3>
                <div class="text-muted small mt-1">แสดงเฉพาะจำนวนรวมตามประเภทสถาบัน</div>
              </div>
              <span class="main-pill">
                <i class="bi bi-database-check text-success"></i>
                <span><%= _institutionTotal %> แห่ง</span>
              </span>
