<!-- include header -->
<%- include('../header.ejs', { title: title }) %>
<style>
  /* prizes-page specific */
  .prize-thumb {
    width: 64px; height: 64px; border-radius: 12px;
    border: 1px solid #e2e8f0; background: #f8fafc;
    object-fit: cover; display: block;
  }
  .prize-thumb-empty {
    width: 64px; height: 64px; border-radius: 12px;
    border: 1px dashed #cbd5e1; display: flex; align-items: center;
    justify-content: center; color: #94a3b8; font-size: .8rem; background: #f8fafc;
  }
  .prize-preview-card {
    width: 160px; height: 160px; border-radius: 14px;
    border: 1px dashed #cbd5e1; background: #f8fafc;
    display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .prize-preview-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .prize-preview-empty { color: #94a3b8; font-size: .9rem; font-weight: 600; }
  .progress { height: 8px; border-radius: 999px; }
  .badge-soft { padding: 6px 10px; border-radius: 999px; font-size: .75rem; font-weight: 600; }
  .badge-active   { background: #dcfce7; color: #15803d; }
  .badge-inactive { background: #e2e8f0; color: #334155; }
  .action-stack { display: grid; gap: 6px; min-width: 140px; }
  .prize-pricing-block { border: 1px dashed #cbd5e1; border-radius: 12px; padding: 12px; background: #f8fafc; }
  .prize-pay-preview { font-weight: 700; color: #0f172a; }
  .modal[id^="editPrizeModal-"] .modal-dialog  { margin: 1rem auto; }
  .modal[id^="editPrizeModal-"] .modal-content { max-height: calc(100vh - 2rem); overflow: hidden; }
  .modal[id^="editPrizeModal-"] .modal-header  { position: sticky; top: 0; background: #fff; z-index: 3; }
  .modal[id^="editPrizeModal-"] .modal-body    { overflow-y: auto; max-height: calc(100vh - 210px); -webkit-overflow-scrolling: touch; }
  .modal[id^="editPrizeModal-"] .modal-footer  { position: sticky; bottom: 0; background: #fff; z-index: 3; border-top: 1px solid #e2e8f0; }
</style>

<%
  const storesSafe = Array.isArray(stores) ? stores : [];
  const campaignsSafe = Array.isArray(campaigns) ? campaigns : [];
%>
<div class="pad-layout">
<%- include('./_sidebar.ejs', { currentPage: 'prizes', promotionAdmin, counts: {} }) %>
<div class="pad-main">
  <header class="pad-topbar">
    <div class="pad-topbar-left">
      <button class="pad-sidebar-toggle" id="padToggle" aria-label="Toggle menu"><i class="bi bi-list"></i></button>
      <div>
        <div class="pad-page-title"><i class="bi bi-gift me-2 text-success"></i>Prize Manager</div>
        <div class="pad-breadcrumb">Promotion Admin › จัดการของรางวัล</div>
      </div>
    </div>
    <div class="pad-topbar-right">
      <span class="pad-date-badge"><i class="bi bi-calendar3 me-1"></i><span id="padDateNow"></span></span>
    </div>
  </header>
  <main class="pad-body">

    <% if (locals && locals.flash) { %>
      <div class="alert alert-<%= locals.flash.type || 'info' %> pad-flash">
        <%= locals.flash.message %>
      </div>
    <% } %>

    <div class="pad-form-card">
      <div class="pad-form-title"><i class="bi bi-plus-circle-fill text-success me-1"></i> เพิ่มของรางวัลใหม่</div>
        <form method="POST" action="/promotion/admin/prizes" class="row g-3 prize-image-form" autocomplete="off" enctype="multipart/form-data">
          <div class="col-md-3">
            <label class="form-label">สาขา</label>
            <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
              <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
              <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
            <% } else { %>
              <select class="form-select" name="store_id" id="storeSelect" required>
                <option value="">เลือกสาขา</option>
                <% storesSafe.forEach(s => { %>
                  <option value="<%= s.id %>"><%= s.name %> (<%= s.store_code || '-' %>)</option>
                <% }) %>
              </select>
            <% } %>
          </div>

          <div class="col-md-3">
            <label class="form-label">แคมเปญ</label>
            <select class="form-select" name="campaign_id" id="campaignSelect" required>
              <option value="">เลือกแคมเปญ</option>
              <% campaignsSafe.forEach(c => { %>
                <option value="<%= c.id %>" data-store-id="<%= c.store_id %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="col-md-3">
            <label class="form-label">ชื่อของรางวัล</label>
            <input type="text" name="name" class="form-control" maxlength="255" required>
          </div>

          <div class="col-md-3">
            <label class="form-label">รหัสของรางวัล (ถ้ามี)</label>
            <input type="text" name="prize_code" class="form-control" maxlength="100">
          </div>

          <div class="col-md-6">
            <label class="form-label">รูปของรางวัล (URL)</label>
            <input type="text" name="image_url" class="form-control prize-image-url" maxlength="2000" placeholder="https://example.com/prize.jpg หรือ /uploads/prizes/item.jpg">
          </div>

          <div class="col-md-6">
            <label class="form-label">อัปโหลดรูปของรางวัล</label>
            <input type="file" name="image_file" class="form-control prize-image-file" accept="image/*">
            <small class="text-muted">รองรับ JPG/PNG/WEBP/GIF ขนาดไม่เกิน 5MB (ถ้าอัปโหลดไฟล์ จะใช้ไฟล์แทน URL)</small>
          </div>
          <div class="col-md-12">
            <label class="form-label">ตัวอย่างรูป</label>
            <div class="prize-preview-card" data-prize-preview>
              <img class="prize-preview-img d-none" alt="Prize preview">
              <div class="prize-preview-empty">ยังไม่มีรูป</div>
            </div>
          </div>

          <div class="col-md-3">
            <label class="form-label">ประเภท</label>
            <select class="form-select" name="type" data-prize-type required>
              <option value="free_product">free_product</option>
              <option value="discount">discount</option>
              <option value="coupon">coupon</option>
              <option value="credit">credit</option>
              <option value="other">other (ไม่ได้รางวัล)</option>
            </select>
          </div>

          <div class="col-md-7" data-pricing-root>
            <label class="form-label">รายละเอียดราคา/สิทธิประโยชน์</label>
            <div class="prize-pricing-block" data-type-section="discount" style="display:none;">
              <div class="row g-2 align-items-end">
                <div class="col-md-4">
                  <label class="form-label mb-1">ราคาเต็มสินค้า (บาท)</label>
                  <input type="number" class="form-control" name="full_price_amount" min="1" max="1000000000" placeholder="เช่น 590">
                </div>
                <div class="col-md-4">
                  <label class="form-label mb-1">ส่วนลด (%)</label>
                  <input type="number" class="form-control" name="discount_percent" min="1" max="100" placeholder="เช่น 10">
                </div>
                <div class="col-md-4">
                  <div class="text-muted small">ต้องระบุเมื่อเลือกประเภท discount</div>
                  <div class="small mt-1 prize-pay-preview" data-pay-preview="discount">ราคาที่ต้องจ่าย: -</div>
                </div>
              </div>
            </div>

            <div class="prize-pricing-block" data-type-section="coupon" style="display:none;">
              <div class="row g-2">
                <div class="col-md-4">
                  <label class="form-label mb-1">ราคาเต็มสินค้า (บาท)</label>
                  <input type="number" class="form-control" name="full_price_amount" min="1" max="1000000000" placeholder="เช่น 590">
                </div>
                <div class="col-md-4">
                  <label class="form-label mb-1">ชนิดคูปอง</label>
                  <select class="form-select" name="coupon_kind" data-coupon-kind>
                    <option value="">เลือกชนิดคูปอง</option>
                    <option value="cash">คูปองเงินสด</option>
                    <option value="discount">คูปองส่วนลด</option>
                  </select>
                </div>
                <div class="col-md-4" data-coupon-section="cash" style="display:none;">
                  <label class="form-label mb-1">มูลค่าคูปองเงินสด (บาท)</label>
                  <input type="number" class="form-control" name="coupon_cash_amount" min="1" max="1000000000" placeholder="เช่น 100">
                </div>
                <div class="col-md-4" data-coupon-section="discount" style="display:none;">
                  <label class="form-label mb-1">ส่วนลด (%)</label>
                  <input type="number" class="form-control" name="coupon_discount_percent" min="1" max="100" placeholder="เช่น 15">
                </div>
                <div class="col-12">
                  <div class="small mt-1 prize-pay-preview" data-pay-preview="coupon">ราคาที่ต้องจ่าย: -</div>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-2">
            <label class="form-label">จำนวนเริ่มต้น</label>
            <input type="number" name="initial_qty" class="form-control" value="0" min="0" max="1000000" required>
          </div>

          <div class="col-md-2">
            <label class="form-label">Weight</label>
            <input type="number" name="weight" class="form-control" value="1" min="1" max="1000000" required>
          </div>

          <div class="col-md-2">
            <label class="form-label d-block">สถานะ</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="activeCheck" name="active" value="1" checked>
              <label class="form-check-label" for="activeCheck">เปิดใช้งาน</label>
            </div>
          </div>

          <div class="col-md-12">
            <label class="form-label">รายละเอียด (ถ้ามี)</label>
            <textarea class="form-control" name="description" rows="2" maxlength="2000"></textarea>
          </div>

          <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-success px-4 fw-bold"><i class="bi bi-check-circle me-1"></i> บันทึกของรางวัล</button>
          </div>
        </form>
    </div>

    <!-- TABLE -->
    <div class="pad-card">
      <div class="pad-card-head">
        <div>
          <div class="pad-card-title"><i class="bi bi-gift me-2 text-success"></i>รายการของรางวัลทั้งหมด</div>
          <div class="pad-card-subtitle">พร้อมสถานะคงเหลือ จองแล้ว และน้ำหนักสำหรับสุ่ม</div>
        </div>
        <% if (Array.isArray(prizes)) { %><span class="pad-card-badge"><%= prizes.length %> รายการ</span><% } %>
      </div>
      <div class="table-responsive">
        <table class="table pad-tbl mb-0 align-middle">
          <thead>
            <tr>
              <th>Prize</th>
              <th>Image</th>
              <th>Type</th>
              <th>Campaign</th>
              <th class="text-end">Remaining</th>
              <th class="text-end">Reserved</th>
              <th class="text-end">Weight</th>
              <th>Stock</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody>
            <% if (Array.isArray(prizes) && prizes.length) { %>
              <% prizes.forEach(p => { 
                const inventory = p.inventory || {};
                const remaining = Number(inventory.remainingQty ?? p.remaining_qty ?? 0);
                const reserved = Number(inventory.reservedQty ?? p.reserved_qty ?? 0);
                const stock = Number(inventory.initialQty ?? p.initial_qty ?? 0);
                const consumed = Number(inventory.consumedQty ?? Math.max(stock - remaining - reserved, 0));
                const needsReconcile = Boolean(inventory.needsReconcile);
                const remainingPercent = Math.max(0, Math.min(100, Number(inventory.availablePercent ?? (stock > 0 ? (remaining / stock) * 100 : 0))));
                const reservedPercent = Math.max(0, Math.min(100, Number(inventory.reservedPercent ?? (stock > 0 ? (reserved / stock) * 100 : 0))));
                const consumedPercent = Math.max(0, Math.min(100, Number(inventory.consumedPercent ?? (stock > 0 ? (consumed / stock) * 100 : 0))));
                const meta = p.metadata_obj || {};
                const fullPrice = Number(meta.full_price_amount || 0);
                const hasFullPrice = Number.isFinite(fullPrice) && fullPrice > 0;
                let payablePrice = null;
                if (hasFullPrice && p.type === 'discount') {
                  const dp = Number(meta.discount_percent || 0);
                  if (dp > 0 && dp <= 100) payablePrice = Math.max(fullPrice - (fullPrice * dp / 100), 0);
                }
                if (hasFullPrice && p.type === 'coupon' && meta.coupon_kind === 'cash') {
                  const cash = Number(meta.coupon_cash_amount || 0);
                  if (cash > 0) payablePrice = Math.max(fullPrice - cash, 0);
                }
                if (hasFullPrice && p.type === 'coupon' && meta.coupon_kind === 'discount') {
                  const cp = Number(meta.coupon_discount_percent || 0);
                  if (cp > 0 && cp <= 100) payablePrice = Math.max(fullPrice - (fullPrice * cp / 100), 0);
                }
                if (hasFullPrice && p.type === 'free_product') {
                  payablePrice = 0;
                }
              %>
              <tr>
                <td class="fw-bold">
                  <%= p.name %>
                  <% if (needsReconcile) { %>
                    <div class="small text-danger fw-semibold">Inventory mismatch</div>
                  <% } %>
                </td>
                <td>
                  <% if (p.image_url) { %>
                    <a href="<%= p.image_url %>" target="_blank" rel="noopener noreferrer">
                      <img src="<%= p.image_url %>" alt="<%= p.name %>" class="prize-thumb">
                    </a>
                  <% } else { %>
                    <div class="prize-thumb-empty">No image</div>
                  <% } %>
                </td>
                <td>
                  <span class="text-muted"><%= p.type || '-' %></span>
                  <% if (p.type === 'discount' && Number.isInteger(Number(meta.discount_percent))) { %>
                    <div class="small text-primary">ลด <%= Number(meta.discount_percent) %>%</div>
                  <% } %>
                  <% if (p.type === 'coupon' && meta.coupon_kind === 'cash') { %>
                    <div class="small text-primary">คูปองเงินสด <%= Number(meta.coupon_cash_amount || 0).toLocaleString('th-TH') %> บาท</div>
                  <% } %>
                  <% if (p.type === 'coupon' && meta.coupon_kind === 'discount') { %>
                    <div class="small text-primary">คูปองส่วนลด <%= Number(meta.coupon_discount_percent || 0) %>%</div>
                  <% } %>
                  <% if (hasFullPrice) { %>
                    <div class="small text-muted">ราคาเต็ม <%= Number(fullPrice).toLocaleString('th-TH') %> บาท</div>
                  <% } %>
                  <% if (payablePrice !== null) { %>
                    <div class="small fw-bold text-success">ต้องจ่าย <%= Number(payablePrice).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 }) %> บาท</div>
                  <% } %>
                </td>

                <td><%= p.campaign_name || '-' %></td>

                <td class="text-end">
                  <span class="fw-semibold"><%= remaining %></span>
                </td>

                <td class="text-end text-muted">
                  <%= reserved %>
                </td>

                <td class="text-end">
                  <span class="fw-semibold"><%= Number(p.weight || 0) %></span>
                </td>

                <!-- 🔥 PROGRESS BAR -->
                <td style="min-width:150px;">
                  <div class="d-flex justify-content-between small mb-1">
                    <span class="fw-semibold"><%= stock %></span>
                    <span class="text-muted">used <%= consumed %></span>
                  </div>
                  <div class="progress" title="Remaining + Reserved + Used = Stock">
                    <div class="progress-bar bg-success" style="width:<%= remainingPercent %>%"></div>
                    <div class="progress-bar bg-warning" style="width:<%= reservedPercent %>%"></div>
                    <div class="progress-bar bg-secondary" style="width:<%= consumedPercent %>%"></div>
                  </div>
                  <small class="text-muted">
                    R <%= remaining %> / Res <%= reserved %> / Used <%= consumed %>
                  </small>
                  <% if (needsReconcile) { %>
                    <small class="text-danger d-block">
                      Draw truth: R <%= inventory.expectedRemainingQty %> / Res <%= inventory.expectedReservedQty %> / Used <%= inventory.claimedDraws %>
                    </small>
                  <% } %>
                </td>

                <td>
                  <% if (p.active) { %>
                    <span class="badge-soft badge-active">Active</span>
                  <% } else { %>
                    <span class="badge-soft badge-inactive">Inactive</span>
                  <% } %>
                </td>
                <td>
                  <div class="action-stack">
                    <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#editPrizeModal-<%= p.id %>">
                      Edit
                    </button>
                    <form method="POST" action="/promotion/admin/prizes/<%= p.id %>/status">
                      <input type="hidden" name="active" value="<%= p.active ? '0' : '1' %>">
                      <button class="btn btn-outline-warning btn-sm w-100">
                        <%= p.active ? 'Deactivate' : 'Activate' %>
                      </button>
                    </form>
                    <form method="POST" action="/promotion/admin/prizes/<%= p.id %>/delete" onsubmit="return confirm('ยืนยันการลบรางวัลนี้?');">
                      <% if (needsReconcile) { %>
                        <button class="btn btn-outline-info btn-sm w-100"
                                type="submit"
                                form="reconcilePrizeForm-<%= p.id %>">Reconcile</button>
                      <% } %>
                      <button class="btn btn-outline-danger btn-sm w-100">Delete</button>
                    </form>
                    <% if (needsReconcile) { %>
                      <form id="reconcilePrizeForm-<%= p.id %>" method="POST" action="/promotion/admin/prizes/<%= p.id %>/reconcile" onsubmit="return confirm('Reconcile inventory from draw history for this prize?');"></form>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
              <td class="text-center text-muted py-4">
                  <span class="pad-empty-icon d-block">🎁</span>
                  <span class="pad-empty-text">ยังไม่มีรายการของรางวัล</span>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
        </div>
      </div>
    </div>
  </main>
</div>
</div>
<% if (Array.isArray(prizes) && prizes.length) { %>
  <% prizes.forEach(p => { %>
    <%
      const inventory = p.inventory || {};
      const editRemaining = Number(inventory.remainingQty ?? p.remaining_qty ?? 0);
      const editReserved = Number(inventory.reservedQty ?? p.reserved_qty ?? 0);
      const editStock = Number(inventory.initialQty ?? p.initial_qty ?? 0);
      const editConsumed = Number(inventory.consumedQty ?? Math.max(editStock - editRemaining - editReserved, 0));
      const editMinStock = Number(inventory.minInitialQty ?? (editConsumed + editReserved));
    %>
    <div class="modal fade" id="editPrizeModal-<%= p.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">แก้ไขของรางวัล #<%= p.id %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form method="POST" action="/promotion/admin/prizes/<%= p.id %>/update" class="prize-image-form" autocomplete="off" enctype="multipart/form-data">
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">ชื่อของรางวัล</label>
                  <input type="text" name="name" class="form-control" maxlength="255" value="<%= p.name || '' %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">รหัสของรางวัล (ถ้ามี)</label>
                  <input type="text" name="prize_code" class="form-control" maxlength="100" value="<%= p.prize_code || '' %>">
                </div>
                <div class="col-12">
                  <label class="form-label">รูปของรางวัล (URL)</label>
                  <input type="text" name="image_url" class="form-control prize-image-url" maxlength="2000" value="<%= p.image_url || '' %>" placeholder="https://example.com/prize.jpg หรือ /uploads/prizes/item.jpg">
                </div>
                <div class="col-12">
                  <label class="form-label">อัปโหลดรูปใหม่</label>
                  <input type="file" name="image_file" class="form-control prize-image-file" accept="image/*">
                  <small class="text-muted">ถ้าอัปโหลดรูปใหม่ ระบบจะใช้ไฟล์ใหม่แทนค่า URL เดิม</small>
                </div>
                <div class="col-12">
                  <label class="form-label">ตัวอย่างรูป</label>
                  <div class="prize-preview-card" data-prize-preview>
                    <img class="prize-preview-img d-none" alt="Prize preview">
                    <div class="prize-preview-empty">ยังไม่มีรูป</div>
                  </div>
                </div>
                <div class="col-md-4">
                  <label class="form-label">ประเภท</label>
                  <select class="form-select" name="type" data-prize-type required>
                    <option value="free_product" <%= p.type === 'free_product' ? 'selected' : '' %>>free_product</option>
                    <option value="discount" <%= p.type === 'discount' ? 'selected' : '' %>>discount</option>
                    <option value="coupon" <%= p.type === 'coupon' ? 'selected' : '' %>>coupon</option>
                    <option value="credit" <%= p.type === 'credit' ? 'selected' : '' %>>credit</option>
                    <option value="other" <%= p.type === 'other' ? 'selected' : '' %>>other (ไม่ได้รางวัล)</option>
                  </select>
                </div>
                <div class="col-md-8" data-pricing-root>
                  <label class="form-label">รายละเอียดราคา/สิทธิประโยชน์</label>
                  <div class="prize-pricing-block" data-type-section="discount" style="display:none;">
                    <div class="row g-2 align-items-end">
                      <div class="col-md-4">
                        <label class="form-label mb-1">ราคาเต็มสินค้า (บาท)</label>
                        <input type="number" class="form-control" name="full_price_amount" min="1" max="1000000000" value="<%= Number((p.metadata_obj && p.metadata_obj.full_price_amount) || '') || '' %>">
                      </div>
                      <div class="col-md-4">
                        <label class="form-label mb-1">ส่วนลด (%)</label>
                        <input type="number" class="form-control" name="discount_percent" min="1" max="100" value="<%= Number((p.metadata_obj && p.metadata_obj.discount_percent) || '') || '' %>">
                      </div>
                      <div class="col-md-4">
                        <div class="text-muted small">ต้องระบุเมื่อเลือกประเภท discount</div>
                        <div class="small mt-1 prize-pay-preview" data-pay-preview="discount">ราคาที่ต้องจ่าย: -</div>
                      </div>
                    </div>
                  </div>
                  <div class="prize-pricing-block" data-type-section="coupon" style="display:none;">
                    <div class="row g-2">
                      <div class="col-md-4">
                        <label class="form-label mb-1">ราคาเต็มสินค้า (บาท)</label>
                        <input type="number" class="form-control" name="full_price_amount" min="1" max="1000000000" value="<%= Number((p.metadata_obj && p.metadata_obj.full_price_amount) || '') || '' %>">
                      </div>
                      <div class="col-md-4">
                        <label class="form-label mb-1">ชนิดคูปอง</label>
                        <select class="form-select" name="coupon_kind" data-coupon-kind>
                          <option value="">เลือกชนิดคูปอง</option>
                          <option value="cash" <%= p.metadata_obj && p.metadata_obj.coupon_kind === 'cash' ? 'selected' : '' %>>คูปองเงินสด</option>
                          <option value="discount" <%= p.metadata_obj && p.metadata_obj.coupon_kind === 'discount' ? 'selected' : '' %>>คูปองส่วนลด</option>
                        </select>
                      </div>
                      <div class="col-md-4" data-coupon-section="cash" style="display:none;">
                        <label class="form-label mb-1">มูลค่าคูปองเงินสด (บาท)</label>
                        <input type="number" class="form-control" name="coupon_cash_amount" min="1" max="1000000000" value="<%= Number((p.metadata_obj && p.metadata_obj.coupon_cash_amount) || '') || '' %>">
                      </div>
                      <div class="col-md-4" data-coupon-section="discount" style="display:none;">
                        <label class="form-label mb-1">ส่วนลด (%)</label>
                        <input type="number" class="form-control" name="coupon_discount_percent" min="1" max="100" value="<%= Number((p.metadata_obj && p.metadata_obj.coupon_discount_percent) || '') || '' %>">
                      </div>
                      <div class="col-12">
                        <div class="small mt-1 prize-pay-preview" data-pay-preview="coupon">ราคาที่ต้องจ่าย: -</div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <label class="form-label">จำนวนรางวัล</label>
                  <input type="number" name="initial_qty" class="form-control" min="<%= editMinStock %>" max="1000000" value="<%= editStock %>" required>
                  <small class="text-muted d-block">Stock total. Remaining <%= editRemaining %> | Reserved <%= editReserved %> | Used <%= editConsumed %> | Min <%= editMinStock %></small>
                  <small class="text-muted">คงเหลือปัจจุบัน <%= Number(p.remaining_qty || 0) %> | จองอยู่ <%= Number(p.reserved_qty || 0) %></small>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Weight</label>
                  <input type="number" name="weight" class="form-control" min="1" max="1000000" value="<%= Number(p.weight || 1) %>" required>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Campaign</label>
                  <input type="text" class="form-control" value="<%= p.campaign_name || '-' %>" readonly>
                </div>
                <div class="col-12">
                  <label class="form-label">รายละเอียด</label>
                  <textarea class="form-control" name="description" rows="3" maxlength="2000"><%= p.description || '' %></textarea>
                </div>
                <div class="col-12">
                  <small class="text-muted">หมายเหตุ: ระบบจะปรับจำนวนคงเหลือให้อัตโนมัติตามจำนวนรางวัลใหม่ โดยไม่กระทบจำนวนที่จองอยู่</small>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
              <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
<% } %>
<script>
  (function () {
    const storeSelect = document.getElementById('storeSelect');
    const campaignSelect = document.getElementById('campaignSelect');
    if (!campaignSelect) return;

    const allCampaignOptions = Array.from(campaignSelect.querySelectorAll('option[data-store-id]')).map((opt) => ({
      value: opt.value,
      label: opt.textContent,
      storeId: String(opt.getAttribute('data-store-id') || '')
    }));

    const renderCampaigns = (storeId) => {
      const current = campaignSelect.value;
      campaignSelect.innerHTML = '<option value="">เลือกแคมเปญ</option>';
      allCampaignOptions
        .filter((item) => !storeId || item.storeId === String(storeId))
        .forEach((item) => {
          const option = document.createElement('option');
          option.value = item.value;
          option.textContent = item.label;
          option.setAttribute('data-store-id', item.storeId);
          if (item.value === current) option.selected = true;
          campaignSelect.appendChild(option);
        });
      if (!campaignSelect.value) campaignSelect.value = '';
    };

    if (storeSelect) {
      storeSelect.addEventListener('change', () => renderCampaigns(storeSelect.value));
      renderCampaigns(storeSelect.value);
    } else {
      renderCampaigns('');
    }
  })();

  (function () {
    const imageForms = Array.from(document.querySelectorAll('.prize-image-form'));
    if (!imageForms.length) return;

    imageForms.forEach((form) => {
      const urlInput = form.querySelector('.prize-image-url');
      const fileInput = form.querySelector('.prize-image-file');
      const previewCard = form.querySelector('[data-prize-preview]');
      if (!previewCard || !urlInput || !fileInput) return;

      const previewImg = previewCard.querySelector('.prize-preview-img');
      const previewEmpty = previewCard.querySelector('.prize-preview-empty');
      let objectUrl = null;

      const showPreview = (src) => {
        if (!previewImg || !previewEmpty || !src) return;
        previewImg.src = src;
        previewImg.classList.remove('d-none');
        previewEmpty.classList.add('d-none');
      };

      const hidePreview = () => {
        if (!previewImg || !previewEmpty) return;
        previewImg.removeAttribute('src');
        previewImg.classList.add('d-none');
        previewEmpty.classList.remove('d-none');
      };

      const clearObjectUrl = () => {
        if (objectUrl) {
          URL.revokeObjectURL(objectUrl);
          objectUrl = null;
        }
      };

      const refreshPreview = () => {
        if (fileInput.files && fileInput.files.length > 0) {
          clearObjectUrl();
          objectUrl = URL.createObjectURL(fileInput.files[0]);
          showPreview(objectUrl);
          return;
        }

        clearObjectUrl();
        const url = String(urlInput.value || '').trim();
        if (url) {
          showPreview(url);
          return;
        }
        hidePreview();
      };

      if (previewImg) {
        previewImg.addEventListener('error', () => {
          if (!fileInput.files || !fileInput.files.length) {
            hidePreview();
          }
        });
      }

      urlInput.addEventListener('input', refreshPreview);
      fileInput.addEventListener('change', refreshPreview);
      form.addEventListener('reset', () => {
        clearObjectUrl();
        setTimeout(refreshPreview, 0);
      });

      refreshPreview();
    });
  })();

  (function () {
    const forms = Array.from(document.querySelectorAll('.prize-image-form'));
    if (!forms.length) return;

    const syncPricingFields = (form) => {
      const typeSelect = form.querySelector('[data-prize-type]');
      const root = form.querySelector('[data-pricing-root]');
      if (!typeSelect || !root) return;

      const sections = {
        discount: root.querySelector('[data-type-section="discount"]'),
        coupon: root.querySelector('[data-type-section="coupon"]')
      };

      const discountInput = root.querySelector('input[name="discount_percent"]');
      const fullPriceInputs = Array.from(root.querySelectorAll('input[name="full_price_amount"]'));
      const couponKind = root.querySelector('[data-coupon-kind]');
      const couponCashWrap = root.querySelector('[data-coupon-section="cash"]');
      const couponDiscountWrap = root.querySelector('[data-coupon-section="discount"]');
      const couponCashInput = root.querySelector('input[name="coupon_cash_amount"]');
      const couponDiscountInput = root.querySelector('input[name="coupon_discount_percent"]');
      const discountPayPreview = root.querySelector('[data-pay-preview="discount"]');
      const couponPayPreview = root.querySelector('[data-pay-preview="coupon"]');

      const type = String(typeSelect.value || '');
      const isDiscount = type === 'discount';
      const isCoupon = type === 'coupon';

      if (sections.discount) sections.discount.style.display = isDiscount ? '' : 'none';
      if (sections.coupon) sections.coupon.style.display = isCoupon ? '' : 'none';
      if (discountInput) discountInput.required = isDiscount;

      const enabledIndex = isDiscount ? 0 : (isCoupon ? 1 : -1);
      const sharedFullPriceValue = fullPriceInputs
        .map((input) => String(input.value || '').trim())
        .find((value) => value !== '') || '';
      fullPriceInputs.forEach((input, index) => {
        const enabled = index === enabledIndex;
        input.disabled = !enabled;
        input.required = enabled;
        if (enabled) input.value = sharedFullPriceValue;
      });

      const fullPriceInput = fullPriceInputs.find((input) => !input.disabled) || null;
      if (couponKind) couponKind.required = isCoupon;

      if (!isDiscount && discountInput) discountInput.value = '';
      if (!(isDiscount || isCoupon) && fullPriceInput) fullPriceInput.value = '';
      if (!isCoupon && couponKind) couponKind.value = '';

      const kind = String((couponKind && couponKind.value) || '');
      const showCash = isCoupon && kind === 'cash';
      const showDiscount = isCoupon && kind === 'discount';

      if (couponCashWrap) couponCashWrap.style.display = showCash ? '' : 'none';
      if (couponDiscountWrap) couponDiscountWrap.style.display = showDiscount ? '' : 'none';
      if (couponCashInput) couponCashInput.required = showCash;
      if (couponDiscountInput) couponDiscountInput.required = showDiscount;

      if (!showCash && couponCashInput) couponCashInput.value = '';
      if (!showDiscount && couponDiscountInput) couponDiscountInput.value = '';

      const fullPrice = Number((fullPriceInput && fullPriceInput.value) || 0);
      const discountPercent = Number((discountInput && discountInput.value) || 0);
      const couponCashAmount = Number((couponCashInput && couponCashInput.value) || 0);
      const couponDiscountPercent = Number((couponDiscountInput && couponDiscountInput.value) || 0);

      const formatMoney = (v) => Number(v).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 });

      if (discountPayPreview) {
        if (isDiscount && fullPrice > 0 && discountPercent > 0 && discountPercent <= 100) {
          const payable = Math.max(fullPrice - (fullPrice * discountPercent / 100), 0);
          discountPayPreview.textContent = `ราคาที่ต้องจ่าย: ${formatMoney(payable)} บาท`;
        } else {
          discountPayPreview.textContent = 'ราคาที่ต้องจ่าย: -';
        }
      }

      if (couponPayPreview) {
        if (isCoupon && fullPrice > 0 && kind === 'cash' && couponCashAmount > 0) {
          const payable = Math.max(fullPrice - couponCashAmount, 0);
          couponPayPreview.textContent = `ราคาที่ต้องจ่าย: ${formatMoney(payable)} บาท`;
        } else if (isCoupon && fullPrice > 0 && kind === 'discount' && couponDiscountPercent > 0 && couponDiscountPercent <= 100) {
          const payable = Math.max(fullPrice - (fullPrice * couponDiscountPercent / 100), 0);
          couponPayPreview.textContent = `ราคาที่ต้องจ่าย: ${formatMoney(payable)} บาท`;
        } else {
          couponPayPreview.textContent = 'ราคาที่ต้องจ่าย: -';
        }
      }
    };

    forms.forEach((form) => {
      const typeSelect = form.querySelector('[data-prize-type]');
      const couponKind = form.querySelector('[data-coupon-kind]');
      const fullPriceInputs = Array.from(form.querySelectorAll('input[name="full_price_amount"]'));
      const discountInput = form.querySelector('input[name="discount_percent"]');
      const couponCashInput = form.querySelector('input[name="coupon_cash_amount"]');
      const couponDiscountInput = form.querySelector('input[name="coupon_discount_percent"]');
      if (typeSelect) typeSelect.addEventListener('change', () => syncPricingFields(form));
      if (couponKind) couponKind.addEventListener('change', () => syncPricingFields(form));
      fullPriceInputs.forEach((fullPriceInput) => {
        fullPriceInput.addEventListener('input', () => syncPricingFields(form));
      });
      if (discountInput) discountInput.addEventListener('input', () => syncPricingFields(form));
      if (couponCashInput) couponCashInput.addEventListener('input', () => syncPricingFields(form));
      if (couponDiscountInput) couponDiscountInput.addEventListener('input', () => syncPricingFields(form));
      syncPricingFields(form);
    });
  })();
</script>
<!-- include footer -->
<%- include('../footer.ejs') %>
