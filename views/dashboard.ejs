  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const calendarEl = document.getElementById('dashboardActivitiesCalendar');
      const fallbackEl = document.getElementById('dashboardActivitiesCalendarFallback');
      if (!calendarEl) return;

      const calendarItems = <%- JSON.stringify(_calendarItems || []).replace(/</g, '\\u003c') %>;
      const sourceClassMap = {
        travel_request: 'calendar-event--travel',
        meetingroom: 'calendar-event--meeting',
        gitgum: 'calendar-event--gitgum'
      };

      function formatThaiDate(value) {
        if (!value) return '-';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return String(value).slice(0, 10);
        return date.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });
      }

      function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value || '-';
      }

      function formatEventDate(item) {
        const props = item.extendedProps || {};
        if (props.dateLabel) return props.dateLabel;
        const startLabel = formatThaiDate(item.start);
        if (!item.end || item.end === item.start) return startLabel;
        const endDate = new Date(item.end);
        if (Number.isNaN(endDate.getTime())) return startLabel;
        endDate.setDate(endDate.getDate() - 1);
        const endLabel = formatThaiDate(endDate);
        return endLabel && endLabel !== startLabel ? startLabel + ' ถึง ' + endLabel : startLabel;
      }

      function openActivityModal(item) {
        const modalEl = document.getElementById('dashboardActivityModal');
        if (!modalEl) return;
        const props = item.extendedProps || {};
        setText('dashboardActivityModalTitle', item.title || '-');
        setText('dashboardActivityDate', formatEventDate(item));
        setText('dashboardActivityTime', props.timeLabel || '-');
        setText('dashboardActivityPlace', props.place || '-');
        setText('dashboardActivityPeople', props.goto || props.respon || '-');

        const detailLink = document.getElementById('dashboardActivityDetailLink');
        if (detailLink) {
          detailLink.href = props.detailUrl || '/gitgum/calendar';
          detailLink.classList.toggle('d-none', !props.detailUrl);
        }

        if (window.bootstrap && window.bootstrap.Modal) {
          window.bootstrap.Modal.getOrCreateInstance(modalEl).show();
        }
      }

      document.querySelectorAll('.dashboard-activity-fallback-item').forEach(function(button) {
        button.addEventListener('click', function() {
          const index = Number(button.getAttribute('data-activity-index'));
          openActivityModal(calendarItems[index] || {});
        });
      });

      if (typeof FullCalendar === 'undefined') {
        if (fallbackEl) fallbackEl.classList.remove('d-none');
        return;
      }

      const events = (calendarItems || [])
        .filter(function(item) { return item && item.start; })
        .map(function(item, index) {
          const props = item.extendedProps || {};
          const sourceType = props.sourceType || 'gitgum';
          const className = sourceClassMap[sourceType] || sourceClassMap.gitgum;
          return Object.assign({}, item, {
            id: item.id || String(index + 1),
            allDay: typeof item.allDay === 'boolean' ? item.allDay : true,
            classNames: Array.from(new Set([].concat(item.classNames || [], className)))
          });
        });

      try {
        const calendar = new FullCalendar.Calendar(calendarEl, {
          initialView: 'dayGridMonth',
          locale: 'th',
          height: 'auto',
          fixedWeekCount: false,
          showNonCurrentDates: false,
          dayMaxEventRows: 2,
          headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: ''
          },
          buttonText: { today: 'วันนี้' },
          events: events,
          eventClick: function(info) {
            info.jsEvent.preventDefault();
            openActivityModal({
              id: info.event.id,
              title: info.event.title,
              start: info.event.startStr,
              end: info.event.endStr || null,
              allDay: info.event.allDay,
              extendedProps: info.event.extendedProps || {}
            });
          }
        });
        calendar.render();
        if (fallbackEl && events.length) fallbackEl.classList.add('d-none');
      } catch (error) {
        if (fallbackEl) fallbackEl.classList.remove('d-none');
      }
    });
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.dashboard-toggle-btn').forEach(function(button) {
        const targetGroup = button.getAttribute('data-target-group');
        const target = document.querySelector('.dashboard-menu-grid[data-dashboard-group="' + targetGroup + '"]');
        if (!target) return;

        if (window.innerWidth > 575.98 || target.children.length <= 6) {
          button.parentElement.style.display = 'none';
          return;
        }

        button.addEventListener('click', function() {
          const expanded = target.classList.toggle('is-expanded');
          button.classList.toggle('is-expanded', expanded);
          button.innerHTML = '<i class="bi bi-chevron-down me-1"></i>' + (expanded ? button.dataset.collapseLabel : button.dataset.expandLabel);
        });
      });
    });
  </script>

