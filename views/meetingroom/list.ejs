<script>
  // Wait for DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', function() {
    (function(){
      const toggleButton = document.querySelector('.meeting-list-toggle');
      const upcomingList = document.querySelector('.upcoming-list');

      if (!toggleButton || !upcomingList || window.innerWidth > 767.98) {
        return;
      }

      toggleButton.addEventListener('click', function() {
        const expanded = upcomingList.classList.toggle('is-expanded');
        toggleButton.classList.toggle('is-expanded', expanded);
        toggleButton.innerHTML = '<i class="bi bi-chevron-down me-1"></i>' + (expanded ? toggleButton.dataset.collapseLabel : toggleButton.dataset.expandLabel);
      });
    })();

    // Modal detail handler
    (function(){
      const detailButtons = document.querySelectorAll('.btn-detail');
      const modal = document.getElementById('detailModal');

      if (!modal) {
        console.error('Detail modal not found');
        return;
      }

      // Move modal under <body> so Bootstrap stacking context works reliably
      if (modal.parentElement && modal.parentElement !== document.body) {
        document.body.appendChild(modal);
      }

      const hasBootstrapModal = !!(window.bootstrap && typeof bootstrap.Modal === 'function');

      // Fallback show/hide when Bootstrap JS is not available (e.g. CDN โหลดไม่ได้)
      function showFallbackModal() {
        modal.classList.add('show');
        modal.style.display = 'block';
        modal.removeAttribute('aria-hidden');
        modal.setAttribute('aria-modal', 'true');
        modal.setAttribute('role', 'dialog');

        // สร้าง backdrop แบบง่าย ๆ
        if (!document.getElementById('detailModal-backdrop-fallback')) {
          const backdrop = document.createElement('div');
          backdrop.id = 'detailModal-backdrop-fallback';
          backdrop.className = 'modal-backdrop fade show';
          document.body.appendChild(backdrop);
        }
        document.body.classList.add('modal-open');
      }

      function hideFallbackModal() {
        modal.classList.remove('show');
        modal.style.display = 'none';
        modal.setAttribute('aria-hidden', 'true');
        modal.removeAttribute('aria-modal');

        const backdrop = document.getElementById('detailModal-backdrop-fallback');
        if (backdrop) backdrop.remove();
        document.body.classList.remove('modal-open');
      }

      if (!hasBootstrapModal) {
        // ถ้าไม่มี Bootstrap JS ให้ผูกปุ่มปิดเอง
        const closeButtons = modal.querySelectorAll('[data-bs-dismiss="modal"], .btn-close');
        closeButtons.forEach(btn => {
          btn.addEventListener('click', hideFallbackModal);
        });
      }

      detailButtons.forEach(btn => {
        btn.addEventListener('click', function() {
          const d = this.dataset;

          // Update modal content
          const mdSubject = document.getElementById('md-subject');
          const mdDatetime = document.getElementById('md-datetime');
          const mdRoom = document.getElementById('md-room');
          const mdRespon = document.getElementById('md-respon');
          const mdSaveby = document.getElementById('md-saveby');
          const mdSavedate = document.getElementById('md-savedate');
          const mdEdit = document.getElementById('md-edit');
          const mdDeleteForm = document.getElementById('md-delete-form');
          const mdDeleteBtn = document.getElementById('md-delete-btn');

          if (mdSubject) mdSubject.textContent = d.subject || '';
          if (mdDatetime) {
            const dt = d.dateDisplay || d.date || '';
            mdDatetime.textContent = (dt ? dt : '') + (d.time ? ' · ' + d.time : '');
          }
          if (mdRoom) mdRoom.textContent = d.room || '';
          if (mdRespon) mdRespon.textContent = d.respon || '';
          if (mdSaveby) mdSaveby.textContent = d.saveby || '';
          if (mdSavedate) mdSavedate.textContent = d.savedateDisplay || d.savedate || '';
          if (mdEdit && d.id) mdEdit.href = '/meetingroom/edit/' + d.id;
          if (mdDeleteForm && d.id) mdDeleteForm.action = '/meetingroom/delete/' + d.id;

          // Check if current user can delete this meeting
          const currentUser = <%- user ? JSON.stringify({
            fullname: user.fullname,
            username: user.username,
            name: user.name,
            mClass: user.mClass
          }) : 'null' %>;

          const canDelete = currentUser && (
            currentUser.mClass === 'admin' || 
            currentUser.mClass === 'pbt' ||
            currentUser.fullname === d.saveby || 
            currentUser.username === d.saveby ||
            currentUser.name === d.saveby
          );
          
          if (mdDeleteBtn) {
            mdDeleteBtn.style.display = canDelete ? 'inline-block' : 'none';
          }

          // Ensure modal is shown even if data-bs-toggle doesn't fire
          if (hasBootstrapModal) {
            const instance = bootstrap.Modal.getOrCreateInstance(modal);
            instance.show();
          } else {
            showFallbackModal();
          }
        });
      });
    })();

    // Delete button handler
    (function(){
      const deleteButtons = document.querySelectorAll('.btn-delete');
      
      deleteButtons.forEach(btn => {
        btn.addEventListener('click', function(event) {
          event.preventDefault();
          event.stopImmediatePropagation();
          const id = this.dataset.id;
          const subject = this.dataset.subject;
          
          if (confirm(`ยืนยันการลบการจอง: "${subject}"?`)) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = `/meetingroom/delete/${id}`;
            document.body.appendChild(form);
            form.submit();
          }
        });
      });
    })();
  });
</script>

