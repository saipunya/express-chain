<%- include('../partials/header') %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">รายงานคำขอไปราชการ</h3>
    <p class="text-muted mb-0">สรุปคำขอไปราชการและการเชื่อมโยงไปยังคำขอใช้รถราชการ</p>
  </div>
  <a href="/official-travel" class="btn btn-outline-secondary">กลับหน้ารายการ</a>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<form class="card shadow-sm border-0 mb-4" method="GET" action="/official-travel/report">
  <div class="card-body">
    <div class="row g-3 align-items-end">
      <div class="col-md-3">
        <label class="form-label">ตั้งแต่วันที่</label>
        <input type="date" class="form-control" name="dateFrom" value="<%= filters.dateFrom %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">ถึงวันที่</label>
        <input type="date" class="form-control" name="dateTo" value="<%= filters.dateTo %>">
      </div>
      <div class="col-md-3">
        <label class="form-label">สถานะ</label>
        <select class="form-select" name="status">
          <option value="" <%= !filters.status ? 'selected' : '' %>>ทั้งหมด</option>
          <% ['draft', 'submitted', 'approved', 'rejected', 'cancelled'].forEach((status) => { %>
            <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>><%= status %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">วิธีเดินทาง</label>
        <select class="form-select" name="transportType">
          <option value="" <%= !filters.transportType ? 'selected' : '' %>>ทั้งหมด</option>
          <% ['official_vehicle', 'private_vehicle', 'other'].forEach((transportType) => { %>
            <option value="<%= transportType %>" <%= filters.transportType === transportType ? 'selected' : '' %>><%= transportType %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12 d-flex gap-2 justify-content-end">
        <button type="submit" class="btn btn-primary">กรองรายงาน</button>
        <a href="/official-travel/report" class="btn btn-outline-secondary">ล้าง</a>
      </div>
    </div>
  </div>
</form>

<div class="row g-3 mb-4">
  <div class="col-md-2 col-6"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">ทั้งหมด</div><div class="fs-4 fw-semibold"><%= summary.total %></div></div></div></div>
  <div class="col-md-2 col-6"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">ส่งอนุมัติ</div><div class="fs-4 fw-semibold"><%= summary.submitted %></div></div></div></div>
  <div class="col-md-2 col-6"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">อนุมัติแล้ว</div><div class="fs-4 fw-semibold"><%= summary.approved %></div></div></div></div>
  <div class="col-md-2 col-6"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">ไม่อนุมัติ</div><div class="fs-4 fw-semibold"><%= summary.rejected %></div></div></div></div>
  <div class="col-md-2 col-6"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">ผูกคำขอใช้รถ</div><div class="fs-4 fw-semibold"><%= summary.withVehicle %></div></div></div></div>
  <div class="col-md-2 col-6"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">นอกจังหวัด</div><div class="fs-4 fw-semibold"><%= summary.outOfProvince %></div></div></div></div>
</div>

<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>เลขที่/เรื่อง</th>
          <th>ผู้ขอ</th>
          <th>ปลายทาง/วันที่ปฏิบัติงาน</th>
          <th>การเดินทาง</th>
          <th>คำขอใช้รถ</th>
          <th>รถ/คนขับ</th>
          <th>สถานะ</th>
          <th class="text-end">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (!items.length) { %>
          <tr><td colspan="8" class="text-center py-4 text-muted">ไม่พบข้อมูลตามเงื่อนไขที่เลือก</td></tr>
        <% } %>
        <% items.forEach((item) => { %>
          <tr>
            <td>
              <div class="fw-semibold"><%= item.request_no %></div>
              <small class="text-muted"><%= item.subject %></small>
            </td>
            <td>
              <div><%= item.requester_name %></div>
              <small class="text-muted"><%= item.requester_group || '-' %></small>
            </td>
            <td>
              <div><%= item.destination_text %></div>
              <small class="text-muted"><%= new Date(item.start_at).toLocaleDateString('th-TH', { dateStyle: 'short' }) %></small>
            </td>
            <td>
              <div><%= item.transport_type %></div>
              <small class="text-muted">ผู้ร่วม <%= item.companion_count || 0 %> คน<%= Number(item.out_of_province) === 1 ? ' / นอกจังหวัด' : '' %></small>
            </td>
            <td>
              <div><%= item.vehicle_request_no || '-' %></div>
              <small class="text-muted"><%= item.vehicle_request_status || '-' %></small>
            </td>
            <td>
              <div><%= item.plate_no_snapshot || '-' %></div>
              <small class="text-muted"><%= item.driver_name_snapshot || '-' %></small>
            </td>
            <td>
              <span class="badge bg-<%= item.status === 'approved' ? 'success' : item.status === 'submitted' ? 'warning text-dark' : item.status === 'rejected' ? 'danger' : item.status === 'cancelled' ? 'secondary' : 'info' %>"><%= item.status %></span>
            </td>
            <td class="text-end text-nowrap">
              <a href="/official-travel/<%= item.id %>" class="btn btn-sm btn-outline-primary">ดู</a>
              <% if (item.vehicle_request_id) { %>
                <a href="/vehicle-request/<%= item.vehicle_request_id %>" class="btn btn-sm btn-outline-secondary">คำขอใช้รถ</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>