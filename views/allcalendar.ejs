<%- include('partials/header') %>
<style>
.fc .fc-toolbar-title {
    font-size: 1rem; font-weight: 400;}
</style>

<!-- FullCalendar CSS (loaded here since header is fixed) -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet">

<div class="container-fluid px-2 px-md-4">
  <div class="d-flex flex-wrap align-items-center justify-content-between my-3 gap-2">
    <h3 class="m-0">📆 ปฏิทินกิจกรรม</h3>
    <div class="d-flex gap-2">
        <!-- ต้องเป็นสมาชิก -->
        
        <% if (user) { %>
            <a href="/gitgum/add" class="btn btn-success"><i class="bi bi-plus-circle"></i> เพิ่มกิจกรรม</a>
        <% } %>
    </div>
  </div>

  <div id="calendar" class="bg-white rounded shadow-sm p-2" style="min-height: 70vh;"></div>
</div>

<!-- Modal แสดงรายละเอียดกิจกรรม -->
<div class="modal fade" id="eventModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="eventTitle">รายละเอียดกิจกรรม</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-2"><i class="bi bi-bookmark-star me-2"></i><span id="eventSource"></span></div>
        <div class="mb-2"><i class="bi bi-upc-scan me-2"></i><span id="eventRequestNumber"></span></div>
        <div class="mb-2"><i class="bi bi-calendar-event me-2"></i><span id="eventDate"></span></div>
        <div class="mb-2"><i class="bi bi-clock me-2"></i><span id="eventTime"></span></div>
        <div class="mb-2"><i class="bi bi-truck me-2"></i><span id="eventVehicle"></span></div>
        <div class="mb-2"><i class="bi bi-person-badge me-2"></i><span id="eventDriver"></span></div>
        <div class="mb-2"><i class="bi bi-signpost-2 me-2"></i><span id="eventTransportType"></span></div>
        <div class="mb-2"><i class="bi bi-patch-check me-2"></i><span id="eventApprovalStatus"></span></div>
        <div class="mb-2"><i class="bi bi-geo-alt me-2"></i><span id="eventPlace"></span></div>
        <div class="mb-2"><i class="bi bi-people me-2"></i><span id="eventRespon"></span></div>
        <div class="mb-2"><i class="bi bi-arrow-right-circle me-2"></i><span id="eventGoto"></span></div>
        <div class="mb-2"><i class="bi bi-diagram-3 me-2"></i><span id="eventGroup"></span></div>
        <div class="mb-0"><i class="bi bi-card-text me-2"></i><span id="eventMaihed"></span></div>
      </div>
      <div class="modal-footer">
        <a id="eventViewBtn" href="#" class="btn btn-outline-primary"><i class="bi bi-eye"></i> ดูรายละเอียด</a>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ปิด</button>
      </div>
    </div>
  </div>
</div>

<!-- FullCalendar JS -->
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales-all.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const calendarEl = document.getElementById('calendar');
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const events = <%- JSON.stringify(events || []) %>;

    const calendar = new FullCalendar.Calendar(calendarEl, {
      locale: 'th',
      timeZone: 'Asia/Bangkok',
      initialView: isMobile ? 'listWeek' : 'dayGridMonth',
      headerToolbar: isMobile
        ? { left: 'prev,next today', center: 'title', right: '' }
        : { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek' },
      height: 'auto',
      stickyHeaderDates: true,
      nowIndicator: true,
      weekNumbers: false,
      navLinks: true,
      dayMaxEvents: true,
      eventTimeFormat: { hour: '2-digit', minute: '2-digit', meridiem: false },
      events,
      eventClick: function(info) {
        info.jsEvent.preventDefault();
        const e = info.event;
        const p = e.extendedProps || {};
        // เติมข้อมูลลงใน Modal
        document.getElementById('eventTitle').textContent = e.title || 'รายละเอียดกิจกรรม';
        const start = e.start ? new Date(e.start) : null;
        const end = e.end ? new Date(e.end) : null;
        const thDate = start ? start.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) : '-';
        const thEndDate = end ? new Date(end.getTime() - 24 * 60 * 60 * 1000).toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
        const dateLabel = p.dateLabel || (thEndDate && start ? `${thDate} ถึง ${thEndDate}` : thDate);
        const thTime = start ? start.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', hour12: false }) : '-';
        document.getElementById('eventSource').textContent = p.sourceLabel || 'กิจกรรม';
        document.getElementById('eventRequestNumber').textContent = p.requestNumber || p.vehicleRequestNo || '-';
        document.getElementById('eventDate').textContent = dateLabel;
        document.getElementById('eventTime').textContent = p.timeLabel || thTime;
        document.getElementById('eventVehicle').textContent = p.vehiclePlate || '-';
        document.getElementById('eventDriver').textContent = p.driverName || '-';
        document.getElementById('eventTransportType').textContent = p.transportType || '-';
        document.getElementById('eventApprovalStatus').textContent = p.approvalStatus || '-';
        document.getElementById('eventPlace').textContent = p.place || '-';
        document.getElementById('eventRespon').textContent = p.respon || '-';
        document.getElementById('eventGoto').textContent = p.goto || '-';
        document.getElementById('eventGroup').textContent = p.group || '-';
        document.getElementById('eventMaihed').textContent = p.maihed || '-';
        const viewBtn = document.getElementById('eventViewBtn');
        if (p.detailUrl) {
          viewBtn.href = p.detailUrl;
          viewBtn.classList.remove('d-none');
        } else {
          viewBtn.href = '#';
          viewBtn.classList.add('d-none');
        }
        const modal = new bootstrap.Modal(document.getElementById('eventModal'));
        modal.show();
      }
    });

    calendar.render();

    // Optional: เปลี่ยน layout เมื่อขนาดจอเปลี่ยน
    window.addEventListener('resize', function() {
      const nowMobile = window.matchMedia('(max-width: 768px)').matches;
      const currentView = calendar.view.type;
      const target = nowMobile ? 'listWeek' : 'dayGridMonth';
      if (currentView !== target) {
        calendar.changeView(target);
      }
    });
  });
</script>

<%- include('partials/footer') %>
