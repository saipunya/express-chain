<%- include('../partials/header') %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">คิวงานคนขับรถ</h3>
    <p class="text-muted mb-0">รายการงานที่ได้รับมอบหมายและพร้อมบันทึกเวลา/เลขไมล์</p>
  </div>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<div class="card shadow-sm border-0">
  <div class="table-responsive d-none d-md-block">
    <table class="table table-hover mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th>เลขที่คำขอ</th>
          <th>ผู้ขอ</th>
          <th>ปลายทาง</th>
          <th>รถ/คนขับ</th>
          <th>สถานะเดินรถ</th>
          <th class="text-end">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (!items.length) { %>
          <tr><td colspan="6" class="text-center py-4 text-muted">ยังไม่มีงานขับรถที่ได้รับมอบหมาย</td></tr>
        <% } %>
        <% items.forEach((item) => { %>
          <tr>
            <td><%= item.vehicle_request_no %></td>
            <td><%= item.requester_name %></td>
            <td><%= item.destination_text %></td>
            <td>
              <div><%= item.plate_no_snapshot || '-' %></div>
              <small class="text-muted"><%= item.driver_name_snapshot || '-' %></small>
            </td>
            <td><span class="badge bg-info"><%= item.log_status || 'not_started' %></span></td>
            <td class="text-end"><a href="/driver-trip/<%= item.vehicle_request_id %>" class="btn btn-sm btn-outline-primary">เปิดงาน</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="d-md-none p-3">
    <% if (!items.length) { %>
      <div class="text-center py-4 text-muted">ยังไม่มีงานขับรถที่ได้รับมอบหมาย</div>
    <% } %>

    <div class="row g-3">
      <% items.forEach((item) => { %>
        <div class="col-12">
          <div class="border rounded-4 p-3 bg-white shadow-sm">
            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
              <div>
                <div class="fw-semibold"><%= item.vehicle_request_no %></div>
                <div class="small text-muted"><%= item.requester_name %></div>
              </div>
              <span class="badge bg-info text-nowrap"><%= item.log_status || 'not_started' %></span>
            </div>

            <div class="mb-2">
              <div class="small text-muted">ปลายทาง</div>
              <div class="fw-medium"><%= item.destination_text %></div>
            </div>

            <div class="row g-2 mb-3">
              <div class="col-6">
                <div class="small text-muted">รถ</div>
                <div class="fw-medium"><%= item.plate_no_snapshot || '-' %></div>
              </div>
              <div class="col-6">
                <div class="small text-muted">คนขับ</div>
                <div class="fw-medium"><%= item.driver_name_snapshot || '-' %></div>
              </div>
            </div>

            <a href="/driver-trip/<%= item.vehicle_request_id %>" class="btn btn-outline-primary w-100">เปิดงาน</a>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
