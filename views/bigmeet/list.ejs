  <nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center" id="pagination"></ul>
  </nav>
</div>

<script>
  const canEdit = <%= canEditServer ? 'true' : 'false' %>;
  let currentPage = 1;
  const itemsPerPage = 10;
  let allItems = <%- JSON.stringify(items || []) %>;
  let filteredItems = [...allItems];

  document.addEventListener('DOMContentLoaded', function() {
    populateYearFilter();
    setupEventListeners();
    filterAndRender();
    initFiscalYearSummary();

    const urlParams = new URLSearchParams(window.location.search);
    const successMessage = urlParams.get('message') || urlParams.get('success');
    if (successMessage) {
      showToast(successMessage);
    }
  });

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeYear(value) {
    const text = String(value || '').trim();
    if (!text) return '';
    const num = Number(text);
    if (!Number.isFinite(num)) return text;
    if (num > 0 && num < 2400) return String(num + 543);
    return String(Math.trunc(num));
  }

  function getCurrentBudgetYear() {
    const now = new Date();
    return now.getMonth() >= 9 ? now.getFullYear() + 544 : now.getFullYear() + 543;
  }

  const currentBudgetYear = getCurrentBudgetYear();
  const thaiMonthMap = {
    'มกราคม': '01',
    'กุมภาพันธ์': '02',
    'มีนาคม': '03',
    'เมษายน': '04',
    'พฤษภาคม': '05',
    'มิถุนายน': '06',
    'กรกฎาคม': '07',
    'สิงหาคม': '08',
    'กันยายน': '09',
    'ตุลาคม': '10',
    'พฤศจิกายน': '11',
    'ธันวาคม': '12'
  };

  function normalizeMonthDay(value) {
    const text = String(value || '').trim();
    if (!text) return '';
    if (/^\d{2}-\d{2}$/.test(text)) return text;
    const match = text.replace(/\s+/g, '').match(/^(\d{1,2})([^\d]+)$/);
    if (!match) return '';
    const month = thaiMonthMap[match[2]];
    return month ? `${month}-${String(match[1]).padStart(2, '0')}` : '';
  }

  function addDays(isoDate, days) {
    if (!isoDate) return '';
    const d = new Date(`${isoDate}T00:00:00`);
    if (Number.isNaN(d.getTime())) return '';
    d.setDate(d.getDate() + Number(days || 0));
    return d.toISOString().slice(0, 10);
  }

  function getFiscalEndDate(item) {
    const monthDay = normalizeMonthDay(item.end_day || item.end_date);
    const budgetYear = Number(item.big_budget_year || item.big_endyear || currentBudgetYear);
    if (monthDay && Number.isFinite(budgetYear)) {
      const year = parseInt(monthDay.slice(0, 2), 10) >= 10 ? budgetYear - 544 : budgetYear - 543;
      return `${year}-${monthDay}`;
    }
    return item.big_fiscal_end_date || '';
  }

  function getDeadlineDate(item) {
    const fiscalEndDate = getFiscalEndDate(item);
    if (fiscalEndDate) return addDays(fiscalEndDate, 150);
    return item.big_deadline_date || '';
  }

  function populateYearFilter() {
    const years = [...new Set(allItems.map(item => normalizeYear(item.big_budget_year || item.big_endyear)).filter(Boolean))]
      .sort()
      .reverse();
    const yearFilter = document.getElementById('yearFilter');
    years.forEach(year => {
      const option = document.createElement('option');
      option.value = year;
      option.textContent = year;
      yearFilter.appendChild(option);
    });
  }

  function setupEventListeners() {
    document.getElementById('searchInput').addEventListener('input', filterAndRender);
    document.getElementById('yearFilter').addEventListener('change', filterAndRender);
    document.getElementById('typeFilter').addEventListener('change', filterAndRender);
    document.getElementById('statusFilter').addEventListener('change', filterAndRender);

    document.getElementById('clearFilters').addEventListener('click', function() {
      document.getElementById('searchInput').value = '';
      document.getElementById('yearFilter').value = '';
      document.getElementById('typeFilter').value = '';
      document.getElementById('statusFilter').value = '';
      filterAndRender();
    });
  }

  function filterAndRender() {
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    const yearFilter = document.getElementById('yearFilter').value;
    const typeFilter = document.getElementById('typeFilter').value;
    const statusFilter = document.getElementById('statusFilter').value;

    filteredItems = allItems.filter(item => {
      const name = String(item.c_name || '').toLowerCase();
      const code = String(item.big_code || '').toLowerCase();
      const matchesSearch = !searchTerm || name.includes(searchTerm) || code.includes(searchTerm);
      const matchesYear = !yearFilter || normalizeYear(item.big_budget_year || item.big_endyear) === yearFilter;
      const matchesType = !typeFilter || String(item.big_type || '') === typeFilter;
      const matchesStatus = !statusFilter || String(item.big_meeting_status || '') === statusFilter;
      return matchesSearch && matchesYear && matchesType && matchesStatus;
    }).sort(compareMeetingDateDesc);

    currentPage = 1;
    renderTable();
  }

  function compareMeetingDateDesc(a, b) {
    const dateA = a.big_date ? new Date(a.big_date).getTime() : 0;
    const dateB = b.big_date ? new Date(b.big_date).getTime() : 0;

    if (dateA !== dateB) return dateB - dateA;
    return Number(b.big_id || 0) - Number(a.big_id || 0);
  }

  function formatLocalDate(dateValue) {
    if (!dateValue) return '-';
    const d = new Date(dateValue);
    return isNaN(d.getTime()) ? '-' : d.toLocaleDateString('th-TH');
  }

  function formatType(value) {
    if (value === 'ใน') return 'ในภาคเกษตร';
    if (value === 'นอก') return 'นอกภาคเกษตร';
    if (value === 'กลุ่มเกษตรกร') return 'กลุ่มเกษตรกร';
    return value || '-';
  }

  function formatAccountingMonthDay(item) {
    const monthDay = normalizeMonthDay(item.end_day || item.end_date);
    if (!monthDay) return '-';

    const monthNames = {
      '01': 'มกราคม',
      '02': 'กุมภาพันธ์',
      '03': 'มีนาคม',
      '04': 'เมษายน',
      '05': 'พฤษภาคม',
      '06': 'มิถุนายน',
      '07': 'กรกฎาคม',
      '08': 'สิงหาคม',
      '09': 'กันยายน',
      '10': 'ตุลาคม',
      '11': 'พฤศจิกายน',
      '12': 'ธันวาคม'
    };
    const [month, day] = monthDay.split('-');
    return `${parseInt(day, 10)} ${monthNames[month] || month}`;
  }

  function formatStatusBadge(status) {
    if (status === 'met_within_150') return '<span class="badge bg-success">ประชุมภายใน 150 วัน</span>';
    if (status === 'met_over_150') return '<span class="badge bg-warning text-dark">ประชุมเกิน 150 วัน</span>';
    if (status === 'not_met') return '<span class="badge bg-danger">ยังไม่ได้ประชุม</span>';
    return '<span class="badge bg-secondary">' + escapeHtml(status || '-') + '</span>';
  }

  function formatNote(item) {
    const parts = [];
    if (item.big_reason) parts.push(item.big_reason);
    if (item.big_note) parts.push(item.big_note);
    const joined = parts.filter(Boolean).join(' | ');
    return joined ? escapeHtml(joined) : '-';
  }

  function renderTable() {
    const tbody = document.getElementById('dataTable');
    const startIndex = (currentPage - 1) * itemsPerPage;
    const endIndex = startIndex + itemsPerPage;
    const pageItems = filteredItems.slice(startIndex, endIndex);
    const colSpan = canEdit ? 11 : 9;

    if (pageItems.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="${colSpan}" class="text-center py-5">
            <div class="text-muted">
              <i class="bi bi-search display-5 d-block mb-3"></i>
              <div class="h5">ไม่พบข้อมูลที่ตรงกับเงื่อนไข</div>
              <div>ลองปรับตัวกรองหรือคำค้นหา</div>
            </div>
          </td>
        </tr>
      `;
      renderPagination();
      return;
    }

    tbody.innerHTML = pageItems.map((item, index) => {
      const globalIndex = startIndex + index + 1;
      const name = escapeHtml(item.c_name || item.big_code || '-');
      const accountingMonthDay = escapeHtml(formatAccountingMonthDay(item));
      const typeText = escapeHtml(formatType(item.big_type));
      const fiscalEndDate = formatLocalDate(getFiscalEndDate(item));
      const deadlineDate = formatLocalDate(getDeadlineDate(item));
      const meetingDate = formatLocalDate(item.big_date);

      return `
        <tr data-id="${item.big_id}">
          <td class="text-center"><span class="bigmeet-index-chip">${globalIndex}</span></td>
          <td>
            <div class="fw-bold">${name}</div>
            <span class="bigmeet-code-chip mt-1">ปีบัญชี: ${accountingMonthDay}</span>
          </td>
          <td class="text-center">${typeText}</td>
          <td class="text-center">${escapeHtml(normalizeYear(item.big_budget_year || item.big_endyear) || '-')}</td>
          <td class="text-center">${fiscalEndDate}</td>
          <td class="text-center">${deadlineDate}</td>
          <td class="text-center">${formatStatusBadge(item.big_meeting_status)}</td>
          <td class="text-center">
            <div>${meetingDate}</div>
            <small class="text-muted">${item.big_saveby ? escapeHtml(item.big_saveby) : ''}</small>
          </td>
          <td><div class="bigmeet-note text-truncate-2">${formatNote(item)}</div></td>
          ${canEdit ? `
            <td class="text-center">
              <a href="/bigmeet/edit/${item.big_id}" class="btn btn-outline-warning btn-sm bigmeet-action" title="แก้ไข">
                <i class="bi bi-pencil-square"></i>
              </a>
            </td>
            <td class="text-center">
              <button class="btn btn-outline-danger btn-sm bigmeet-action" onclick="confirmDelete(${item.big_id})" title="ลบ">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          ` : ''}
        </tr>
      `;
    }).join('');

    renderPagination();
  }

  function renderPagination() {
    const totalPages = Math.ceil(filteredItems.length / itemsPerPage);
    const pagination = document.getElementById('pagination');

    if (totalPages <= 1) {
      pagination.innerHTML = '';
      return;
    }

    let html = '';
    html += `
      <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="changePage(${currentPage - 1})">ก่อนหน้า</a>
      </li>
    `;

    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
        html += `
          <li class="page-item ${i === currentPage ? 'active' : ''}">
            <a class="page-link" href="#" onclick="changePage(${i})">${i}</a>
          </li>
        `;
      } else if (i === currentPage - 3 || i === currentPage + 3) {
        html += '<li class="page-item disabled"><a class="page-link">...</a></li>';
      }
    }

    html += `
      <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
        <a class="page-link" href="#" onclick="changePage(${currentPage + 1})">ถัดไป</a>
      </li>
    `;

    pagination.innerHTML = html;
  }

  function changePage(page) {
    const totalPages = Math.ceil(filteredItems.length / itemsPerPage);
    if (page < 1 || page > totalPages) return;
    currentPage = page;
    renderTable();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function confirmDelete(id) {
    if (confirm('คุณต้องการลบข้อมูลนี้ใช่หรือไม่?')) {
      deleteItem(id);
    }
  }

  async function deleteItem(id) {
    showLoading(true);
    try {
      const response = await fetch(`/bigmeet/delete/${id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      if (response.ok) {
        allItems = allItems.filter(item => item.big_id !== id);
        filteredItems = filteredItems.filter(item => item.big_id !== id);
        renderTable();
        showToast('ลบข้อมูลสำเร็จ');
      } else {
        throw new Error('Delete failed');
      }
    } catch (error) {
      console.error('Delete error:', error);
      showToast('ลบข้อมูลไม่สำเร็จ กรุณาลองใหม่', 'error');
    } finally {
      showLoading(false);
    }
  }

  function showToast(message, type = 'success') {
    let toast = document.getElementById('toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'toast';
      toast.className = 'toast position-fixed top-0 end-0 m-3';
      toast.style.zIndex = '1050';
      toast.style.display = 'none';
      toast.innerHTML = '<div class="toast-body text-white"><span id="toastMessage"></span></div>';
      document.body.appendChild(toast);
    }

    let toastMessage = document.getElementById('toastMessage');
    if (!toastMessage) {
      toastMessage = document.createElement('span');
      toastMessage.id = 'toastMessage';
      toast.querySelector('.toast-body').appendChild(toastMessage);
    }

    const toastBody = toast.querySelector('.toast-body');
    toastMessage.textContent = message;
    toastBody.className = `toast-body ${type === 'success' ? 'bg-success' : 'bg-danger'} text-white`;
    toast.style.display = 'block';
    toast.classList.add('show');

    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => {
        toast.style.display = 'none';
      }, 300);
    }, 3000);
  }

  function showLoading(show) {
    const spinner = document.getElementById('loadingSpinner');
    const table = document.querySelector('.table-responsive');
    if (show) {
      spinner.style.display = 'block';
      table.style.opacity = '0.5';
    } else {
      spinner.style.display = 'none';
      table.style.opacity = '1';
    }
  }

  function initFiscalYearSummary() {
    const fySelect = document.getElementById('fySelect');
    if (!fySelect) return;

    const now = new Date();
    const nowBE = now.getFullYear() + 543;
    const guessFY = (now.getMonth() + 1) >= 10 ? nowBE + 1 : nowBE;
    const fys = [guessFY - 1, guessFY, guessFY + 1].filter((v, i, a) => a.indexOf(v) === i);

    fySelect.innerHTML = fys.map(fy => `<option value="${fy}">${fy}</option>`).join('');
    fySelect.value = String(guessFY);
    updateSummaryLinks(fySelect.value);

    fySelect.addEventListener('change', () => {
      updateSummaryLinks(fySelect.value);
      loadFiscalYearSummary(fySelect.value);
    });
    loadFiscalYearSummary(fySelect.value);
  }

  function updateSummaryLinks(fy) {
    document.querySelectorAll('[data-summary-link]').forEach((link) => {
      const type = link.dataset.summaryType;
      const status = link.dataset.summaryStatus;
      link.href = `/bigmeet/summary/detail?fy=${encodeURIComponent(fy)}&type=${encodeURIComponent(type)}&status=${encodeURIComponent(status)}`;
    });
  }

  async function loadFiscalYearSummary(fy) {
    try {
      const res = await fetch(`/bigmeet/summary?fy=${encodeURIComponent(fy)}`);
      const json = await res.json();
      if (!json || !json.success) throw new Error(json && json.error ? json.error : 'Failed');

      const d = json.data;
      document.getElementById('sumTotal').textContent = d.totalCoopsInList;
      document.getElementById('sumMet').textContent = d.metInFiscalYear;
      document.getElementById('sumNotMet').textContent = d.notMetInFiscalYear;
      document.getElementById('sumAgriTotal').textContent = d.agriTotal;
      document.getElementById('sumAgriMet').textContent = d.agriMet;
      document.getElementById('sumAgriNotMet').textContent = d.agriNotMet;
      document.getElementById('sumNonAgriTotal').textContent = d.nonAgriTotal;
      document.getElementById('sumNonAgriMet').textContent = d.nonAgriMet;
      document.getElementById('sumNonAgriNotMet').textContent = d.nonAgriNotMet;
      document.getElementById('sumFarmerTotal').textContent = d.farmerTotal;
      document.getElementById('sumFarmerMet').textContent = d.farmerMet;
      document.getElementById('sumFarmerNotMet').textContent = d.farmerNotMet;

      const fmt = (iso) => {
        if (!iso) return '-';
        const dt = new Date(iso + 'T00:00:00');
        return isNaN(dt.getTime()) ? iso : dt.toLocaleDateString('th-TH');
      };
      const rangeText = d.range
        ? `ผลประชุม: ${fmt(d.range.start)} - ${fmt(d.range.end)}${d.accountingRange ? ` | ปีบัญชีที่ต้องประชุม: ${fmt(d.accountingRange.start)} - ${fmt(d.accountingRange.end)}` : ''}`
        : '-';
      document.getElementById('sumRange').textContent = rangeText;
    } catch (e) {
      console.error('loadFiscalYearSummary:', e);
      document.getElementById('sumTotal').textContent = allItems.length;
      document.getElementById('sumMet').textContent = '-';
      document.getElementById('sumNotMet').textContent = '-';
      ['sumAgriTotal', 'sumAgriMet', 'sumAgriNotMet', 'sumNonAgriTotal', 'sumNonAgriMet', 'sumNonAgriNotMet', 'sumFarmerTotal', 'sumFarmerMet', 'sumFarmerNotMet'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.textContent = '-';
      });
      document.getElementById('sumRange').textContent = 'โหลดสรุปไม่สำเร็จ';
    }
  }
</script>

