<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>แก้ไขการจองห้องประชุม</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
  <%
    function dateInputValue(value) {
      if (!value) return '';
      if (typeof value === 'string') return value.slice(0, 10);
      const dt = new Date(value);
      if (isNaN(dt)) return '';
      const year = dt.getFullYear();
      const month = String(dt.getMonth() + 1).padStart(2, '0');
      const day = String(dt.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    }
    const roomOptions = [
      { value: 'พิทยาลงกรณ์', label: 'ห้องประชุมพิทยาลงกรณ์' },
      { value: 'ดอกกระเจียว', label: 'ห้องประชุมดอกกระเจียว' }
    ];
    const roomValue = meeting.mee_room || '';
    const roomIsKnown = roomOptions.some(room => room.value === roomValue);
  %>

  <div class="meetingroom-form-page py-4 py-lg-5">
    <div class="container">
      <div class="form-shell">
        <div class="form-hero">
          <div class="form-hero__icon">
            <i class="bi bi-pencil-square"></i>
          </div>
          <div class="form-hero__copy">
            <p class="form-kicker mb-1">Meeting Room</p>
            <h1 class="form-title mb-2">แก้ไขการจองห้องประชุม</h1>
            <p class="form-subtitle mb-0">ปรับวัน เวลา หรือรายละเอียดได้จากหน้านี้ แล้วบันทึกกลับเข้าระบบทันที</p>
          </div>
        </div>

        <div class="form-card">
          <form action="/meetingroom/edit/<%= meeting.mee_id %>" method="POST" class="row g-4">
            <div class="col-12 col-lg-4">
              <label for="mee_date" class="form-label">วันที่ประชุม</label>
              <input type="date" id="mee_date" name="mee_date" class="form-control form-control-lg" value="<%= dateInputValue(meeting.mee_date) %>" required>
            </div>

            <div class="col-12 col-lg-4">
              <label for="mee_time" class="form-label">เวลา</label>
              <input type="text" id="mee_time" name="mee_time" class="form-control form-control-lg" value="<%= meeting.mee_time %>" required>
            </div>

            <div class="col-12 col-lg-4">
              <label for="mee_room" class="form-label">ห้องประชุม</label>
              <select class="form-select form-select-lg" name="mee_room" id="mee_room" required>
                <% if (!roomIsKnown && roomValue) { %>
                  <option value="<%= roomValue %>" selected><%= roomValue %></option>
                <% } %>
                <option value="" disabled <%= roomValue ? '' : 'selected' %>>++โปรดเลือก++</option>
                <% roomOptions.forEach(room => { %>
                  <option value="<%= room.value %>" <%= roomValue === room.value ? 'selected' : '' %>><%= room.label %></option>
                <% }) %>
              </select>
            </div>

            <div class="col-12">
              <label for="mee_subject" class="form-label">เรื่อง/วัตถุประสงค์</label>
              <textarea id="mee_subject" name="mee_subject" class="form-control" rows="4" required><%= meeting.mee_subject %></textarea>
            </div>

            <div class="col-12 col-lg-4">
              <label for="mee_respon" class="form-label">ผู้รับผิดชอบ</label>
              <input type="text" id="mee_respon" name="mee_respon" class="form-control form-control-lg" value="<%= meeting.mee_respon %>" required>
            </div>

            <div class="col-12 col-lg-4">
              <label for="mee_saveby" class="form-label">ผู้บันทึก</label>
              <input type="text" id="mee_saveby" name="mee_saveby" class="form-control form-control-lg" value="<%= meeting.mee_saveby %>" required>
            </div>

            <div class="col-12 col-lg-4">
              <label for="mee_savedate" class="form-label">วันที่บันทึก</label>
              <input type="date" id="mee_savedate" name="mee_savedate" class="form-control form-control-lg" value="<%= dateInputValue(meeting.mee_savedate) %>" required>
            </div>

            <div class="col-12">
              <div class="meta-panel">
                <div class="meta-panel__item">
                  <span>รายการนี้ถูกบันทึกด้วย ID</span>
                  <strong>#<%= meeting.mee_id %></strong>
                </div>
                <div class="meta-panel__item">
                  <span>กำลังแก้ไขข้อมูลปัจจุบัน</span>
                  <strong><%= meeting.mee_subject ? meeting.mee_subject.slice(0, 40) : '-' %><%= meeting.mee_subject && meeting.mee_subject.length > 40 ? '…' : '' %></strong>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="form-actions">
                <a href="/meetingroom" class="btn btn-outline-secondary btn-action">
                  <i class="bi bi-x-circle"></i>
                  ยกเลิก
                </a>
                <button class="btn btn-primary btn-action" type="submit">
                  <i class="bi bi-check2-circle"></i>
                  บันทึกการแก้ไข
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <style>
  .meetingroom-form-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(16, 185, 129, 0.07), transparent 32%),
      radial-gradient(circle at bottom right, rgba(45, 212, 191, 0.06), transparent 28%),
      #f6f8fb;
  }

    .form-shell {
      display: grid;
      gap: 1.25rem;
    }

  .form-hero,
  .form-card {
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid #e3f0ea;
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.07);
    border-radius: 22px;
  }

    .form-hero {
      padding: 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

  .form-hero__icon {
      width: 60px;
      height: 60px;
      border-radius: 18px;
      display: grid;
      place-items: center;
    background: rgba(16, 185, 129, 0.1);
    color: #0f8f7b;
      font-size: 1.5rem;
      flex: 0 0 auto;
    }

    .form-kicker {
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #64748b;
      letter-spacing: 0;
    }

    .form-title {
      color: #0f172a;
      font-weight: 800;
      line-height: 1.12;
    }

    .form-subtitle {
      color: #64748b;
      max-width: 60ch;
    }

    .form-card {
      padding: 1.25rem;
    }

    .form-label {
      font-weight: 600;
      color: #334155;
      margin-bottom: 0.45rem;
    }

  .form-control,
  .form-select {
    border-radius: 16px;
    border-color: #d6e8e1;
    min-height: 52px;
    box-shadow: none;
  }

  .form-control:focus,
  .form-select:focus {
    border-color: #8dd4c7;
    box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.08);
  }

    textarea.form-control {
      min-height: 132px;
    }

    .meta-panel {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }

  .meta-panel__item {
    border: 1px solid #e1efea;
    border-radius: 16px;
    background: #f7fcfa;
      padding: 0.9rem 1rem;
      display: grid;
      gap: 0.15rem;
    }

    .meta-panel__item span {
      font-size: 0.78rem;
      color: #64748b;
    }

    .meta-panel__item strong {
      color: #0f172a;
      font-weight: 700;
    }

    .form-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: flex-end;
      padding-top: 0.25rem;
    }

  .btn-action {
      min-width: 160px;
      min-height: 46px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    gap: 0.5rem;
    font-weight: 600;
  }

  .meetingroom-form-page .btn-primary {
    background-color: #0f8f7b;
    border-color: #0f8f7b;
  }

  .meetingroom-form-page .btn-primary:hover,
  .meetingroom-form-page .btn-primary:focus {
    background-color: #0c7c6b;
    border-color: #0c7c6b;
  }

  .meetingroom-form-page .btn-outline-secondary {
    color: #475569;
    border-color: #cbd5e1;
  }

  .meetingroom-form-page .btn-outline-secondary:hover,
  .meetingroom-form-page .btn-outline-secondary:focus {
    background: #f4f6f9;
    color: #334155;
  }

    @media (max-width: 768px) {
      .form-hero {
        flex-direction: column;
        align-items: flex-start;
      }

      .meta-panel {
        grid-template-columns: 1fr;
      }

      .form-actions {
        flex-direction: column-reverse;
      }

      .btn-action {
        width: 100%;
      }
    }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
