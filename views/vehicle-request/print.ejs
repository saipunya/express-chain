<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>พิมพ์คำขอใช้รถราชการ</title>
  <style>
    @font-face {
      font-family: 'THSarabunNew';
      src: url('/fonts/THSarabunNew.ttf') format('truetype');
      font-weight: 400;
      font-style: normal;
    }

    @font-face {
      font-family: 'THSarabunNew';
      src: url('/fonts/THSarabunNew-Bold.ttf') format('truetype');
      font-weight: 700;
      font-style: normal;
    }

    body {
      font-family: 'THSarabunNew', 'TH Sarabun New', 'Sarabun', Arial, sans-serif;
      margin: 0;
      padding: 20px;
      background: #fff;
      color: #111;
      font-size: 20px;
      line-height: 1.5;
    }

    .print-sheet {
      max-width: 780px;
      margin: 0 auto;
      padding: 12px 18px 18px;
      box-sizing: border-box;
    }

    .document-header {
      text-align: center;
      margin-bottom: 18px;
    }

    .document-header h1 {
      margin: 0;
      font-size: 28px;
      letter-spacing: 0;
      font-weight: 700;
    }

    .document-header h2 {
      margin: 8px 0 0;
      font-size: 18px;
      font-weight: 400;
    }

    .meta-table,
    .field-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 16px;
    }

    .meta-table td,
    .field-table td {
      padding: 6px 4px;
      vertical-align: top;
      border-bottom: 1px dotted #999;
      font-size: 22px;
    }

    .meta-table .label,
    .field-table .label {
      width: 128px;
      font-weight: 700;
      white-space: nowrap;
    }

    .two-column {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }

    .field-box {
      border: 1px solid #333;
      padding: 10px 12px;
      min-height: 104px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .field-box strong {
      display: block;
      margin-bottom: 6px;
      font-size: 18px;
      font-weight: 700;
    }

    .field-value {
      font-size: 20px;
      line-height: 1.45;
      white-space: pre-wrap;
    }

    .section-title {
      font-size: 20px;
      font-weight: 700;
      margin: 16px 0 6px;
    }

    .signature-block {
      margin-top: 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .signature-row {
      display: flex;
      align-items: center;
      width: 100%;
      max-width: 520px;
      gap: 10px;
      font-size: 20px;
      white-space: nowrap;
    }

    .signature-row span {
      display: inline-block;
      min-width: 90px;
      text-align: center;
    }

    .signature-line {
      flex: 1;
      border-bottom: 1px solid #000;
      height: 1px;
    }

    .signature-name {
      text-align: center;
      font-size: 20px;
      width: 100%;
      max-width: 520px;
    }

    strong {
      font-weight: 700;
    }

    .no-print {
      margin-bottom: 24px;
      text-align: right;
    }

    .summary-block {
      margin-bottom: 18px;
      font-size: 20px;
      line-height: 1.6;
    }

    .summary-block span {
      display: inline;
    }

    @media print {
      @page {
        size: A4;
        margin: 16mm 14mm;
      }

      .no-print {
        display: none;
      }

      body {
        padding: 0;
      }

      .print-sheet {
        box-shadow: none;
        padding: 0;
        max-width: none;
      }
    }
  </style>
</head>
<body>
  <div class="print-sheet">
    <div class="no-print">
      <button onclick="window.print()">พิมพ์</button>
    </div>


    <div class="document-header">
      <h1>บันทึกข้อความ</h1>
    </div>
    <table class="meta-table" style="margin-bottom:24px;">
      <tr>
        <td class="label">ส่วนราชการ</td>
        <td colspan="3">สำนักงานสหกรณ์จังหวัดชัยภูมิ ฝ่ายบริหารทั่วไป โทร. 0 4482 2218 ต่อ 1</td>
      </tr>
      <tr>
        <td class="label">ที่</td>
        <td style="width:180px"><%= item.vehicle_request_no || '-' %></td>
        <td class="label">วันที่</td>
        <td>
          <% function thaiDate(dateStr) {
            if (!dateStr) return '-';
            const d = new Date(dateStr);
            if (isNaN(d)) return '-';
            const months = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
            return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear() + 543}`;
          } %>
          <%= thaiDate(item.request_date) %>
        </td>
      </tr>
      <tr>
        <td class="label">เรื่อง</td>
        <td colspan="3">ขออนุญาตใช้รถยนต์ราชการ</td>
      </tr>
      <tr>
        <td class="label">เรียน</td>
        <td colspan="3">สหกรณ์จังหวัดชัยภูมิ</td>
      </tr>
    </table>

    <div class="summary-block">
      <span>ข้าพเจ้า <strong><%= item.requester_name || '-' %></strong> ตำแหน่ง <strong><%= item.requester_position || '-' %></strong></span>
      <span>มีความประสงค์ขออนุญาตใช้รถราชการเพื่อ <strong><%= item.mission_text || '-' %></strong></span>
      <span>ปลายทาง <strong><%= item.destination_text || '-' %></strong></span>
      <span>ในวันที่ <strong><%= item.trip_start_at ? thaiDate(item.trip_start_at) : '-' %></strong></span>
      <span>ถึงวันที่ <strong><%= item.trip_end_at ? thaiDate(item.trip_end_at) : '-' %></strong></span>
      <span>เวลา <strong><%= item.trip_start_at ? new Date(item.trip_start_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) : '-' %> - <%= item.trip_end_at ? new Date(item.trip_end_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) : '-' %></strong></span>
      <span>จำนวนผู้โดยสาร <strong><%= item.passenger_count != null ? item.passenger_count : '-' %></strong> คน</span>
    </div>

    <% const hasEstimatedCosts = item.transport_type === 'official_vehicle' || Number(item.estimated_allowance) > 0 || Number(item.estimated_lodging) > 0 || Number(item.estimated_fuel) > 0; %>
    <% if (hasEstimatedCosts) { %>
      <div class="section-title">ประมาณการค่าใช้จ่าย</div>
      <table class="field-table">
        <tr>
          <td class="label">ค่าเบี้ยเลี้ยง (บาท)</td>
          <td><strong><%= item.estimated_allowance ?? '-' %></strong></td>
        </tr>
        <tr>
          <td class="label">ค่าที่พัก (บาท)</td>
          <td><strong><%= item.estimated_lodging ?? '-' %></strong></td>
        </tr>
        <tr>
          <td class="label">ค่าพาหนะ/น้ำมันเชื้อเพลิง (บาท)</td>
          <td><strong><%= item.estimated_fuel ?? '-' %></strong></td>
        </tr>
      </table>
    <% } %>

    <div style="margin-top: 32px; display: flex; flex-direction: column; align-items: flex-end;">
      <div style="min-width: 320px; text-align: center;">
        <div style="margin-bottom: 36px;">&nbsp;</div>
        <div>ลงชื่อ....................................................</div>
        <div>(<%= item.requester_name || '-' %>)</div>
        <div style="margin-top: 4px;">ตำแหน่ง <%= item.requester_position || '-' %></div>
      </div>
    </div>
    <div style="margin-top: 32px; display: flex; flex-direction: column; align-items: flex-end;">
      <div style="min-width: 320px; text-align: center;">
        <div style="margin-bottom: 36px;">&nbsp;</div>
        <div>ลงชื่อ....................................................</div>
        <div>(....................................................)</div>
        <div style="margin-top: 4px;">ตำแหน่ง....................................................</div>
      </div>
    </div>
  </div>
</body>
</html>
