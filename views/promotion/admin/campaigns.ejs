<!-- include header -->
<%- include('../header.ejs', { title: title }) %>
<style>
  .promo-campaign-page {
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    min-height: 100vh;
    padding: 40px 0 56px;
  }

  .promo-campaign-shell {
    max-width: 1280px;
    margin: 0 auto;
  }

  .promo-campaign-topbar {
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
    margin-bottom: 24px;
  }

  .promo-campaign-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    background: #eff6ff;
    color: #2563eb;
    font-size: 0.92rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .promo-campaign-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
    line-height: 1.08;
    margin-bottom: 10px;
    letter-spacing: -0.03em;
  }

  .promo-campaign-desc {
    color: #64748b;
    margin-bottom: 0;
    line-height: 1.7;
    max-width: 760px;
  }

  .promo-campaign-back {
    border-radius: 12px;
    padding: 10px 14px;
    font-weight: 600;
    border-width: 1.5px;
  }

  .promo-campaign-card {
    border: none;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
  }

  .promo-campaign-form-card {
    border: none;
    border-radius: 24px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
    margin-bottom: 18px;
  }

  .promo-campaign-form-card .form-control,
  .promo-campaign-form-card .form-select {
    border-radius: 12px;
  }

  .promo-campaign-table {
    margin-bottom: 0;
  }

  .promo-campaign-table thead th {
    background: #f8fafc;
    color: #475569;
    font-size: 0.83rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #e2e8f0;
    padding: 14px 16px;
    white-space: nowrap;
  }

  .promo-campaign-table tbody td {
    padding: 15px 16px;
    vertical-align: middle;
    border-color: #eef2f7;
    color: #0f172a;
    font-size: 0.95rem;
  }

  .promo-campaign-table tbody tr:hover {
    background: #f8fbff;
  }

  .promo-campaign-id {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 52px;
    padding: 6px 10px;
    border-radius: 10px;
    background: #eff6ff;
    color: #2563eb;
    font-weight: 800;
    font-size: 0.85rem;
  }

  .promo-campaign-name {
    font-weight: 700;
    color: #0f172a;
  }

  .promo-store-name {
    font-weight: 600;
    color: #0f172a;
  }

  .promo-store-code {
    color: #64748b;
    font-size: 0.88rem;
  }

  .promo-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 7px 12px;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .promo-status-active {
    background: #dcfce7;
    color: #15803d;
  }

  .promo-status-inactive {
    background: #e2e8f0;
    color: #334155;
  }

  .promo-status-scheduled {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .promo-status-expired {
    background: #fee2e2;
    color: #b91c1c;
  }

  .promo-campaign-meta {
    color: #64748b;
    font-size: 0.85rem;
    margin-top: 4px;
  }

  .promo-date {
    color: #0f172a;
    font-weight: 500;
    white-space: nowrap;
  }

  .promo-empty {
    padding: 36px 16px !important;
    color: #64748b !important;
    font-size: 0.98rem;
  }

  .promo-action-stack {
    display: grid;
    gap: 6px;
    min-width: 140px;
  }

  @media (max-width: 767.98px) {
    .promo-campaign-page {
      padding: 24px 0 36px;
    }

    .promo-campaign-topbar {
      padding: 18px;
      border-radius: 18px;
    }
  }
</style>

<div class="promo-campaign-page">
  <div class="container promo-campaign-shell">
    <% const storesSafe = Array.isArray(stores) ? stores : []; %>
    <%
      const toDateTimeLocal = (raw) => {
        if (!raw) return '';
        const d = new Date(raw);
        if (Number.isNaN(d.getTime())) return '';
        const pad = (n) => String(n).padStart(2, '0');
        return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
      };
    %>

    <div class="promo-campaign-topbar">
      <div class="d-flex flex-column flex-xl-row justify-content-between align-items-start gap-3">
        <div>
          <div class="promo-campaign-badge">
            <span>📣</span>
            <span>Promotion Campaign Manager</span>
          </div>
          <h1 class="promo-campaign-title"><%= title %></h1>
          <p class="promo-campaign-desc">
            รายการแคมเปญทั้งหมด พร้อมข้อมูลร้าน สถานะการเปิดใช้งาน และช่วงเวลาของกิจกรรมในระบบ
          </p>
        </div>

        <div class="d-flex gap-2 align-items-center">
          <% if (promotionAdmin) { %>
            <small class="text-muted"><%= promotionAdmin.display_name || promotionAdmin.username %> (<%= promotionAdmin.role %>)</small>
          <% } %>
          <% if (promotionAdmin && promotionAdmin.role === 'super_admin') { %>
            <a href="/promotion/admin/users" class="btn btn-outline-primary btn-sm">Admin Users</a>
            <a href="/promotion/admin/stores" class="btn btn-outline-primary btn-sm">Stores</a>
          <% } %>
          <a href="/promotion/admin" class="btn btn-outline-secondary btn-sm promo-campaign-back">
            Back to dashboard
          </a>
          <a href="/promotion/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a>
        </div>
      </div>
    </div>

    <% if (locals && locals.flash) { %>
      <div class="alert alert-<%= locals.flash.type || 'info' %> rounded-3 mb-3">
        <%= locals.flash.message %>
      </div>
    <% } %>

    <%
      const nowTs = Date.now();
      const getCampaignTimeState = (campaign) => {
        const startTs = campaign && campaign.start_at ? new Date(campaign.start_at).getTime() : null;
        const endTs = campaign && campaign.end_at ? new Date(campaign.end_at).getTime() : null;
        const active = Boolean(campaign && campaign.active);
        const expired = Number.isFinite(endTs) && endTs < nowTs;
        const upcoming = Number.isFinite(startTs) && startTs > nowTs;
        const usable = active && !expired && !upcoming;
        if (expired) return { key: 'expired', label: 'หมดอายุแล้ว', className: 'promo-status-expired', detail: 'เกินช่วงเวลาที่กำหนดแล้ว' };
        if (upcoming) return { key: 'scheduled', label: 'ยังไม่เริ่ม', className: 'promo-status-scheduled', detail: 'รอถึงเวลาเริ่มต้น' };
        if (usable) return { key: 'usable', label: 'ยังใช้ได้', className: 'promo-status-active', detail: 'อยู่ในช่วงใช้งานปกติ' };
        return { key: 'inactive', label: 'ปิดใช้งาน', className: 'promo-status-inactive', detail: 'ถูกปิดใช้งานโดยแอดมิน' };
      };
    %>

    <div class="card promo-campaign-form-card">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3">➕ เพิ่มแคมเปญ</h5>
        <form method="POST" action="/promotion/admin/campaigns" class="row g-3" autocomplete="off">
          <div class="col-md-3">
            <label class="form-label">สาขา</label>
            <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
              <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
              <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
            <% } else { %>
              <select class="form-select" name="store_id" required>
                <option value="">เลือกสาขา</option>
                <% storesSafe.forEach(s => { %>
                  <option value="<%= s.id %>"><%= s.name %> (<%= s.store_code || '-' %>)</option>
                <% }) %>
              </select>
            <% } %>
          </div>

          <div class="col-md-3">
            <label class="form-label">Campaign Code</label>
            <input type="text" name="campaign_code" class="form-control" maxlength="100" required placeholder="เช่น CMP-STORE01-2026">
          </div>

          <div class="col-md-6">
            <label class="form-label">ชื่อแคมเปญ</label>
            <input type="text" name="name" class="form-control" maxlength="255" required>
          </div>

          <div class="col-md-3">
            <label class="form-label">เริ่มต้น</label>
            <input type="datetime-local" name="start_at" class="form-control">
          </div>

          <div class="col-md-3">
            <label class="form-label">สิ้นสุด</label>
            <input type="datetime-local" name="end_at" class="form-control">
          </div>

          <div class="col-md-2">
            <label class="form-label d-block">สถานะ</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="campaignActive" name="active" value="1" checked>
              <label class="form-check-label" for="campaignActive">เปิดใช้งาน</label>
            </div>
          </div>

          <div class="col-md-12">
            <label class="form-label">รายละเอียด (ถ้ามี)</label>
            <textarea class="form-control" name="description" rows="2" maxlength="2000"></textarea>
          </div>

          <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-primary">บันทึกแคมเปญ</button>
          </div>
        </form>
      </div>
    </div>

    <div class="card promo-campaign-card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table promo-campaign-table table-hover mb-0">
            <thead>
              <tr>
                <th>Campaign ID</th>
                <th>Name</th>
                <th>Store</th>
                <th>Active</th>
                <th>Start</th>
                <th>End</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (Array.isArray(campaigns) && campaigns.length) { %>
                <% campaigns.forEach(c => { %>
                  <% const campaignState = getCampaignTimeState(c); %>
                  <tr>
                    <td>
                      <span class="promo-campaign-id">#<%= c.id %></span>
                    </td>
                    <td>
                      <div class="promo-campaign-name"><%= c.name %></div>
                    </td>
                    <td>
                      <% if (c.store_name) { %>
                        <div class="promo-store-name"><%= c.store_name %></div>
                        <div class="promo-store-code"><%= c.store_code || '-' %></div>
                      <% } else { %>
                        <span class="text-muted">-</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="promo-status <%= campaignState.className %>"><%= campaignState.label %></span>
                      <div class="promo-campaign-meta"><%= campaignState.detail %></div>
                    </td>
                    <td>
                      <span class="promo-date">
                        <%= c.start_at ? new Date(c.start_at).toLocaleString() : '-' %>
                      </span>
                    </td>
                    <td>
                      <span class="promo-date">
                        <%= c.end_at ? new Date(c.end_at).toLocaleString() : '-' %>
                      </span>
                      <div class="promo-campaign-meta">
                        <%= campaignState.label %>
                      </div>
                    </td>
                    <td>
                      <div class="promo-action-stack">
                        <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#editCampaignModal-<%= c.id %>">
                          Edit
                        </button>
                        <form method="POST" action="/promotion/admin/campaigns/<%= c.id %>/status">
                          <input type="hidden" name="active" value="<%= c.active ? '0' : '1' %>">
                          <button class="btn btn-outline-warning btn-sm w-100">
                            <%= c.active ? 'Deactivate' : 'Activate' %>
                          </button>
                        </form>
                        <a href="#editCampaignModal-<%= c.id %>" class="btn btn-outline-secondary btn-sm w-100" data-bs-toggle="modal">
                          <%= campaignState.key === 'expired' ? 'View expired campaign' : 'Check campaign' %>
                        </a>
                        <form method="POST" action="/promotion/admin/campaigns/<%= c.id %>/delete"
                              onsubmit="return confirm('ยืนยันลบแคมเปญนี้ใช่หรือไม่?');">
                          <button class="btn btn-outline-danger btn-sm w-100">
                            Delete
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center promo-empty">
                    ยังไม่พบรายการแคมเปญในระบบ
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>
<% if (Array.isArray(campaigns) && campaigns.length) { %>
  <% campaigns.forEach(c => { %>
    <% const campaignStateModal = getCampaignTimeState(c); %>
    <div class="modal fade" id="editCampaignModal-<%= c.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">แก้ไขแคมเปญ #<%= c.id %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form method="POST" action="/promotion/admin/campaigns/<%= c.id %>/update" autocomplete="off">
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label">Campaign Code</label>
                  <input type="text" name="campaign_code" class="form-control" maxlength="100" value="<%= c.campaign_code || '' %>" required>
                </div>
                <div class="col-md-8">
                  <label class="form-label">ชื่อแคมเปญ</label>
                  <input type="text" name="name" class="form-control" maxlength="255" value="<%= c.name || '' %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label">เริ่มต้น</label>
                  <input type="datetime-local" name="start_at" class="form-control" value="<%= toDateTimeLocal(c.start_at) %>">
                </div>
                <div class="col-md-6">
                  <label class="form-label">สิ้นสุด</label>
                  <input type="datetime-local" name="end_at" class="form-control" value="<%= toDateTimeLocal(c.end_at) %>">
                </div>
                <div class="col-12">
                  <label class="form-label">รายละเอียด</label>
                  <textarea class="form-control" name="description" rows="3" maxlength="2000"><%= c.description || '' %></textarea>
                </div>
                <div class="col-12">
                  <small class="text-muted">
                    สาขา: <%= c.store_name || '-' %> (<%= c.store_code || '-' %>) • สถานะปัจจุบัน: <%= c.active ? 'Active' : 'Inactive' %> • <%= campaignStateModal.label %>
                  </small>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
              <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
<% } %>
<!-- include footer -->
<%- include('../footer.ejs') %>
