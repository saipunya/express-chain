              <ul class="main-chart-fallback" id="institutionSummaryChartFallback" hidden>
                <% _institutionChartData.forEach(function(item) { %>
                  <li>
                    <span><span class="main-chart-dot" style="--dot-color: <%= item.color %>"></span><%= item.label %></span>
                    <strong><%= item.count %> แห่ง</strong>
                  </li>
                <% }); %>
              </ul>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-7">
          <div class="row g-3 h-100">
            <% _institutionSummaryList.forEach(function(item) { %>
              <div class="col-md-4">
                <button
                  type="button"
                  class="main-institution-card"
                  data-institution-type="<%= item.key %>"
                  data-bs-toggle="modal"
                  data-bs-target="#institutionSummaryModal">
                  <div class="d-flex align-items-start justify-content-between gap-3">
                    <div>
                      <div class="main-institution-label"><%= item.label %></div>
                      <div class="main-institution-count mt-2"><%= item.count || 0 %></div>
                      <div class="main-institution-hint mt-2">
                        <span>ดูรายชื่อ</span>
                        <i class="bi bi-arrow-right-short"></i>
                      </div>
                    </div>
                    <div class="main-stat-icon <%= item.tone %>">
                      <i class="bi <%= item.icon %>"></i>
                    </div>
                  </div>
                </button>
              </div>
            <% }); %>
          </div>
        </div>
      </div>
