<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'หน้าแรกระบบ CoopChain' %></title>
    <% if (typeof themeColor !== 'undefined' && themeColor) { %>
      <meta name="theme-color" content="<%= themeColor %>" />
    <% } %>
    <% if (typeof manifestPath !== 'undefined' && manifestPath) { %>
      <link rel="manifest" href="<%= manifestPath %>" />
      <link rel="icon" href="/icon/seal.svg" />
      <link rel="apple-touch-icon" href="/icon/seal.svg" />
      <meta name="mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-title" content="CoopChain" />
      <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@200;400;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="d-flex flex-column min-vh-100 flex-grow-1">
    <main class="container py-4 flex-grow-1">

<style>
  .main-landing {
    min-height: calc(100vh - 220px);
  }

  .main-brand-panel {
    background:
      linear-gradient(135deg, rgba(16, 185, 129, 0.92), rgba(14, 116, 144, 0.88)),
      url('/icon/seal.svg') center 2rem / 15rem no-repeat;
    color: #fff;
    border-radius: 8px;
    overflow: hidden;
  }

  .main-brand-panel__inner {
    min-height: 28rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.02), rgba(4, 47, 46, 0.45));
  }

  .main-login-card,
  .main-link-card {
    border-radius: 8px;
  }

  .main-system-link {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .85rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    text-decoration: none;
    color: #0f172a;
    background: #fff;
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }

  .main-system-link:hover {
    color: #047857;
    border-color: #86efac;
    box-shadow: 0 .5rem 1.25rem rgba(15, 23, 42, .08);
    transform: translateY(-1px);
  }

  .main-system-link i {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: #ecfdf5;
    color: #059669;
    flex: 0 0 auto;
  }

  .main-deadline-section {
    margin-top: 1.5rem;
  }

  .main-deadline-card {
    border: 0;
    border-radius: 8px;
    box-shadow: 0 .25rem 1rem rgba(15, 23, 42, .08);
    height: 100%;
    overflow: hidden;
  }

  .main-deadline-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: #f8fafc;
    border-bottom: 1px solid #e5e7eb;
  }

  .main-deadline-title {
    display: flex;
    align-items: center;
    gap: .65rem;
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
  }

  .main-deadline-title i {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: #ecfdf5;
    color: #059669;
  }

  .main-deadline-count {
    white-space: nowrap;
    font-weight: 700;
  }

  .main-deadline-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .main-deadline-group + .main-deadline-group {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #eef2f7;
  }

  .main-deadline-group-name {
    font-size: .9rem;
    font-weight: 700;
    color: #047857;
    margin-bottom: .65rem;
  }

  .main-deadline-table {
    margin-bottom: 0;
    font-size: .92rem;
  }

  .main-deadline-table th {
    color: #64748b;
    font-weight: 700;
    white-space: nowrap;
  }

  .main-deadline-table td {
    vertical-align: middle;
  }

  .main-deadline-name {
    min-width: 12rem;
    font-weight: 600;
    color: #0f172a;
  }

  .main-empty {
    border: 1px dashed #cbd5e1;
    border-radius: 8px;
    color: #64748b;
    padding: 1rem;
    text-align: center;
    background: #f8fafc;
  }
</style>

<%
  const _bigmeetThisMonthGroups = (typeof bigmeetThisMonthGroups !== 'undefined' && Array.isArray(bigmeetThisMonthGroups)) ? bigmeetThisMonthGroups : [];
  const _closingWithin30Groups = (typeof closingWithin30Groups !== 'undefined' && Array.isArray(closingWithin30Groups)) ? closingWithin30Groups : [];
  const _bigmeetMonthLabel = (typeof bigmeetMonthLabel !== 'undefined' && bigmeetMonthLabel) ? bigmeetMonthLabel : '';
  const _closingWindowLabel = (typeof closingWindowLabel !== 'undefined' && closingWindowLabel) ? closingWindowLabel : '30 วันข้างหน้า';
  const _bigmeetCount = _bigmeetThisMonthGroups.reduce((sum, group) => sum + ((group.rows || []).length), 0);
  const _closingCount = _closingWithin30Groups.reduce((sum, group) => sum + ((group.rows || []).length), 0);
%>

<section class="main-landing">
  <div class="row g-4 align-items-stretch">
    <div class="col-lg-7">
      <div class="main-brand-panel h-100 shadow-sm">
        <div class="main-brand-panel__inner">
          <div class="mb-3">
            <span class="badge text-bg-light text-success px-3 py-2">CoopChain</span>
          </div>
          <h1 class="display-6 fw-bold mb-3 text-white">ระบบสารสนเทศและเครือข่ายสหกรณ์ในจังหวัดชัยภูมิ</h1>
          <p class="lead mb-0 text-white-50">ศูนย์รวมข้อมูล งานบริการ และเมนูสำหรับเจ้าหน้าที่ สหกรณ์ และกลุ่มเกษตรกร</p>
        </div>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="card main-login-card border-0 shadow-sm h-100">
        <div class="card-body p-4 p-xl-5 d-flex flex-column">
          <div class="mb-4">
            <h2 class="h4 fw-bold mb-2">เข้าสู่ระบบ</h2>
            <p class="text-muted mb-0">ลงชื่อเข้าใช้เพื่อเข้าสู่หน้าหลักตามสิทธิ์ของบัญชี</p>
          </div>

          <form action="/auth/login" method="POST" class="mb-4" novalidate>
            <div class="mb-3">
              <label for="username" class="form-label">ชื่อผู้ใช้</label>
              <input type="text" name="username" id="username" class="form-control form-control-lg" autocomplete="username" required autofocus>
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">รหัสผ่าน</label>
              <input type="password" name="password" id="password" class="form-control form-control-lg" autocomplete="current-password" required>
            </div>

            <div class="form-check mb-4">
              <input class="form-check-input" type="checkbox" id="rememberMe" name="rememberMe">
              <label class="form-check-label" for="rememberMe">จดจำฉัน</label>
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100">
              <i class="bi bi-box-arrow-in-right me-1"></i>เข้าสู่ระบบ
            </button>
          </form>

          <div class="mt-auto">
            <div class="small text-uppercase text-muted fw-semibold mb-2">เมนูลัด</div>
            <div class="d-grid gap-2">
              <a href="/register" class="main-system-link">
                <i class="bi bi-person-plus"></i>
                <span>สมัครสมาชิก</span>
              </a>
              <a href="/" class="main-system-link">
                <i class="bi bi-house-door"></i>
                <span>หน้าเว็บไซต์ข้อมูลสาธารณะ</span>
              </a>
              <a href="/meetingroom" class="main-system-link">
                <i class="bi bi-calendar-week"></i>
                <span>ห้องประชุม</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="main-deadline-section">
  <div class="row g-4 align-items-stretch">
    <div class="col-lg-6">
      <div class="card main-deadline-card">
        <div class="main-deadline-head">
          <h2 class="main-deadline-title">
            <i class="bi bi-people"></i>
            ประชุมใหญ่ภายในเดือนนี้
          </h2>
          <span class="badge text-bg-success main-deadline-count"><%= _bigmeetCount %> แห่ง</span>
        </div>
        <div class="main-deadline-body">
          <div class="text-muted small mb-3">
            กำหนดประชุมใหญ่ภายในเดือน <%= _bigmeetMonthLabel || '-' %> อ้างอิงจากวันสิ้นปีบัญชี + 150 วัน
          </div>
          <% if (_bigmeetThisMonthGroups.length) { %>
            <% _bigmeetThisMonthGroups.forEach(function(group) { %>
              <div class="main-deadline-group">
                <div class="main-deadline-group-name"><%= group.groupName %></div>
                <div class="table-responsive">
                  <table class="table table-sm main-deadline-table align-middle">
                    <thead>
                      <tr>
                        <th>สถาบัน</th>
                        <th>สิ้นปีบัญชี</th>
                        <th>ครบกำหนด</th>
                        <th>สถานะ</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% (group.rows || []).forEach(function(row) { %>
                        <tr>
                          <td class="main-deadline-name"><%= row.c_name || '-' %></td>
                          <td><%= row.endDateThai || '-' %></td>
                          <td><%= row.meetingDeadlineThai || '-' %></td>
                          <td>
                            <% if (row.meetingDateThai) { %>
                              <span class="badge text-bg-success">ประชุมแล้ว <%= row.meetingDateThai %></span>
                            <% } else if (row.meetingRecordedStatus === 'not_met') { %>
                              <span class="badge text-bg-secondary">บันทึกว่ายังไม่ประชุม</span>
                            <% } else { %>
                              <span class="badge text-bg-warning text-dark">รอดำเนินการ</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="main-empty">ไม่มีรายการครบกำหนดประชุมใหญ่ในเดือนนี้</div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card main-deadline-card">
        <div class="main-deadline-head">
          <h2 class="main-deadline-title">
            <i class="bi bi-journal-check"></i>
            ปิดบัญชีภายใน 30 วัน
          </h2>
          <span class="badge text-bg-info main-deadline-count"><%= _closingCount %> แห่ง</span>
        </div>
        <div class="main-deadline-body">
          <div class="text-muted small mb-3">
            รายการครบกำหนดปิดบัญชีในช่วง <%= _closingWindowLabel %> โดยนับจากวันสิ้นปีบัญชี + 30 วัน
          </div>
          <% if (_closingWithin30Groups.length) { %>
            <% _closingWithin30Groups.forEach(function(group) { %>
              <div class="main-deadline-group">
                <div class="main-deadline-group-name"><%= group.groupName %></div>
                <div class="table-responsive">
                  <table class="table table-sm main-deadline-table align-middle">
                    <thead>
                      <tr>
                        <th>สถาบัน</th>
                        <th>สิ้นปีบัญชี</th>
                        <th>ครบกำหนดปิดบัญชี</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% (group.rows || []).forEach(function(row) { %>
                        <tr>
                          <td class="main-deadline-name"><%= row.c_name || '-' %></td>
                          <td><%= row.endDateThai || '-' %></td>
                          <td><%= row.closingDeadlineThai || '-' %></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="main-empty">ไม่มีรายการครบกำหนดปิดบัญชีใน 30 วันข้างหน้า</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
