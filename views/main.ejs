    <section class="main-institution-section" aria-labelledby="mainDownloadTitle">
      <div class="main-section-title">
        <div>
          <h2 id="mainDownloadTitle">ดาวน์โหลด</h2>
          <div class="text-muted small">
            เอกสารและลิงก์สำหรับสหกรณ์/กลุ่มเกษตรกร และผู้ใช้งานทั่วไป
          </div>
        </div>
        <span class="badge text-bg-primary">
          <%= Number(_mainDownloads.length || 0).toLocaleString('th-TH') %> รายการ
        </span>
      </div>

      <% if (_mainDownloads.length) { %>
        <div class="main-download-list">
          <% _mainDownloads.forEach(function(item) { %>
            <% const itemUrl = item.downloadUrl || '#'; %>
            <% const itemDisabled = !item.downloadUrl; %>
            <a
              class="main-download-item <%= itemDisabled ? 'pe-none opacity-75' : '' %>"
              href="<%= itemUrl %>"
              target="_blank"
              rel="noopener"
              aria-label="ดาวน์โหลด <%= item.down_subject || 'เอกสาร' %>"
            >
              <span class="main-download-icon">
                <i class="bi <%= item.hasFile ? 'bi-file-earmark-arrow-down' : 'bi-link-45deg' %>"></i>
              </span>
              <div class="main-download-content">
                <div class="main-download-subject"><%= item.down_subject || '-' %></div>
                <div class="main-download-meta">
                  <% if (item.down_group) { %>
                    <span><i class="bi bi-folder2-open"></i><%= item.down_group %></span>
                  <% } %>
                  <% if (item.down_type) { %>
                    <span><i class="bi bi-tag"></i><%= item.down_type %></span>
                  <% } %>
                  <% if (item.savedDateThai) { %>
                    <span><i class="bi bi-calendar3"></i><%= item.savedDateThai %></span>
                  <% } %>
                </div>
              </div>
              <span class="main-download-action">
                <span class="badge <%= item.down_for === 'all' ? 'text-bg-success' : 'text-bg-info' %>">
                  <%= item.down_for === 'all' ? 'all' : 'coop' %>
                </span>
                <i class="bi bi-box-arrow-up-right text-muted"></i>
              </span>
            </a>
          <% }); %>
        </div>
      <% } else { %>
        <div class="main-empty">ยังไม่มีรายการดาวน์โหลดสำหรับ all หรือ coop</div>
      <% } %>
    </section>

 <section class="main-deadline-section" aria-labelledby="mainOnlineTitle">
      <div class="main-online-card">
        <div class="main-online-head">
          <h2 class="main-online-title" id="mainOnlineTitle">
            <i class="bi bi-person-check"></i>
            Members Online
          </h2>
          <span class="badge text-bg-success">
            <span id="onlineCountValue" aria-live="polite"><%= _onlineCount %></span> ออนไลน์
          </span>
        </div>
        <div class="main-online-body">
          <div class="main-online-summary">
            <div>
              <div class="text-muted small">บุคคลทั่วไปออนไลน์ขณะนี้</div>
              <div class="main-online-count" id="onlineCountSummary" aria-live="polite"><%= _onlineCount %></div>
            </div>
            <span class="main-pill">
              <i class="bi bi-circle-fill main-online-dot"></i>
              <span>อัปเดตแบบเรียลไทม์</span>
            </span>
          </div>

          <% if (_onlineUsers.length) { %>
            <div class="main-online-list">
              <% _onlineUsers.forEach(function(user) { %>
