<%- include('../header.ejs', { title: title }) %>
<style>
  .promo-users-page {
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    min-height: 100vh;
    padding: 36px 0 52px;
  }
  .promo-users-shell {
    max-width: 1320px;
    margin: 0 auto;
  }
  .promo-users-topbar,
  .promo-users-card {
    background: #fff;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 12px 34px rgba(15, 23, 42, 0.06);
  }
  .promo-users-topbar {
    padding: 22px;
    margin-bottom: 18px;
  }
  .promo-users-card {
    padding: 20px;
  }
  .promo-title {
    font-size: clamp(1.6rem, 2.8vw, 2.3rem);
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 6px;
  }
  .promo-subtitle {
    color: #64748b;
    margin-bottom: 0;
  }
  .table thead th {
    font-size: 0.82rem;
    text-transform: uppercase;
    color: #64748b;
    letter-spacing: 0.04em;
  }
  .badge-role {
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .badge-role-super {
    background: #dbeafe;
    color: #1d4ed8;
  }
  .badge-role-coop {
    background: #dcfce7;
    color: #166534;
  }
  .badge-active {
    background: #dcfce7;
    color: #166534;
  }
  .badge-inactive {
    background: #fee2e2;
    color: #991b1b;
  }
  .form-control,
  .form-select,
  .btn {
    border-radius: 10px;
  }
</style>

<div class="promo-users-page">
  <div class="container promo-users-shell">
    <div class="promo-users-topbar d-flex flex-column flex-xl-row justify-content-between align-items-start gap-3">
      <div>
        <h1 class="promo-title">🛡️ <%= title %></h1>
        <p class="promo-subtitle">จัดการบัญชีผู้ดูแล `/promotion` แยกตามสิทธิ์ super_admin และ coop_admin</p>
      </div>
      <div class="d-flex gap-2 align-items-center">
        <% if (promotionAdmin) { %>
          <small class="text-muted"><%= promotionAdmin.display_name || promotionAdmin.username %> (<%= promotionAdmin.role %>)</small>
        <% } %>
        <a href="/promotion/admin/stores" class="btn btn-outline-primary btn-sm">Stores</a>
        <a href="/promotion/admin" class="btn btn-outline-secondary btn-sm">Back to dashboard</a>
        <a href="/promotion/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a>
      </div>
    </div>

    <% if (locals && locals.flash) { %>
      <div class="alert alert-<%= locals.flash.type || 'info' %> rounded-3">
        <%= locals.flash.message %>
      </div>
    <% } %>

    <div class="promo-users-card mb-3">
      <h5 class="fw-bold mb-3">Create Admin User</h5>
      <form class="row g-3" method="POST" action="/promotion/admin/users" autocomplete="off">
        <div class="col-md-3">
          <label class="form-label">Username</label>
          <input type="text" name="username" class="form-control" required maxlength="100" placeholder="promo-store2">
        </div>
        <div class="col-md-3">
          <label class="form-label">Display Name</label>
          <input type="text" name="display_name" class="form-control" maxlength="150" placeholder="Promotion Admin Store 2">
        </div>
        <div class="col-md-2">
          <label class="form-label">Role</label>
          <select class="form-select" id="create_role" name="role" data-role-select data-target="#create_store" required>
            <option value="coop_admin" selected>coop_admin</option>
            <option value="super_admin">super_admin</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Store</label>
          <select class="form-select" id="create_store" name="store_id">
            <option value="">เลือกสาขา</option>
            <% stores.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.name %> (<%= s.store_code || '-' %>)</option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" minlength="8" maxlength="200" required>
        </div>
        <div class="col-12 d-flex justify-content-end">
          <button class="btn btn-primary">Create User</button>
        </div>
      </form>
    </div>

    <div class="promo-users-card">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>User</th>
              <th>Role / Scope</th>
              <th>Status</th>
              <th>Last Login</th>
              <th style="min-width: 340px;">Profile Update</th>
              <th style="min-width: 260px;">Reset Password</th>
              <th style="min-width: 150px;">Delete User</th>
            </tr>
          </thead>
          <tbody>
            <% if (Array.isArray(users) && users.length) { %>
              <% users.forEach(u => { %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= u.display_name || '-' %></div>
                    <div><code><%= u.username %></code></div>
                  </td>
                  <td>
                    <div class="mb-1">
                      <span class="badge-role <%= u.role === 'super_admin' ? 'badge-role-super' : 'badge-role-coop' %>"><%= u.role %></span>
                    </div>
                    <% if (u.role === 'coop_admin') { %>
                      <small class="text-muted">Store: <%= u.store_name || '-' %> (<%= u.store_code || '-' %>)</small>
                    <% } else { %>
                      <small class="text-muted">All stores</small>
                    <% } %>
                  </td>
                  <td>
                    <form method="POST" action="/promotion/admin/users/<%= u.id %>/status" class="d-inline">
                      <input type="hidden" name="is_active" value="<%= Number(u.is_active) ? '0' : '1' %>">
                      <span class="badge-role <%= Number(u.is_active) ? 'badge-active' : 'badge-inactive' %>">
                        <%= Number(u.is_active) ? 'active' : 'inactive' %>
                      </span>
                      <button class="btn btn-sm <%= Number(u.is_active) ? 'btn-outline-danger' : 'btn-outline-success' %> ms-2">
                        <%= Number(u.is_active) ? 'Disable' : 'Enable' %>
                      </button>
                    </form>
                  </td>
                  <td>
                    <small><%= u.last_login_at ? new Date(u.last_login_at).toLocaleString() : '-' %></small>
                  </td>
                  <td>
                    <form method="POST" action="/promotion/admin/users/<%= u.id %>/update" class="row g-2">
                      <div class="col-12">
                        <input type="text" class="form-control form-control-sm" name="display_name" maxlength="150" value="<%= u.display_name || '' %>" placeholder="Display name">
                      </div>
                      <div class="col-6">
                        <select class="form-select form-select-sm"
                                name="role"
                                data-role-select
                                data-target="#user_store_<%= u.id %>">
                          <option value="super_admin" <%= u.role === 'super_admin' ? 'selected' : '' %>>super_admin</option>
                          <option value="coop_admin" <%= u.role === 'coop_admin' ? 'selected' : '' %>>coop_admin</option>
                        </select>
                      </div>
                      <div class="col-6">
                        <select class="form-select form-select-sm" id="user_store_<%= u.id %>" name="store_id">
                          <option value="">เลือกสาขา</option>
                          <% stores.forEach(s => { %>
                            <option value="<%= s.id %>" <%= Number(u.store_id) === Number(s.id) ? 'selected' : '' %>>
                              <%= s.name %>
                            </option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="col-12 text-end">
                        <button class="btn btn-sm btn-outline-primary">Save Profile</button>
                      </div>
                    </form>
                  </td>
                  <td>
                    <form method="POST" action="/promotion/admin/users/<%= u.id %>/reset-password" class="row g-2">
                      <div class="col-12">
                        <input type="password" name="password" class="form-control form-control-sm" minlength="8" maxlength="200" placeholder="New password" required>
                      </div>
                      <div class="col-12">
                        <input type="password" name="confirm_password" class="form-control form-control-sm" minlength="8" maxlength="200" placeholder="Confirm password" required>
                      </div>
                      <div class="col-12 text-end">
                        <button class="btn btn-sm btn-outline-warning">Reset Password</button>
                      </div>
                    </form>
                  </td>
                  <td>
                    <% const isSelfUser = promotionAdmin && Number(promotionAdmin.id) === Number(u.id); %>
                    <% if (isSelfUser) { %>
                      <small class="text-muted">Current account</small>
                    <% } else { %>
                      <form method="POST" action="/promotion/admin/users/<%= u.id %>/delete" class="text-end" onsubmit="return confirm('ยืนยันลบผู้ใช้งาน <%= u.username %> ?');">
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">ยังไม่พบบัญชีผู้ใช้งาน admin</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const roleSelectors = document.querySelectorAll('[data-role-select]');
    roleSelectors.forEach((roleSelect) => {
      const targetSelector = roleSelect.getAttribute('data-target');
      if (!targetSelector) return;
      const storeSelect = document.querySelector(targetSelector);
      if (!storeSelect) return;

      const syncStoreState = () => {
        const isCoop = roleSelect.value === 'coop_admin';
        storeSelect.disabled = !isCoop;
        storeSelect.required = isCoop;
        if (!isCoop) storeSelect.value = '';
      };

      roleSelect.addEventListener('change', syncStoreState);
      syncStoreState();
    });
  })();
</script>

<%- include('../footer.ejs') %>
