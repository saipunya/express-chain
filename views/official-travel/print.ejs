<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>พิมพ์คำขอไปราชการ</title>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Sarabun', 'TH SarabunPSK', 'TH Sarabun New', Arial, sans-serif;
      margin: 0;
      padding: 18px;
      background: #fff;
      color: #111;
      font-size: 15px;
      line-height: 1.45;
    }
    .print-sheet {
      max-width: 900px;
      margin: 0 auto;
      padding: 18px;
      box-sizing: border-box;
    }
    .document-header {
      text-align: center;
      margin-bottom: 14px;
    }
    .document-header h1 {
      margin: 0;
      font-size: 24px;
      letter-spacing: 0.05em;
    }
    .document-header h2 {
      margin: 6px 0 0;
      font-size: 16px;
      font-weight: 400;
    }
    .meta-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 16px;
      font-size: 14px;
      line-height: 1.35;
    }
    .meta-table td {
      padding: 5px 6px;
      vertical-align: top;
      border-bottom: 1px dotted #999;
    }
    .meta-table .label {
      width: 120px;
      font-weight: 700;
      white-space: nowrap;
    }
    .section-title {
      font-size: 15px;
      font-weight: 700;
      margin: 14px 0 6px;
    }
    .signature-block {
      margin-top: 28px;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
    }
    .signature-row {
      width: 100%;
      display: flex;
      justify-content: space-between;
      gap: 24px;
    }
    .signature-area {
      min-width: 320px;
      flex: 1;
      text-align: center;
    }
    .signature-area.left {
      text-align: center;
    }
    .signature-area.right {
      text-align: center;
    }
    .no-print {
      margin-bottom: 14px;
      text-align: right;
    }
    .summary-block {
      font-size: 15px;
      line-height: 1.6;
      margin-bottom: 16px;
    }
    .summary-block span {
      display: block;
    }
    .companions-list {
      margin: 0 0 0 22px;
      padding: 0;
    }
    .companions-list li {
      margin: 0 0 3px;
      line-height: 1.35;
    }
    @media print {
      .no-print { display: none; }
      body { padding: 0; }
      .print-sheet { box-shadow: none; padding: 0; }
    }
  </style>
</head>
<body>
  <div class="print-sheet">
    <div class="no-print">
      <button onclick="window.print()">พิมพ์</button>
    </div>

    <div class="document-header">
      <h1 style="font-size:24px;margin-bottom:6px;">บันทึกข้อความ</h1>
      <h2>คำขออนุญาตเดินทางไปราชการ</h2>
    </div>

    <% function thaiDate(dateStr) {
      if (!dateStr) return '-';
      const d = new Date(dateStr);
      if (Number.isNaN(d.getTime())) return '-';
      return d.toLocaleDateString('th-TH', { dateStyle: 'long', timeZone: 'Asia/Bangkok' });
    }

    function thaiTime(dateStr) {
      if (!dateStr) return '-';
      const d = new Date(dateStr);
      if (Number.isNaN(d.getTime())) return '-';
      return d.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Bangkok' });
    }

    function transportLabel(type, otherText) {
      if (type === 'official_vehicle') return 'รถยนต์ราชการ';
      if (type === 'private_vehicle') return 'รถยนต์ส่วนตัว';
      if (type === 'public_transport') return 'รถโดยสารสาธารณะ';
      if (type === 'airplane') return 'เครื่องบิน';
      if (type === 'train') return 'รถไฟ';
      if (type === 'other') return otherText || 'อื่น ๆ';
      return type || '-';
    }

    const startDate = thaiDate(item.start_at);
    const endDate = thaiDate(item.end_at || item.start_at);
    const startTime = thaiTime(item.start_at);
    const endTime = thaiTime(item.end_at);
    const departmentName = item.department_name || item.requester_group || 'สำนักงานสหกรณ์จังหวัดชัยภูมิ';
    %>

    <table class="meta-table">
      <tr>
        <td class="label">ส่วนราชการ</td>
        <td colspan="3"><%= departmentName %></td>
      </tr>
      <tr>
        <td class="label">ที่</td>
        <td style="width:180px"><%= item.request_no || '-' %></td>
        <td class="label">วันที่</td>
        <td><%= thaiDate(item.request_date) %></td>
      </tr>
      <tr>
        <td class="label">เรื่อง</td>
        <td colspan="3"><%= item.subject || 'ขออนุญาตไปราชการ' %></td>
      </tr>
      <tr>
        <td class="label">เรียน</td>
        <td colspan="3"><%= item.learn_to || 'ผู้อำนวยการสำนักงานสหกรณ์จังหวัดชัยภูมิ' %></td>
      </tr>
    </table>

    <div class="summary-block">
      <span>ข้าพเจ้า <strong><%= item.requester_name || '-' %></strong> ตำแหน่ง <strong><%= item.requester_position || '-' %></strong> กลุ่มงาน <strong><%= item.requester_group || '-' %></strong></span>
      <span>มีความประสงค์ขออนุญาตไปราชการเพื่อ <strong><%= item.purpose_text || '-' %></strong></span>
      <span>สถานที่ <strong><%= item.destination_text || '-' %></strong></span>
      <span>ระหว่างวันที่ <strong><%= startDate %></strong> ถึงวันที่ <strong><%= endDate %></strong></span>
      <span>เวลา <strong><%= startTime %></strong> ถึง <strong><%= endTime %></strong></span>
      <span>วิธีเดินทาง <strong><%= transportLabel(item.transport_type, item.transport_other_text) %></strong></span>
    </div>

    <div>
      <div class="section-title">ผู้ร่วมเดินทาง</div>
      <% if (item.companions && item.companions.length > 0) { %>
        <ol class="companions-list">
          <% item.companions.forEach((companion) => { %>
            <li><%= companion.companion_name %> (<%= companion.companion_position || '-' %>)</li>
          <% }) %>
        </ol>
      <% } else { %>
        <div style="margin-left: 24px;">-</div>
      <% } %>
    </div>

    <% const hasEstimatedCosts = item.transport_type === 'official_vehicle' || Number(item.estimated_allowance) > 0 || Number(item.estimated_lodging) > 0 || Number(item.estimated_fuel) > 0; %>
    <% if (hasEstimatedCosts) { %>
      <div style="margin: 16px 0 24px;">
        <div class="section-title">ประมาณการค่าใช้จ่าย</div>
        <table style="width:100%; border-collapse:collapse; font-size:14px; line-height:1.45;">
          <tr>
            <td style="width: 50%; padding: 3px 0;">ค่าเบี้ยเลี้ยง (บาท)</td>
            <td style="padding: 3px 0; border-bottom: 1px dotted #999;"><strong><%= item.estimated_allowance ?? '-' %></strong></td>
          </tr>
          <tr>
            <td style="padding: 3px 0;">ค่าที่พัก (บาท)</td>
            <td style="padding: 3px 0; border-bottom: 1px dotted #999;"><strong><%= item.estimated_lodging ?? '-' %></strong></td>
          </tr>
          <tr>
            <td style="padding: 3px 0;">ค่าน้ำมัน/พาหนะเชื้อเพลิง (บาท)</td>
            <td style="padding: 3px 0; border-bottom: 1px dotted #999;"><strong><%= item.estimated_fuel ?? '-' %></strong></td>
          </tr>
        </table>
      </div>
    <% } %>

    <div class="signature-block">
      <div class="signature-row">
        <div class="signature-area left">
          <div style="margin-bottom: 48px;">&nbsp;</div>
          <div>ผู้เห็นชอบ</div>
          <div>ลงชื่อ....................................................</div>
          <div>(....................................................)</div>
          <div style="margin-top: 4px;">ตำแหน่ง....................................................</div>
        </div>
        <div class="signature-area right">
          <div style="margin-bottom: 48px;">&nbsp;</div>
          <div>ผู้ขออนุมัติ</div>
          <div>ลงชื่อ....................................................</div>
          <div>(<%= item.requester_name || '-' %>)</div>
          <div style="margin-top: 4px;">ตำแหน่ง....................................................</div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
