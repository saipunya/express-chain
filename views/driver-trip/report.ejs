<%- include('../partials/header') %>
<% const canEditMileage = user && ['admin', 'hiring'].includes(user.mClass); %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">รายงานการใช้รถยนต์รายเดือน</h3>
    <p class="text-muted mb-0">กรองตามชื่อพนักงานขับรถยนต์และเดือน เพื่อดูรายการงานและส่งออก PDF</p>
  </div>
  <div class="d-flex gap-2">
    <a href="/driver-trip/queue" class="btn btn-outline-secondary">กลับคิวงาน</a>
    <% if (selectedDriverId) { %>
      <a href="/driver-trip/report/pdf?driverId=<%= encodeURIComponent(selectedDriverId) %>&month=<%= encodeURIComponent(month) %>" target="_blank" class="btn btn-danger">
        ส่งออก PDF
      </a>
    <% } %>
  </div>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<div id="driverTripReportFeedback"></div>

<form method="GET" action="/driver-trip/report" class="card shadow-sm border-0 mb-4" id="driverTripReportForm">
  <div class="card-body">
    <div class="row g-3 align-items-end">
      <div class="col-md-5">
        <label class="form-label">พนักงานขับรถ</label>
        <select class="form-select" name="driverId" required onchange="document.getElementById('driverTripReportForm').submit()">
          <option value="">เลือกพนักงานขับรถ</option>
          <% (drivers || []).forEach((driver) => { %>
            <option value="<%= driver.id %>" <%= String(selectedDriverId) === String(driver.id) ? 'selected' : '' %>><%= driver.driver_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">เดือน</label>
        <select class="form-select" name="month" required onchange="document.getElementById('driverTripReportForm').submit()">
          <% (monthOptions || []).forEach((option) => { %>
            <option value="<%= option.value %>" <%= String(month) === String(option.value) ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>
      </div>
    </div>
  </div>
</form>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted small">จำนวนงานทั้งหมด</div>
        <div class="fs-3 fw-bold"><%= summary.total || 0 %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted small">บันทึกเช้าแล้ว</div>
        <div class="fs-3 fw-bold"><%= summary.morningLogged || 0 %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted small">เสร็จสิ้นแล้ว</div>
        <div class="fs-3 fw-bold"><%= summary.completed || 0 %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="text-muted small">ระยะทางรวม</div>
        <div class="fs-3 fw-bold"><%= Number(summary.distance || 0).toFixed(1) %> กม.</div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <div>
      <h5 class="mb-0">รายการเดือน <%= monthLabel %></h5>
      <div class="small text-muted"><%= selectedDriver ? selectedDriver.driver_name : '-' %></div>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th>วันเดินทาง</th>
          <th>เลขที่คำขอ</th>
          <th>ปลายทาง</th>
          <th>เวลา/ไมล์</th>
          <th>ระยะทาง</th>
          <th>สถานะ</th>
          <th class="text-end">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (!items.length) { %>
          <tr>
            <td colspan="7" class="text-center py-4 text-muted">ไม่พบรายการในเดือนนี้</td>
          </tr>
        <% } %>
        <% items.forEach((item) => { %>
          <tr>
            <td><%= item.trip_start_at ? new Date(item.trip_start_at).toLocaleDateString('th-TH', { dateStyle: 'medium' }) : '-' %></td>
            <td>
              <div class="fw-semibold"><%= item.vehicle_request_no %></div>
              <div class="mt-1">
                <span class="badge text-bg-light border"><%= item.travel_request_id ? 'คำขอปกติ' : 'คำขอใช้รถยนต์ตรง' %></span>
              </div>
            </td>
            <td>
              <div class="fw-semibold"><%= item.destination_text %></div>
              <small class="text-muted"><%= item.requester_name %></small>
            </td>
            <td>
              <div>เช้า: <%= item.morning_departure_at ? new Date(item.morning_departure_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) : '-' %></div>
              <div>บ่าย: <%= item.afternoon_return_at ? new Date(item.afternoon_return_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) : '-' %></div>
            </td>
            <td>
              <div>ออก: <%= item.morning_odometer || '-' %></div>
              <div>เข้า: <%= item.afternoon_odometer || '-' %></div>
            </td>
            <td>
              <span class="badge <%= item.log_status === 'completed' ? 'bg-success' : item.log_status === 'morning_logged' ? 'bg-warning text-dark' : 'bg-danger' %>">
                <%= item.log_status === 'completed' ? 'เสร็จสิ้น' : item.log_status === 'morning_logged' ? 'บันทึกเช้าแล้ว' : 'เข้าใหม่' %>
              </span>
            </td>
            <td class="text-end">
              <div class="btn-group btn-group-sm" role="group">
                <a href="/driver-trip/<%= item.vehicle_request_id %>" class="btn btn-outline-primary">เปิดงาน</a>
                <% if (canEditMileage) { %>
                <button
                  type="button"
                  class="btn btn-outline-secondary"
                  data-bs-toggle="modal"
                  data-bs-target="#editMileageModal-<%= item.vehicle_request_id %>">
                  แก้ไขไมล์
                </button>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<% if (canEditMileage) { (items || []).forEach((item) => { %>
  <div class="modal fade" id="editMileageModal-<%= item.vehicle_request_id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form method="POST" action="/driver-trip/report/<%= item.vehicle_request_id %>/mileage">
          <div class="modal-header">
            <h5 class="modal-title">แก้ไขข้อมูลไมล์</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" name="driverId" value="<%= selectedDriverId %>">
            <input type="hidden" name="month" value="<%= month %>">
            <div class="mb-3">
              <label class="form-label">ไมล์เช้า</label>
              <input
                type="number"
                step="0.1"
                min="0"
                class="form-control"
                name="morning_odometer"
                value="<%= item.morning_odometer !== null && item.morning_odometer !== undefined ? item.morning_odometer : '' %>">
            </div>
            <div>
              <label class="form-label">ไมล์บ่าย</label>
              <input
                type="number"
                step="0.1"
                min="0"
                class="form-control"
                name="afternoon_odometer"
                value="<%= item.afternoon_odometer !== null && item.afternoon_odometer !== undefined ? item.afternoon_odometer : '' %>">
            </div>
            <div class="form-text mt-2">ถ้าปล่อยว่าง ระบบจะคงค่าปัจจุบันไว้</div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
            <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% }) } %>

<script>
  (function () {
    const feedback = document.getElementById('driverTripReportFeedback');
    if (!feedback) return;

    const params = new URLSearchParams(window.location.search);
    const success = params.get('success');
    const error = params.get('error');
    if (!success && !error) return;

    const alertClass = success ? 'alert-success' : 'alert-danger';
    const message = success || error;
    const alert = document.createElement('div');
    alert.className = 'alert ' + alertClass + ' alert-dismissible fade show';
    alert.setAttribute('role', 'alert');

    const text = document.createElement('span');
    text.textContent = message;

    const closeButton = document.createElement('button');
    closeButton.type = 'button';
    closeButton.className = 'btn-close';
    closeButton.setAttribute('data-bs-dismiss', 'alert');
    closeButton.setAttribute('aria-label', 'Close');

    alert.appendChild(text);
    alert.appendChild(closeButton);
    feedback.appendChild(alert);
  })();
</script>

<%- include('../partials/footer') %>
