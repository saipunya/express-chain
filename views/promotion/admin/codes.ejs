<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
    <div>
      <h1 class="display-6 fw-bold mb-2"><%= title %></h1>
      <p class="text-muted mb-0">สร้างและดูโค้ดโปรโมชั่น พร้อมดูโค้ดใหม่ที่สร้างขึ้นในหน้าเดียว</p>
    </div>
    <a href="/promotion/admin" class="btn btn-outline-secondary btn-sm">Back</a>
  </div>

  <% if (locals.flash) { %>
    <div class="mb-3">
      <div class="alert alert-<%= locals.flash.type || 'info' %> alert-dismissible fade show"><%= locals.flash.message %><button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
    </div>
  <% } %>

  <div class="row g-3 mb-4">
    <div class="col-12 col-lg-5">
      <div class="card shadow-sm rounded-4 h-100">
        <div class="card-body">
          <h2 class="h5 fw-semibold mb-3">Generate Codes</h2>
          <form method="POST" action="/promotion/admin/codes/generate" class="mt-3">
            <div class="mb-3">
              <label class="form-label">Store</label>
              <select class="form-select" id="storeSelect" name="store_id">
                <option value="">-- All stores --</option>
                <% if (Array.isArray(stores)) { %>
                  <% stores.forEach(s => { %>
                    <option value="<%= s.id %>"><%= s.name %> (<%= s.store_code %>)</option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Campaign</label>
              <select class="form-select" id="campaignSelect" name="campaign_id">
                <option value="">-- All campaigns --</option>
                <% if (Array.isArray(campaigns)) { %>
                  <% campaigns.forEach(c => { %>
                    <option value="<%= c.id %>" data-store-id="<%= c.store_id %>"><%= c.name %> (<%= c.campaign_code %>)</option>
                  <% }) %>
                <% } %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Quantity</label>
              <input type="number" name="quantity" class="form-control" min="1" max="50000" value="100" required />
              <div class="form-text">ระบุจำนวนโค้ดที่ต้องการสร้าง (สูงสุด 50,000). ตัวอักษรอย่าง O,0,I,1 ถูกละไว้</div>
            </div>

            <div class="d-grid">
              <button type="submit" class="btn btn-primary">Generate</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-7">
      <% if (newCodes && newCodes.length) { %>
        <div class="card shadow-sm rounded-4 border-success h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h5 class="card-title mb-1">Newly Generated Codes (<%= newCodes.length %>)</h5>
                <div class="small text-muted">คัดลอกหรือส่งออกโค้ดที่สร้างใหม่ได้จากที่นี่</div>
              </div>
              <div>
                <button id="copyCodesBtn" class="btn btn-sm btn-outline-secondary">Copy</button>
              </div>
            </div>

            <div class="table-responsive mt-3">
              <table class="table table-sm table-bordered mb-0">
                <thead class="table-light">
                  <tr><th>Code</th><th>Issued At</th><th>Expires At</th></tr>
                </thead>
                <tbody>
                  <% newCodes.forEach(nc => { %>
                    <tr>
                      <td><code class="text-break"><%= nc.code %></code></td>
                      <td><%= nc.issued_at ? new Date(nc.issued_at).toLocaleString() : '-' %></td>
                      <td><%= nc.expires_at ? new Date(nc.expires_at).toLocaleString() : '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card shadow-sm rounded-4">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-striped mb-0">
          <thead class="table-light">
            <tr>
              <th>Code</th>
              <th>Store</th>
              <th>Campaign</th>
              <th>Status</th>
              <th>Issued At</th>
              <th>Expires At</th>
            </tr>
          </thead>
          <tbody>
            <% if (Array.isArray(codes) && codes.length) { %>
              <% codes.forEach(c => { %>
                <tr>
                  <td><%= c.code %></td>
                  <td><%= c.store_name || '-' %></td>
                  <td><%= c.campaign_name || '-' %></td>
                  <td><span class="badge bg-<%= c.status === 'unused' ? 'success' : 'secondary' %>"><%= c.status %></span></td>
                  <td><%= c.issued_at ? new Date(c.issued_at).toLocaleString() : '-' %></td>
                  <td><%= c.expires_at ? new Date(c.expires_at).toLocaleString() : '-' %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="6" class="text-center text-muted">No codes found</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    (function() {
      const storeSelect = document.getElementById('storeSelect');
      const campaignSelect = document.getElementById('campaignSelect');
      const copyBtn = document.getElementById('copyCodesBtn');

      if (storeSelect && campaignSelect) {
        function filterCampaigns() {
          const storeId = storeSelect.value;
          Array.from(campaignSelect.options).forEach(opt => {
            if (!opt.value) return opt.hidden = false;
            const optStore = opt.getAttribute('data-store-id') || '';
            opt.hidden = storeId && optStore !== storeId;
          });
        }
        storeSelect.addEventListener('change', filterCampaigns);
        filterCampaigns();
      }

      // Prevent double-submit on generate form
      const form = document.querySelector('form[action="/promotion/admin/codes/generate"]');
      if (form) {
        form.addEventListener('submit', function () {
          const btn = form.querySelector('button[type="submit"]');
          if (btn) {
            btn.disabled = true;
            btn.innerText = 'Generating...';
          }
        }, { once: true });
      }

      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          const rows = Array.from(document.querySelectorAll('table tbody tr'));
          const codes = rows.map(r => r.querySelector('td') ? r.querySelector('td').innerText.trim() : '').filter(Boolean).join('\n');
          if (!codes) return;
          navigator.clipboard && navigator.clipboard.writeText(codes).then(() => {
            copyBtn.innerText = 'Copied';
            setTimeout(() => { copyBtn.innerText = 'Copy'; }, 2000);
          }).catch(() => { alert('Copy failed'); });
        });
      }
    })();
  </script>
</div>
