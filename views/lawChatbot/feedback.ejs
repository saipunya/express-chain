<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
      <h1 class="h4 mb-1">ข้อมูลฟีดแบ็กแชตบอทกฎหมาย</h1>
      <div class="text-muted small">ทั้งหมด <%= total %> รายการ</div>
    </div>
    <a href="/law-chatbot" class="btn btn-sm btn-outline-primary">กลับไปหน้าแชตบอท</a>
  </div>

  <form method="get" action="/law-chatbot/feedback" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label small mb-1">เป้าหมายกฎหมาย</label>
        <select name="target" class="form-select form-select-sm">
          <option value="" <%= !filters.target ? 'selected' : '' %>>ทั้งหมด</option>
          <option value="coop" <%= filters.target === 'coop' ? 'selected' : '' %>>สหกรณ์</option>
          <option value="group" <%= filters.target === 'group' ? 'selected' : '' %>>กลุ่มเกษตรกร</option>
          <option value="all" <%= filters.target === 'all' ? 'selected' : '' %>>รวมทุกกฎหมาย</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label small mb-1">ความเป็นประโยชน์</label>
        <select name="helpful" class="form-select form-select-sm">
          <option value="" <%= !filters.helpful ? 'selected' : '' %>>ทั้งหมด</option>
          <option value="1" <%= filters.helpful === '1' ? 'selected' : '' %>>มีประโยชน์</option>
          <option value="0" <%= filters.helpful === '0' ? 'selected' : '' %>>ควรปรับปรุง</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small mb-1">ต่อหน้า</label>
        <select name="pageSize" class="form-select form-select-sm">
          <% [20, 50, 100].forEach(size => { %>
            <option value="<%= size %>" <%= Number(pageSize) === size ? 'selected' : '' %>><%= size %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4 d-flex gap-2">
        <button type="submit" class="btn btn-sm btn-primary">กรองข้อมูล</button>
        <a href="/law-chatbot/feedback" class="btn btn-sm btn-outline-secondary">ล้างตัวกรอง</a>
      </div>
    </div>
  </form>

  <div class="card">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th style="width: 80px;">ID</th>
            <th style="width: 120px;">เวลา</th>
            <th style="width: 90px;">เป้าหมาย</th>
            <th style="width: 120px;">ผลประเมิน</th>
            <th>คำถาม</th>
            <th>คำตอบที่แสดง</th>
            <th>คำตอบที่คาดหวัง</th>
            <th style="width: 150px;">มาตราที่แนะนำ</th>
          </tr>
        </thead>
        <tbody>
          <% if (!feedbackRows || !feedbackRows.length) { %>
            <tr>
              <td colspan="8" class="text-center text-muted py-4">ยังไม่มีข้อมูลฟีดแบ็ก</td>
            </tr>
          <% } %>

          <% (feedbackRows || []).forEach((row) => { %>
            <tr>
              <td><%= row.id %></td>
              <td class="small"><%= new Date(row.created_at).toLocaleString('th-TH') %></td>
              <td><span class="badge bg-secondary"><%= row.target %></span></td>
              <td>
                <% if (Number(row.is_helpful) === 1) { %>
                  <span class="badge bg-success">มีประโยชน์</span>
                <% } else { %>
                  <span class="badge bg-warning text-dark">ควรปรับปรุง</span>
                <% } %>
              </td>
              <td class="small" style="min-width: 210px;"><%= row.question %></td>
              <td class="small" style="min-width: 280px; white-space: pre-wrap;"><%= row.answer_shown %></td>
              <td class="small" style="min-width: 220px;"><%= row.expected_answer || '-' %></td>
              <td class="small"><%= row.suggested_law_number || '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="card-footer bg-light d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div class="small text-muted">หน้า <%= page %> / <%= totalPages %></div>
      <% const prev = Math.max(1, page - 1); const next = Math.min(totalPages, page + 1); %>
      <div class="d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary <%= page <= 1 ? 'disabled' : '' %>" href="/law-chatbot/feedback?<%= new URLSearchParams({ ...filters, pageSize, page: prev }).toString() %>">ก่อนหน้า</a>
        <a class="btn btn-sm btn-outline-secondary <%= page >= totalPages ? 'disabled' : '' %>" href="/law-chatbot/feedback?<%= new URLSearchParams({ ...filters, pageSize, page: next }).toString() %>">ถัดไป</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
