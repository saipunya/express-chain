<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>พิมพ์คำขอใช้รถราชการ</title>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Sarabun', 'TH SarabunPSK', 'TH Sarabun New', Arial, sans-serif;
      margin: 0;
      padding: 24px;
      background: #fff;
      color: #111;
    }

    .print-sheet {
      max-width: 900px;
      margin: 0 auto;
      padding: 24px;
      box-sizing: border-box;
    }

    .document-header {
      text-align: center;
      margin-bottom: 20px;
    }

    .document-header h1 {
      margin: 0;
      font-size: 28px;
      letter-spacing: 0.05em;
    }

    .document-header h2 {
      margin: 8px 0 0;
      font-size: 18px;
      font-weight: 400;
    }

    .meta-table,
    .field-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 16px;
    }

    .meta-table td,
    .field-table td {
      padding: 8px 6px;
      vertical-align: top;
      border-bottom: 1px dotted #999;
    }

    .meta-table .label,
    .field-table .label {
      width: 120px;
      font-weight: 700;
      white-space: nowrap;
    }

    .two-column {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 16px;
    }

    .field-box {
      border: 1px solid #333;
      padding: 12px;
      min-height: 116px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .field-box strong {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
    }

    .field-value {
      font-size: 15px;
      line-height: 1.5;
      white-space: pre-wrap;
    }

    .section-title {
      font-size: 16px;
      font-weight: 700;
      margin: 20px 0 8px;
    }

    .signature-block {
      margin-top: 36px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .signature-row {
      display: flex;
      align-items: center;
      width: 100%;
      max-width: 560px;
      gap: 12px;
      font-size: 14px;
      white-space: nowrap;
    }

    .signature-row span {
      display: inline-block;
      min-width: 90px;
      text-align: center;
    }

    .signature-line {
      flex: 1;
      border-bottom: 1px solid #000;
      height: 1px;
    }

    .signature-name {
      text-align: center;
      font-size: 14px;
      width: 100%;
      max-width: 560px;
    }

    .no-print {
      margin-bottom: 24px;
      text-align: right;
    }

    @media print {
      .no-print {
        display: none;
      }

      body {
        padding: 0;
      }

      .print-sheet {
        box-shadow: none;
        padding: 0;
      }
    }
  </style>
</head>
<body>
  <div class="print-sheet">
    <div class="no-print">
      <button onclick="window.print()">พิมพ์</button>
    </div>


    <div class="document-header">
      <h1 style="font-size:32px;margin-bottom:8px;">บันทึกข้อความ</h1>
    </div>
    <table class="meta-table" style="margin-bottom:24px;">
      <tr>
        <td class="label">ส่วนราชการ</td>
        <td colspan="3">สำนักงานสหกรณ์จังหวัดชัยภูมิ ฝ่ายบริหารทั่วไป โทร. 0 4482 2218 ต่อ 1</td>
      </tr>
      <tr>
        <td class="label">ที่</td>
        <td style="width:180px"><%= item.vehicle_request_no || '-' %></td>
        <td class="label">วันที่</td>
        <td>
          <% function thaiDate(dateStr) {
            if (!dateStr) return '-';
            const d = new Date(dateStr);
            if (isNaN(d)) return '-';
            const months = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
            return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear() + 543}`;
          } %>
          <%= thaiDate(item.request_date) %>
        </td>
      </tr>
      <tr>
        <td class="label">เรื่อง</td>
        <td colspan="3">ขออนุญาตใช้รถราชการ</td>
      </tr>
      <tr>
        <td class="label">เรียน</td>
        <td colspan="3"><%= item.learn_to || '-' %></td>
      </tr>
    </table>

    <div style="margin-bottom: 24px; font-size: 16px; line-height: 2.1;">
      <span>ข้าพเจ้า <strong><%= item.requester_name || '-' %></strong> ตำแหน่ง <strong><%= item.requester_position || '-' %></strong></span>
      <span>มีความประสงค์ขออนุญาตใช้รถราชการเพื่อ <strong><%= item.mission_text || '-' %></strong></span>
      <span>ปลายทาง <strong><%= item.destination_text || '-' %></strong></span>
      <span>ในวันที่ <strong><%= item.trip_start_at ? thaiDate(item.trip_start_at) : '-' %></strong></span>
      <span>เวลา <strong><%= item.trip_start_at ? new Date(item.trip_start_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) : '-' %> - <%= item.trip_end_at ? new Date(item.trip_end_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) : '-' %></strong></span>
      <span>จำนวนผู้โดยสาร <strong><%= typeof item.passenger_count !== 'undefined' ? item.passenger_count : '-' %></strong> คน</span>
    </div>

    <div style="margin-top: 48px; display: flex; flex-direction: column; align-items: flex-end;">
      <div style="min-width: 320px; text-align: center;">
        <div style="margin-bottom: 48px;">&nbsp;</div>
        <div>ลงชื่อ....................................................</div>
        <div>(<%= item.requester_name || '-' %>)</div>
        <div style="margin-top: 4px;">ตำแหน่ง <%= item.requester_position || '-' %></div>
      </div>
    </div>
  </div>
</body>
</html>
