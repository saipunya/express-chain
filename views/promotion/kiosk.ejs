<!-- include header -->
<%- include('header.ejs') %>
<%
  const storeSafe = (typeof store !== 'undefined') ? store : null;
  const storeCodeSafe = (typeof storeCode !== 'undefined' && storeCode)
    ? String(storeCode).toUpperCase()
    : (storeSafe && storeSafe.store_code ? String(storeSafe.store_code).toUpperCase() : '');
  const featuredPrizesSafe = Array.isArray(featuredPrizes) ? featuredPrizes : [];
%>

<style>
  .promo-kiosk-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    padding: 32px 0 48px;
  }

  .promo-kiosk-shell {
    max-width: 1200px;
    margin: 0 auto;
  }

  .promo-kiosk-top {
    text-align: center;
    margin-bottom: 24px;
  }

  .promo-kiosk-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    background: #eff6ff;
    color: #2563eb;
    font-weight: 700;
    font-size: 0.98rem;
    margin-bottom: 16px;
  }

  .promo-kiosk-title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin-bottom: 12px;
  }

  .promo-kiosk-highlight {
    color: #2563eb;
  }

  .promo-kiosk-desc {
    max-width: 860px;
    margin: 0 auto;
    font-size: 1.08rem;
    color: #64748b;
    line-height: 1.7;
  }

  .promo-kiosk-store-chip-row {
    margin-top: 14px;
    display: flex;
    justify-content: center;
  }

  .promo-kiosk-store-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 10px 16px;
    background: #e0f2fe;
    color: #0c4a6e;
    font-weight: 700;
  }

  .promo-kiosk-card {
    background: #fff;
    border: 1px solid rgba(37, 99, 235, 0.10);
    border-radius: 32px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    overflow: hidden;
    position: relative;
  }

  .promo-kiosk-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(37, 99, 235, 0.08), transparent 28%),
      radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.08), transparent 24%);
    pointer-events: none;
  }

  .promo-kiosk-card-body {
    position: relative;
    z-index: 1;
    padding: 32px;
  }

  .promo-stage-box {
    background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 24px;
    padding: 28px;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
  }

  .promo-stage-head {
    text-align: center;
    margin-bottom: 24px;
  }

  .promo-stage-icon {
    width: 88px;
    height: 88px;
    margin: 0 auto 14px;
    border-radius: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    color: #fff;
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    box-shadow: 0 16px 32px rgba(37, 99, 235, 0.22);
  }

  .promo-stage-title {
    font-size: 1.9rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .promo-stage-desc {
    font-size: 1.02rem;
    color: #64748b;
    margin-bottom: 0;
  }

  .promo-kiosk-label {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 10px;
  }

  .promo-kiosk-code {
    min-height: 88px;
    border-radius: 22px;
    border: 2px solid #dbeafe;
    background: #fff;
    box-shadow: 0 12px 28px rgba(37, 99, 235, 0.07);
    text-align: center;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    color: #0f172a;
    transition: all 0.18s ease;
  }

  .promo-kiosk-code:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 0.3rem rgba(37, 99, 235, 0.14), 0 18px 34px rgba(37, 99, 235, 0.10);
  }

  .promo-kiosk-helper {
    margin-top: 10px;
    text-align: center;
    color: #64748b;
    font-size: 0.95rem;
  }

  .promo-kiosk-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 24px;
  }

  .promo-kiosk-btn {
    min-height: 62px;
    padding: 14px 26px;
    border-radius: 18px;
    font-size: 1.08rem;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.18s ease;
    text-decoration: none;
    border-width: 2px;
  }

  .promo-kiosk-btn-primary {
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    color: #fff;
    border: none;
    box-shadow: 0 16px 32px rgba(37, 99, 235, 0.22);
  }

  .promo-kiosk-btn-primary:hover {
    color: #fff;
    transform: translateY(-2px);
    background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
  }

  .promo-kiosk-btn-success {
    background: linear-gradient(135deg, #059669 0%, #10b981 100%);
    color: #fff;
    border: none;
    box-shadow: 0 16px 32px rgba(5, 150, 105, 0.20);
  }

  .promo-kiosk-btn-success:hover {
    color: #fff;
    transform: translateY(-2px);
  }

  .promo-kiosk-btn-outline {
    background: #fff;
    color: #475569;
    border: 2px solid #cbd5e1;
  }

  .promo-kiosk-btn-outline:hover {
    background: #f8fafc;
    color: #0f172a;
    transform: translateY(-2px);
  }

  .promo-kiosk-btn-danger {
    background: #fff;
    color: #dc2626;
    border: 2px solid rgba(220, 38, 38, 0.24);
  }

  .promo-kiosk-btn-danger:hover {
    background: #fef2f2;
    color: #b91c1c;
    transform: translateY(-2px);
  }

  .promo-kiosk-alert .alert {
    border-radius: 18px;
    padding: 16px 18px;
    font-size: 1rem;
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.04);
  }

  .promo-campaign-box,
  .promo-result-box {
    background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 22px;
    padding: 24px;
    text-align: center;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
  }

  .promo-campaign-name,
  .promo-prize-name {
    font-size: 2rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 6px;
    line-height: 1.2;
  }

  .promo-campaign-sub,
  .promo-prize-desc {
    color: #64748b;
    font-size: 1rem;
    margin-bottom: 0;
  }

  .promo-benefit-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 2px auto 12px;
    padding: 9px 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #0284c7, #2563eb);
    color: #fff;
    font-weight: 800;
    box-shadow: 0 10px 22px rgba(2, 132, 199, 0.24);
  }

  .promo-prize-detail-box {
    width: min(100%, 560px);
    margin: 12px auto 0;
    border-radius: 16px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: #f8fafc;
    padding: 12px 14px;
    text-align: left;
  }

  .promo-prize-detail-title {
    font-size: 0.85rem;
    color: #334155;
    font-weight: 800;
    margin-bottom: 4px;
  }

  .promo-prize-detail-text {
    color: #475569;
    margin: 0;
    white-space: pre-wrap;
  }

  .promo-price-grid {
    width: min(100%, 560px);
    margin: 8px auto 10px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .promo-price-item {
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 14px;
    background: #fff;
    padding: 10px 12px;
    text-align: left;
  }

  .promo-price-label {
    font-size: 0.78rem;
    color: #64748b;
    font-weight: 700;
    margin-bottom: 3px;
  }

  .promo-price-value {
    font-size: 1.05rem;
    font-weight: 800;
    color: #0f172a;
  }

  .promo-price-value.payable {
    color: #059669;
  }

  .promo-prize-visual {
    width: min(100%, 480px);
    margin: 0 auto 14px;
    border-radius: 20px;
    border: 1px solid rgba(148, 163, 184, 0.22);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.1);
    overflow: hidden;
    background: #fff;
  }

  .promo-prize-visual img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  .promo-prize-visual-empty {
    width: 100%;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    color: #64748b;
    font-weight: 700;
  }

  .promo-no-prize {
    font-size: 1.7rem;
    font-weight: 800;
    color: #64748b;
    margin-bottom: 0;
  }

  .promo-claim-box {
    margin-top: 22px;
    background: #ffffff;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 22px;
    padding: 22px;
  }

  .promo-claim-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: #0f172a;
    text-align: center;
    margin-bottom: 18px;
  }

  .promo-claim-input {
    min-height: 62px;
    border-radius: 16px;
    text-align: center;
    font-size: 1.12rem;
    border: 2px solid #e2e8f0;
  }

  .promo-claim-input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.12);
  }

  .promo-kiosk-note-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 24px;
  }

  .promo-kiosk-showcase {
    margin: 0 0 22px;
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 20px;
    background: linear-gradient(180deg, #fff 0%, #f8fbff 100%);
    padding: 16px;
  }

  .promo-kiosk-showcase-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: #1e293b;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .promo-kiosk-showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
  }

  .promo-kiosk-showcase-item {
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 14px;
    background: #fff;
    padding: 10px;
    position: relative;
    overflow: hidden;
  }

  .promo-kiosk-showcase-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    z-index: 2;
    background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
    color: #fff;
    border-radius: 999px;
    padding: 5px 10px;
    font-size: 0.75rem;
    font-weight: 800;
    line-height: 1;
    box-shadow: 0 8px 16px rgba(239, 68, 68, 0.24);
  }

  .promo-kiosk-showcase-badge.is-discount {
    background: linear-gradient(135deg, #dc2626 0%, #f97316 100%);
    box-shadow: 0 8px 16px rgba(220, 38, 38, 0.24);
  }

  .promo-kiosk-showcase-badge.is-coupon-cash {
    background: linear-gradient(135deg, #059669 0%, #16a34a 100%);
    box-shadow: 0 8px 16px rgba(5, 150, 105, 0.24);
  }

  .promo-kiosk-showcase-badge.is-coupon-discount {
    background: linear-gradient(135deg, #0284c7 0%, #2563eb 100%);
    box-shadow: 0 8px 16px rgba(2, 132, 199, 0.24);
  }

  .promo-kiosk-showcase-badge.is-credit {
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
    box-shadow: 0 8px 16px rgba(124, 58, 237, 0.24);
  }

  .promo-kiosk-showcase-badge.is-free {
    background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
    box-shadow: 0 8px 16px rgba(245, 158, 11, 0.24);
  }

  .promo-kiosk-showcase-image {
    width: 100%;
    height: 110px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
    background: #f1f5f9;
    margin-bottom: 8px;
  }

  .promo-kiosk-showcase-noimage {
    width: 100%;
    height: 110px;
    border-radius: 10px;
    background: #eff6ff;
    color: #2563eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 8px;
  }

  .promo-kiosk-showcase-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.35;
    min-height: 2.6em;
  }

  .promo-kiosk-showcase-stock {
    margin-top: 6px;
    font-size: 0.8rem;
    color: #64748b;
  }

  .promo-kiosk-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 15px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 0.95rem;
    font-weight: 700;
  }

  a.promo-kiosk-chip {
    text-decoration: none;
  }

  a.promo-kiosk-chip:hover {
    color: #1d4ed8;
    background: #dbeafe;
  }

  .promo-kiosk-chip-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2563eb;
    display: inline-block;
  }

  @media (max-width: 767.98px) {
    .promo-kiosk-page {
      padding: 20px 0 32px;
    }

    .promo-kiosk-card-body {
      padding: 18px;
    }

    .promo-stage-box {
      padding: 20px 16px;
      border-radius: 20px;
    }

    .promo-stage-title {
      font-size: 1.55rem;
    }

    .promo-kiosk-code {
      min-height: 74px;
      font-size: 1.55rem;
      letter-spacing: 0.12em;
    }

    .promo-kiosk-actions {
      flex-direction: column;
    }

    .promo-kiosk-btn {
      width: 100%;
    }

    .promo-campaign-name,
    .promo-prize-name {
      font-size: 1.55rem;
    }

    .promo-no-prize {
      font-size: 1.35rem;
    }
  }
  .spin-box {
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spin-wheel {
  font-size: 70px;
  animation: spinRoll 0.6s linear infinite;
}

@keyframes spinRoll {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(360deg) scale(1); }
}

/* ตอน reveal */
.spin-stop {
  animation: popReveal 0.6s ease;
}

@keyframes popReveal {
  0% { transform: scale(0.5); opacity: 0; }
  70% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.promo-spin-modal[hidden] {
  display: none !important;
}

.promo-spin-modal {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: rgba(15, 23, 42, 0.42);
  backdrop-filter: blur(4px);
}

.promo-spin-panel {
  width: min(100%, 420px);
  background: #fff;
  border-radius: 24px;
  padding: 28px 24px;
  text-align: center;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.24);
}

.promo-kiosk-page.is-result-mode .promo-kiosk-top,
.promo-kiosk-page.is-result-mode #messageBox,
.promo-kiosk-page.is-result-mode .promo-kiosk-note-row,
.promo-kiosk-page.is-result-mode .promo-kiosk-showcase,
.promo-kiosk-page.is-result-mode #stage-enter,
.promo-kiosk-page.is-result-mode #stage-validated {
  display: none !important;
}

.promo-kiosk-page.is-result-mode .promo-kiosk-card-body {
  padding-top: 28px;
}

body.promo-spin-open {
  overflow: hidden;
}
</style>

<div class="promo-kiosk-page" id="kioskPageRoot">
  <div class="container-fluid">
    <div class="promo-kiosk-shell">

      <div class="promo-kiosk-top">
        <div class="promo-kiosk-badge">
          <span>🖥️</span>
          <span>โหมดคีออสก์</span>
        </div>
        <h1 class="promo-kiosk-title">
          <%= title %><span class="promo-kiosk-highlight"> สำหรับหน้าร้าน</span>
        </h1>
        <p class="promo-kiosk-desc">
          กรอกรหัสโปรโมชั่น แล้วแตะตรวจสอบเพื่อเข้าสู่ขั้นตอนจับรางวัลได้อย่างรวดเร็ว
          เหมาะสำหรับใช้งานบนหน้าจอคีออสก์หรือจุดบริการลูกค้า
        </p>
        <% if (storeSafe) { %>
          <div class="promo-kiosk-store-chip-row">
            <span class="promo-kiosk-store-chip">
              <i class="bi bi-shop"></i>
              สาขา <%= storeSafe.name %> (<%= storeCodeSafe || '-' %>)
            </span>
          </div>
        <% } %>
      </div>

      <div class="promo-kiosk-card">
        <div class="promo-kiosk-card-body">

          <div id="messageBox" class="promo-kiosk-alert mb-3" aria-live="polite"></div>

          <div class="promo-kiosk-note-row mb-4">
            <span class="promo-kiosk-chip"><span class="promo-kiosk-chip-dot"></span> กรอกง่าย</span>
            <span class="promo-kiosk-chip"><span class="promo-kiosk-chip-dot"></span> ปุ่มใหญ่</span>
            <span class="promo-kiosk-chip"><span class="promo-kiosk-chip-dot"></span> ใช้งานเร็ว</span>
            <a class="promo-kiosk-chip" href="/promotion/admin">
              <i class="bi bi-shield-lock"></i>
              <span>สำหรับผู้ดูแล</span>
            </a>
          </div>

          <% if (storeSafe && featuredPrizesSafe.length) { %>
            <div class="promo-kiosk-showcase">
              <div class="promo-kiosk-showcase-title">
                <i class="bi bi-stars"></i>
                ของรางวัลเด่นของสาขานี้
              </div>
              <div class="promo-kiosk-showcase-grid">
                <% featuredPrizesSafe.forEach(prize => { %>
                  <div class="promo-kiosk-showcase-item">
                    <% if (prize.badge_text) { %>
                      <span class="promo-kiosk-showcase-badge <%= prize.badge_class || '' %>"><%= prize.badge_text %></span>
                    <% } %>
                    <% if (prize.image_url) { %>
                      <img src="<%= prize.image_url %>" alt="<%= prize.name || 'Prize image' %>" class="promo-kiosk-showcase-image">
                    <% } else { %>
                      <div class="promo-kiosk-showcase-noimage">🎁</div>
                    <% } %>
                    <div class="promo-kiosk-showcase-name"><%= prize.name || '-' %></div>
                    <div class="promo-kiosk-showcase-stock">คงเหลือประมาณ <%= Number(prize.remaining_qty || 0) %> ชิ้น</div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>

          <div class="promo-stage-box" id="stage-enter">
            <div class="promo-stage-head">
              <div class="promo-stage-icon">🎁</div>
              <div class="promo-stage-title">กรอกรหัสโปรโมชั่น</div>
              <p class="promo-stage-desc">รับรหัสจากเจ้าหน้าที่ แล้วกรอกเพื่อเริ่มต้นลุ้นรางวัล</p>
            </div>

            <div class="mb-3">
              <label for="kiosk-code" class="promo-kiosk-label">รหัสโปรโมชั่น</label>
              <input
                id="kiosk-code"
                class="form-control promo-kiosk-code"
                placeholder="กรอกรหัสที่นี่"
                inputmode="numeric"
                autocomplete="off"
                autocorrect="off"
                autocapitalize="characters"
                spellcheck="false"
                aria-label="รหัสโปรโมชั่น"
              >
              <div class="promo-kiosk-helper">ระบบจะปรับรหัสให้เป็นตัวพิมพ์ใหญ่และตัดอักขระที่ไม่ถูกต้องให้อัตโนมัติ</div>
            </div>

            <div class="promo-kiosk-actions">
              <button id="validateBtn" class="btn promo-kiosk-btn promo-kiosk-btn-primary">ตรวจสอบรหัส</button>
              <button id="clearBtn" class="btn promo-kiosk-btn promo-kiosk-btn-outline">ล้างข้อมูล</button>
            </div>
          </div>

          <div id="stage-validated" class="d-none">
            <div class="promo-stage-box">
              <div class="promo-stage-head">
                <div class="promo-stage-icon">✅</div>
                <div class="promo-stage-title">ตรวจสอบรหัสสำเร็จ</div>
                <p class="promo-stage-desc">พร้อมเข้าสู่ขั้นตอนการจับรางวัล</p>
              </div>

              <div id="campaignInfo" class="promo-campaign-box mb-4"></div>

              <div class="promo-kiosk-actions">
                <button id="drawBtn" class="btn promo-kiosk-btn promo-kiosk-btn-success">จับรางวัล</button>
                <button id="backToInputBtn" class="btn promo-kiosk-btn promo-kiosk-btn-outline">เริ่มใหม่</button>
              </div>
            </div>
          </div>

          <div id="stage-result" class="d-none">
            <div class="promo-stage-box">
              <div class="promo-stage-head">
                <div class="promo-stage-icon">🎉</div>
                <div class="promo-stage-title">ผลการจับรางวัล</div>
                <p class="promo-stage-desc">ตรวจสอบผลลัพธ์ด้านล่าง และเลือกดำเนินการต่อได้ทันที</p>
              </div>

              <div id="prizeBox" class="promo-result-box mb-3"></div>

              <div id="claimArea" class="promo-claim-box d-none">
                <div class="promo-claim-title">ฟอร์มยืนยันการรับรางวัล</div>
                <input
                  id="customerName"
                  class="form-control promo-claim-input mb-3"
                  placeholder="ชื่อผู้รับ"
                  autocomplete="off"
                  aria-label="ชื่อผู้รับ"
                />
                <input
                  id="customerPhone"
                  class="form-control promo-claim-input mb-3"
                  placeholder="เบอร์โทรศัพท์"
                  inputmode="tel"
                  autocomplete="off"
                  aria-label="เบอร์โทรศัพท์"
                />
                <div class="promo-kiosk-actions">
                  <button id="claimBtn" class="btn promo-kiosk-btn promo-kiosk-btn-success">ยืนยันการเคลม</button>
                  <button id="declineBtn" class="btn promo-kiosk-btn promo-kiosk-btn-danger">ปฏิเสธรางวัล</button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
<div id="spinModal" class="promo-spin-modal" hidden>
  <div class="promo-spin-panel">
    <div class="spin-box mb-3">
      <div class="spin-wheel" id="spinWheel">🎁</div>
    </div>

    <h4 class="fw-bold">กำลังสุ่มรางวัล...</h4>
    <p class="text-muted mb-0">โปรดรอสักครู่</p>
  </div>
</div>
<script>
(() => {
  const STORE_CODE = <%- JSON.stringify(storeCodeSafe || null) %>;
  const el = id => document.getElementById(id);
  const kioskPageRoot = el('kioskPageRoot');
  const msgBox = el('messageBox');
  const codeInput = el('kiosk-code');
  const validateBtn = el('validateBtn');
  const clearBtn = el('clearBtn');
  const stageEnter = el('stage-enter');
  const stageValidated = el('stage-validated');
  const campaignInfo = el('campaignInfo');
  const drawBtn = el('drawBtn');
  const backToInputBtn = el('backToInputBtn');
  const stageResult = el('stage-result');
  const prizeBox = el('prizeBox');
  const claimArea = el('claimArea');
  const customerName = el('customerName');
  const customerPhone = el('customerPhone');
  const claimBtn = el('claimBtn');
  const declineBtn = el('declineBtn');
  const spinModal = el('spinModal');
  const spinWheel = el('spinWheel');

  let currentDrawToken = null;
  let autoResetTimer = null;

  function showMessage(text, type = 'info') {
    if (!msgBox) return;
    msgBox.innerHTML = '';
    const div = document.createElement('div');
    div.className = 'alert alert-' + (type || 'info');
    div.role = 'alert';
    div.innerText = text;
    msgBox.appendChild(div);
  }

  function clearMessage() {
    if (msgBox) msgBox.innerHTML = '';
  }

  function sanitizeCodeInput(s) {
    if (!s) return '';
    return String(s).toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 64);
  }

  function toEnter() {
    clearTimeout(autoResetTimer);
    currentDrawToken = null;
    hideDrawEffect();
    if (kioskPageRoot) kioskPageRoot.classList.remove('is-result-mode');

    if (codeInput) codeInput.value = '';
    if (customerName) customerName.value = '';
    if (customerPhone) customerPhone.value = '';

    if (stageEnter) stageEnter.classList.remove('d-none');
    if (stageValidated) stageValidated.classList.add('d-none');
    if (stageResult) stageResult.classList.add('d-none');

    if (campaignInfo) campaignInfo.innerHTML = '';
    if (prizeBox) prizeBox.innerHTML = '';
    if (claimArea) claimArea.classList.add('d-none');

    clearMessage();
    setTimeout(() => {
      if (codeInput) codeInput.focus();
    }, 250);
  }

  function showDrawEffect() {
    if (!spinModal || !spinWheel) return;
    spinModal.hidden = false;
    document.body.classList.add('promo-spin-open');
    spinWheel.innerHTML = '🎁';
    spinWheel.classList.remove('spin-stop');
    spinWheel.style.animation = 'spinRoll 0.6s linear infinite';
  }

  function hideDrawEffect() {
    if (!spinModal || !spinWheel) return;
    spinWheel.style.animation = 'none';
    spinWheel.classList.remove('spin-stop');
    spinWheel.innerHTML = '🎁';
    spinModal.hidden = true;
    document.body.classList.remove('promo-spin-open');
  }

  function renderDrawResult(data) {
    currentDrawToken = data.draw_token;
    if (kioskPageRoot) kioskPageRoot.classList.add('is-result-mode');

    if (stageValidated) stageValidated.classList.add('d-none');
    if (stageResult) stageResult.classList.remove('d-none');

    if (!prizeBox) return;

    prizeBox.innerHTML = '';

    if (data.prize) {
      const visual = document.createElement('div');
      visual.className = 'promo-prize-visual';
      if (data.prize.image_url) {
        const img = document.createElement('img');
        img.src = data.prize.image_url;
        img.alt = data.prize.name || 'Prize image';
        visual.appendChild(img);
      } else {
        const empty = document.createElement('div');
        empty.className = 'promo-prize-visual-empty';
        empty.innerText = '🎁 รูปรางวัลจะปรากฏเมื่อมีการอัปโหลด';
        visual.appendChild(empty);
      }

      const heading = document.createElement('div');
      heading.className = 'promo-prize-name';
      heading.innerText = data.prize.name || 'รางวัล';

      const benefit = document.createElement('div');
      benefit.className = 'promo-benefit-chip';
      benefit.innerText = data.prize.benefit_text
        ? ('สิทธิ์ที่ได้รับ: ' + data.prize.benefit_text)
        : 'สิทธิ์ที่ได้รับ: รางวัลพิเศษ';

      const description = document.createElement('div');
      description.className = 'promo-prize-desc';
      description.innerText = data.prize.description || '';

      const detailBox = document.createElement('div');
      detailBox.className = 'promo-prize-detail-box';
      const detailTitle = document.createElement('div');
      detailTitle.className = 'promo-prize-detail-title';
      detailTitle.innerText = 'รายละเอียดของรางวัล';
      const detailText = document.createElement('p');
      detailText.className = 'promo-prize-detail-text';
      detailText.innerText = data.prize.description || '-';
      detailBox.appendChild(detailTitle);
      detailBox.appendChild(detailText);

      const hasPrice = data.prize.full_price_amount || data.prize.payable_amount === 0 || data.prize.payable_amount;
      let priceGrid = null;
      if (hasPrice) {
        priceGrid = document.createElement('div');
        priceGrid.className = 'promo-price-grid';

        if (data.prize.full_price_amount) {
          const fullPriceItem = document.createElement('div');
          fullPriceItem.className = 'promo-price-item';
          const fullPriceLabel = document.createElement('div');
          fullPriceLabel.className = 'promo-price-label';
          fullPriceLabel.innerText = 'ราคาเต็มสินค้า';
          const fullPriceValue = document.createElement('div');
          fullPriceValue.className = 'promo-price-value';
          fullPriceValue.innerText = `${Number(data.prize.full_price_amount).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} บาท`;
          fullPriceItem.appendChild(fullPriceLabel);
          fullPriceItem.appendChild(fullPriceValue);
          priceGrid.appendChild(fullPriceItem);
        }

        if (data.prize.payable_amount === 0 || data.prize.payable_amount) {
          const payableItem = document.createElement('div');
          payableItem.className = 'promo-price-item';
          const payableLabel = document.createElement('div');
          payableLabel.className = 'promo-price-label';
          payableLabel.innerText = 'ราคาที่ต้องจ่าย';
          const payableValue = document.createElement('div');
          payableValue.className = 'promo-price-value payable';
          payableValue.innerText = `${Number(data.prize.payable_amount).toLocaleString('th-TH', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} บาท`;
          payableItem.appendChild(payableLabel);
          payableItem.appendChild(payableValue);
          priceGrid.appendChild(payableItem);
        }
      }

      prizeBox.appendChild(visual);
      prizeBox.appendChild(heading);
      prizeBox.appendChild(benefit);
      if (priceGrid) prizeBox.appendChild(priceGrid);
      prizeBox.appendChild(description);
      prizeBox.appendChild(detailBox);

      if (claimArea) claimArea.classList.remove('d-none');
      return;
    }

    const noPrize = document.createElement('div');
    noPrize.className = 'promo-no-prize';
    noPrize.innerText = 'ขออภัย วันนี้คุณไม่ได้รับรางวัล';
    prizeBox.appendChild(noPrize);

    if (claimArea) claimArea.classList.add('d-none');
    autoReset(8000);
  }

  async function handleValidate() {
    const code = sanitizeCodeInput(codeInput ? codeInput.value : '');
    if (!code) {
      showMessage('กรุณากรอกรหัสโปรโมชั่น', 'warning');
      return;
    }

    showMessage('กำลังตรวจสอบรหัส...', 'info');
    if (validateBtn) validateBtn.disabled = true;

    try {
      const resp = await fetch('/promotion/kiosk/validate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          code,
          store_code: STORE_CODE || undefined
        })
      });
      const data = await resp.json();

      if (!data.ok) {
        showMessage(data.message || 'ไม่สามารถตรวจสอบได้', 'danger');
        autoReset(5000);
        return;
      }

      if (campaignInfo) {
        campaignInfo.innerHTML = '';

        const name = document.createElement('div');
        name.className = 'promo-campaign-name';
        name.innerText = (data.campaign && data.campaign.name) || '-';

        const details = document.createElement('div');
        details.className = 'promo-campaign-sub';
        details.innerText = data.store
          ? `${data.store.name} (${data.store.store_code || '-'})`
          : '';

        campaignInfo.appendChild(name);
        campaignInfo.appendChild(details);
      }

      if (stageEnter) stageEnter.classList.add('d-none');
      if (stageValidated) stageValidated.classList.remove('d-none');
      if (stageResult) stageResult.classList.add('d-none');

      clearMessage();
    } catch (err) {
      console.error(err);
      showMessage('เกิดข้อผิดพลาดขณะตรวจสอบ', 'danger');
      autoReset(5000);
    } finally {
      if (validateBtn) validateBtn.disabled = false;
    }
  }

  async function handleDraw() {
    const code = sanitizeCodeInput(codeInput ? codeInput.value : '');
    if (!code) {
      showMessage('กรุณากรอกรหัสโปรโมชั่น', 'warning');
      return;
    }

    clearMessage();
    if (drawBtn) {
      drawBtn.disabled = true;
      drawBtn.innerText = 'กำลังสุ่มรางวัล...';
    }

    try {
      const resp = await fetch('/promotion/kiosk/draw', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          code,
          store_code: STORE_CODE || undefined
        })
      });
      const contentType = resp.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        throw new Error('Unexpected response type from /promotion/kiosk/draw');
      }
      const data = await resp.json();

      if (!resp.ok || !data.ok) {
        showMessage(data.message || 'จับรางวัลไม่สำเร็จ', data.messageType || 'danger');
        autoReset(5000);
        return;
      }

      showDrawEffect();
      await new Promise(r => setTimeout(r, 1800));

      if (spinWheel) {
        spinWheel.style.animation = 'none';
        spinWheel.classList.add('spin-stop');
        spinWheel.innerHTML = data.prize ? '🎉' : '😢';
      }

      if (data.prize && navigator.vibrate) {
        navigator.vibrate([200, 100, 200]);
      }
      if (data.prize && typeof confetti === 'function') {
        confetti({
          particleCount: 120,
          spread: 70,
          origin: { y: 0.6 }
        });
      }

      await new Promise(r => setTimeout(r, 1800));

      hideDrawEffect();
      renderDrawResult(data);

      clearMessage();
    } catch (err) {
      console.error(err);
      hideDrawEffect();
      showMessage('เกิดข้อผิดพลาดขณะจับรางวัล', 'danger');
      autoReset(5000);
    } finally {
      if (drawBtn) {
        drawBtn.disabled = false;
        drawBtn.innerText = 'จับรางวัล';
      }
    }
  }

  async function handleClaim() {
    const name = customerName ? customerName.value.trim() : '';
    const phone = customerPhone ? customerPhone.value.trim() : '';

    if (!name || !phone) {
      showMessage('กรุณากรอกชื่อและเบอร์โทรศัพท์', 'warning');
      return;
    }

    if (claimBtn) claimBtn.disabled = true;
    showMessage('กำลังบันทึกการเคลม...', 'info');

    try {
      const resp = await fetch('/promotion/kiosk/claim', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          draw_token: currentDrawToken,
          customer_name: name,
          customer_phone: phone
        })
      });
      const data = await resp.json();

      if (!data.ok) {
        showMessage(data.message || 'ไม่สามารถเคลมได้', 'danger');
        autoReset(5000);
        return;
      }

      showMessage(data.message || 'เคลมสำเร็จ', 'success');

      if (claimArea) claimArea.classList.add('d-none');

      if (customerName) customerName.value = '';
      if (customerPhone) customerPhone.value = '';

      autoReset(10000);
    } catch (err) {
      console.error(err);
      showMessage('เกิดข้อผิดพลาดขณะเคลม', 'danger');
      autoReset(5000);
    } finally {
      if (claimBtn) claimBtn.disabled = false;
    }
  }

  async function handleDecline() {
    const name = customerName ? customerName.value.trim() : '';
    const phone = customerPhone ? customerPhone.value.trim() : '';

    if (!confirm('คุณต้องการปฏิเสธรางวัลใช่หรือไม่?')) return;

    if (declineBtn) declineBtn.disabled = true;
    showMessage('กำลังบันทึกการปฏิเสธ...', 'info');

    try {
      const resp = await fetch('/promotion/kiosk/decline', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          draw_token: currentDrawToken,
          customer_name: name,
          customer_phone: phone
        })
      });
      const data = await resp.json();

      if (!data.ok) {
        showMessage(data.message || 'ไม่สามารถปฏิเสธได้', 'danger');
        autoReset(5000);
        return;
      }

      const redirectUrl = data.redirect_url || '/promotion/kiosk';
      window.location.href = redirectUrl;
    } catch (err) {
      console.error(err);
      showMessage('เกิดข้อผิดพลาดขณะปฏิเสธรางวัล', 'danger');
      autoReset(5000);
    } finally {
      if (declineBtn) declineBtn.disabled = false;
    }
  }

  function autoReset(delay = 8000) {
    clearTimeout(autoResetTimer);
    autoResetTimer = setTimeout(() => {
      toEnter();
    }, delay);
  }

  if (validateBtn) validateBtn.addEventListener('click', handleValidate);
  if (codeInput) {
    codeInput.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter') {
        ev.preventDefault();
        handleValidate();
      }
    });
  }
  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      if (codeInput) codeInput.value = '';
      if (codeInput) codeInput.focus();
      clearMessage();
    });
  }
  if (backToInputBtn) backToInputBtn.addEventListener('click', toEnter);
  if (drawBtn) drawBtn.addEventListener('click', handleDraw);
  if (claimBtn) claimBtn.addEventListener('click', handleClaim);
  if (declineBtn) declineBtn.addEventListener('click', handleDecline);

  toEnter();
})();
</script>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<!-- include footer -->
<%- include('footer.ejs') %>
