<%- include('./partials/header') %>

<form action="/business/upload" method="POST" enctype="multipart/form-data">
  <h3 class="mt-4">📤 อัพโหลด</h3><a href="https://www.ilovepdf.com/compress_pdf" target="_blank">ลดขนาดก่อนไหม ?</a>
  
  <div class="mb-3">
    <label for="c_group" class="form-label">กลุ่มส่งสหกรณ์</label>
    <select id="c_group" class="form-select" required>
      <option value="">++ โปรดเลือก ++</option>
      <option value="group1">กลุ่มส่งสหกรณ์ 1</option>
      <option value="group2">กลุ่มส่งสหกรณ์ 2</option>
      <option value="group3">กลุ่มส่งสหกรณ์ 3</option>
      <option value="group4">กลุ่มส่งสหกรณ์ 4</option>
      <option value="group5">กลุ่มส่งสหกรณ์ 5</option>
    </select>
  </div>
  
  <div class="mb-3">
    <label for="bu_code" class="form-label">สหกรณ์/กลุ่มเกษตรกร</label>
    <select name="bu_code" id="bu_code" class="form-select" required>
      <option value="">++โปรดเลือก++</option>
    </select>
  </div>
  <input type="hidden" name="bu_name" id="bu_name">
  
  <div class="mb-3">
    <label for="bu_endyear" class="form-label">ปีบัญชี</label>
    <%    const nowYear = new Date().getFullYear() %>
    <select name="bu_endyear" class="form-select">
      <option value="<%= nowYear + 542 %>"><%= nowYear + 542 %></option>
        <option value="<%= nowYear + 543 %>" selected><%= nowYear + 543 %></option>
        <option value="<%= nowYear + 544 %>"><%= nowYear + 544 %></option>
    </select>
  </div>
  
  <div class="mb-3">
    <label>ไฟล์ PDF</label>
    <input type="file" name="file" class="form-control" required>
  </div>
  
  <button type="submit" class="btn btn-success">โหลด</button>
</form>

<hr>
<h5 class="mt-5">📂 โหลดล่าสุด</h5>
<table class="table table-bordered">
  <thead>
    <tr>
      <th>สหกรณ์/กลุ่มเกษตรกร</th>
      <th>ปลาย</th>
      <th>ไฟล์</th>
      <th>โหลดโดย</th>
      <th>เมื่อ</th>
      <% if(user && user.mClass=='admin'){ %>
      <th>ลบ</th>
      <% } %>
    </tr>
  </thead>
  <tbody>
    <% recentUploads.slice(0, 5).forEach(file => { %>
      <tr>
        <td><%= file.bu_name %></td>
        <td><%= file.bu_endyear %></td>
        <td>
          <a href="/business/download/<%= file.bu_id %>" target="_blank" class="btn btn-sm btn-outline-primary">
            📄 ไฟล์
          </a>
        </td>
        <td><%= file.bu_saveby %></td>
        <td>
          <%= new Date(file.bu_savedate).toLocaleDateString('th-TH', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
          }) %>
        </td>
        <% if(user && user.mClass=='admin'){ %>
        <td>
          <a href="/business/delete/<%= file.bu_id %>" class="btn btn-sm btn-outline-danger" 
             onclick="return confirm('แน่ใจไหมจะลบไฟล์?')">
            <i class="bi bi-trash"></i>
          </a>
        </td>
        <% } %>
      </tr>
    <% }) %>
  </tbody>
</table>

<div class="mt-4 text-end">
    <a href="/business" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> ข้อมูลทั้งหมด
    </a>
</div>

<script>
  const cGroupSelect = document.getElementById('c_group');
  const cCodeSelect = document.getElementById('bu_code');
  const cNameInput = document.getElementById('bu_name');

  cGroupSelect.addEventListener('change', async function () {
    const group = this.value;
    cCodeSelect.innerHTML = '<option value="">โหลด...</option>';

    if (!group) {
      cCodeSelect.innerHTML = '<option value="">-- เลือกกลุ่มก่อน --</option>';
      return;
    }

    try {
      const response = await fetch(`/business/coops/${group}`);
      const data = await response.json();
      
      if (Array.isArray(data) && data.length > 0) {
        cCodeSelect.innerHTML = '<option value="">-- เลือกสหกรณ์ --</option>';
        data.forEach(coop => {
          const option = document.createElement('option');
          option.value = coop.c_code;
          option.text = coop.c_name;
          cCodeSelect.appendChild(option);
        });
      } else {
        cCodeSelect.innerHTML = '<option value="">ไม่พบสหกรณ์ในกลุ่ม</option>';
      }
    } catch (error) {
      console.error('โหลดข้อมูลสหกรณ์ล้มเหลว:', error);
      cCodeSelect.innerHTML = '<option value="">ข้อผิดพลาด</option>';
    }
  });

  cCodeSelect.addEventListener('change', function () {
    const selectedOption = this.options[this.selectedIndex];
    cNameInput.value = selectedOption.text !== '-- เลือกสหกรณ์ --' ? selectedOption.text : '';
  });
</script>

<%- include('./partials/footer') %>
