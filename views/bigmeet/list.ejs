<%- include('../partials/header') %>
<% const canEditServer = (user && (user.mClass === 'kbs' || user.mClass === 'admin')); %>

<%
  const meetingStatusLabels = {
    met_within_150: { text: 'ประชุมภายใน 150 วัน', className: 'bg-success' },
    met_over_150: { text: 'ประชุมเกิน 150 วัน', className: 'bg-warning text-dark' },
    not_met: { text: 'ยังไม่ได้ประชุม', className: 'bg-danger' },
  };

  const typeLabels = {
    ใน: 'ในภาคเกษตร',
    นอก: 'นอกภาคเกษตร',
    'กลุ่มเกษตรกร': 'กลุ่มเกษตรกร',
  };

  const formatDate = (value) => {
    if (!value) return '-';
    const d = new Date(value);
    return Number.isNaN(d.getTime()) ? '-' : d.toLocaleDateString('th-TH');
  };

  const normalizeYear = (value) => {
    const text = String(value || '').trim();
    if (!text) return '';
    const num = Number(text);
    if (!Number.isFinite(num)) return text;
    if (num > 0 && num < 2400) return String(num + 543);
    return String(Math.trunc(num));
  };

  function getCurrentBudgetYear() {
    const now = new Date();
    return now.getMonth() >= 9 ? now.getFullYear() + 544 : now.getFullYear() + 543;
  }

  const currentBudgetYear = getCurrentBudgetYear();
  const thaiMonthMap = {
    'มกราคม': '01',
    'กุมภาพันธ์': '02',
    'มีนาคม': '03',
    'เมษายน': '04',
    'พฤษภาคม': '05',
    'มิถุนายน': '06',
    'กรกฎาคม': '07',
    'สิงหาคม': '08',
    'กันยายน': '09',
    'ตุลาคม': '10',
    'พฤศจิกายน': '11',
    'ธันวาคม': '12'
  };

  const normalizeMonthDay = (value) => {
    const text = String(value || '').trim();
    if (!text) return '';
    if (/^\d{2}-\d{2}$/.test(text)) return text;
    const match = text.replace(/\s+/g, '').match(/^(\d{1,2})([^\d]+)$/);
    if (!match) return '';
    const month = thaiMonthMap[match[2]];
    return month ? `${month}-${String(match[1]).padStart(2, '0')}` : '';
  };

  const addDays = (isoDate, days) => {
    if (!isoDate) return '';
    const d = new Date(`${isoDate}T00:00:00`);
    if (Number.isNaN(d.getTime())) return '';
    d.setDate(d.getDate() + Number(days || 0));
    return d.toISOString().slice(0, 10);
  };

  const getFiscalEndDate = (item) => {
    const monthDay = normalizeMonthDay(item.end_day || item.end_date);
    const budgetYear = Number(item.big_budget_year || currentBudgetYear);
    if (monthDay && Number.isFinite(budgetYear)) {
      const month = parseInt(monthDay.slice(0, 2), 10);
      const year = month >= 10 ? budgetYear - 544 : budgetYear - 543;
      return `${year}-${monthDay}`;
    }
    return item.big_fiscal_end_date || '';
  };

  const getDeadlineDate = (item) => {
    const fiscalEndDate = getFiscalEndDate(item);
    if (fiscalEndDate) return addDays(fiscalEndDate, 150);
    return item.big_deadline_date || '';
  };

  const statusLabel = (value) => meetingStatusLabels[value] || { text: value || '-', className: 'bg-secondary' };
  const typeLabel = (value) => typeLabels[value] || value || '-';
%>

<style>
