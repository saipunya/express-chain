<%- include('../partials/header') %>

<style>
  .driver-queue-shell {
    --queue-gap: 1rem;
  }

  .driver-queue-shell .queue-header {
    gap: 0.75rem;
  }

  .driver-queue-shell .queue-actions {
    gap: 0.5rem;
  }

  .driver-queue-shell .queue-card {
    border: 0;
    border-radius: 1rem;
    overflow: hidden;
  }

  .driver-queue-shell .queue-card .card-header {
    padding: 1rem 1.25rem;
  }

  .driver-queue-shell .queue-card .card-body {
    padding: 1rem;
  }

  .driver-queue-shell .queue-table-wrap {
    overflow-x: auto;
  }

  .driver-queue-shell .queue-table {
    min-width: 760px;
  }

  .driver-queue-shell .queue-table th,
  .driver-queue-shell .queue-table td {
    vertical-align: middle;
  }

  .driver-queue-shell .queue-mobile-card {
    border-radius: 1rem;
  }

  .driver-queue-shell .queue-mobile-card .meta-label {
    font-size: 0.78rem;
    color: #6b7280;
  }

  .driver-queue-shell .queue-mobile-card .meta-value {
    font-weight: 600;
    word-break: break-word;
  }

  @media (max-width: 575.98px) {
    .driver-queue-shell .queue-header h3 {
      font-size: 1.4rem;
    }

    .driver-queue-shell .queue-actions .btn {
      width: 100%;
    }

    .driver-queue-shell .queue-card .card-header {
      padding: 0.9rem 1rem;
    }

    .driver-queue-shell .queue-card .card-body {
      padding: 0.85rem;
    }
  }
</style>

<div class="driver-queue-shell">
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2 mb-4 queue-header">
    <div>
      <h3 class="mb-1">คิวงานคนขับ</h3>
      <p class="text-muted mb-0">รายการงานที่ได้รับมอบหมายและแยกตามสถานะการบันทึกเวลา/ไมล์</p>
    </div>
    <div class="queue-actions d-flex flex-wrap">
      <a href="/driver-trip/report" class="btn btn-outline-primary">
        <i class="bi bi-file-earmark-text me-1"></i> รายงานการใช้รถ
      </a>
    </div>
  </div>

  <% if (warning) { %>
    <div class="alert alert-warning"><%= warning %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="ปิด"></button>
    </div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="ปิด"></button>
    </div>
  <% } %>

  <% function getQueueStatusLabel(item) {
       if (!item.log_status) return 'เข้าใหม่';
       if (item.log_status === 'morning_logged') return 'บันทึกเวลาเช้าแล้ว';
       if (item.log_status === 'completed') return 'บันทึกเวลาและไมล์แล้ว';
       return item.log_status;
     } %>

  <% (queueGroups || []).forEach((group) => { %>
    <div class="card shadow-sm queue-card mb-4">
      <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
        <div>
          <h5 class="mb-0"><%= group.title %></h5>
          <div class="small text-muted"><%= group.subtitle %></div>
        </div>
        <span class="badge <%= group.badgeClass %>"><%= group.items.length %> งาน</span>
      </div>

      <div class="queue-table-wrap d-none d-md-block">
        <table class="table table-hover mb-0 align-middle queue-table">
          <thead class="table-light">
            <tr>
              <th>เลขที่คำขอ</th>
              <th>ผู้ขอ</th>
              <th>ปลายทาง</th>
              <th>รถ/คนขับ</th>
              <th>สถานะเดินรถ</th>
              <th class="text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (!group.items.length) { %>
              <tr>
                <td colspan="6" class="text-center py-4 text-muted">ไม่มีรายการในหมวดนี้</td>
              </tr>
            <% } %>
            <% group.items.forEach((item) => { %>
              <tr>
                <td><%= item.vehicle_request_no %></td>
                <td><%= item.requester_name %></td>
                <td><%= item.destination_text %></td>
                <td>
                  <div><%= item.plate_no_snapshot || '-' %></div>
                  <small class="text-muted"><%= item.driver_name_snapshot || '-' %></small>
                </td>
                <td>
                  <span class="badge <%= item.log_status ? 'bg-success' : 'bg-danger' %>">
                    <%= getQueueStatusLabel(item) %>
                  </span>
                </td>
                <td class="text-end">
                  <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                    <% if (canManageAssignments) { %>
                      <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#assignmentModal-<%= item.vehicle_request_id %>">
                        <i class="bi bi-pencil-square me-1"></i>แก้ไข
                      </button>
                      <form action="/driver-trip/<%= item.vehicle_request_id %>/cancel" method="POST" class="d-inline" onsubmit="return confirm('ยืนยันยกเลิกงานนี้? รายการที่เกี่ยวข้องในปฏิทินงานจะถูกลบออกด้วย');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                          <i class="bi bi-x-circle me-1"></i>ยกเลิก
                        </button>
                      </form>
                    <% } %>
                    <a href="/driver-trip/<%= item.vehicle_request_id %>" class="btn btn-sm btn-outline-primary">เปิดงาน</a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="d-md-none p-3">
        <% if (!group.items.length) { %>
          <div class="text-center py-4 text-muted">ไม่มีรายการในหมวดนี้</div>
        <% } %>

        <div class="row g-3">
          <% group.items.forEach((item) => { %>
            <div class="col-12">
              <div class="border rounded-4 p-3 bg-white shadow-sm queue-mobile-card">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                  <div>
                    <div class="fw-semibold"><%= item.vehicle_request_no %></div>
                    <div class="small text-muted"><%= item.requester_name %></div>
                  </div>
                  <span class="badge <%= item.log_status ? 'bg-success' : 'bg-danger' %> text-nowrap">
                    <%= getQueueStatusLabel(item) %>
                  </span>
                </div>

                <div class="mb-3">
                  <div class="meta-label">ปลายทาง</div>
                  <div class="meta-value"><%= item.destination_text %></div>
                </div>

                <div class="row g-2 mb-3">
                  <div class="col-6">
                    <div class="meta-label">รถ</div>
                    <div class="meta-value"><%= item.plate_no_snapshot || '-' %></div>
                  </div>
                  <div class="col-6">
                    <div class="meta-label">คนขับ</div>
                    <div class="meta-value"><%= item.driver_name_snapshot || '-' %></div>
                  </div>
                </div>

                <div class="d-grid gap-2">
                  <% if (canManageAssignments) { %>
                    <button type="button" class="btn btn-outline-warning w-100" data-bs-toggle="modal" data-bs-target="#assignmentModal-<%= item.vehicle_request_id %>">
                      <i class="bi bi-pencil-square me-1"></i>แก้ไขรถ/คนขับ
                    </button>
                    <form action="/driver-trip/<%= item.vehicle_request_id %>/cancel" method="POST" onsubmit="return confirm('ยืนยันยกเลิกงานนี้? รายการที่เกี่ยวข้องในปฏิทินงานจะถูกลบออกด้วย');">
                      <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-x-circle me-1"></i>ยกเลิกงาน
                      </button>
                    </form>
                  <% } %>
                  <a href="/driver-trip/<%= item.vehicle_request_id %>" class="btn btn-outline-primary w-100">เปิดงาน</a>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  <% }) %>

  <% if (canManageAssignments) { %>
    <% (items || []).forEach((item) => { %>
      <div class="modal fade" id="assignmentModal-<%= item.vehicle_request_id %>" tabindex="-1" aria-labelledby="assignmentModalLabel-<%= item.vehicle_request_id %>" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <form action="/driver-trip/<%= item.vehicle_request_id %>/assignment" method="POST">
              <div class="modal-header">
                <div>
                  <h5 class="modal-title" id="assignmentModalLabel-<%= item.vehicle_request_id %>">แก้ไขรถและคนขับ</h5>
                  <div class="small text-muted"><%= item.vehicle_request_no %> · <%= item.destination_text %></div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="ปิด"></button>
              </div>
              <div class="modal-body">
                <div class="mb-3">
                  <label class="form-label" for="vehicle-<%= item.vehicle_request_id %>">รถยนต์</label>
                  <select id="vehicle-<%= item.vehicle_request_id %>" class="form-select" name="vehicle_id" required>
                    <option value="">เลือกรถ</option>
                    <% (vehicles || []).forEach((vehicle) => { %>
                      <option value="<%= vehicle.id %>" <%= Number(item.vehicle_id) === Number(vehicle.id) ? 'selected' : '' %>>
                        <%= vehicle.plate_no %> - <%= vehicle.vehicle_name || 'รถราชการ' %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div class="mb-3">
                  <label class="form-label" for="driver-<%= item.vehicle_request_id %>">คนขับ</label>
                  <select id="driver-<%= item.vehicle_request_id %>" class="form-select" name="driver_id" required>
                    <option value="">เลือกคนขับ</option>
                    <% (drivers || []).forEach((driver) => { %>
                      <option value="<%= driver.id %>" <%= Number(item.driver_id) === Number(driver.id) ? 'selected' : '' %>>
                        <%= driver.driver_name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label class="form-label" for="assignment-note-<%= item.vehicle_request_id %>">หมายเหตุ</label>
                  <textarea id="assignment-note-<%= item.vehicle_request_id %>" class="form-control" name="assignment_note" rows="3"><%= item.assignment_note || '' %></textarea>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                <button type="submit" class="btn btn-primary" <%= !(vehicles || []).length || !(drivers || []).length ? 'disabled' : '' %>>บันทึก</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('../partials/footer') %>
