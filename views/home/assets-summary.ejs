<section class="py-2 bg-white">
  <div class="container-lg">
    <div class="card modern-card shadow-sm border-0">
      <div class="card-gradient-bar"></div>
      <div class="card-header text-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-box-seam me-2"></i> สรุปข้อมูลอุปกรณ์การตลาดตามสหกรณ์</h6>
        <a href="/cooperatives-assets/summary" class="btn btn-sm btn-light">ดูสรุปทั้งหมด</a>
      </div>
      <div class="card-body">
        <div id="assetsSummaryContent">
          <div class="text-center py-3">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">กำลังโหลด...</span>
            </div>
          </div>
        </div>
      </div>
      <div class="card-footer bg-light small text-muted">
        อัปเดตอัตโนมัติเมื่อเปิดหน้า | แสดงข้อมูลอุปกรณ์การตลาดทั้งหมด
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  const content = document.getElementById('assetsSummaryContent');
  if(!content) return;
  
  fetch('/cooperatives-assets/api/assets')
    .then(r => r.json())
    .then(assets => {
      if(!Array.isArray(assets) || !assets.length){
        content.innerHTML = '<div class="text-center py-5"><i class="bi bi-box-seam fs-1 text-muted d-block mb-3"></i><h6 class="text-muted">ไม่มีข้อมูลอุปกรณ์การตลาด</h6></div>';
        return;
      }

      // Overall summary only
      const totalAssets = assets.length;
      const totalValue = assets.reduce((sum, asset) => sum + Number(asset.price_total || 0), 0);
      const totalWorking = assets.filter(a => a.status === 'ใช้งานได้').length;
      const totalNotWorking = assets.filter(a => a.status === 'ใช้งานไม่ได้').length;
      const totalGroups = new Set(assets.map(asset => asset.c_group || asset.coop_group || 'ไม่ระบุ')).size;
      const totalCoops = new Set(assets.map(asset => asset.coop_code).filter(Boolean)).size;
      
      // Group assets by group number (1-5)
      const groupData = {};
      for (let i = 1; i <= 5; i++) {
        groupData[i] = {
          assets: assets.filter(a => {
            const groupField = a.c_group || a.coop_group || '';
            // Handle both "group5" and "5" formats
            return groupField === `group${i}` || groupField === i.toString();
          }),
          count: 0,
          value: 0,
          working: 0,
          notWorking: 0
        };
      }

      // Calculate statistics for each group
      for (let i = 1; i <= 5; i++) {
        const groupAssets = groupData[i].assets;
        groupData[i].count = groupAssets.length;
        groupData[i].value = groupAssets.reduce((sum, asset) => sum + Number(asset.price_total || 0), 0);
        groupData[i].working = groupAssets.filter(a => a.status === 'ใช้งานได้').length;
        groupData[i].notWorking = groupAssets.filter(a => a.status === 'ใช้งานไม่ได้').length;
      }

      // Generate group summary HTML
      let groupsHtml = '';
      for (let i = 1; i <= 5; i++) {
        const group = groupData[i];
        const groupColor = ['primary', 'success', 'warning', 'info', 'secondary'][i - 1];
        groupsHtml += `
          <div class="col-md-6 col-lg-4 mb-3">
            <div class="card border-${groupColor} h-100">
              <div class="card-header bg-${groupColor} text-white py-2 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-people-fill me-1"></i> กลุ่ม ${i}</h6>
                <a href="/cooperatives-assets/summary?group=group${i}" class="btn btn-sm btn-light">
                  <i class="bi bi-eye"></i> ดูรายละเอียด
                </a>
              </div>
              <div class="card-body p-2">
                <div class="row text-center g-2">
                  <div class="col-6">
                    <div class="fw-bold text-${groupColor}">${group.count}</div>
                    <small class="text-muted d-block">อุปกรณ์</small>
                  </div>
                  <div class="col-6">
                    <div class="fw-bold text-success">${group.value.toLocaleString('th-TH')}</div>
                    <small class="text-muted d-block">มูลค่า(บาท)</small>
                  </div>
                  <div class="col-6">
                    <div class="fw-bold text-success">${group.working}</div>
                    <small class="text-muted d-block">ใช้งานได้</small>
                  </div>
                  <div class="col-6">
                    <div class="fw-bold text-danger">${group.notWorking}</div>
                    <small class="text-muted d-block">ใช้งานไม่ได้</small>
                  </div>
                </div>
              </div>
            </div>
          </div>
        `;
      }

      const html = `
        <div class="alert alert-info mb-3">
          <div class="row text-center">
            <div class="col-3">
              <div class="fw-bold text-primary">${totalAssets}</div>
              <small class="text-muted">อุปกรณ์การตลาดทั้งหมด</small>
            </div>
            <div class="col-3">
              <div class="fw-bold text-success">${totalValue.toLocaleString('th-TH')}</div>
              <small class="text-muted">มูลค่ารวม(บาท)</small>
            </div>
            <div class="col-3">
              <div class="fw-bold text-success">${totalWorking}</div>
              <small class="text-muted">ใช้งานได้</small>
            </div>
            <div class="col-3">
              <div class="fw-bold text-danger">${totalNotWorking}</div>
              <small class="text-muted">ใช้งานไม่ได้</small>
            </div>
          </div>
        </div>
        
        <div class="mb-3">
          <h6 class="text-muted mb-2"><i class="bi bi-layers me-1"></i> สรุปอุปกรณ์การตลาดแยกตามกลุ่ม</h6>
          <div class="row g-2">
            ${groupsHtml}
          </div>
        </div>
        
        <div class="row g-3">
          <div class="col-md-6">
            <div class="p-3 rounded-3 bg-light h-100">
              <div class="text-muted small mb-1">จำนวนกลุ่มส่งเสริมสหกรณ์</div>
              <div class="h4 fw-bold mb-0">${totalGroups}</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 rounded-3 bg-light h-100">
              <div class="text-muted small mb-1">จำนวนสหกรณ์ที่มีรายการ</div>
              <div class="h4 fw-bold mb-0">${totalCoops}</div>
            </div>
          </div>
        </div>
      `;
      
      content.innerHTML = html;
    })
    .catch(err => {
      console.error('Error loading assets summary:', err);
      content.innerHTML = '<div class="text-center py-5 text-danger"><i class="bi bi-exclamation-triangle fs-1 d-block mb-3"></i><h6>โหลดข้อมูลไม่สำเร็จ</h6></div>';
    });
})();
</script>
