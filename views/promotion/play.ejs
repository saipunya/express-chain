
<%- include('header.ejs') %>
<%
  const campaignSafe = (typeof campaign !== 'undefined') ? campaign : null;
  const storeSafe = (typeof store !== 'undefined') ? store : null;
  const storeCodeSafe = (typeof storeCode !== 'undefined' && storeCode)
    ? String(storeCode).toUpperCase()
    : (storeSafe && storeSafe.store_code ? String(storeSafe.store_code).toUpperCase() : '');
  const featuredPrizesSafe = Array.isArray(featuredPrizes) ? featuredPrizes : [];
%>

<style>
  html,
  body {
    height: 100%;
    overflow-x: hidden;
    overflow-y: hidden;
  }

  .promo-play-section {
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    height: 100svh;
    min-height: 100vh;
    padding: clamp(10px, 2.4vh, 24px) 0;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .promo-play-section > .container {
    height: 100%;
    min-height: 0;
    display: flex;
  }

  .promo-play-shell {
    max-width: 1080px;
    margin: 0 auto;
    width: 100%;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }

  .promo-play-hero {
    text-align: center;
    margin-bottom: clamp(8px, 1.8vh, 16px);
    flex: 0 0 auto;
  }

  .promo-play-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 13px;
    border-radius: 999px;
    background: #eff6ff;
    color: #2563eb;
    font-weight: 700;
    font-size: 0.88rem;
    margin-bottom: clamp(6px, 1.2vh, 12px);
  }

  .promo-play-title {
    font-size: clamp(1.45rem, 4.2vh, 2.15rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin-bottom: 0;
  }

  .promo-play-highlight {
    color: #2563eb;
  }

  .promo-play-desc {
    font-size: 1.05rem;
    color: #64748b;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .promo-store-chip-row {
    margin-top: clamp(6px, 1.3vh, 12px);
    display: flex;
    justify-content: center;
  }

  .promo-store-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #e0f2fe;
    color: #0c4a6e;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 0.86rem;
    font-weight: 700;
  }

  .promo-showcase-wrap {
    min-height: 0;
    margin: clamp(10px, 1.8vh, 16px) 0 0;
    order: 20;
  }

  .promo-showcase-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: #1e293b;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .promo-showcase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 8px;
    min-height: 0;
  }

  .promo-showcase-item {
    background: #fff;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 14px;
    padding: 8px;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.04);
    position: relative;
    overflow: hidden;
  }

  .promo-showcase-badge {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    background: linear-gradient(135deg, #ef4444 0%, #f97316 100%);
    color: #fff;
    border-radius: 999px;
    padding: 5px 9px;
    font-size: 0.75rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
    box-shadow: 0 8px 16px rgba(239, 68, 68, 0.24);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .promo-showcase-badge.is-discount {
    background: linear-gradient(135deg, #dc2626 0%, #f97316 100%);
    box-shadow: 0 8px 16px rgba(220, 38, 38, 0.24);
  }

  .promo-showcase-badge.is-coupon-cash {
    background: linear-gradient(135deg, #059669 0%, #16a34a 100%);
    box-shadow: 0 8px 16px rgba(5, 150, 105, 0.24);
  }

  .promo-showcase-badge.is-coupon-discount {
    background: linear-gradient(135deg, #0284c7 0%, #2563eb 100%);
    box-shadow: 0 8px 16px rgba(2, 132, 199, 0.24);
  }

  .promo-showcase-badge.is-credit {
    background: linear-gradient(135deg, #7c3aed 0%, #a855f7 100%);
    box-shadow: 0 8px 16px rgba(124, 58, 237, 0.24);
  }

  .promo-showcase-badge.is-free {
    background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
    box-shadow: 0 8px 16px rgba(245, 158, 11, 0.24);
  }

  .promo-showcase-image {
    width: 100%;
    height: clamp(64px, 10vh, 92px);
    object-fit: cover;
    border-radius: 10px;
    background: #f1f5f9;
    display: block;
  }

  .promo-prize-image-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    border-radius: 10px;
    margin-bottom: 6px;
    cursor: zoom-in;
    overflow: hidden;
  }

  .promo-prize-image-btn:focus-visible {
    outline: 3px solid rgba(37, 99, 235, 0.5);
    outline-offset: 3px;
  }

  .promo-prize-image-btn:hover .promo-showcase-image {
    transform: scale(1.03);
  }

  .promo-prize-image-btn .promo-showcase-image {
    transition: transform 0.18s ease;
  }

  .promo-showcase-noimage {
    width: 100%;
    height: clamp(64px, 10vh, 92px);
    border-radius: 10px;
    background: #eff6ff;
    color: #2563eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 6px;
  }

  .promo-showcase-name {
    font-size: 0.86rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.35;
    min-height: 2.6em;
  }

  .promo-showcase-stock {
    margin-top: 4px;
    font-size: 0.74rem;
    color: #64748b;
  }

  .promo-play-card {
    background: #fff;
    border: 1px solid rgba(37, 99, 235, 0.10);
    border-radius: 28px;
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
    overflow: hidden;
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    order: 1;
  }

  .promo-play-card:not(.has-prizes) {
    width: 100%;
    max-width: 980px;
    margin: 0 auto;
  }

  .promo-play-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(37, 99, 235, 0.08), transparent 28%),
      radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.08), transparent 24%);
    pointer-events: none;
  }

  .promo-play-card-body {
    position: relative;
    z-index: 1;
    padding: clamp(14px, 2.8vh, 24px);
    height: 100%;
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
    display: flex;
    flex-direction: column;
  }

  .promo-play-head {
    text-align: center;
    margin-bottom: clamp(10px, 1.8vh, 16px);
  }

  .promo-play-icon {
    width: clamp(48px, 8vh, 68px);
    height: clamp(48px, 8vh, 68px);
    margin: 0 auto clamp(8px, 1.3vh, 12px);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(1.45rem, 3.8vh, 1.9rem);
    color: #fff;
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    box-shadow: 0 16px 32px rgba(37, 99, 235, 0.22);
  }

  .promo-play-subtitle {
    color: #64748b;
    font-size: 0.9rem;
    margin-bottom: 0;
  }

  .promo-info-card {
    background: linear-gradient(180deg, #f8fbff 0%, #f8fafc 100%);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 18px;
    padding: 10px 14px;
    margin-bottom: clamp(10px, 1.8vh, 16px);
    font-size: 0.9rem;
  }

  .promo-info-row + .promo-info-row {
    margin-top: 5px;
  }

  .promo-info-label {
    font-weight: 700;
    color: #2563eb;
    margin-right: 6px;
  }

  .promo-info-store {
    color: #059669;
  }

  .promo-howto-card {
    order: 15;
    background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
    border: 1px solid rgba(37, 99, 235, 0.14);
    border-radius: 20px;
    padding: 16px;
    color: #0f172a;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .promo-howto-title {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #1d4ed8;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .promo-howto-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .promo-howto-list li {
    display: flex;
    gap: 10px;
    line-height: 1.45;
    font-size: 0.92rem;
  }

  .promo-howto-step {
    flex: 0 0 auto;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #2563eb;
    color: #fff;
    font-weight: 800;
    font-size: 0.82rem;
  }

  .promo-label {
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
  }

  .promo-code-input {
    min-height: clamp(52px, 8vh, 64px);
    border-radius: 16px;
    border: 2px solid #dbeafe;
    background: #fff;
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.06);
    text-align: center;
    font-size: clamp(1.1rem, 3vh, 1.34rem);
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #0f172a;
    transition: all 0.18s ease;
  }

  .promo-code-input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 0.25rem rgba(37, 99, 235, 0.14), 0 14px 28px rgba(37, 99, 235, 0.10);
  }

  .promo-helper {
    margin-top: 6px;
    color: #64748b;
    font-size: 0.82rem;
    text-align: center;
  }

  .promo-submit-btn {
    min-height: clamp(48px, 7vh, 54px);
    border: none;
    border-radius: 16px;
    font-weight: 800;
    font-size: 0.98rem;
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    color: #fff;
    box-shadow: 0 16px 32px rgba(37, 99, 235, 0.22);
    transition: all 0.18s ease;
  }

  .promo-submit-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
    color: #fff;
  }

  .promo-back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #64748b;
    text-decoration: none;
    font-weight: 500;
  }

  .promo-back-link:hover {
    color: #2563eb;
  }

  .promo-note-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: clamp(8px, 1.5vh, 14px);
  }

  .promo-note-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .promo-note-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2563eb;
    display: inline-block;
  }

  @media (max-width: 767.98px) {
    .promo-play-section {
      padding: 10px 0;
    }

    .promo-play-title {
      font-size: clamp(1.28rem, 4.6vh, 1.75rem);
    }

    .promo-play-card-body {
      padding: 14px;
    }

    .promo-code-input {
      min-height: 52px;
      font-size: 1.05rem;
      letter-spacing: 0.1em;
    }

    .promo-showcase-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 992px) {
    .promo-play-card .promo-play-card-body {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 340px);
      grid-auto-rows: min-content;
      column-gap: clamp(18px, 2.4vw, 30px);
      row-gap: clamp(10px, 1.4vh, 14px);
      align-content: start;
    }

    .promo-play-card .promo-play-card-body > :not(.promo-showcase-wrap):not(.promo-howto-card) {
      grid-column: 1;
    }

    .promo-play-card .promo-howto-card {
      grid-column: 2;
      grid-row: 1 / span 5;
      align-self: stretch;
      order: 0;
    }

    .promo-play-card.has-prizes .promo-showcase-wrap {
      grid-column: 1 / -1;
      grid-row: auto;
      margin-top: 0;
      order: 20;
    }

    .promo-play-card.has-prizes .promo-showcase-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      max-height: 100%;
      overflow: hidden;
    }
  }

  @media (max-width: 991.98px), (max-height: 720px) {
    html,
    body {
      height: auto;
      overflow-y: auto;
    }

    .promo-play-section {
      height: auto;
      min-height: 100svh;
      overflow: visible;
      align-items: flex-start;
    }

    .promo-play-section > .container,
    .promo-play-shell,
    .promo-play-card,
    .promo-play-card-body {
      height: auto;
      overflow: visible;
    }

    .promo-play-card {
      flex: 0 0 auto;
    }
  }

  .promo-play-head h2 {
    font-size: clamp(1.08rem, 3vh, 1.45rem) !important;
  }

  .promo-play-card-body form .mb-3 {
    margin-bottom: 0.65rem !important;
  }

  .promo-play-card-body form .mt-4 {
    margin-top: clamp(10px, 1.8vh, 16px) !important;
  }

  .promo-play-links {
    flex: 0 0 auto;
    margin-top: clamp(8px, 1.6vh, 14px) !important;
    white-space: normal;
  }

  @media (max-height: 700px) {
    .promo-play-badge,
    .promo-info-card,
    .promo-note-row {
      display: none;
    }
  }

  @media (max-height: 620px) {
    .promo-play-hero {
      display: none;
    }

    .promo-play-icon {
      display: none;
    }
  }

  @media (max-width: 575.98px), (max-height: 720px) {
    .promo-play-links {
      display: none;
    }
  }
  .spin-box {
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spin-wheel {
  font-size: 70px;
  animation: spinRoll 0.6s linear infinite;
}

@keyframes spinRoll {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(360deg) scale(1); }
}

/* ตอน reveal */
.spin-stop {
  animation: popReveal 0.6s ease;
}

@keyframes popReveal {
  0% { transform: scale(0.5); opacity: 0; }
  70% { transform: scale(1.2); }
  100% { transform: scale(1); opacity: 1; }
}

.promo-spin-modal[hidden] {
  display: none !important;
}

.promo-spin-modal {
  position: fixed;
  inset: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: rgba(15, 23, 42, 0.42);
  backdrop-filter: blur(4px);
}

.promo-spin-panel {
  width: min(100%, 420px);
  background: #fff;
  border-radius: 24px;
  padding: 28px 24px;
  text-align: center;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.24);
}

body.promo-spin-open {
  overflow: hidden;
}

.promo-prize-modal[hidden] {
  display: none !important;
}

.promo-prize-modal {
  position: fixed;
  inset: 0;
  z-index: 2100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: rgba(15, 23, 42, 0.72);
  backdrop-filter: blur(5px);
}

.promo-prize-modal-panel {
  width: min(100%, 920px);
  max-height: min(88vh, 760px);
  background: #fff;
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 28px 80px rgba(15, 23, 42, 0.34);
  display: flex;
  flex-direction: column;
}

.promo-prize-modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 18px;
  border-bottom: 1px solid rgba(148, 163, 184, 0.18);
}

.promo-prize-modal-title {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 800;
  color: #0f172a;
}

.promo-prize-modal-close {
  width: 38px;
  height: 38px;
  border: 0;
  border-radius: 999px;
  background: #eff6ff;
  color: #1d4ed8;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.15rem;
}

.promo-prize-modal-close:hover {
  background: #dbeafe;
}

.promo-prize-modal-body {
  padding: 16px;
  background: #f8fafc;
  min-height: 0;
}

.promo-prize-modal-image {
  width: 100%;
  max-height: 72vh;
  object-fit: contain;
  display: block;
  border-radius: 16px;
  background: #fff;
}
</style>

<div class="promo-play-section">
  <div class="container">
    <div class="promo-play-shell">

      <div class="promo-play-hero">
        <div class="promo-play-badge">
          <span>🎁</span>
          <span>หน้ากรอกรหัสโปรโมชั่น</span>
        </div>
        <h1 class="promo-play-title">
          กรอกรหัสเพื่อ<span class="promo-play-highlight">ลุ้นรับรางวัลทันที</span>
        </h1>
        
        <% if (storeSafe) { %>
          <div class="promo-store-chip-row">
            <span class="promo-store-chip">
              <i class="bi bi-shop"></i>
              สาขา <%= storeSafe.name %> (<%= storeCodeSafe || '-' %>)
            </span>
          </div>
        <% } %>
      </div>

      <div class="promo-play-card <%= featuredPrizesSafe.length ? 'has-prizes' : '' %>">
        <div class="promo-play-card-body">

          <div class="promo-play-head">
            <div class="promo-play-icon">🎉</div>
            <h2 class="fw-bold mb-2" style="font-size: 1.7rem;">เริ่มลุ้นรางวัลของคุณ</h2>
            <p class="promo-play-subtitle">กรอกรหัสให้ถูกต้องเพื่อดำเนินการต่อ</p>
          </div>

          <!-- Validation / Flash Messages -->
          <% if (locals && locals.flash) { %>
            <div class="alert alert-<%= locals.flash.type || 'info' %> alert-dismissible fade show mb-3 rounded-4" role="alert">
              <%= locals.flash.message %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>
          <% if (typeof validation !== 'undefined' && validation && validation.message) { %>
            <div class="alert alert-<%= validation.type || 'info' %> mb-3 rounded-4" role="alert">
              <%= validation.message %>
            </div>
          <% } %>
	          <% if (typeof message !== 'undefined' && message) { %>
	            <div class="alert alert-<%= messageType || 'info' %> mb-3 rounded-4" role="alert">
	              <%= message %>
	            </div>
	          <% } %>
	
	          <!-- Campaign/Store Info -->
	          <% if (campaignSafe || storeSafe) { %>
	            <div class="promo-info-card">
	              <% if (campaignSafe) { %>
	                <div class="promo-info-row">
	                  <span class="promo-info-label"><i class="bi bi-gift me-1"></i>แคมเปญ:</span>
	                  <span><%= campaignSafe.name %></span>
	                </div>
	              <% } %>
	              <% if (storeSafe) { %>
	                <div class="promo-info-row">
	                  <span class="promo-info-label promo-info-store"><i class="bi bi-shop me-1"></i>สาขา:</span>
	                  <span><%= storeSafe.name %></span>
	                  <% if (storeSafe.store_code) { %>
	                    <span class="text-muted small">(<%= storeSafe.store_code %>)</span>
	                  <% } %>
	                </div>
	              <% } %>
	            </div>
	          <% } %>

            <div class="promo-howto-card">
              <div class="promo-howto-title">
                <i class="bi bi-info-circle"></i>
                <span>วิธีการเล่น</span>
              </div>
              <ul class="promo-howto-list">
                <li>
                  <span class="promo-howto-step">1</span>
                  <span>รับรหัสโปรโมชั่นจากเจ้าหน้าที่หรือใบเสร็จของสาขา</span>
                </li>
                <li>
                  <span class="promo-howto-step">2</span>
                  <span>กรอกรหัสให้ถูกต้อง แล้วกดตรวจสอบเพื่อลุ้นรางวัล</span>
                </li>
                <li>
                  <span class="promo-howto-step">3</span>
                  <span>รอระบบสุ่มรางวัล และดูผลลัพธ์ได้ทันทีบนหน้าจอ</span>
                </li>
              </ul>
            </div>

            <% if (featuredPrizesSafe.length) { %>
              <div class="promo-showcase-wrap">
                <div class="promo-showcase-title">
                  <i class="bi bi-stars"></i>
                  <%= storeSafe ? 'ของรางวัลเด่นของสาขานี้' : 'ของรางวัลเด่นที่ร่วมรายการ' %>
                </div>
                <div class="promo-showcase-grid">
                  <% featuredPrizesSafe.forEach(prize => { %>
                    <div class="promo-showcase-item">
                      <% if (prize.badge_text) { %>
                        <span class="promo-showcase-badge <%= prize.badge_class || '' %>"><%= prize.badge_text %></span>
                      <% } %>
                      <% if (prize.image_url) { %>
                        <button
                          type="button"
                          class="promo-prize-image-btn"
                          data-prize-image="<%= prize.image_url %>"
                          data-prize-name="<%= prize.name || 'Prize image' %>"
                          aria-label="ดูภาพรางวัล <%= prize.name || '' %>"
                        >
                          <img src="<%= prize.image_url %>" alt="<%= prize.name || 'Prize image' %>" class="promo-showcase-image">
                        </button>
                      <% } else { %>
                        <div class="promo-showcase-noimage">🎁</div>
                      <% } %>
                      <div class="promo-showcase-name"><%= prize.name || '-' %></div>
                      <% if (!storeSafe && (prize.store_name || prize.store_code)) { %>
                        <div class="promo-showcase-stock">
                          สาขา <%= prize.store_name || prize.store_code %>
                          <% if (prize.store_code) { %>
                            (<%= String(prize.store_code).toUpperCase() %>)
                          <% } %>
                        </div>
                      <% } %>
                      <div class="promo-showcase-stock">คงเหลือประมาณ <%= Number(prize.remaining_qty || 0) %> ชิ้น</div>
                    </div>
                  <% }) %>
                </div>
              </div>
            <% } %>

          <!-- Code Entry Form -->
	          <form method="post" action="/promotion/validate-code" autocomplete="off" class="needs-validation" novalidate>
              <% if (storeCodeSafe) { %>
                <input type="hidden" name="store_code" value="<%= storeCodeSafe %>">
              <% } %>
            <div class="mb-3">
              <label for="codeValue" class="promo-label">รหัสโปรโมชั่น</label>
              <input
                type="text"
                class="form-control promo-code-input"
                id="codeValue"
                name="codeValue"
                value="<%= typeof codeValue !== 'undefined' ? codeValue : '' %>"
                maxlength="16"
                required
                pattern="[A-Za-z0-9]+"
                placeholder="กรอกรหัสที่นี่"
                autofocus
                inputmode="text"
                autocomplete="off"
              >
              <div class="invalid-feedback text-center">
                กรุณากรอกรหัสโปรโมชั่นที่ถูกต้อง (A-Z, 0-9)
              </div>
              <div class="promo-helper">รองรับเฉพาะตัวอักษรภาษาอังกฤษ A-Z และตัวเลข 0-9</div>
            </div>

            <div class="d-grid mt-4">
              <button type="submit" class="btn promo-submit-btn" id="submitBtn">
                <i class="bi bi-arrow-right-circle me-1"></i> ตรวจสอบรหัสและลุ้นรางวัล
              </button>
            </div>
          </form>

          <div class="promo-note-row">
            <span class="promo-note-chip"><span class="promo-note-dot"></span> ใช้เวลาไม่นาน</span>
            <span class="promo-note-chip"><span class="promo-note-dot"></span> ทราบผลทันที</span>
            <span class="promo-note-chip"><span class="promo-note-dot"></span> ใช้งานง่าย</span>
          </div>

        </div>
      </div>

      <div class="text-center mt-4 promo-play-links">
        <a href="/promotion" class="promo-back-link">
          <i class="bi bi-chevron-left"></i>
          <span>กลับหน้าโปรโมชั่น</span>
        </a>
        <% if (storeCodeSafe) { %>
          <span class="mx-2 text-muted">|</span>
          <a href="/promotion/<%= encodeURIComponent(storeCodeSafe) %>/kiosk" class="promo-back-link">
            <i class="bi bi-display"></i>
            <span>เปิดโหมด Kiosk ของสาขานี้</span>
          </a>
        <% } %>
        <span class="mx-2 text-muted">|</span>
        <a href="/promotion/admin" class="promo-back-link">
          <i class="bi bi-shield-lock"></i>
          <span>สำหรับผู้ดูแล</span>
        </a>
      </div>

    </div>
  </div>
</div>
<div id="prizeImageModal" class="promo-prize-modal" hidden>
  <div class="promo-prize-modal-panel" role="dialog" aria-modal="true" aria-labelledby="prizeImageModalTitle">
    <div class="promo-prize-modal-head">
      <h3 id="prizeImageModalTitle" class="promo-prize-modal-title">ภาพรางวัล</h3>
      <button type="button" class="promo-prize-modal-close" id="prizeImageModalClose" aria-label="ปิด">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>
    <div class="promo-prize-modal-body">
      <img id="prizeImageModalImg" class="promo-prize-modal-image" src="" alt="">
    </div>
  </div>
</div>
<div id="spinModal" class="promo-spin-modal" hidden>
  <div class="promo-spin-panel">
    <div class="spin-box mb-3">
      <div class="spin-wheel" id="spinWheel">🎁</div>
    </div>

    <h4 class="fw-bold">กำลังสุ่มรางวัล...</h4>
    <p class="text-muted mb-0">โปรดรอสักครู่</p>
  </div>
</div>
<script>
const STORE_CODE = <%- JSON.stringify(storeCodeSafe || null) %>;

	  (function () {
	    const modal = document.getElementById('prizeImageModal');
	    const modalImg = document.getElementById('prizeImageModalImg');
	    const modalTitle = document.getElementById('prizeImageModalTitle');
	    const closeBtn = document.getElementById('prizeImageModalClose');
	    if (!modal || !modalImg || !modalTitle || !closeBtn) return;

	    function closePrizeImageModal() {
	      modal.hidden = true;
	      modalImg.src = '';
	      modalImg.alt = '';
	      document.body.classList.remove('promo-spin-open');
	    }

	    document.querySelectorAll('[data-prize-image]').forEach(function (button) {
	      button.addEventListener('click', function () {
	        const src = button.getAttribute('data-prize-image');
	        const name = button.getAttribute('data-prize-name') || 'ภาพรางวัล';
	        if (!src) return;
	        modalImg.src = src;
	        modalImg.alt = name;
	        modalTitle.textContent = name;
	        modal.hidden = false;
	        document.body.classList.add('promo-spin-open');
	        closeBtn.focus();
	      });
	    });

	    closeBtn.addEventListener('click', closePrizeImageModal);
	    modal.addEventListener('click', function (event) {
	      if (event.target === modal) closePrizeImageModal();
	    });
	    document.addEventListener('keydown', function (event) {
	      if (event.key === 'Escape' && !modal.hidden) closePrizeImageModal();
	    });
	  })();

	  (function () {
	    var forms = document.querySelectorAll('.needs-validation');
	    Array.prototype.slice.call(forms).forEach(function (form) {
	      form.addEventListener('submit', function (event) {
	        event.preventDefault();
	        if (!form.checkValidity()) {
	          event.stopPropagation();
	          form.classList.add('was-validated');
	          return;
	        }
	        form.classList.add('was-validated');
	        handleSubmit(form);
	      }, false);
	    });
	  })();
async function startDrawWithEffect(code) {
  const modalEl = document.getElementById('spinModal');
  const wheel = document.getElementById('spinWheel');
  const submitBtn = document.getElementById('submitBtn');
  const flashContainer = document.querySelector('.promo-play-card-body');

  function showClientAlert(message, type) {
    const oldAlert = document.getElementById('clientDrawAlert');
    if (oldAlert) oldAlert.remove();
    if (!flashContainer || !message) return;

    const alert = document.createElement('div');
    alert.id = 'clientDrawAlert';
    alert.className = 'alert alert-' + (type || 'danger') + ' mb-3 rounded-4';
    alert.setAttribute('role', 'alert');
    alert.textContent = message;
    flashContainer.insertBefore(alert, flashContainer.firstChild);
  }

  function resetDrawUi() {
    wheel.style.animation = "none";
    wheel.classList.remove('spin-stop');
    wheel.innerHTML = "🎁";

    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.innerText = "ตรวจสอบรหัสและลุ้นรางวัล";
    }
    modalEl.hidden = true;
    document.body.classList.remove('promo-spin-open');
  }

  function showDrawUi() {
    modalEl.hidden = false;
    document.body.classList.add('promo-spin-open');
    wheel.innerHTML = "🎁";
    wheel.classList.remove('spin-stop');
    wheel.style.animation = "spinRoll 0.6s linear infinite";
  }
	
  try {
    const oldAlert = document.getElementById('clientDrawAlert');
    if (oldAlert) oldAlert.remove();

    const resp = await fetch('/promotion/draw', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        code,
        store_code: STORE_CODE || undefined
      })
    });

    const contentType = resp.headers.get('content-type') || '';
    if (!contentType.includes('application/json')) {
      throw new Error('Unexpected response type from /promotion/draw');
    }

    const data = await resp.json();

    if (!resp.ok || !data.ok) {
      const drawError = new Error((data && data.message) || 'Draw failed');
      drawError.alertType = (data && data.messageType) || 'danger';
      throw drawError;
    }

    showDrawUi();

    await new Promise(r => setTimeout(r, 1800));

    wheel.style.animation = "none";
    wheel.classList.add('spin-stop');

    // ✅ อยู่ตรงนี้
    if (data.prize) {
      wheel.innerHTML = "🎉";
      // 🔥 ใส่ตรงนี้เลย
        if (navigator.vibrate) {
          navigator.vibrate([200,100,200]);
        }
      if (typeof confetti === 'function') {
        confetti({
          particleCount: 120,
          spread: 70,
          origin: { y: 0.6 }
        });
      }

    } else {
      wheel.innerHTML = "😢";
    }

    await new Promise(r => setTimeout(r, 1800));

    resetDrawUi();

    handleDrawResult(data);

  } catch (err) {
    console.error(err);
    resetDrawUi();
    showClientAlert(
      err && err.message ? err.message : "ระบบขัดข้อง กรุณาลองใหม่",
      err && err.alertType ? err.alertType : 'danger'
    );
  }
}
function handleSubmit(form) {
  const input = form.codeValue;

  let code = input.value
    .replace(/[^A-Za-z0-9]/g, '')
    .toUpperCase();

  if (!code) return;

  input.value = code;
  const btn = form.querySelector('button[type="submit"]');
  if (btn) {
    btn.disabled = true;
    btn.innerText = "กำลังสุ่มรางวัล...";
  }

  // 👉 เรียก effect
  startDrawWithEffect(code);
  
}
function handleDrawResult(data) {
  if (data && data.redirect_url) {
    window.location.href = data.redirect_url;
    return;
  }
  if (data && data.draw_token) {
    window.location.href = '/promotion/result/' + encodeURIComponent(data.draw_token);
    return;
  }
  if (data.prize) {
    window.location.href = '/promotion/result?win=1';
  } else {
    window.location.href = '/promotion/result?win=0';
  }
}



</script>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
<%- include('footer.ejs') %>
