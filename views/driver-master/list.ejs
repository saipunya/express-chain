<%- include('../partials/header') %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">ทะเบียนพนักงานขับรถ</h3>
    <p class="text-muted mb-0">จัดการรายชื่อคนขับที่จะใช้ตอนมอบหมายงาน</p>
  </div>
  <a href="/driver-master/create" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i> เพิ่มคนขับ</a>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th>ชื่อคนขับ</th>
          <th>ตำแหน่ง</th>
          <th>ผูกสมาชิกระบบ</th>
          <th>ใบขับขี่</th>
          <th>โทรศัพท์</th>
          <th>สถานะ</th>
          <th class="text-end">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (!items.length) { %>
          <tr><td colspan="7" class="text-center py-4 text-muted">ยังไม่มีข้อมูลคนขับ</td></tr>
        <% } %>
        <% items.forEach((item) => { %>
          <tr>
            <td class="fw-semibold"><%= item.driver_name %></td>
            <td><%= item.driver_position || '-' %></td>
            <td><%= item.member_name || '-' %></td>
            <td><%= item.license_no || '-' %></td>
            <td><%= item.phone || '-' %></td>
            <td>
              <span class="badge bg-<%= item.status === 'active' ? 'success' : 'secondary' %>"><%= item.status %></span>
            </td>
            <td class="text-end"><a href="/driver-master/<%= item.id %>/edit" class="btn btn-sm btn-outline-warning">แก้ไข</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>