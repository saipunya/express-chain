<!-- include header -->
<%- include('../header.ejs', { title: title }) %>
<style>
  /* codes-page specific */
  .pcode-stat-card {
    border-radius: 18px; padding: 22px 20px; height: 100%; background: #fff;
    box-shadow: 0 8px 24px rgba(15,23,42,.07); position: relative; overflow: hidden;
    transition: transform .15s, box-shadow .15s;
  }
  .pcode-stat-card:hover { transform: translateY(-2px); box-shadow: 0 14px 32px rgba(15,23,42,.11); }
  .pcode-stat-card::before { content:""; position:absolute; top:0; right:0; width:80px; height:80px; border-radius:50%; opacity:.12; pointer-events:none; transform:translate(20px,-20px); }
  .pcode-total::before  { background: #2563eb; }
  .pcode-used::before   { background: #7c3aed; }
  .pcode-remain::before { background: #16a34a; }
  .pcode-expired-c::before { background: #ef4444; }
  .pcode-stat-icon  { width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.1rem; margin-bottom:12px; }
  .pcode-total  .pcode-stat-icon { background:#eff6ff; color:#2563eb; }
  .pcode-used   .pcode-stat-icon { background:#f5f3ff; color:#7c3aed; }
  .pcode-remain .pcode-stat-icon { background:#f0fdf4; color:#16a34a; }
  .pcode-expired-c .pcode-stat-icon { background:#fff1f2; color:#ef4444; }
  .pcode-stat-label { font-size:.78rem; font-weight:700; color:#64748b; text-transform:uppercase; letter-spacing:.06em; margin-bottom:4px; }
  .pcode-stat-val   { font-size:clamp(1.7rem,3.5vw,2.3rem); font-weight:800; color:#0f172a; line-height:1; margin-bottom:4px; }
  .pcode-stat-foot  { font-size:.83rem; color:#94a3b8; }
  .pcode-generate-btn  { border-radius:14px; font-weight:700; min-height:46px; }
  .pcode-reset-box { border:1.5px solid #fecaca; border-radius:16px; background:#fff7f7; padding:16px; }
  .pcode-filter-label { font-size:.83rem; font-weight:700; color:#334155; margin-bottom:4px; display:block; }
  .pcode-filter-help  { color:#94a3b8; font-size:.82rem; }
  .pcode-apply-btn { border-radius:12px; font-weight:600; }
  .pcode-new-code-row code { font-size:.9rem; color:#0f172a; letter-spacing:.04em; }
  .pcode-scope-badge { background:#f1f5f9; color:#334155; border-radius:999px; padding:3px 10px; font-size:.78rem; font-weight:600; }
</style>

<%
  const codesSafe      = Array.isArray(codes)     ? codes     : [];
  const storesSafe     = Array.isArray(stores)    ? stores    : [];
  const campaignsSafe  = Array.isArray(campaigns) ? campaigns : [];
  const summarySafe    = summary || {};
  const selectedStoreObj    = selectedStore    || (selectedStoreId    ? storesSafe.find(s    => Number(s.id)    === Number(selectedStoreId))    : null);
  const selectedCampaignObj = selectedCampaign || (selectedCampaignId ? campaignsSafe.find(c => Number(c.id)    === Number(selectedCampaignId)) : null);
  const showExpiredSafe = Boolean(showExpired);
  const canClear        = Boolean(selectedStoreId || selectedCampaignId);
  const canReset        = Number(summarySafe.total || 0) > 0;
  const clearScopeLabel = selectedCampaignObj
    ? selectedCampaignObj.name + (selectedStoreObj ? ' / ' + selectedStoreObj.name : '')
    : selectedStoreObj ? selectedStoreObj.name : 'ทั้งหมด';
  const scopeStoreIdValue = selectedStoreId || (selectedCampaignObj ? selectedCampaignObj.store_id : '');
%>

<div class="pad-layout">
<%- include('./_sidebar.ejs', { currentPage: 'codes', promotionAdmin, counts: {} }) %>
<div class="pad-main">

  <header class="pad-topbar">
    <div class="pad-topbar-left">
      <button class="pad-sidebar-toggle" id="padToggle" aria-label="Toggle menu"><i class="bi bi-list"></i></button>
      <div>
        <div class="pad-page-title"><i class="bi bi-key me-2" style="color:#d97706"></i>Code Manager</div>
        <div class="pad-breadcrumb">Promotion Admin › จัดการโค้ดโปรโมชั่น</div>
      </div>
    </div>
    <div class="pad-topbar-right">
      <span class="pad-date-badge"><i class="bi bi-calendar3 me-1"></i><span id="padDateNow"></span></span>
    </div>
  </header>

  <main class="pad-body">

    <% if (locals && locals.flash) { %>
      <div class="alert alert-<%= locals.flash.type || 'info' %> pad-flash">
        <%= locals.flash.message %>
      </div>
    <% } %>

    <!-- STAT CARDS -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-xl-3">
        <div class="pcode-stat-card pcode-total">
          <div class="pcode-stat-icon"><i class="bi bi-tags-fill"></i></div>
          <div class="pcode-stat-label">Total</div>
          <div class="pcode-stat-val"><%= summarySafe.total || 0 %></div>
          <div class="pcode-stat-foot">โค้ดทั้งหมดใน scope</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="pcode-stat-card pcode-used">
          <div class="pcode-stat-icon"><i class="bi bi-check2-circle"></i></div>
          <div class="pcode-stat-label">Used</div>
          <div class="pcode-stat-val"><%= summarySafe.used || 0 %></div>
          <div class="pcode-stat-foot">ถูกใช้งานแล้ว</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="pcode-stat-card pcode-remain">
          <div class="pcode-stat-icon"><i class="bi bi-hourglass-split"></i></div>
          <div class="pcode-stat-label">Remaining</div>
          <div class="pcode-stat-val"><%= summarySafe.unused || 0 %></div>
          <div class="pcode-stat-foot">ยังไม่ถูกใช้</div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="pcode-stat-card pcode-expired-c">
          <div class="pcode-stat-icon"><i class="bi bi-clock-history"></i></div>
          <div class="pcode-stat-label">Expired</div>
          <div class="pcode-stat-val"><%= summarySafe.expired || 0 %></div>
          <div class="pcode-stat-foot">หมดอายุแล้ว</div>
        </div>
      </div>
    </div>

    <!-- FILTER & GENERATE ROW -->
    <div class="row g-4 mb-4">

      <!-- FILTER CARD -->
      <div class="col-lg-6">
        <div class="pad-card h-100">
          <div class="pad-card-head">
            <div>
              <div class="pad-card-title"><i class="bi bi-funnel-fill me-2 text-primary"></i>Scope &amp; Filter</div>
              <div class="pad-card-subtitle">
                <% if (selectedCampaignObj) { %>แสดงเฉพาะแคมเปญ: <strong><%= selectedCampaignObj.name %></strong>
                <% } else if (selectedStoreObj) { %>แสดงเฉพาะสาขา: <strong><%= selectedStoreObj.name %></strong>
                <% } else { %>แสดงข้อมูลรวมทุกสาขา<% } %>
              </div>
            </div>
          </div>
          <div class="p-3 pt-0">
            <form method="GET" action="/promotion/admin/codes">
              <div class="row g-3 align-items-end">

                <div class="col-md-5">
                  <label class="pcode-filter-label">สาขา</label>
                  <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
                    <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
                    <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
                  <% } else { %>
                    <select class="form-select" name="store_id">
                      <option value="">ทั้งหมด</option>
                      <% storesSafe.forEach(s => { %>
                        <option value="<%= s.id %>" <%= Number(selectedStoreId) === Number(s.id) ? 'selected' : '' %>>
                          <%= s.name %> (<%= s.store_code || '-' %>)
                        </option>
                      <% }) %>
                    </select>
                  <% } %>
                </div>

                <div class="col-md-5">
                  <label class="pcode-filter-label">แคมเปญ</label>
                  <select class="form-select" name="campaign_id">
                    <option value="">ทั้งหมด</option>
                    <% campaignsSafe.forEach(c => { %>
                      <option value="<%= c.id %>" <%= Number(selectedCampaignId) === Number(c.id) ? 'selected' : '' %>>
                        <%= c.name %> (<%= c.campaign_code || '-' %>)
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="col-md-2 d-grid">
                  <button class="btn btn-primary pcode-apply-btn">
                    <i class="bi bi-search"></i>
                  </button>
                </div>

                <div class="col-12 d-flex flex-wrap align-items-center gap-2">
                  <% if (showExpiredSafe) { %>
                    <a href="/promotion/admin/codes<%= selectedStoreId ? `?store_id=${selectedStoreId}` : '' %><%= selectedCampaignId ? `${selectedStoreId ? '&' : '?'}campaign_id=${selectedCampaignId}` : '' %>"
                       class="btn btn-outline-secondary btn-sm">
                      <i class="bi bi-eye-slash me-1"></i>ซ่อน Expired
                    </a>
                  <% } else { %>
                    <a href="/promotion/admin/codes<%= selectedStoreId ? `?store_id=${selectedStoreId}` : '' %><%= selectedCampaignId ? `${selectedStoreId ? '&' : '?'}campaign_id=${selectedCampaignId}` : '' %>&show_expired=1"
                       class="btn btn-outline-secondary btn-sm">
                      <i class="bi bi-eye me-1"></i>แสดง Expired
                    </a>
                  <% } %>
                  <span class="pcode-filter-help">ค่าเริ่มต้นซ่อน expired เพื่อให้ดูผลล้างโค้ดชัดขึ้น</span>
                </div>

                <div class="col-12 d-flex flex-wrap gap-2">
                  <% if (selectedStoreObj) { %>
                    <span class="badge text-bg-primary"><i class="bi bi-shop me-1"></i><%= selectedStoreObj.name %> (<%= selectedStoreObj.store_code || '-' %>)</span>
                  <% } else { %>
                    <span class="badge text-bg-secondary"><i class="bi bi-shop me-1"></i>สาขา: ทั้งหมด</span>
                  <% } %>
                  <% if (selectedCampaignObj) { %>
                    <span class="badge text-bg-info"><i class="bi bi-megaphone me-1"></i><%= selectedCampaignObj.name %></span>
                  <% } else { %>
                    <span class="badge text-bg-light text-muted"><i class="bi bi-megaphone me-1"></i>แคมเปญ: ทั้งหมด</span>
                  <% } %>
                  <a href="/promotion/admin/codes" class="badge text-bg-light text-decoration-none text-muted">
                    <i class="bi bi-x-circle me-1"></i>Reset filter
                  </a>
                </div>

              </div>
            </form>
          </div>
        </div>
      </div>

      <!-- GENERATE & MANAGE CARD -->
      <div class="col-lg-6">
        <div class="pad-form-card h-100">
          <div class="pad-form-title">
            <i class="bi bi-lightning-fill text-warning me-1"></i> Generate &amp; Manage
            <span class="pcode-scope-badge ms-2"><%= clearScopeLabel %></span>
          </div>
          <div class="p-3 pt-2 d-flex flex-column gap-3">

            <form method="POST" action="/promotion/admin/codes/generate">
              <div class="d-flex flex-column gap-3">

                <div>
                  <label class="pcode-filter-label">สาขา</label>
                  <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
                    <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
                    <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
                  <% } else { %>
                    <select class="form-select" name="store_id" required>
                      <option value="">เลือกสาขา</option>
                      <% storesSafe.forEach(s => { %>
                        <option value="<%= s.id %>" <%= Number(selectedStoreId) === Number(s.id) ? 'selected' : '' %>>
                          <%= s.name %> (<%= s.store_code || '-' %>)
                        </option>
                      <% }) %>
                    </select>
                  <% } %>
                </div>

                <div>
                  <label class="pcode-filter-label">แคมเปญ</label>
                  <select class="form-select" name="campaign_id">
                    <option value="">ทั้งหมด</option>
                    <% campaignsSafe.forEach(c => { %>
                      <option value="<%= c.id %>" <%= Number(selectedCampaignId) === Number(c.id) ? 'selected' : '' %>>
                        <%= c.name %> (<%= c.campaign_code || '-' %>)
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div>
                  <label class="pcode-filter-label">จำนวน</label>
                  <input type="number" name="quantity" class="form-control" value="100" min="1" max="50000">
                </div>

                <button class="btn btn-primary pcode-generate-btn w-100">
                  <i class="bi bi-rocket me-1"></i> Generate Now
                </button>

              </div>
            </form>

            <hr class="my-0">

            <div>
              <div class="fw-bold mb-1" style="font-size:.9rem"><i class="bi bi-trash3 me-1 text-danger"></i>Clear unused / expired</div>
              <p class="pcode-filter-help mb-2">ลบเฉพาะโค้ดสถานะ <code>unused</code> และ <code>expired</code> ของ scope ที่เลือก</p>
              <form method="POST" action="/promotion/admin/codes/clear"
                    onsubmit="return confirm('ยืนยันลบโค้ด unused/expired ของ <%= clearScopeLabel %> ใช่หรือไม่?');">
                <input type="hidden" name="store_id"   value="<%= scopeStoreIdValue || '' %>">
                <input type="hidden" name="campaign_id" value="<%= selectedCampaignId || '' %>">
                <button class="btn btn-outline-danger w-100 btn-sm <%= canClear ? '' : 'disabled' %>" <%= canClear ? '' : 'disabled' %>>
                  <i class="bi bi-trash me-1"></i>Clear unused / expired codes
                </button>
                <% if (!canClear) { %><div class="pcode-filter-help mt-1">กรุณาเลือกสาขาหรือแคมเปญก่อน</div><% } %>
              </form>
            </div>

            <div class="pcode-reset-box">
              <div class="fw-bold text-danger mb-1" style="font-size:.9rem"><i class="bi bi-exclamation-triangle me-1"></i>Reset all codes</div>
              <p class="pcode-filter-help mb-2">ลบโค้ดทุกสถานะใน scope ปัจจุบัน เพื่อเริ่มต้นชุดโค้ดใหม่ทั้งหมด</p>
              <form method="POST" action="/promotion/admin/codes/reset"
                    onsubmit="return confirm('ยืนยัน RESET โค้ดทั้งหมดใน scope นี้? การทำรายการนี้จะลบโค้ดทุกสถานะและไม่สามารถย้อนกลับได้');">
                <input type="hidden" name="store_id"   value="<%= scopeStoreIdValue || '' %>">
                <input type="hidden" name="campaign_id" value="<%= selectedCampaignId || '' %>">
                <button class="btn btn-danger w-100 btn-sm <%= canReset ? '' : 'disabled' %>" <%= canReset ? '' : 'disabled' %>>
                  <i class="bi bi-arrow-counterclockwise me-1"></i>Reset all codes
                </button>
                <% if (!canReset) { %><div class="pcode-filter-help mt-1">ยังไม่มีโค้ดใน scope นี้ให้รีเซ็ต</div><% } %>
              </form>
            </div>

          </div>
        </div>
      </div>

    </div>

    <!-- NEW CODES PANEL -->
    <% if (newCodes && newCodes.length) { %>
    <div class="pad-card mb-4">
      <div class="pad-card-head">
        <div>
          <div class="pad-card-title"><i class="bi bi-fire me-2 text-danger"></i>โค้ดที่เพิ่งสร้าง</div>
          <div class="pad-card-subtitle"><%= newCodes.length %> codes created</div>
        </div>
        <button id="copyCodesBtn" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-clipboard me-1"></i>Copy All
        </button>
      </div>
      <div class="table-responsive">
        <table class="table pad-tbl mb-0">
          <tbody>
            <% newCodes.forEach(nc => { %>
              <tr class="pcode-new-code-row">
                <td><span class="pad-code"><%= nc.code %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

    <!-- CODES TABLE -->
    <div class="pad-card">
      <div class="pad-card-head">
        <div>
          <div class="pad-card-title"><i class="bi bi-table me-2 text-primary"></i>รายการโค้ดทั้งหมด</div>
          <div class="pad-card-subtitle"><%= codesSafe.length %> โค้ดใน scope ปัจจุบัน</div>
        </div>
        <% if (codesSafe.length) { %>
          <span class="pad-card-badge"><%= codesSafe.length %> รายการ</span>
        <% } %>
      </div>
      <div class="table-responsive">
        <table class="table pad-tbl table-hover mb-0">
          <thead>
            <tr>
              <th>Code</th>
              <th>สาขา</th>
              <th>แคมเปญ</th>
              <th>สถานะ</th>
              <th>วันหมดอายุ</th>
            </tr>
          </thead>
          <tbody>
            <% if (codesSafe.length) { %>
              <% codesSafe.forEach(c => { %>
                <tr>
                  <td><span class="pad-code"><%= c.code %></span></td>
                  <td>
                    <div class="pad-semibold"><%= c.store_name || '-' %></div>
                    <span class="pad-store-chip"><%= c.store_code || '-' %></span>
                  </td>
                  <td class="pad-semibold"><%= c.campaign_name || '-' %></td>
                  <td>
                    <span class="pad-status ps-<%= c.status || 'unused' %>">
                      <%= c.status || 'unused' %>
                    </span>
                  </td>
                  <td class="pad-muted">
                    <%= c.expires_at ? new Date(c.expires_at).toLocaleDateString('th-TH') : '-' %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="pad-empty-cell">
                  <span class="pad-empty-icon d-block">🔑</span>
                  <span class="pad-empty-text">ยังไม่พบโค้ดใน scope ที่เลือก</span>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

  </main>
</div>
</div>

<script>
  const copyBtn = document.getElementById('copyCodesBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      const codes = Array.from(document.querySelectorAll('.pcode-new-code-row .pad-code'))
        .map(el => el.innerText)
        .join('\n');
      navigator.clipboard.writeText(codes).then(() => {
        copyBtn.innerHTML = '<i class="bi bi-check2 me-1"></i>Copied!';
        setTimeout(() => copyBtn.innerHTML = '<i class="bi bi-clipboard me-1"></i>Copy All', 2000);
      });
    });
  }
</script>

<%- include('../footer.ejs') %>
