<%- include('../partials/header', { title: (vongBusiness ? 'แก้ไข' : 'สร้าง') + ' ข้อมูลวงเงินกลุ่มเกษตรกร' }) %>

<div class="container my-5">
  <h1 class="text-center mb-4"><%= vongBusiness ? 'แก้ไข' : 'เพิ่ม' %> ข้อมูลวงเงินกลุ่มเกษตรกร</h1>
  <form method="POST" enctype="multipart/form-data" action="<%= vongBusiness ? '/vong-business/edit/' + vongBusiness.vongb_id : '/vong-business/create' %>">

    <div class="mb-3">
      <label for="vongb_code" class="form-label">รหัสเอกสาร</label>
      <select name="vongb_code" id="vongb_code" class="form-select" required>
        <option value="">-- เลือกกลุ่มเกษตรกร --</option>
        <% 
          const groupedCoops = (activeCoops || []).reduce((acc, coop) => {
            const groupName = coop.c_group || 'ไม่ระบุกลุ่ม';
            if (!acc[groupName]) acc[groupName] = [];
            acc[groupName].push(coop);
            return acc;
          }, {});
        %>
        <% Object.keys(groupedCoops).forEach(groupName => { %>
          <optgroup label="<%= groupName %>">
            <% groupedCoops[groupName].forEach(coop => { %>
              <option value="<%= coop.c_code %>" <%= vongBusiness && vongBusiness.vongb_code === coop.c_code ? 'selected' : '' %>>
                <%= coop.c_name %> (<%= coop.c_code %>)
              </option>
            <% }) %>
          </optgroup>
        <% }) %>
      </select>
    </div>

    <div class="mb-3">
      <label for="vongb_year" class="form-label">ปี พ.ศ.</label>
      <% const nowYear = new Date().getFullYear(); const selectedYear = vongBusiness ? String(vongBusiness.vongb_year) : String(nowYear + 543); %>
      <select name="vongb_year" id="vongb_year" class="form-select" required>
        <option value="<%= nowYear + 542 %>" <%= selectedYear === String(nowYear + 542) ? 'selected' : '' %>><%= nowYear + 542 %></option>
        <option value="<%= nowYear + 543 %>" <%= selectedYear === String(nowYear + 543) ? 'selected' : '' %>><%= nowYear + 543 %></option>
        <option value="<%= nowYear + 544 %>" <%= selectedYear === String(nowYear + 544) ? 'selected' : '' %>><%= nowYear + 544 %></option>
      </select>
    </div>

    <div class="mb-3">
      <label for="vongb_money" class="form-label">ยอดเงินกู้ยืมหรือค้ำประกันกลุ่มเกษตรกร (บาท)</label>
      <% const moneyDisplay = vongBusiness && vongBusiness.vongb_money !== null && vongBusiness.vongb_money !== undefined && !isNaN(Number(vongBusiness.vongb_money)) ? Number(vongBusiness.vongb_money).toLocaleString('th-TH') : ''; %>
      <input name="vongb_money" id="vongb_money" value="<%= moneyDisplay %>" placeholder="ยอดเงินกู้ยืมหรือค้ำประกัน ไม่ต้องใส่ comma (, )" class="form-control" required>
    </div>

    <div class="mb-3">
      <label for="vongb_money2" class="form-label">วงเงินดำเนินกิจการของกลุ่มเกษตรกร (บาท)</label>
      <% const money2Display = vongBusiness && vongBusiness.vongb_money2 !== null && vongBusiness.vongb_money2 !== undefined && !isNaN(Number(vongBusiness.vongb_money2)) ? Number(vongBusiness.vongb_money2).toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : ''; %>
      <input name="vongb_money2" id="vongb_money2" value="<%= money2Display %>" placeholder="วงเงินดำเนินกิจการ ไม่ต้องใส่ comma (, )" class="form-control" required>
    </div>

    <script>
      ['vongb_money', 'vongb_money2'].forEach(function(name) {
        const input = document.querySelector('input[name="' + name + '"]');
        if (!input) return;
        input.addEventListener('input', function() {
          this.value = this.value.replace(/,/g, '');
        });
      });
    </script>

    <div class="mb-3">
      <label for="vongb_date" class="form-label">วันที่อนุมัติ</label>
      <input name="vongb_date" id="vongb_date" type="date" value="<%= vongBusiness && vongBusiness.vongb_date ? String(vongBusiness.vongb_date).slice(0, 10) : '' %>" class="form-control" required>
    </div>

    <div class="mb-3">
      <label for="vongb_file" class="form-label">แนบไฟล์ (PDF, DOCX, ฯลฯ)</label>
      <input type="file" name="vongb_file" id="vongb_file" class="form-control" <%= vongBusiness ? '' : 'required' %>>
      <% if (vongBusiness && vongBusiness.vongb_filename) { %>
        <a href="/uploads/vong_business/<%= vongBusiness.vongb_filename %>" target="_blank" class="mt-2 d-block">ไฟล์ปัจจุบัน: <%= vongBusiness.vongb_filename %></a>
      <% } %>
    </div>

    <button type="submit" class="btn btn-success">บันทึก</button>
  </form>
</div>

<%- include('../partials/footer') %>
