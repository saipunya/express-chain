<%- include('../partials/header') %>
<%- include('../partials/travel-navbar', { currentPage: 'travel-create' }) %>

<div class="d-flex justify-content-between align-items-center mb-4 gap-2 flex-wrap">
  <div>
    <h3 class="mb-1"><%= title %></h3>
    <p class="text-muted mb-0">บันทึกข้อมูลคำขอไปราชการตามแบบฟอร์มของหน่วยงาน</p>
  </div>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<form action="<%= formAction %>" method="POST" class="card shadow-sm border-0">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-3">
        <label class="form-label">เลขที่คำขอ</label>
        <input type="text" class="form-control" value="<%= item.request_no || '' %>" readonly>
        <div class="form-text">ระบบจะกำหนดเลขที่คำขอให้อัตโนมัติเมื่อบันทึก</div>
      </div>
      <div class="col-md-3">
        <label class="form-label">วันที่คำขอ</label>
        <% function thaiDate(dateStr) {
          if (!dateStr) return '-';
          const d = new Date(dateStr);
          if (isNaN(d)) return '-';
          const months = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
          return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear() + 543}`;
        }
        function toIsoDateValue(value) {
          if (!value) return '';
          if (value instanceof Date) {
            return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Bangkok' }).format(value);
          }
          const s = String(value).trim();
          const isoMatch = s.match(/^(\d{4})[-\/\.](\d{1,2})[-\/\.](\d{1,2})/);
          if (isoMatch) {
            let y = Number(isoMatch[1]);
            const m = String(isoMatch[2]).padStart(2, '0');
            const d = String(isoMatch[3]).padStart(2, '0');
            if (y > 2500) y = y - 543;
            return `${String(y).padStart(4, '0')}-${m}-${d}`;
          }
          const monthsMap = {
            'มกราคม':1,'กุมภาพันธ์':2,'มีนาคม':3,'เมษายน':4,'พฤษภาคม':5,'มิถุนายน':6,
            'กรกฎาคม':7,'สิงหาคม':8,'กันยายน':9,'ตุลาคม':10,'พฤศจิกายน':11,'ธันวาคม':12
          };
          const thaiMatch = s.match(/(\d{1,2})\s+([^\d\s]+)\s+(\d{4})/);
          if (thaiMatch) {
            const day = String(Number(thaiMatch[1])).padStart(2,'0');
            const monthName = thaiMatch[2].trim();
            let year = Number(thaiMatch[3]);
            const mIndex = monthsMap[monthName];
            if (mIndex) {
              if (year > 2500) year = year - 543;
              return `${String(year).padStart(4,'0')}-${String(mIndex).padStart(2,'0')}-${day}`;
            }
          }
          const d = new Date(s);
          if (!isNaN(d)) {
            return new Intl.DateTimeFormat('en-CA', { timeZone: 'Asia/Bangkok' }).format(d);
          }
          return s.slice(0,10);
        } %>
        <input type="text" class="form-control" value="<%= thaiDate(item.request_date) %>" readonly>
        <input type="hidden" name="request_date" value="<%= toIsoDateValue(item.request_date) %>">
      </div>
      <div class="col-md-6">
        <label class="form-label">เรียน</label>
        <input type="text" class="form-control" name="learn_to" value="<%= item.learn_to || '' %>">
      </div>
      <div class="col-md-12">
        <label class="form-label">เรื่อง</label>
        <input type="hidden" name="subject" value="<%= item.subject || '' %>">
        <input type="text" class="form-control" value="<%= item.subject || '' %>" readonly>
      </div>
      <div class="col-md-4">
        <label class="form-label">ผู้ขอ</label>
        <input type="text" class="form-control" name="requester_name" value="<%= item.requester_name || '' %>" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">ตำแหน่ง</label>
        <input type="text" class="form-control" name="requester_position" value="<%= item.requester_position || '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">กลุ่ม/หน่วยงาน</label>
        <input type="text" class="form-control" value="<%= item.requester_group || '' %>" readonly>
        <div class="form-text">ดึงจาก member3.m_class ของผู้ใช้งานในระบบ</div>
      </div>
      <div class="col-md-6">
        <label class="form-label">สถานที่ / ปลายทาง</label>
        <input type="text" class="form-control" name="destination_text" value="<%= item.destination_text || '' %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">วันที่ปฏิบัติงาน</label>
        <input type="date" class="form-control" name="operation_date" value="<%= item.operation_date || '' %>" required>
      </div>
      <div class="col-md-1">
        <label class="form-label">เวลาไป</label>
        <input type="time" class="form-control" name="start_time" value="<%= item.start_time || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">เวลากลับ</label>
        <input type="time" class="form-control" name="end_time" value="<%= item.end_time || '' %>">
      </div>
      <div class="col-md-12">
        <label class="form-label">วัตถุประสงค์</label>
        <textarea class="form-control" name="purpose_text" rows="3" required><%= item.purpose_text || '' %></textarea>
      </div>
      <div class="col-md-4">
        <label class="form-label">วิธีเดินทาง</label>
        <select class="form-select" name="transport_type" id="transport-type-select">
          <option value="official_vehicle" <%= item.transport_type === 'official_vehicle' ? 'selected' : '' %>>รถราชการ</option>
          <option value="private_vehicle" <%= item.transport_type === 'private_vehicle' ? 'selected' : '' %>>รถส่วนตัว</option>
          <option value="other" <%= item.transport_type === 'other' ? 'selected' : '' %>>อื่น ๆ</option>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">รายละเอียดพาหนะอื่น</label>
        <input type="text" class="form-control" id="transport-other-input" name="transport_other_text" value="<%= item.transport_other_text || '' %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">ออกนอกจังหวัด</label>
        <select class="form-select" name="out_of_province">
          <option value="0" <%= Number(item.out_of_province) === 0 ? 'selected' : '' %>>ไม่ใช่</option>
          <option value="1" <%= Number(item.out_of_province) === 1 ? 'selected' : '' %>>ใช่</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">ต้องใช้รถราชการ</label>
        <select class="form-select" name="requires_vehicle_request" id="requires-vehicle-select">
          <option value="0" <%= Number(item.requires_vehicle_request) === 0 ? 'selected' : '' %>>ไม่ต้อง</option>
          <option value="1" <%= Number(item.requires_vehicle_request) === 1 ? 'selected' : '' %>>ต้องใช้</option>
        </select>
      </div>
      <div class="col-12 <%= item.transport_type === 'official_vehicle' ? '' : 'd-none' %>" id="estimated-cost-section">
        <div class="border rounded-3 p-3 bg-light-subtle">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div>
              <h5 class="mb-1">ประมาณการค่าใช้จ่าย</h5>
              <div class="text-muted small">แสดงในแบบ PDF เมื่อใช้รถยนต์ราชการ</div>
            </div>
          </div>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label">ค่าเบี้ยเลี้ยง (บาท)</label>
              <input type="number" class="form-control" name="estimated_allowance" min="0" step="0.01" value="<%= item.estimated_allowance ?? '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">ค่าที่พัก (บาท)</label>
              <input type="number" class="form-control" name="estimated_lodging" min="0" step="0.01" value="<%= item.estimated_lodging ?? '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">ค่าพาหนะ/น้ำมันเชื้อเพลิง (บาท)</label>
              <input type="number" class="form-control" name="estimated_fuel" min="0" step="0.01" value="<%= item.estimated_fuel ?? '' %>">
            </div>
          </div>
        </div>
      </div>
    </div>

    <hr class="my-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 class="mb-0">ผู้ร่วมเดินทาง</h5>
      <div class="d-flex align-items-center gap-2">
        <small class="text-muted">เพิ่มได้สูงสุด 7 คน</small>
        <span class="badge text-bg-light" id="companion-count-badge">0/7</span>
        <button type="button" class="btn btn-sm btn-outline-primary" id="add-companion-row">เพิ่มรายชื่อ</button>
      </div>
    </div>

    <% const rows = companions && companions.length ? companions : [{ companion_name: '', companion_position: '' }]; %>
    <div id="companion-rows">
    <% rows.forEach((companion, index) => { %>
      <div class="row g-3 mb-2 companion-row" data-row-index="<%= index + 1 %>">
        <div class="col-md-1 text-muted pt-2 companion-seq">#<%= index + 1 %></div>
        <div class="col-md-4">
          <input type="text" class="form-control" name="companion_name" value="<%= companion.companion_name || '' %>" placeholder="ชื่อผู้ร่วมเดินทาง">
        </div>
        <div class="col-md-5">
          <input type="text" class="form-control" name="companion_position" value="<%= companion.companion_position || '' %>" placeholder="ตำแหน่งผู้ร่วมเดินทาง">
        </div>
        <div class="col-md-2 d-flex align-items-start">
          <button type="button" class="btn btn-outline-danger w-100 remove-companion-row">ลบ</button>
        </div>
      </div>
    <% }) %>
    </div>
  </div>
  <div class="card-footer bg-white d-flex gap-2 justify-content-end">
    <button type="submit" class="btn btn-success"><%= submitLabel %></button>
  </div>
</form>

<template id="companion-row-template">
  <div class="row g-3 mb-2 companion-row">
    <div class="col-md-1 text-muted pt-2 companion-seq"></div>
    <div class="col-md-4">
      <input type="text" class="form-control" name="companion_name" value="" placeholder="ชื่อผู้ร่วมเดินทาง">
    </div>
    <div class="col-md-5">
      <input type="text" class="form-control" name="companion_position" value="" placeholder="ตำแหน่งผู้ร่วมเดินทาง">
    </div>
    <div class="col-md-2 d-flex align-items-start">
      <button type="button" class="btn btn-outline-danger w-100 remove-companion-row">ลบ</button>
    </div>
  </div>
</template>

<script>
  (() => {
    const rowsContainer = document.getElementById('companion-rows');
    const addButton = document.getElementById('add-companion-row');
    const rowTemplate = document.getElementById('companion-row-template');
    const companionCountBadge = document.getElementById('companion-count-badge');
    const transportTypeSelect = document.getElementById('transport-type-select');
    const transportOtherInput = document.getElementById('transport-other-input');
    const requiresVehicleSelect = document.getElementById('requires-vehicle-select');
    const estimatedCostSection = document.getElementById('estimated-cost-section');

    if (!rowsContainer || !addButton || !rowTemplate) {
      return;
    }

    const updateSequence = () => {
      const rows = rowsContainer.querySelectorAll('.companion-row');
      rows.forEach((row, index) => {
        row.dataset.rowIndex = String(index + 1);
        const seq = row.querySelector('.companion-seq');
        if (seq) {
          seq.textContent = `#${index + 1}`;
        }
      });

      if (companionCountBadge) {
        const filledRows = Array.from(rows).filter((row) => {
          const nameInput = row.querySelector('input[name="companion_name"]');
          return nameInput && nameInput.value.trim();
        });
        companionCountBadge.textContent = `${filledRows.length}/7`;
      }

      addButton.disabled = rows.length >= 7;
    };

    const attachRowEvents = (row) => {
      const removeButton = row.querySelector('.remove-companion-row');
      const nameInput = row.querySelector('input[name="companion_name"]');
      if (!removeButton) {
        return;
      }

      if (nameInput) {
        nameInput.addEventListener('input', updateSequence);
      }

      removeButton.addEventListener('click', () => {
        const rows = rowsContainer.querySelectorAll('.companion-row');
        if (rows.length === 1) {
          row.querySelector('input[name="companion_name"]').value = '';
          row.querySelector('input[name="companion_position"]').value = '';
          return;
        }
        row.remove();
        updateSequence();
      });
    };

    rowsContainer.querySelectorAll('.companion-row').forEach(attachRowEvents);

    addButton.addEventListener('click', () => {
      const currentRows = rowsContainer.querySelectorAll('.companion-row');
      if (currentRows.length >= 7) {
        return;
      }

      const fragment = rowTemplate.content.cloneNode(true);
      rowsContainer.appendChild(fragment);
      attachRowEvents(rowsContainer.lastElementChild);
      updateSequence();
      const nameInput = rowsContainer.lastElementChild.querySelector('input[name="companion_name"]');
      if (nameInput) {
        nameInput.focus();
      }
    });

    const syncTransportFields = () => {
      if (!transportTypeSelect || !transportOtherInput || !requiresVehicleSelect) {
        return;
      }

      const transportType = transportTypeSelect.value;
      if (estimatedCostSection) {
        estimatedCostSection.classList.toggle('d-none', transportType !== 'official_vehicle');
        estimatedCostSection.querySelectorAll('input').forEach((input) => {
          input.disabled = transportType !== 'official_vehicle';
        });
      }
      transportOtherInput.disabled = transportType !== 'other';
      transportOtherInput.placeholder = transportType === 'other' ? 'ระบุรายละเอียดพาหนะ' : 'ใช้เมื่อเลือก "อื่น ๆ"';

      if (transportType !== 'other' && !transportOtherInput.dataset.userEdited) {
        transportOtherInput.value = '';
      }

      if (transportType === 'official_vehicle') {
        requiresVehicleSelect.value = '1';
      }
    };

    if (transportOtherInput) {
      transportOtherInput.addEventListener('input', () => {
        transportOtherInput.dataset.userEdited = transportOtherInput.value.trim() ? '1' : '';
      });
    }

    if (transportTypeSelect) {
      transportTypeSelect.addEventListener('change', syncTransportFields);
    }

    updateSequence();
    syncTransportFields();
  })();
</script>

<%- include('../partials/footer') %>
