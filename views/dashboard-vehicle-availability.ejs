<%- include('partials/header') %>
<%- include('partials/travel-navbar', { currentPage: 'vehicle-availability' }) %>

<%
  const summary = (typeof vehicleUsageSummary !== 'undefined' && vehicleUsageSummary)
    ? vehicleUsageSummary
    : { total: 0, vehicleCount: 0, availabilityStart: null, availabilityEnd: null, vehicles: [], matrix: [] };
  const formatThaiDate = (value) => {
    if (!value) return '-';
    const date = value instanceof Date ? value : new Date(value);
    return Number.isNaN(date.getTime())
      ? String(value).slice(0, 10)
      : date.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'Asia/Bangkok' });
  };
  const formatThaiTime = (value) => {
    if (!value) return '';
    const date = value instanceof Date ? value : new Date(value);
    return Number.isNaN(date.getTime())
      ? ''
      : date.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Bangkok' });
  };
%>

<style>
  .availability-page {
    padding-bottom: 2rem;
  }

  .availability-hero {
    border: 1px solid #dfe7e2;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 10px 28px rgba(31, 41, 55, .06);
    padding: 1rem;
  }

  .availability-table-wrap {
    border: 1px solid #e6edf5;
    border-radius: 8px;
    max-height: 72vh;
    overflow: auto;
    background: #fff;
  }

  .availability-table {
    font-size: .84rem;
    min-width: 920px;
  }

  .availability-table th,
  .availability-table td {
    border-color: #edf1f6;
    min-width: 10rem;
    padding: .55rem;
    vertical-align: top;
  }

  .availability-table thead th {
    background: #f8fafc;
    color: #475467;
    font-size: .78rem;
    font-weight: 800;
    position: sticky;
    top: 0;
    z-index: 3;
  }

  .availability-sticky-col {
    left: 0;
    min-width: 9rem !important;
    position: sticky;
    z-index: 4 !important;
  }

  .availability-table tbody .availability-sticky-col {
    background: #fff;
    color: #344054;
  }

  .availability-cell.is-available {
    background: #f6fdf9;
  }

  .availability-cell.is-busy {
    background: #fff8f8;
  }

  .availability-pill {
    border-radius: 999px;
    display: inline-flex;
    font-size: .75rem;
    font-weight: 800;
    margin-bottom: .35rem;
    padding: .2rem .5rem;
  }

  .availability-pill.available {
    background: #d1e7dd;
    color: #0f5132;
  }

  .availability-pill.busy {
    background: #f8d7da;
    color: #842029;
  }

  .availability-assignment {
    background: #fff;
    border: 1px solid #f1d0d4;
    border-radius: 8px;
    color: #212529;
    cursor: pointer;
    display: grid;
    gap: .1rem;
    margin-top: .25rem;
    padding: .45rem;
    text-decoration: none;
    text-align: left;
    width: 100%;
  }

  .availability-assignment:hover {
    background: #fff;
    color: #0d6efd;
  }

  .availability-muted {
    color: #667085;
    font-size: .78rem;
  }

  .availability-detail-grid {
    display: grid;
    gap: .75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .availability-detail-item {
    border: 1px solid #edf1f6;
    border-radius: 8px;
    background: #fbfcfe;
    padding: .75rem;
  }

  .availability-detail-item.full {
    grid-column: 1 / -1;
  }

  .availability-detail-label {
    color: #667085;
    font-size: .78rem;
    font-weight: 800;
    margin-bottom: .2rem;
  }

  .availability-detail-value {
    color: #212529;
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  @media (max-width: 575.98px) {
    .availability-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="availability-page">
  <div class="availability-hero mb-3">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
      <div>
        <div class="text-uppercase text-muted fw-semibold small mb-1">Vehicle Availability</div>
        <h3 class="fw-bold mb-1">สถานะการใช้รถยนต์ราชการ 30 วันข้างหน้า</h3>
        <div class="text-muted">
          ช่วง <%= formatThaiDate(summary.availabilityStart) %> ถึง <%= formatThaiDate(summary.availabilityEnd) %>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2 align-items-center">
        <span class="badge text-bg-primary"><%= Number(summary.vehicleCount || 0).toLocaleString('th-TH') %> คัน</span>
        <span class="badge text-bg-secondary"><%= Number(summary.total || 0).toLocaleString('th-TH') %> งานที่มอบหมาย</span>
        <a href="/dashboard" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i>กลับ Dashboard
        </a>
        <a href="/vehicle-approval/pending" class="btn btn-primary btn-sm">
          <i class="bi bi-check2-square me-1"></i>คิวอนุมัติ
        </a>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex flex-wrap align-items-center justify-content-between gap-2">
      <div>
        <h5 class="mb-1 fw-bold">ตารางสถานะรถ</h5>
        <div class="small text-muted">แถวคือวันที่ คอลัมน์คือทะเบียนรถ คลิกรายการเพื่อดูรายละเอียด</div>
      </div>
      <div class="d-flex flex-wrap gap-3 small fw-semibold text-muted">
        <span><span class="availability-pill available mb-0">ว่าง</span></span>
        <span><span class="availability-pill busy mb-0">ไม่ว่าง</span></span>
      </div>
    </div>

    <% if ((summary.matrix || []).length && (summary.vehicles || []).length) { %>
      <div class="availability-table-wrap">
        <table class="table table-bordered availability-table align-middle mb-0">
          <thead>
            <tr>
              <th class="availability-sticky-col">วันที่</th>
              <% (summary.vehicles || []).forEach((vehicle) => { %>
                <th class="text-center">
                  <div class="fw-bold"><%= vehicle.plate_no %></div>
                  <div class="availability-muted"><%= vehicle.vehicle_name || '-' %></div>
                </th>
              <% }); %>
            </tr>
          </thead>
          <tbody>
            <% (summary.matrix || []).forEach((row) => { %>
              <tr>
                <th class="availability-sticky-col"><%= formatThaiDate(row.dateKey) %></th>
                <% (row.cells || []).forEach((cell) => { %>
                  <td class="availability-cell <%= cell.available ? 'is-available' : 'is-busy' %>">
                    <% if (cell.available) { %>
                      <span class="availability-pill available">ว่าง</span>
                    <% } else { %>
                      <span class="availability-pill busy">ไม่ว่าง</span>
                      <% (cell.assignments || []).forEach((assignment) => { %>
                        <button
                          type="button"
                          class="availability-assignment"
                          data-bs-toggle="modal"
                          data-bs-target="#vehicleAssignmentModal"
                          data-request-url="/vehicle-request/<%= assignment.vehicleRequestId %>"
                          data-request-no="<%= assignment.vehicleRequestNo || '-' %>"
                          data-plate-no="<%= cell.plateNo || '-' %>"
                          data-vehicle-name="<%= cell.vehicleName || '-' %>"
                          data-destination="<%= assignment.destination || '-' %>"
                          data-driver-name="<%= assignment.driverName || '-' %>"
                          data-trip-date="<%= formatThaiDate(row.dateKey) %>"
                          data-trip-time="<%= (formatThaiTime(assignment.tripStartAt) || '-') + ' - ' + (formatThaiTime(assignment.tripEndAt) || '-') %>"
                          data-trip-start="<%= formatThaiDate(assignment.tripStartAt) %> <%= formatThaiTime(assignment.tripStartAt) || '' %>"
                          data-trip-end="<%= formatThaiDate(assignment.tripEndAt) %> <%= formatThaiTime(assignment.tripEndAt) || '' %>"
                          data-status="<%= assignment.status || '-' %>">
                          <span class="fw-bold"><%= assignment.vehicleRequestNo || '-' %></span>
                          <span><%= assignment.destination || '-' %></span>
                          <span class="availability-muted">คนขับ: <%= assignment.driverName || '-' %></span>
                          <span class="availability-muted"><%= formatThaiTime(assignment.tripStartAt) || '-' %> - <%= formatThaiTime(assignment.tripEndAt) || '-' %></span>
                        </button>
                      <% }); %>
                    <% } %>
                  </td>
                <% }); %>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-5 text-muted">ยังไม่มีข้อมูลสถานะรถในช่วง 30 วันข้างหน้า</div>
    <% } %>
  </div>
</div>

<div class="modal fade" id="vehicleAssignmentModal" tabindex="-1" aria-labelledby="vehicleAssignmentModalTitle" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <div>
          <div class="small text-muted fw-semibold mb-1">รายละเอียดการใช้รถยนต์ราชการ</div>
          <h5 class="modal-title fw-bold mb-0" id="vehicleAssignmentModalTitle">-</h5>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="ปิด"></button>
      </div>
      <div class="modal-body">
        <div class="availability-detail-grid">
          <div class="availability-detail-item">
            <div class="availability-detail-label">วันที่ในตาราง</div>
            <div class="availability-detail-value" data-vehicle-modal-field="tripDate">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">เวลา</div>
            <div class="availability-detail-value" data-vehicle-modal-field="tripTime">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">ทะเบียนรถ</div>
            <div class="availability-detail-value" data-vehicle-modal-field="plateNo">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">ชื่อรถ</div>
            <div class="availability-detail-value" data-vehicle-modal-field="vehicleName">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">คนขับ</div>
            <div class="availability-detail-value" data-vehicle-modal-field="driverName">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">สถานะ</div>
            <div class="availability-detail-value" data-vehicle-modal-field="status">-</div>
          </div>
          <div class="availability-detail-item full">
            <div class="availability-detail-label">สถานที่ / ปลายทาง</div>
            <div class="availability-detail-value" data-vehicle-modal-field="destination">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">เริ่มใช้งาน</div>
            <div class="availability-detail-value" data-vehicle-modal-field="tripStart">-</div>
          </div>
          <div class="availability-detail-item">
            <div class="availability-detail-label">สิ้นสุดใช้งาน</div>
            <div class="availability-detail-value" data-vehicle-modal-field="tripEnd">-</div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <a href="#" class="btn btn-primary" id="vehicleAssignmentViewLink">
          <i class="bi bi-eye me-1"></i>เปิดหน้าคำขอ
        </a>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">ปิด</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var modal = document.getElementById('vehicleAssignmentModal');
    if (!modal) return;

    function setField(name, value) {
      var el = modal.querySelector('[data-vehicle-modal-field="' + name + '"]');
      if (el) el.textContent = value || '-';
    }

    modal.addEventListener('show.bs.modal', function (event) {
      var button = event.relatedTarget;
      if (!button) return;

      var requestNo = button.getAttribute('data-request-no') || '-';
      var title = modal.querySelector('#vehicleAssignmentModalTitle');
      if (title) title.textContent = requestNo;

      setField('tripDate', button.getAttribute('data-trip-date'));
      setField('tripTime', button.getAttribute('data-trip-time'));
      setField('plateNo', button.getAttribute('data-plate-no'));
      setField('vehicleName', button.getAttribute('data-vehicle-name'));
      setField('driverName', button.getAttribute('data-driver-name'));
      setField('status', button.getAttribute('data-status'));
      setField('destination', button.getAttribute('data-destination'));
      setField('tripStart', button.getAttribute('data-trip-start'));
      setField('tripEnd', button.getAttribute('data-trip-end'));

      var viewLink = document.getElementById('vehicleAssignmentViewLink');
      if (viewLink) viewLink.href = button.getAttribute('data-request-url') || '#';
    });
  });
</script>

<%- include('partials/footer') %>
