<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'หน้าหลักสมาชิกสถาบัน' %></title>
    <% if (typeof themeColor !== 'undefined' && themeColor) { %>
      <meta name="theme-color" content="<%= themeColor %>" />
    <% } %>
    <% if (typeof manifestPath !== 'undefined' && manifestPath) { %>
      <link rel="manifest" href="<%= manifestPath %>" />
      <link rel="icon" href="/icon/seal.svg" />
      <link rel="apple-touch-icon" href="/icon/seal.svg" />
      <meta name="mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-title" content="CoopChain" />
      <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@200;400;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="d-flex flex-column min-vh-100 flex-grow-1">
    <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm sticky-top">
      <div class="container">
        <a class="navbar-brand fw-semibold" href="/homecoop">
          <i class="bi bi-building me-1" aria-hidden="true"></i>CoopChain
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#homecoopNavbar" aria-controls="homecoopNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="homecoopNavbar">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link active" aria-current="page" href="/homecoop">
                <i class="bi bi-house-door me-1" aria-hidden="true"></i>หน้าแรก
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4 flex-grow-1">

<style>
  .homecoop-hero {
    border-radius: 8px;
    background: linear-gradient(135deg, #047857, #0e7490);
    color: #fff;
    overflow: hidden;
  }

  .homecoop-menu {
    display: block;
    height: 100%;
    padding: 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    color: #0f172a;
    text-decoration: none;
    background: #fff;
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }

  .homecoop-menu:hover {
    color: #047857;
    border-color: #86efac;
    box-shadow: 0 .5rem 1.25rem rgba(15, 23, 42, .08);
    transform: translateY(-1px);
  }

  .homecoop-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: #ecfdf5;
    color: #059669;
    margin-bottom: .75rem;
  }
</style>

<section class="homecoop-page">
  <div class="homecoop-hero shadow-sm mb-4">
    <div class="p-4 p-lg-5">
      <div class="row g-4 align-items-center">
        <div class="col-lg-8">
          <div class="badge text-bg-light text-success px-3 py-2 mb-3">CoopChain</div>
          <h1 class="h2 fw-bold text-white mb-2">หน้าหลักสมาชิกสถาบัน</h1>
          <p class="mb-0 text-white-50">เมนูสำหรับสหกรณ์และกลุ่มเกษตรกร</p>
        </div>
        <div class="col-lg-4">
          <div class="bg-white bg-opacity-10 border border-white border-opacity-25 rounded p-3">
            <div class="fw-semibold"><%= user ? (user.fullname || user.username || '-') : '-' %></div>
            <div class="small text-white-50">ชื่อผู้ใช้: <%= user ? (user.username || '-') : '-' %></div>
            <div class="small text-white-50">กลุ่มสิทธิ์: <%= user ? (user.mClass || user.m_class || '-') : '-' %></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
      <a href="/allCoop/profile/<%= user ? (user.username || user.m_user || '') : '' %>" class="homecoop-menu">
        <span class="homecoop-icon"><i class="bi bi-building"></i></span>
        <div class="fw-semibold mb-1">ข้อมูลสถาบันของฉัน</div>
        <div class="text-muted small">ข้อมูลทะเบียนและรายละเอียดสถาบัน</div>
      </a>
    </div>
    <div class="col-md-6 col-xl-3">
      <a href="/chamra" class="homecoop-menu">
        <span class="homecoop-icon"><i class="bi bi-cash-coin"></i></span>
        <div class="fw-semibold mb-1">ผลการชำระบัญชี</div>
        <div class="text-muted small">ข้อมูลสถานะและผลการดำเนินงาน</div>
      </a>
    </div>
    <div class="col-md-6 col-xl-3">
      <a href="/meetingroom" class="homecoop-menu">
        <span class="homecoop-icon"><i class="bi bi-calendar-week"></i></span>
        <div class="fw-semibold mb-1">ห้องประชุม</div>
        <div class="text-muted small">ดูข้อมูลการใช้งานห้องประชุม</div>
      </a>
    </div>
    <div class="col-md-6 col-xl-3">
      <a href="/" class="homecoop-menu">
        <span class="homecoop-icon"><i class="bi bi-house-door"></i></span>
        <div class="fw-semibold mb-1">ข้อมูลสาธารณะ</div>
        <div class="text-muted small">กลับไปยังหน้าเว็บไซต์หลัก</div>
      </a>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <a href="/auth/logout" class="btn btn-outline-danger">
      <i class="bi bi-box-arrow-right me-1"></i>ออกจากระบบ
    </a>
  </div>
</section>

<%- include('partials/footer') %>
