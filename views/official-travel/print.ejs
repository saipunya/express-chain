<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>พิมพ์คำขอไปราชการ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Sarabun', sans-serif; padding: 24px; }
    .print-sheet { max-width: 800px; margin: 0 auto; }
    @media print { .no-print { display: none; } }
  </style>
</head>
<body>
  <% const requestNoDisplay = 'ชย 0010(ดท)/..............'; %>
  <div class="print-sheet">
    <div class="text-end no-print mb-3">
      <button class="btn btn-dark" onclick="window.print()">พิมพ์</button>
    </div>
    <h2 class="text-center mb-4">บันทึกข้อความ</h2>
    <p><strong>เลขที่</strong> <%= requestNoDisplay %></p>
    <p><strong>วันที่</strong> <%= new Date(item.request_date).toLocaleDateString('th-TH') %></p>
    <p><strong>เรียน</strong> <%= item.learn_to || '-' %></p>
    <p><strong>เรื่อง</strong> <%= item.subject %></p>
    <p><strong>ข้าพเจ้า</strong> <%= item.requester_name %> ตำแหน่ง <%= item.requester_position || '-' %> กลุ่มงาน <%= item.requester_group || '-' %></p>
    <p><strong>ขออนุญาตไปราชการเพื่อ</strong> <%= item.purpose_text %></p>
    <p><strong>สถานที่</strong> <%= item.destination_text %></p>
    <p><strong>ระหว่างวันที่</strong> <%= new Date(item.start_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short' }) %> ถึง <%= new Date(item.end_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short' }) %></p>
    <p><strong>วิธีเดินทาง</strong> <%= item.transport_type %> <%= item.transport_other_text || '' %></p>
    <p><strong>ผู้ร่วมเดินทาง</strong></p>
    <ol>
      <% item.companions.forEach((companion) => { %>
        <li><%= companion.companion_name %> (<%= companion.companion_position || '-' %>)</li>
      <% }) %>
    </ol>
    <div class="mt-5 text-end">
      <p>ลงชื่อ ................................................</p>
      <p>(<%= item.requester_name %>)</p>
    </div>
  </div>
</body>
</html>