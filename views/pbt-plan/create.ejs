<%- include('../partials/header') %>
<div class="container py-4">
  <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1"><i class="bi bi-folder-plus me-2"></i>เพิ่มข้อมูล pbt_plan</h1>
      <p class="text-muted mb-0">สร้างข้อมูลได้หลายรายการในครั้งเดียว แยกตามแผน a, b, c, d</p>
    </div>
    <div class="d-flex gap-2">
      <a href="/pbt-plan" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>กลับไปหน้ารายการ</a>
    </div>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form action="/pbt-plan/create" method="post" enctype="multipart/form-data" id="pbtPlanForm">
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="row g-3 align-items-end">
          <div class="col-md-2">
            <label class="form-label">เดือน</label>
            <select name="p_month" class="form-select" required>
              <% for (let i = 1; i <= 12; i++) { const value = String(i).padStart(2, '0'); %>
                <option value="<%= value %>" <%= defaultMonth === value ? 'selected' : '' %>><%= value %></option>
              <% } %>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">ปี</label>
            <input type="text" name="p_year" class="form-control" value="<%= defaultYear %>" required>
          </div>
          <div class="col-md-3">
            <label class="form-label">ผู้บันทึก</label>
            <input type="text" name="p_saveby" class="form-control" value="<%= defaultSaveby %>" readonly>
          </div>
          <div class="col-md-3">
            <label class="form-label">วันที่บันทึก</label>
            <input type="date" name="p_savedate" class="form-control" value="<%= defaultSavedate %>" readonly>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-success w-100"><i class="bi bi-save me-1"></i>บันทึก</button>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <% planOptions.forEach((plan) => { %>
        <div class="col-12 col-xl-6">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
              <div>
                <strong><%= plan.label %></strong>
                <span class="badge bg-primary ms-2" id="count-<%= plan.value %>">0 รายการ</span>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="<%= plan.value %>">
                <i class="bi bi-plus-circle me-1"></i>เพิ่มโครงการ
              </button>
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th style="width: 120px;">รหัส</th>
                      <th>โครงการ</th>
                      <th style="width: 170px;">รูป/ไฟล์</th>
                      <th style="width: 70px;"></th>
                    </tr>
                  </thead>
                  <tbody id="tbody-<%= plan.value %>"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </form>
</div>

<script type="application/json" id="pbtPlanOptions"><%- JSON.stringify(planOptions) %></script>

<script>
  (function () {
    const planDataEl = document.getElementById('pbtPlanOptions');
    const planOptions = JSON.parse(planDataEl.textContent || '[]');
    const form = document.getElementById('pbtPlanForm');
    let rowCounter = 0;

    const PROJECT_OPTIONS = [
      { code: 'a01', name: 'สหกรณ์และกลุ่มเกษตรกรได้รับการส่งเสริมและพัฒนาให้มีความเข้มแข็งตามศักยภาพ' },
      { code: 'a02', name: 'ส่งเสริมสหกรณ์/กลุ่มเกษตรกรสู่ดีเด่น' },
      { code: 'a03', name: 'แผนฟื้นฟูให้สหกรณ์มีกำไรสุทธิประจำปี' },
      { code: 'a04', name: 'การจัดทำแผนกลยุทธ์สหกรณ์' },
      { code: 'b01', name: 'โครงการส่งเสริมการดำเนินงานอันเนื่องมาจากพระราชดำริ' },
      { code: 'c01', name: 'โครงการส่งเสริมและพัฒนาอาชีพเพื่อแก้ไขปัญหาที่ดินทำกินของเกษตรกร' },
      { code: 'c02', name: 'โครงการพัฒนาผลิตภัณฑ์ชุมชนของสถาบันเกษตรกรและสมาชิก' },
      { code: 'c03', name: 'โครงการส่งเสริมการเป็นหุ้นส่วนเศรษฐกิจกับภาคเอกชนของสหกรณ์และชุมนุมสหกรณ์เดินรถ' },
      { code: 'c04', name: 'โครงการเสริมสร้างศักยภาพสหกรณ์สู่การเป็นองค์กรสมรรถนะสูงด้วยนวัตกรรมและเทคโนโลยีที่เหมาะสม' },
      { code: 'c05', name: 'โครงการแก้ไขปัญหาหนี้สินและพัฒนาคุณภาพชีวิตสมาชิกสหกรณ์และกลุ่มเกษตรกรด้วยระบบสหกรณ์' },
      { code: 'd01', name: 'โครงการส่งเสริมและพัฒนาสถาบันเกษตรกร' },
      { code: 'd02', name: 'โครงการยกระดับสถาบันเกษตรกรให้เป็นผู้ประกอบการธุรกิจเกษตร' },
      { code: 'd03', name: 'โครงการเพิ่มประสิทธิภาพด้านการผลิตและการขนส่งของสหกรณ์เพื่อเป็นต้นแบบในการบริหารจัดการ' },
      { code: 'd04', name: 'โครงการส่งเสริมและพัฒนาสินค้าเกษตรอัตลักษณ์พื้นถิ่น' },
      { code: 'd05', name: 'โครงการพัฒนาศักยภาพดำเนินธุรกิจเพื่อสร้างความเข้มแข็งให้กับสหกรณ์ผู้เลี้ยงโค' },
      { code: 'd06', name: 'โครงการสร้างมูลค่าเพิ่มจากวัสดุเหลือใช้ทางการเกษตร' },
      { code: 'd07', name: 'โครงการส่งเสริมการแปรรูปสินค้าเกษตร' },
      { code: 'd08', name: 'โครงการระบบส่งเสริมการเกษตรแบบแปลงใหญ่' },
      { code: 'd09', name: 'โครงการยกระดับศักยภาพสถาบันเกษตรกรให้เป็นผู้ให้บริการทางการเกษตรแบบครบวงจร' },
      { code: 'd10', name: 'โครงการพัฒนาศักยภาพการดำเนินธุรกิจสถาบันเกษตรกรด้วยเทคโนโลยีและนวัตกรรม' }
    ];

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function buildProjectOptions(planValue, selectedValue = '') {
      const allowedPrefix = String(planValue || '').toLowerCase();
      const options = ['<option value="">เลือกโครงการ</option>'];
      PROJECT_OPTIONS
        .filter((project) => String(project.code || '').toLowerCase().startsWith(allowedPrefix))
        .forEach((project) => {
          const selected = String(selectedValue || '') === String(project.code || '') ? 'selected' : '';
          options.push(
            `<option value="${escapeHtml(project.code)}" ${selected}>${escapeHtml(project.name)}</option>`
          );
        });
      return options.join('');
    }

    function makeRow(planValue, preset = {}) {
      const key = preset.key || String(rowCounter++);
      const row = document.createElement('tr');
      row.dataset.rowKey = key;
      row.dataset.plan = planValue;
      row.innerHTML = `
        <td>
          <input type="text" name="rows[${key}][p_code]" class="form-control form-control-sm" placeholder="เช่น ${planValue.toUpperCase()}01" value="${preset.p_code || ''}" required>
          <input type="hidden" name="rows[${key}][p_plan]" value="${planValue}">
        </td>
        <td>
          <select class="form-select form-select-sm" data-project-select required>
            ${buildProjectOptions(planValue, preset.p_code || '')}
          </select>
          <input type="hidden" name="rows[${key}][p_project]" value="${preset.p_project || ''}">
        </td>
        <td>
          <input type="file" name="p_img_${key}" class="form-control form-control-sm" required>
          <div class="form-text">เก็บเป็นไฟล์รูป/เอกสาร</div>
        </td>
        <td class="text-end">
          <button type="button" class="btn btn-outline-danger btn-sm" data-remove-row>
            <i class="bi bi-trash"></i>
          </button>
        </td>
      `;
      return row;
    }

    function getTbody(planValue) {
      return document.getElementById(`tbody-${planValue}`);
    }

    function updateCount(planValue) {
      const tbody = getTbody(planValue);
      const badge = document.getElementById(`count-${planValue}`);
      const count = tbody ? tbody.querySelectorAll('tr').length : 0;
      if (badge) badge.textContent = `${count} รายการ`;
    }

    function addRow(planValue) {
      const tbody = getTbody(planValue);
      if (!tbody) return;
      const row = makeRow(planValue);
      tbody.appendChild(row);
      syncProjectSelection(row);
      updateCount(planValue);
    }

    function syncProjectSelection(row) {
      const select = row.querySelector('[data-project-select]');
      const codeInput = row.querySelector('input[name$="[p_code]"]');
      const projectInput = row.querySelector('input[name$="[p_project]"]');
      if (!select || !codeInput || !projectInput) return;

      const selectedOption = select.selectedOptions && select.selectedOptions[0] ? select.selectedOptions[0] : null;
      codeInput.value = select.value || codeInput.value || '';
      projectInput.value = selectedOption ? (selectedOption.textContent || '').trim() : projectInput.value || '';
    }

    document.querySelectorAll('[data-add-row]').forEach((btn) => {
      btn.addEventListener('click', () => {
        addRow(btn.dataset.addRow);
      });
    });

    form.addEventListener('change', (e) => {
      const select = e.target.closest('[data-project-select]');
      if (!select) return;
      const row = select.closest('tr');
      if (!row) return;
      syncProjectSelection(row);
    });

    form.addEventListener('click', (e) => {
      const removeBtn = e.target.closest('[data-remove-row]');
      if (!removeBtn) return;
      const tr = removeBtn.closest('tr');
      if (!tr) return;
      const planValue = tr.dataset.plan;
      tr.remove();
      updateCount(planValue);
    });

    form.addEventListener('submit', (e) => {
      const anyRows = planOptions.some((plan) => getTbody(plan.value).querySelectorAll('tr').length > 0);
      if (!anyRows) {
        e.preventDefault();
        alert('กรุณาเพิ่มข้อมูลอย่างน้อย 1 รายการ');
      }
    });
  })();
</script>

<%- include('../partials/footer') %>
