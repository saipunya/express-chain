<%- include('../partials/header') %>

<%
  const itemsSafe = Array.isArray(items) ? items : [];
  const formatDate = (value) => {
    if (!value) return '-';
    const d = new Date(String(value).includes('T') ? String(value) : `${value}T00:00:00`);
    return Number.isNaN(d.getTime()) ? '-' : d.toLocaleDateString('th-TH', { day: 'numeric', month: 'long', year: 'numeric' });
  };
%>

<style>
  .bigmeet-detail-page {
    color: #172033;
  }

  .bigmeet-detail-hero {
    border: 0;
    border-radius: 8px;
    background: linear-gradient(135deg, #0f766e 0%, #166534 60%, #365314 100%);
    color: #fff;
    box-shadow: 0 18px 42px rgba(15, 118, 110, .18);
  }

  .bigmeet-detail-title {
    font-size: clamp(1.2rem, 2vw, 1.7rem);
    letter-spacing: 0;
  }

  .bigmeet-detail-muted {
    color: rgba(255, 255, 255, .78);
  }

  .bigmeet-detail-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, .14);
    color: #fff;
    padding: .35rem .65rem;
    font-weight: 700;
    font-size: .85rem;
  }

  .bigmeet-detail-card {
    border: 0;
    border-radius: 8px;
    box-shadow: 0 14px 34px rgba(15, 23, 42, .08);
  }

  .bigmeet-detail-table thead th {
    background: #f8fafc;
    color: #475569;
    font-size: .82rem;
    font-weight: 800;
    border-bottom: 1px solid #e2e8f0;
  }

  .bigmeet-detail-table td {
    border-color: #eef2f7;
  }

  .bigmeet-account-chip {
    display: inline-flex;
    border-radius: 999px;
    background: #ecfdf5;
    color: #047857;
    padding: .22rem .58rem;
    font-weight: 800;
    font-size: .8rem;
  }

  .bigmeet-action {
    border-radius: 8px;
    font-weight: 700;
  }
</style>

<div class="container-fluid mt-4 bigmeet-detail-page">
  <div class="card bigmeet-detail-hero mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <div class="small text-uppercase fw-bold mb-1 bigmeet-detail-muted">Big Meeting Registry</div>
          <h1 class="bigmeet-detail-title fw-bold mb-2">
            <i class="bi bi-list-check me-2"></i><%= typeLabel %> - <%= statusLabel %>
          </h1>
          <div class="bigmeet-detail-muted">
            ปีงบประมาณ <%= fiscalYear %> | ผลประชุม <%= formatDate(summary.range.start) %> - <%= formatDate(summary.range.end) %>
          </div>
          <div class="bigmeet-detail-muted mt-1">
            ปีบัญชีที่ต้องประชุม <%= formatDate(summary.accountingRange.start) %> - <%= formatDate(summary.accountingRange.end) %>
          </div>
        </div>
        <div class="text-md-end">
          <div class="bigmeet-detail-chip mb-2"><%= itemsSafe.length %> รายการ</div>
          <div>
            <a class="btn btn-light btn-sm bigmeet-action" href="/bigmeet">
              <i class="bi bi-arrow-left me-1"></i>กลับภาพรวม
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card bigmeet-detail-card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 bigmeet-detail-table">
          <thead>
            <tr>
              <th class="text-center" style="width: 70px;">#</th>
              <th>สถาบัน</th>
              <th class="text-center" style="width: 190px;">ปีบัญชีล่าสุด</th>
              <th class="text-center" style="width: 180px;">วันที่ประชุม</th>
              <th style="width: 220px;">หมายเหตุ</th>
            </tr>
          </thead>
          <tbody>
            <% if (!itemsSafe.length) { %>
              <tr>
                <td colspan="5" class="text-center py-5 text-muted">
                  <i class="bi bi-search display-6 d-block mb-2"></i>
                  ไม่พบรายการ
                </td>
              </tr>
            <% } %>
            <% itemsSafe.forEach((item, index) => { %>
              <tr>
                <td class="text-center fw-bold text-success"><%= index + 1 %></td>
                <td>
                  <div class="fw-bold"><%= item.c_name || item.big_code %></div>
                  <div class="small text-muted">รหัส: <%= item.big_code %></div>
                </td>
                <td class="text-center">
                  <span class="bigmeet-account-chip"><%= item.fiscalEndDateText %></span>
                </td>
                <td class="text-center">
                  <% if (item.isMet) { %>
                    <div class="fw-bold"><%= item.meetingDateText %></div>
                    <% if (item.saveBy) { %><div class="small text-muted"><%= item.saveBy %></div><% } %>
                  <% } else { %>
                    <span class="badge text-bg-warning">ยังไม่พบผลประชุม</span>
                  <% } %>
                </td>
                <td class="text-muted">
                  <%= item.reason || item.note || '-' %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
