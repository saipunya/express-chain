<%- include('../partials/header') %>
<%- include('../partials/travel-navbar', { currentPage: 'vehicle' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">รายละเอียดคำขอใช้รถราชการ</h3>
    <p class="text-muted mb-0"><%= item.travel_request_no || item.vehicle_request_no %></p>
  </div>
  <div class="d-flex gap-2">
    <% if (user && (user.mClass === 'admin' || user.mClass === 'pbt')) { %>
      <a href="/vehicle-approval/request/<%= item.id %>" class="btn btn-outline-primary">พิจารณา</a>
    <% } %>
    <a href="/vehicle-request/<%= item.id %>/print" target="_blank" class="btn btn-outline-secondary">พิมพ์</a>
    <a href="/vehicle-request/<%= item.id %>/edit" class="btn btn-warning text-white">แก้ไข</a>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">อ้างอิงคำขอไปราชการ</dt><dd class="col-sm-8"><a href="/official-travel/<%= item.travel_request_id %>"><%= item.travel_request_no %></a></dd>
          <dt class="col-sm-4">ผู้ขอใช้รถ</dt><dd class="col-sm-8"><%= item.requester_name %> <span class="text-muted">(<%= item.requester_position || '-' %>)</span></dd>
          <dt class="col-sm-4">ปลายทาง</dt><dd class="col-sm-8"><%= item.destination_text %></dd>
          <dt class="col-sm-4">ภารกิจ</dt><dd class="col-sm-8"><%= item.mission_text %></dd>
          <dt class="col-sm-4">วันที่ปฏิบัติงาน</dt><dd class="col-sm-8"><%= new Date(item.trip_start_at).toLocaleDateString('th-TH', { dateStyle: 'medium' }) %></dd>
          <dt class="col-sm-4">จำนวนผู้โดยสาร</dt><dd class="col-sm-8"><%= item.passenger_count %></dd>
          <dt class="col-sm-4">สถานะ</dt><dd class="col-sm-8"><span class="badge bg-info"><%= item.status %></span></dd>
          <dt class="col-sm-4">ผู้พิจารณา</dt><dd class="col-sm-8"><%= item.approver_name || '-' %></dd>
          <dt class="col-sm-4">ความเห็น</dt><dd class="col-sm-8"><%= item.approval_comment || '-' %></dd>
        </dl>
      </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
      <div class="card-header bg-white"><h5 class="mb-0">ข้อมูลการมอบหมายและบันทึกเดินรถ</h5></div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">ทะเบียนรถ</dt><dd class="col-sm-8"><%= item.plate_no_snapshot || '-' %></dd>
          <dt class="col-sm-4">คนขับ</dt><dd class="col-sm-8"><%= item.driver_name_snapshot || '-' %></dd>
          <dt class="col-sm-4">เวลาออกเช้า</dt><dd class="col-sm-8"><%= item.morning_departure_at ? new Date(item.morning_departure_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short' }) : '-' %></dd>
          <dt class="col-sm-4">เลขไมล์ออก</dt><dd class="col-sm-8"><%= item.morning_odometer || '-' %></dd>
          <dt class="col-sm-4">เวลากลับบ่าย</dt><dd class="col-sm-8"><%= item.afternoon_return_at ? new Date(item.afternoon_return_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short' }) : '-' %></dd>
          <dt class="col-sm-4">เลขไมล์เข้า</dt><dd class="col-sm-8"><%= item.afternoon_odometer || '-' %></dd>
          <dt class="col-sm-4">ระยะทางรวม</dt><dd class="col-sm-8"><%= item.distance_km || '-' %></dd>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white"><h5 class="mb-0">การดำเนินการ</h5></div>
      <div class="card-body d-grid gap-2">
        <a href="/official-travel/<%= item.travel_request_id %>" class="btn btn-outline-primary">กลับไปคำขอไปราชการ</a>
        <a href="/vehicle-request" class="btn btn-outline-secondary">กลับหน้ารายการ</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
