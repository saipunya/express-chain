<!-- include header -->
<%- include('header.ejs') %>

<style>
  .promo-result-page {
    min-height: 100vh;
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 16px;
  }

  .promo-result-card {
    width: 100%;
    max-width: 720px;
    background: #fff;
    border-radius: 32px;
    padding: 36px 28px;
    box-shadow: 0 30px 70px rgba(15, 23, 42, 0.12);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .promo-result-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(37,99,235,0.15), transparent 30%),
      radial-gradient(circle at bottom left, rgba(59,130,246,0.12), transparent 28%);
    pointer-events: none;
  }

  .promo-result-inner {
    position: relative;
    z-index: 1;
  }

  .promo-result-icon {
    font-size: 90px;
    margin-bottom: 12px;
    animation: bounce 1.2s infinite alternate;
  }

  @keyframes bounce {
    from { transform: translateY(0); }
    to { transform: translateY(-10px); }
  }

  .promo-result-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .promo-result-win {
    color: #16a34a;
  }

  .promo-result-lose {
    color: #64748b;
  }

  .promo-prize-name {
    font-size: 1.8rem;
    font-weight: 800;
    color: #2563eb;
    margin-bottom: 6px;
  }

  .promo-prize-desc {
    color: #64748b;
    margin-bottom: 20px;
  }

  .promo-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 18px;
  }

  .promo-btn {
    min-height: 54px;
    padding: 12px 22px;
    border-radius: 14px;
    font-weight: 700;
    border: none;
    transition: all 0.2s;
  }

  .promo-btn-primary {
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    color: #fff;
    box-shadow: 0 14px 28px rgba(37,99,235,0.25);
  }

  .promo-btn-primary:hover {
    transform: translateY(-2px);
  }

  .promo-btn-success {
    background: linear-gradient(135deg, #16a34a, #22c55e);
    color: #fff;
  }

  .promo-btn-danger {
    background: #fff;
    color: #dc2626;
    border: 2px solid rgba(220,38,38,0.25);
  }

  .promo-btn-outline {
    background: #fff;
    border: 2px solid #cbd5e1;
  }

  @media(max-width:768px){
    .promo-result-title {
      font-size: 1.7rem;
    }

    .promo-prize-name {
      font-size: 1.4rem;
    }

    .promo-actions {
      flex-direction: column;
    }

    .promo-btn {
      width: 100%;
    }
  }
</style>

<div class="promo-result-page">
  <div class="promo-result-card">
    <div class="promo-result-inner">

      <% const drawSafe = (typeof draw !== 'undefined') ? draw : null; %>
      <% const hasPrize = drawSafe && drawSafe.prize_id && drawSafe.prize_type !== 'other'; %>
      <% if (hasPrize) { %>

        <div class="promo-result-icon">🎉</div>

        <div class="promo-result-title promo-result-win">
          ยินดีด้วย! คุณได้รับรางวัล
        </div>

        <div class="promo-prize-name">
          <%= drawSafe.prize_name %>
        </div>

        <div class="promo-prize-desc">
          <%= drawSafe.prize_description || '' %>
        </div>

        <div class="promo-actions">
          <form method="post" action="/promotion/claim">
            <input type="hidden" name="draw_token" value="<%= drawSafe.draw_token %>">
            <button class="promo-btn promo-btn-success">🎁 เคลมรางวัล</button>
          </form>

          <form method="post" action="/promotion/decline">
            <input type="hidden" name="draw_token" value="<%= drawSafe.draw_token %>">
            <button class="promo-btn promo-btn-danger">ปฏิเสธ</button>
          </form>
        </div>

      <% } else { %>

        <div class="promo-result-icon">😢</div>

        <div class="promo-result-title promo-result-lose">
          ขออภัย คุณไม่ได้รับรางวัล
        </div>

        <div class="promo-prize-desc">
          ลองใหม่อีกครั้งในโอกาสถัดไปนะครับ
        </div>

        <div class="promo-actions">
          <a href="/promotion/play" class="promo-btn promo-btn-primary">
            🔄 ลองใหม่
          </a>
        </div>

      <% } %>

      <div class="promo-actions mt-3">
        <a href="/promotion" class="promo-btn promo-btn-outline">
          ← กลับหน้าแรก
        </a>
      </div>

    </div>
  </div>
</div>
<!-- include footer -->
<%- include('footer.ejs') %>
