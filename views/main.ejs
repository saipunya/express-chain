    <section class="main-institution-section" aria-labelledby="strengthGradeSummaryTitle">
      <div class="main-section-title">
        <div>
          <h2 id="strengthGradeSummaryTitle">สรุปผลความเข้มแข็งสหกรณ์และกลุ่มเกษตรกร</h2>
          <div class="text-muted small">
            ประจำปี <%= _strengthGradeSummary.year || 2568 %> แยกตามชั้นและประเภทสถาบัน
          </div>
        </div>
        <span class="badge text-bg-info">
          รวม <%= Number(_strengthGradeTotals.total || 0).toLocaleString('th-TH') %> แห่ง
        </span>
      </div>

      <% if (_strengthGradeList.length && Number(_strengthGradeTotals.total || 0) > 0) { %>
        <div class="row g-3 align-items-stretch">
          <% _strengthGradeList.forEach(function(item) { %>
            <% const total = Number(item.total || 0); %>
            <% const gradeRows = [
              { label: 'ชั้น 1', value: Number(item.grade1 || 0), className: 'grade-1' },
              { label: 'ชั้น 2', value: Number(item.grade2 || 0), className: 'grade-2' },
              { label: 'ชั้น 3', value: Number(item.grade3 || 0), className: 'grade-3' }
            ]; %>
            <div class="col-md-4">
              <div class="main-strength-card">
                <div class="d-flex align-items-start justify-content-between gap-3">
                  <div>
                    <div class="main-turnover-label"><%= item.label %></div>
                    <div class="main-turnover-value"><%= Number(total).toLocaleString('th-TH') %> แห่ง</div>
                    <div class="text-muted small mt-1">
                      ชั้น 1 <%= total > 0 ? Number(item.grade1Percent || 0).toFixed(1) : '0.0' %>%
                    </div>
                  </div>
                  <div class="main-stat-icon <%= item.tone %>">
                    <i class="bi <%= item.icon %>"></i>
                  </div>
                </div>

                <div class="main-strength-grade-list">
                  <% gradeRows.forEach(function(row) { %>
                    <% const width = total > 0 ? Math.max(0, Math.min(100, (row.value / total) * 100)) : 0; %>
                    <div class="main-strength-grade-row">
                      <div class="main-strength-grade-label"><%= row.label %></div>
                      <div class="main-strength-bar" aria-hidden="true">
                        <div class="main-strength-bar-fill <%= row.className %>" style="--strength-width: <%= width %>%;"></div>
                      </div>
                      <div class="main-strength-grade-value"><%= row.value.toLocaleString('th-TH') %></div>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="main-empty">ยังไม่มีข้อมูลความเข้มแข็งประจำปี <%= _strengthGradeSummary.year || 2568 %></div>
      <% } %>
    </section>
    <section class="main-institution-section" aria-labelledby="turnoverSummaryTitle">
      <div class="main-section-title">
        <div>
          <h2 id="turnoverSummaryTitle">ปริมาณธุรกิจภาพรวม</h2>
          <div class="text-muted small">
            แยกตามประเภทสถาบัน ปีงบประมาณ <%= _turnoverCategorySummary.latestBudYearThai || '-' %>
          </div>
        </div>
        <span class="badge text-bg-primary"><%= _formatTurnoverAmount(_turnoverTotalAmount) %></span>
      </div>

      <% if (_turnoverCategoryList.length && _turnoverTotalAmount > 0) { %>
        <div class="row g-3 align-items-stretch">
          <% _turnoverCategoryList.forEach(function(item) { %>
            <div class="col-md-4">
              <div class="main-turnover-card <%= item.tone %>">
                <div class="d-flex align-items-start justify-content-between gap-3">
                  <div class="min-w-0">
                    <div class="main-turnover-label"><%= item.label %></div>
                    <div class="main-turnover-value"><%= _formatTurnoverAmount(item.totalAmount) %></div>
                  </div>
                  <div class="main-stat-icon <%= item.tone %>">
                    <i class="bi <%= item.icon %>"></i>
                  </div>
                </div>
                <div class="main-turnover-meta">
                  <span><i class="bi bi-building me-1"></i><%= Number(item.institutionCount || 0).toLocaleString('th-TH') %> แห่ง</span>
                  <span><i class="bi bi-calendar3 me-1"></i><%= Number(item.monthsWithData || 0).toLocaleString('th-TH') %> เดือน</span>
                  <span><i class="bi bi-clock-history me-1"></i><%= item.latestMonth || '-' %> <%= item.latestYear ? Number(item.latestYear).toLocaleString('th-TH', { useGrouping: false }) : '' %></span>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="main-empty">ยังไม่มีข้อมูลปริมาณธุรกิจสำหรับแสดงภาพรวม</div>
      <% } %>
    </section>

    <section class="main-institution-section" aria-labelledby="bigmeetFiscalSummaryTitle">
      <div class="main-section-title">
        <div>
          <h2 id="bigmeetFiscalSummaryTitle">สรุปผลการประชุมใหญ่</h2>
          <div class="text-muted small">
            ประจำปีงบประมาณ <%= _bigmeetFiscalSummary.fiscalYearThai || '-' %> แยกตามประเภทสถาบัน
          </div>
        </div>
        <span class="badge text-bg-success">
          ประชุมแล้ว <%= Number(_bigmeetFiscalTotals.met || 0).toLocaleString('th-TH') %>/<%= Number(_bigmeetFiscalTotals.total || 0).toLocaleString('th-TH') %> แห่ง
        </span>
      </div>

      <% if (_bigmeetFiscalCategories.length && _bigmeetFiscalTotals.total > 0) { %>
        <div class="row g-3 align-items-stretch">
          <% _bigmeetFiscalCategories.forEach(function(item) { %>
            <% const itemPercent = Math.max(0, Math.min(100, Number(item.percent || 0))); %>
            <div class="col-md-4">
              <div class="main-bigmeet-card">
                <div class="d-flex align-items-start justify-content-between gap-3">
                  <div>
                    <div class="main-turnover-label"><%= item.label %></div>
                    <div class="main-turnover-value"><%= itemPercent.toFixed(1) %>%</div>
                    <div class="text-muted small mt-1">อัตราประชุมแล้ว</div>
                  </div>
                  <div class="main-stat-icon <%= item.tone %>">
                    <i class="bi <%= item.icon %>"></i>
                  </div>
                </div>
                <div class="main-bigmeet-progress" aria-hidden="true">
                  <div class="main-bigmeet-progress-bar" style="--meeting-progress: <%= itemPercent %>%;"></div>
                </div>
                <div class="main-bigmeet-counts">
                  <div class="main-bigmeet-count">
                    <div class="main-bigmeet-count-label">ทั้งหมด</div>
                    <div class="main-bigmeet-count-value"><%= Number(item.total || 0).toLocaleString('th-TH') %></div>
                  </div>
                  <div class="main-bigmeet-count">
                    <div class="main-bigmeet-count-label">ประชุมแล้ว</div>
                    <div class="main-bigmeet-count-value text-success"><%= Number(item.met || 0).toLocaleString('th-TH') %></div>
                  </div>
                  <div class="main-bigmeet-count">
                    <div class="main-bigmeet-count-label">ยังไม่ประชุม</div>
                    <div class="main-bigmeet-count-value text-warning"><%= Number(item.notMet || 0).toLocaleString('th-TH') %></div>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="main-empty">ยังไม่มีข้อมูลผลการประชุมใหญ่สำหรับปีงบประมาณล่าสุด</div>
      <% } %>
    </section>


  <section class="main-institution-section" aria-labelledby="overdueMeetingTitle">
      <div class="main-section-title">
        <div>
          <h2 id="overdueMeetingTitle">เลยกำหนดประชุมใหญ่แล้วยังไม่มีผลประชุม</h2>
          <div class="text-muted small">
            สถาบันที่ต้องประชุมใหญ่ภายใน 150 วัน ในปีงบประมาณ พ.ศ. <%= _overdueMeetingSummary.fiscalYear || 2569 %>
          </div>
        </div>
        <span class="badge text-bg-danger">
          <%= Number(_overdueMeetingSummary.total || 0).toLocaleString('th-TH') %> แห่ง
        </span>
      </div>

      <% if (_overdueMeetingList.length && Number(_overdueMeetingSummary.total || 0) > 0) { %>
        <div class="row g-3 align-items-stretch">
          <% _overdueMeetingList.forEach(function(item) { %>
            <div class="col-md-4">
              <div class="main-overdue-card">
                <div class="d-flex align-items-start justify-content-between gap-3">
                  <div>
                    <div class="main-turnover-label"><%= item.label %></div>
                    <div class="main-turnover-value text-danger"><%= Number(item.count || 0).toLocaleString('th-TH') %> แห่ง</div>
                    <div class="text-muted small mt-1">ยังไม่พบผลประชุมใหญ่</div>
                  </div>
                  <div class="main-stat-icon red">
                    <i class="bi bi-exclamation-triangle"></i>
                  </div>
                </div>
                <% if ((item.rows || []).length) { %>
                  <div class="main-closing-list">
                    <% item.rows.slice(0, 4).forEach(function(row) { %>
                      <div class="main-closing-item">
                        <span class="main-closing-name"><%= row.c_name || '-' %></span>
                        <span class="main-closing-date"><%= row.meetingDeadlineThai || '-' %></span>
                      </div>
                    <% }); %>
                    <% if (item.rows.length > 4) { %>
                      <div class="small text-muted text-end">อีก <%= Number(item.rows.length - 4).toLocaleString('th-TH') %> แห่ง</div>
                    <% } %>
                  </div>
                <% } else { %>
                  <div class="main-empty mt-3 py-2">ไม่มีรายการในประเภทนี้</div>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="main-empty">ไม่มีรายการที่เลยกำหนดประชุมใหญ่และยังไม่มีผลประชุมในปีงบประมาณ พ.ศ. <%= _overdueMeetingSummary.fiscalYear || 2569 %></div>
      <% } %>
    </section>



<section class="main-deadline-section">
  <div class="row g-4 align-items-stretch">
    <div class="col-lg-6">
      <div class="card main-deadline-card">
        <div class="main-deadline-head">
          <h2 class="main-deadline-title">
            <i class="bi bi-people"></i>
            ประชุมใหญ่ภายในเดือนนี้
          </h2>
          <span class="badge text-bg-success main-deadline-count"><%= _bigmeetCount %> แห่ง</span>
        </div>
        <div class="main-deadline-body">
          <div class="text-muted small mb-3">
            กำหนดประชุมใหญ่ภายในเดือน <%= _bigmeetMonthLabel || '-' %> อ้างอิงจากวันสิ้นปีบัญชี + 150 วัน
          </div>
          <% if (_bigmeetThisMonthGroups.length) { %>
            <% _bigmeetThisMonthGroups.forEach(function(group) { %>
              <div class="main-deadline-group">
                <div class="main-deadline-group-name"><%= group.groupName %></div>
                <div class="table-responsive">
                  <table class="table table-sm main-deadline-table align-middle">
                    <thead>
                      <tr>
                        <th>สถาบัน</th>
                        <th>สิ้นปีบัญชี</th>
                        <th>ครบกำหนด</th>
                        <th>สถานะ</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% (group.rows || []).forEach(function(row) { %>
                        <tr>
                          <td class="main-deadline-name"><%= row.c_name || '-' %></td>
                          <td><%= row.endDateThai || '-' %></td>
                          <td><%= row.meetingDeadlineThai || '-' %></td>
                          <td>
                            <% if (row.meetingDateThai) { %>
                              <span class="badge text-bg-success">ประชุมแล้ว <%= row.meetingDateThai %></span>
                            <% } else if (row.meetingRecordedStatus === 'not_met') { %>
                              <span class="badge text-bg-secondary">บันทึกว่ายังไม่ประชุม</span>
                            <% } else { %>
                              <span class="badge text-bg-warning text-dark">รอดำเนินการ</span>
                            <% } %>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="main-empty">ไม่มีรายการครบกำหนดประชุมใหญ่ในเดือนนี้</div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-lg-6">
      <div class="card main-deadline-card">
        <div class="main-deadline-head">
          <h2 class="main-deadline-title">
            <i class="bi bi-journal-check"></i>
            ปิดบัญชีภายใน 30 วัน
          </h2>
          <span class="badge text-bg-info main-deadline-count"><%= _closingCount %> แห่ง</span>
        </div>
        <div class="main-deadline-body">
          <div class="text-muted small mb-3">
            รายการครบกำหนดปิดบัญชีในช่วง <%= _closingWindowLabel %> โดยนับจากวันสิ้นปีบัญชี + 30 วัน
          </div>
          <% if (_closingWithin30Groups.length) { %>
            <% _closingWithin30Groups.forEach(function(group) { %>
              <div class="main-deadline-group">
                <div class="main-deadline-group-name"><%= group.groupName %></div>
                <div class="table-responsive">
                  <table class="table table-sm main-deadline-table align-middle">
                    <thead>
                      <tr>
                        <th>สถาบัน</th>
                        <th>สิ้นปีบัญชี</th>
                        <th>ครบกำหนดปิดบัญชี</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% (group.rows || []).forEach(function(row) { %>
                        <tr>
                          <td class="main-deadline-name"><%= row.c_name || '-' %></td>
                          <td><%= row.endDateThai || '-' %></td>
                          <td><%= row.closingDeadlineThai || '-' %></td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="main-empty">ไม่มีรายการครบกำหนดปิดบัญชีใน 30 วันข้างหน้า</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="institutionSummaryModal" tabindex="-1" aria-labelledby="institutionSummaryModalTitle" aria-hidden="true">
