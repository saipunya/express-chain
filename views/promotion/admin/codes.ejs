<!-- include header -->
<%- include('../header.ejs', { title: title }) %>
<style>
  body {
    background: #f1f5f9;
  }

  .admin-container {
    max-width: 1200px;
    margin: auto;
  }

  .topbar {
    background: #fff;
    border-radius: 16px;
    padding: 20px 25px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  }

  .card-soft {
    border-radius: 18px;
    border: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
  }

  .stat-card {
    padding: 20px;
    border-radius: 16px;
    background: #fff;
    text-align: center;
  }

  .stat-number {
    font-size: 1.8rem;
    font-weight: 800;
  }

  .btn-main {
    border-radius: 12px;
    font-weight: 600;
    padding: 12px;
  }

  .code-highlight {
    background: #ecfdf5;
    font-weight: bold;
  }

  .table td, .table th {
    vertical-align: middle;
  }

  .table-hover tbody tr:hover {
    background: #f1f5f9;
  }

  .badge-status {
    padding: 6px 10px;
    border-radius: 10px;
  }
</style>

<div class="container py-4 admin-container">

  <!-- TOP BAR -->
  <div class="topbar mb-4 d-flex justify-content-between align-items-center">
    <div>
      <h4 class="fw-bold mb-1">🎯 Promotion Code Manager</h4>
      <small class="text-muted">จัดการโค้ดโปรโมชั่นแบบมืออาชีพ</small>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <% if (promotionAdmin) { %>
        <small class="text-muted"><%= promotionAdmin.display_name || promotionAdmin.username %> (<%= promotionAdmin.role %>)</small>
      <% } %>
      <% if (promotionAdmin && promotionAdmin.role === 'super_admin') { %>
        <a href="/promotion/admin/users" class="btn btn-outline-primary btn-sm">Admin Users</a>
        <a href="/promotion/admin/stores" class="btn btn-outline-primary btn-sm">Stores</a>
      <% } %>
      <a href="/promotion/admin" class="btn btn-outline-secondary btn-sm">← Back</a>
      <a href="/promotion/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a>
    </div>
  </div>

  <!-- STATS -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="stat-card">
        <div class="stat-number"><%= codes.length %></div>
        <div class="text-muted">Total Codes</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card">
        <div class="stat-number text-success">
          <%= codes.filter(c => c.status === 'unused').length %>
        </div>
        <div class="text-muted">Available</div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="stat-card">
        <div class="stat-number text-danger">
          <%= codes.filter(c => c.status !== 'unused').length %>
        </div>
        <div class="text-muted">Used</div>
      </div>
    </div>
  </div>

  <div class="row g-4">

    <!-- GENERATE PANEL -->
    <div class="col-lg-4">
      <div class="card card-soft p-4">

        <h5 class="fw-bold mb-3">⚡ Generate Codes</h5>

        <form method="POST" action="/promotion/admin/codes/generate">

          <div class="mb-3">
            <label class="form-label">Store</label>
            <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
              <input type="hidden" name="store_id" value="<%= stores[0] ? stores[0].id : '' %>">
              <input type="text" class="form-control" value="<%= stores[0] ? stores[0].name : '-' %>" readonly>
            <% } else { %>
              <select class="form-select" name="store_id" required>
                <option value="">เลือกสาขา</option>
                <% stores.forEach(s => { %>
                  <option value="<%= s.id %>"><%= s.name %></option>
                <% }) %>
              </select>
            <% } %>
          </div>

          <div class="mb-3">
            <label class="form-label">Campaign</label>
            <select class="form-select" name="campaign_id">
              <option value="">ทั้งหมด</option>
              <% campaigns.forEach(c => { %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Quantity</label>
            <input type="number" name="quantity" class="form-control" value="100">
          </div>

          <button class="btn btn-primary btn-main w-100">
            🚀 Generate Now
          </button>

        </form>

      </div>
    </div>

    <!-- NEW CODES -->
    <div class="col-lg-8">
      <% if (newCodes && newCodes.length) { %>
      <div class="card card-soft p-4 border-success">

        <div class="d-flex justify-content-between mb-3">
          <div>
            <h5 class="fw-bold">🔥 New Codes</h5>
            <small class="text-muted"><%= newCodes.length %> codes created</small>
          </div>
          <button id="copyCodesBtn" class="btn btn-outline-primary btn-sm">
            Copy All
          </button>
        </div>

        <div class="table-responsive">
          <table class="table table-bordered">
            <tbody>
              <% newCodes.forEach(nc => { %>
                <tr class="code-highlight">
                  <td><code><%= nc.code %></code></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      </div>
      <% } %>
    </div>

  </div>

  <!-- ALL CODES TABLE -->
  <div class="card card-soft mt-4">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Code</th>
            <th>Store</th>
            <th>Campaign</th>
            <th>Status</th>
            <th>Expire</th>
          </tr>
        </thead>
        <tbody>
          <% codes.forEach(c => { %>
            <tr>
              <td><%= c.code %></td>
              <td><%= c.store_name || '-' %></td>
              <td><%= c.campaign_name || '-' %></td>
              <td>
                <span class="badge-status bg-<%= c.status === 'unused' ? 'success' : 'secondary' %> text-white">
                  <%= c.status %>
                </span>
              </td>
              <td><%= c.expires_at ? new Date(c.expires_at).toLocaleDateString() : '-' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
  const copyBtn = document.getElementById('copyCodesBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      const codes = Array.from(document.querySelectorAll('code'))
        .map(el => el.innerText)
        .join('\n');

      navigator.clipboard.writeText(codes).then(() => {
        copyBtn.innerText = 'Copied!';
        setTimeout(() => copyBtn.innerText = 'Copy All', 2000);
      });
    });
  }
</script>

<%- include('../footer.ejs') %>
