<%- include('../partials/header') %>
<%- include('../partials/travel-navbar', { currentPage: 'approval-dashboard' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">แดชบอร์ดการอนุมัติ</h3>
    <p class="text-muted mb-0">สรุปสถานะคำขอไปราชการและคำขอใช้รถสำหรับผู้อนุมัติ</p>
  </div>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<div class="row g-4 mb-4">
  <div class="col-lg-6">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <h5 class="card-title">คำขอไปราชการรออนุมัติ</h5>
        <p class="card-text">จำนวนคำขอรวม <strong><%= travelItems.length %></strong> รายการ</p>
        <a href="/vehicle-approval/pending" class="btn btn-primary">ไปที่คิวอนุมัติ</a>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <h5 class="card-title">คำขอใช้รถรออนุมัติ/มอบหมาย</h5>
        <p class="card-text">จำนวนคำขอรวม <strong><%= vehicleItems.length %></strong> รายการ</p>
        <a href="/vehicle-approval/pending" class="btn btn-primary">ไปที่คิวอนุมัติ</a>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white"><h5 class="mb-0">คำขอไปราชการล่าสุด</h5></div>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>เลขที่</th>
              <th>เรื่อง</th>
              <th>ผู้ขอ</th>
              <th class="text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (!travelItems.length) { %>
              <tr><td colspan="4" class="text-center py-4 text-muted">ไม่มีคำขอไปราชการรออนุมัติ</td></tr>
            <% } %>
            <% travelItems.slice(0, 5).forEach((item) => { %>
              <tr>
                <td><%= item.request_no %></td>
                <td><%= item.subject %></td>
                <td><%= item.requester_name %></td>
                <td class="text-end"><a href="/vehicle-approval/travel/<%= item.id %>" class="btn btn-sm btn-outline-primary">เปิด</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white"><h5 class="mb-0">คำขอใช้รถล่าสุด</h5></div>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>เลขที่</th>
              <th>ปลายทาง</th>
              <th>ผู้ขอ</th>
              <th class="text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (!vehicleItems.length) { %>
              <tr><td colspan="4" class="text-center py-4 text-muted">ไม่มีคำขอใช้รถรออนุมัติ</td></tr>
            <% } %>
            <% vehicleItems.slice(0, 5).forEach((item) => { %>
              <tr>
                <td><%= item.travel_request_no || item.vehicle_request_no %></td>
                <td><%= item.destination_text %></td>
                <td><%= item.requester_name %></td>
                <td class="text-end"><a href="/vehicle-approval/request/<%= item.id %>" class="btn btn-sm btn-outline-primary">เปิด</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
