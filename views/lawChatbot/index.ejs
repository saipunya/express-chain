<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="<%= themeColor || '#2f5f7a' %>" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="กฎหมายสหกรณ์" />
  <link rel="manifest" href="<%= manifestPath || '/manifest-law-chatbot.json' %>" />
  <link rel="apple-touch-icon" href="/icon/calendar-icon-192.svg" />
  <title><%= title || 'แชตบอทกฎหมายสหกรณ์' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-start: #eef4f8;
      --bg-end: #f8fafc;
      --surface: #ffffff;
      --surface-soft: #f4f7fa;
      --primary: #1e5f86;
      --primary-soft: #d8e8f3;
      --text-main: #1f2a37;
      --text-sub: #5d6a79;
      --border: #d8e2ea;
      --ok: #1d7a52;
      --warn: #8b2e2e;
    }

    html, body {
      margin: 0;
      padding: 0;
      font-family: 'Sarabun', sans-serif;
      min-height: 100%;
      background: linear-gradient(160deg, var(--bg-start), var(--bg-end));
      color: var(--text-main);
    }

    .lawbot-app {
      min-height: 100dvh;
      padding: 0.7rem;
      padding-top: max(0.7rem, env(safe-area-inset-top));
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .top-status {
      width: min(980px, 100%);
      display: flex;
      gap: 0.5rem;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }

    .status-chip {
      background: rgba(255, 255, 255, 0.8);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.25rem 0.65rem;
      font-size: 0.82rem;
      color: var(--text-sub);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      backdrop-filter: blur(6px);
    }

    .chat-shell {
      width: min(980px, 100%);
      border-radius: 1.2rem;
      border: 1px solid var(--border);
      background: var(--surface);
      overflow: hidden;
      box-shadow: 0 14px 36px rgba(32, 56, 81, 0.08);
      min-height: calc(100dvh - 82px);
      display: flex;
      flex-direction: column;
    }

    .chat-header {
      padding: 1rem 1.1rem;
      background: linear-gradient(145deg, #edf5fb, #e6f0f7);
      border-bottom: 1px solid var(--border);
    }

    .target-law-wrap .btn {
      white-space: normal;
      line-height: 1.3;
      font-size: 0.83rem;
    }

    .chat-messages {
      flex: 1;
      min-height: 420px;
      overflow-y: auto;
      background: var(--surface-soft);
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: 1rem;
    }

    .bubble {
      max-width: 90%;
      border-radius: 0.95rem;
      padding: 0.68rem 0.9rem;
      line-height: 1.45;
      white-space: pre-wrap;
      word-break: break-word;
      animation: bubbleFadeIn 220ms ease-out both;
    }

    .bubble-user {
      align-self: flex-end;
      color: #fff;
      background: linear-gradient(140deg, #2e78aa, #1d5d86);
      border-bottom-right-radius: 0.25rem;
    }

    .bubble-bot {
      align-self: flex-start;
      color: var(--text-main);
      border: 1px solid var(--border);
      background: #fff;
      border-bottom-left-radius: 0.25rem;
    }

    .bubble-loading {
      color: var(--text-sub);
      font-style: italic;
    }

    .feedback-actions {
      display: flex;
      gap: 0.4rem;
      margin-top: 0.55rem;
      flex-wrap: wrap;
    }

    .feedback-actions .btn {
      --bs-btn-padding-y: 0.2rem;
      --bs-btn-padding-x: 0.55rem;
      --bs-btn-font-size: 0.76rem;
    }

    .hl-hit {
      background: #fff2a2;
      border-radius: 0.2rem;
      padding: 0 0.1rem;
      animation: markGlow 420ms ease-out both;
    }

    .chat-input-wrap {
      border-top: 1px solid var(--border);
      padding: 0.8rem;
      background: #fff;
    }

    .btn-install {
      display: none;
    }

    .voice-btn-listening {
      color: #fff !important;
      background: #b42318 !important;
      border-color: #b42318 !important;
    }

    @keyframes bubbleFadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes markGlow {
      from { background-color: #ffe57c; }
      to { background-color: #fff2a2; }
    }

    @media (max-width: 768px) {
      .lawbot-app {
        padding: 0;
        padding-top: env(safe-area-inset-top);
        gap: 0.45rem;
      }
      .top-status { padding: 0.55rem 0.55rem 0; }
      .chat-shell {
        border-radius: 0;
        border-left: none;
        border-right: none;
        min-height: calc(100dvh - 52px);
      }
      .chat-messages { min-height: 0; }
      .bubble { max-width: 95%; }
    }

    @media (prefers-reduced-motion: reduce) {
      .bubble, .hl-hit { animation: none !important; }
    }
  </style>
</head>
<body>
  <div class="lawbot-app">
    <div class="top-status">
      <div class="status-chip"><i class="bi bi-robot"></i>แชตบอทกฎหมายสหกรณ์ Version 1.0</div>
      <div class="d-flex gap-2 flex-wrap">
        <button id="installBtn" class="btn btn-sm btn-success btn-install"><i class="bi bi-download me-1"></i>ติดตั้งแอป</button>
        <span id="onlineBadge" class="status-chip"><i class="bi bi-wifi"></i>ออนไลน์</span>
      </div>
    </div>

    <div class="chat-shell">
      <div class="chat-header d-none d-md-block">
        <h1 class="h5 mb-1">แชตบอทกฎหมายสหกรณ์</h1>
        <p class="mb-0 small text-muted">ระบบค้นหากฎหมายแบบ PWA สำหรับมือถือและเดสก์ท็อป</p>
      </div>

      <div class="quick-questions px-3 py-2 border-bottom">
        <div class="d-flex align-items-center justify-content-between mb-2">
      
        </div>
        <div class="target-law-wrap mb-2">
          <div class="small text-secondary mb-1">เลือกกฎหมายก่อนค้นหา</div>
          <div class="btn-group btn-group-sm w-100" role="group" aria-label="เลือกฐานกฎหมาย">
            <button type="button" class="btn btn-primary target-law-btn active" data-target="coop">พระราชบัญญัติสหกรณ์ พ.ศ. 2542</button>
            <button type="button" class="btn btn-outline-primary target-law-btn" data-target="group">พระราชกฤษฎีกาว่าด้วยกลุ่มเกษตรกร พ.ศ. 2547</button>
          </div>
        </div>
        <div class="d-flex justify-content-between">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#developerModal">
  <i class="bi bi-person-circle me-1"></i>ติดต่อผู้พัฒนา
</button>

<!-- Developer Modal -->
<div class="modal fade" id="developerModal" tabindex="-1" aria-labelledby="developerModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="developerModalLabel"><i class="bi bi-person-circle me-2"></i>ข้อมูลผู้พัฒนา</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="text-center mb-3">
          <i class="bi bi-code-slash" style="font-size: 3rem; color: var(--primary);"></i>
        </div>
        <ul class="list-unstyled">
          <li class="mb-2"><i class="bi bi-person me-2"></i><strong>ชื่อ:</strong> นายสุเมธ ชูรัตน์</li>
          <li class="mb-2"><i class="bi bi-envelope me-2"></i><strong>ตำแหน่ง</strong> นักวิชาการสหกรณ์ชำนาญการ</li>
          <li class="mb-2"><i class="bi bi-telephone me-2"></i><strong>โทรศัพท์:</strong> 080-8281906</li>
          <li class="mb-2"><i class="bi bi-building me-2"></i><strong>หน่วยงาน:</strong> สำนักงานสหกรณ์จังหวัดชัยภูมิ</li>
        </ul>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ปิด</button>
      </div>
    </div>
  </div>
</div>
              <button type="button" id="clearChatBtn" class="btn btn-sm btn-outline-danger">ล้างประวัติแชต</button>
        </div>
       
      </div>

      <div id="chatMessages" class="chat-messages" aria-live="polite"></div>

      <form id="chatForm" class="chat-input-wrap" autocomplete="off">
        <div class="input-group">
          <input id="chatInput" type="text" class="form-control" placeholder="พิมพ์คำถามเกี่ยวกับกฎหมาย..." maxlength="500" required />
          <button id="voiceBtn" type="button" class="btn btn-outline-secondary" title="ค้นหาด้วยเสียง" aria-label="ค้นหาด้วยเสียง">
            <i class="bi bi-mic-fill"></i>
          </button>
          <button id="sendBtn" type="submit" class="btn btn-primary px-4">ส่ง</button>
        </div>
        <div id="voiceStatus" class="small text-muted mt-1"></div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (() => {
      const CHAT_CACHE_KEY = 'lawbot-chat-cache-v1';
      const CHAT_CACHE_LIMIT = 20;

      const chatMessages = document.getElementById('chatMessages');
      const chatForm = document.getElementById('chatForm');
      const chatInput = document.getElementById('chatInput');
      const voiceBtn = document.getElementById('voiceBtn');
      const voiceStatus = document.getElementById('voiceStatus');
      const sendBtn = document.getElementById('sendBtn');
      const clearChatBtn = document.getElementById('clearChatBtn');
      const quickButtons = document.querySelectorAll('.quick-btn');
      const targetLawButtons = document.querySelectorAll('.target-law-btn');
      const installBtn = document.getElementById('installBtn');
      const onlineBadge = document.getElementById('onlineBadge');
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      let selectedTarget = 'coop';
      let deferredInstallPrompt = null;
      let recognition = null;
      let isListening = false;
      let isSubmitting = false;
      let shouldSubmitVoiceOnEnd = false;

      function setOnlineState() {
        const online = navigator.onLine;
        onlineBadge.innerHTML = online
          ? '<i class="bi bi-wifi"></i>ออนไลน์'
          : '<i class="bi bi-wifi-off"></i>ออฟไลน์';
        onlineBadge.style.color = online ? 'var(--ok)' : 'var(--warn)';
      }

      function updateTargetButtons() {
        targetLawButtons.forEach((button) => {
          const isActive = button.dataset.target === selectedTarget;
          button.classList.toggle('active', isActive);
          button.classList.toggle('btn-primary', isActive);
          button.classList.toggle('btn-outline-primary', !isActive);
        });
      }

      function autoScroll() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }

      function setVoiceStatus(text = '', isError = false) {
        if (!voiceStatus) return;
        voiceStatus.textContent = text;
        voiceStatus.classList.toggle('text-danger', !!isError);
        voiceStatus.classList.toggle('text-muted', !isError);
      }

      function updateVoiceButton() {
        if (!voiceBtn) return;

        if (!SpeechRecognition) {
          voiceBtn.disabled = true;
          setVoiceStatus('เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง', true);
          return;
        }

        voiceBtn.disabled = false;
        voiceBtn.classList.toggle('voice-btn-listening', isListening);
        voiceBtn.innerHTML = isListening ? '<i class="bi bi-stop-fill"></i>' : '<i class="bi bi-mic-fill"></i>';
        voiceBtn.title = isListening ? 'หยุดฟังเสียง' : 'ค้นหาด้วยเสียง';
        voiceBtn.setAttribute('aria-label', isListening ? 'หยุดฟังเสียง' : 'ค้นหาด้วยเสียง');
      }

      function updateSendButtonState() {
        sendBtn.disabled = isListening || isSubmitting;
      }

      function initVoiceRecognition() {
        if (!SpeechRecognition || recognition) return;

        recognition = new SpeechRecognition();
        recognition.lang = 'th-TH';
        recognition.interimResults = true;
        recognition.continuous = false;
        recognition.maxAlternatives = 1;

        let finalTranscript = '';

        recognition.onstart = () => {
          isListening = true;
          finalTranscript = '';
          shouldSubmitVoiceOnEnd = true;
          setVoiceStatus('กำลังฟัง... พูดคำค้นหาได้เลย');
          updateVoiceButton();
        };

        recognition.onresult = (event) => {
          let interimTranscript = '';
          for (let i = event.resultIndex; i < event.results.length; i += 1) {
            const result = event.results[i];
            const text = result[0] && result[0].transcript ? result[0].transcript : '';
            if (result.isFinal) finalTranscript += `${text} `;
            else interimTranscript += text;
          }
          chatInput.value = `${finalTranscript}${interimTranscript}`.trim();
        };

        recognition.onerror = (event) => {
          isListening = false;
          shouldSubmitVoiceOnEnd = false;
          updateVoiceButton();

          const errorMap = {
            'not-allowed': 'ไม่ได้รับอนุญาตไมโครโฟน กรุณาอนุญาตสิทธิ์การใช้ไมค์',
            'service-not-allowed': 'ไม่สามารถใช้ไมโครโฟนได้ในอุปกรณ์นี้',
            'audio-capture': 'ไม่พบไมโครโฟน',
            'no-speech': 'ไม่ได้ยินเสียงพูด ลองใหม่อีกครั้ง',
            network: 'เครือข่ายมีปัญหาในการรับเสียง'
          };

          setVoiceStatus(errorMap[event.error] || 'เกิดข้อผิดพลาดในการค้นหาด้วยเสียง', true);
        };

        recognition.onend = () => {
          const hasText = String(chatInput.value || '').trim().length > 0;
          const keepTranscript = shouldSubmitVoiceOnEnd && hasText;

          isListening = false;
          shouldSubmitVoiceOnEnd = false;
          updateVoiceButton();

          if (keepTranscript) {
            setVoiceStatus('ถอดเสียงสำเร็จ กรุณากดปุ่มส่ง');
            chatInput.focus();
            return;
          }

          if (!hasText) setVoiceStatus('กดปุ่มไมค์เพื่อเริ่มค้นหาด้วยเสียง');
        };
      }

      function escapeHtml(text) {
        return String(text || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function escapeRegExp(text) {
        return String(text || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      function buildHighlightTerms(query) {
        const source = String(query || '').trim();
        if (!source) return [];
        const terms = new Set([source]);
        source
          .split(/\s+/)
          .map((part) => part.trim())
          .filter((part) => part.length >= 2)
          .forEach((part) => terms.add(part));
        return Array.from(terms).sort((a, b) => b.length - a.length);
      }

      function applyHighlightHtml(text, terms) {
        let html = escapeHtml(text);
        if (!Array.isArray(terms) || !terms.length) return html;
        terms.forEach((term) => {
          if (!term) return;
          const re = new RegExp(`(${escapeRegExp(escapeHtml(term))})`, 'gi');
          html = html.replace(re, '<mark class="hl-hit">$1</mark>');
        });
        return html;
      }

      async function submitFeedback({ question, answerShown, isHelpful, target }) {
        const payload = {
          message: question,
          answerShown,
          isHelpful,
          target
        };

        if (!isHelpful) {
          payload.expectedAnswer = window.prompt('คำตอบที่ต้องการให้ระบบตอบ (ถ้ามี):', '') || '';
          payload.suggestedLawNumber = window.prompt('มาตราที่เกี่ยวข้อง (ถ้าทราบ):', '') || '';
        }

        const response = await fetch('/chat-feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const data = await response.json();
        if (!response.ok || !data || !data.success) {
          throw new Error((data && data.message) || 'ไม่สามารถบันทึกข้อเสนอแนะได้');
        }
      }

      function attachFeedbackActions(container, { question, answerShown, target }) {
        if (!question || !answerShown) return;

        const wrap = document.createElement('div');
        wrap.className = 'feedback-actions';
        wrap.innerHTML = `
          <button type="button" class="btn btn-outline-success btn-sm" data-helpful="1">มีประโยชน์</button>
          <button type="button" class="btn btn-outline-warning btn-sm" data-helpful="0">ควรปรับปรุง</button>
        `;

        wrap.querySelectorAll('button').forEach((button) => {
          button.addEventListener('click', async () => {
            if (wrap.dataset.sent === '1') return;
            const isHelpful = button.dataset.helpful === '1';
            try {
              await submitFeedback({ question, answerShown, isHelpful, target });
              wrap.dataset.sent = '1';
              wrap.innerHTML = '<span class="text-success small">ขอบคุณสำหรับข้อเสนอแนะ</span>';
            } catch (_) {
              wrap.innerHTML = '<span class="text-danger small">บันทึกข้อเสนอแนะไม่สำเร็จ</span>';
            }
          });
        });

        container.appendChild(wrap);
      }

      function addBubble(text, role, isLoading = false, highlightTerms = [], feedbackContext = null) {
        const div = document.createElement('div');
        div.className = `bubble ${role === 'user' ? 'bubble-user' : 'bubble-bot'}${isLoading ? ' bubble-loading' : ''}`;
        if (role === 'bot' && !isLoading) div.innerHTML = applyHighlightHtml(text, highlightTerms);
        else div.textContent = text;

        if (role === 'bot' && !isLoading && feedbackContext && feedbackContext.question) {
          attachFeedbackActions(div, {
            question: feedbackContext.question,
            answerShown: text,
            target: feedbackContext.target || selectedTarget
          });
        }

        chatMessages.appendChild(div);
        autoScroll();
      }

      function saveRecentChats() {
        const items = Array.from(chatMessages.querySelectorAll('.bubble'))
          .map((node) => ({ text: node.textContent || '', role: node.classList.contains('bubble-user') ? 'user' : 'bot' }))
          .slice(-CHAT_CACHE_LIMIT);
        localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify(items));
      }

      function restoreRecentChats() {
        try {
          const raw = localStorage.getItem(CHAT_CACHE_KEY);
          if (!raw) return;
          const parsed = JSON.parse(raw);
          if (!Array.isArray(parsed)) return;
          parsed.forEach((item) => {
            if (item && item.text && (item.role === 'user' || item.role === 'bot')) addBubble(item.text, item.role);
          });
        } catch (_) {}
      }

      async function submitMessage(message) {
        const trimmed = String(message || '').trim();
        if (!trimmed) return;

        if (recognition && isListening) {
          shouldSubmitVoiceOnEnd = false;
          recognition.stop();
        }

        isSubmitting = true;
        updateSendButtonState();
        addBubble(trimmed, 'user');
        addBubble('กำลังพิมพ์...', 'bot', true);

        try {
          const response = await fetch('/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: trimmed, target: selectedTarget })
          });
          const data = await response.json();
          chatMessages.lastElementChild.remove();
          const answerText = data && data.answer ? data.answer : 'ไม่พบข้อมูลที่ชัดเจนในฐานข้อมูล ขอให้ท่านตรวจสอบ...';
          addBubble(answerText, 'bot', false, buildHighlightTerms(trimmed), {
            question: trimmed,
            target: selectedTarget
          });
        } catch (_) {
          chatMessages.lastElementChild.remove();
          addBubble('ไม่พบข้อมูลที่ชัดเจนในฐานข้อมูล ขอให้ท่านตรวจสอบ...', 'bot', false, [], {
            question: trimmed,
            target: selectedTarget
          });
        } finally {
          isSubmitting = false;
          updateSendButtonState();
          chatInput.focus();
          if (SpeechRecognition && !isListening) {
            setVoiceStatus('กดปุ่มไมค์เพื่อเริ่มค้นหาด้วยเสียง');
          }
          saveRecentChats();
        }
      }

      chatForm.addEventListener('submit', (event) => {
        event.preventDefault();
        const currentMessage = chatInput.value;
        chatInput.value = '';
        submitMessage(currentMessage);
      });

      voiceBtn.addEventListener('click', () => {
        if (!SpeechRecognition) {
          setVoiceStatus('เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง', true);
          return;
        }

        if (!recognition) initVoiceRecognition();
        if (!recognition) return;

        if (isListening) {
          recognition.stop();
          return;
        }

        if (isSubmitting) return;

        try {
          setVoiceStatus('กำลังเปิดไมโครโฟน...');
          recognition.start();
        } catch (_) {
          setVoiceStatus('ไม่สามารถเริ่มไมโครโฟนได้ ลองใหม่อีกครั้ง', true);
        }
      });

      quickButtons.forEach((button) => button.addEventListener('click', () => submitMessage(button.dataset.question || '')));

      targetLawButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedTarget = button.dataset.target || 'coop';
          updateTargetButtons();
        });
      });

      clearChatBtn.addEventListener('click', () => {
        chatMessages.innerHTML = '';
        localStorage.removeItem(CHAT_CACHE_KEY);
        addBubble('ใช้คำที่เกี่ยวข้องเท่านั้น', 'bot');
      });

      window.addEventListener('beforeinstallprompt', (event) => {
        event.preventDefault();
        deferredInstallPrompt = event;
        installBtn.style.display = 'inline-block';
      });

      installBtn.addEventListener('click', async () => {
        if (!deferredInstallPrompt) return;
        deferredInstallPrompt.prompt();
        await deferredInstallPrompt.userChoice;
        deferredInstallPrompt = null;
        installBtn.style.display = 'none';
      });

      window.addEventListener('online', setOnlineState);
      window.addEventListener('offline', setOnlineState);

      updateTargetButtons();
      setOnlineState();
      updateVoiceButton();
      updateSendButtonState();
      if (SpeechRecognition) {
        setVoiceStatus('กดปุ่มไมค์เพื่อเริ่มค้นหาด้วยเสียง');
        initVoiceRecognition();
      }
      restoreRecentChats();
      if (!chatMessages.querySelector('.bubble')) addBubble('กรุณาใส่คำที่เกี่ยวข้องเท่านั้น !', 'bot');

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw-law-chatbot.js').catch(() => {});
        });
      }
    })();
  </script>
</body>
</html>
