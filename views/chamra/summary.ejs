<%- include('../partials/header',{title : 'สรุปขั้นตอนการชำระบัญชี'}) %>

<style>
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 25px 0;
    font-size: 18px;
    text-align: left;
    box-shadow: 0 2px 5px rgba(0,0,0,0.15);
  }
  th, td {
    padding: 12px 15px;
    border-bottom: 1px solid #ddd;
  }
  th {
    background-color: #4CAF50;
    color: white;
  }
  tr:nth-child(even) {
    background-color: #f2f2f2;
  }
  tr:hover {
    background-color: #f5f5f5;
  }
  /* Responsive design */
  @media (max-width: 600px) {
    table, thead, tbody, th, td, tr {
      display: block;
    }
    thead {
      display: none;
    }
    tr {
      margin-bottom: 15px;
    }
    td {
      text-align: right;
      padding-left: 50%;
      position: relative;
    }
    td::before {
      content: attr(data-label);
      position: absolute;
      left: 0;
      width: 45%;
      padding-left: 15px;
      font-weight: bold;
      text-align: left;
    }
  }
</style>
<div class="row my-2">
  <div class="col-12 text-center fw-bold">
    <h3>เปรียบเทียบสถานะการชำระบัญชี</h3>
    <p class="text-muted">แสดงเฉพาะสหกรณ์ที่เลิกกิจการและมีการเคลื่อนไหวของขั้นตอนชำระบัญชีหลังวันที่ 1 ต.ค. 2568</p>
  </div>
</div>
<table>
  <thead>
    <tr>
      <th>Date(ต.ค.2568 - ก.ย.2569)</th>    
      <th>Institution Name(group by)</th>
      <th>สถานะ 1 ต.ค. 2568</th>
      <th>ขั้นสูงสุดปัจจุบัน</th>
    </tr>
  </thead>
  <tbody>
    <% if (!data || data.length === 0) { %>
      <tr>
        <td colspan="4" class="text-center text-muted">ไม่พบข้อมูลในช่วงวันที่ที่กำหนด</td>
      </tr>
    <% } %>
    <% data.forEach(item => { %>
      <tr>
        <td data-label="Date">
          <% if (item.date) { %>
            <%= new Date(item.date).toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) %>
          <% } else { %>
            <span class="text-muted">-</span>
          <% } %>
        </td>
        <td data-label="Institution Name"><%= item.institution_name %></td>
        <td data-label="สถานะ 1 ต.ค. 2568">
          
          <% if (item.oct1_step === '0' || !item.oct1_step) { %>
            <br><small class="text-muted">ยังไม่เริ่ม</small>
          <% } else { %>
          <span class="badge bg-danger"><small><%= item.oct1_step_label || (`ขั้นที่ ${item.oct1_step}`) %></small></span>
            <% if (item.oct1_date) { %>
              <br><small class="text-muted">วันที่: <%= new Date(item.oct1_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) %></small>
            <% } %>
          <% } %>
        </td>
        <td data-label="ขั้นสูงสุดปัจจุบัน">
          <% if (item.current_max_step === '0' || !item.current_max_step) { %>
            <span class="badge bg-secondary">ยังไม่เริ่ม</span>
          <% } else { %>
            <span class="badge bg-primary"><%= item.current_max_step_label || (`ขั้นที่ ${item.current_max_step}`) %></span>
            <% if (item.current_max_date) { %>
              <br><small class="text-muted">วันที่: <%= new Date(item.current_max_date).toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) %></small>
            <% } %>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

 <div class="row text-center mt-2">
  <!-- ย้อนกลับหน้าหลัก /chamra -->
     <a href="/chamra" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
       <i class="bi bi-arrow-left me-2"></i> กลับไปยังหน้าหลัก
     </a>
 </div>

<%- include('../partials/footer') %>
