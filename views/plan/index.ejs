<%- include('../partials/header') %>


<div class="py-4">
  <%- include('../partials/plan-navbar', { currentPage: 'planmain' }) %>

  <div class="mobile-page-header">
    <div>
      <h1 class="mobile-page-header__title">
        <i class="bi bi-clipboard-check me-2"></i>แผนงานหลัก
      </h1>
      <p class="mobile-page-header__subtitle">ดูรายการแผนงานหลักแบบย่อและเข้าถึงการจัดการได้ง่ายขึ้นบนมือถือ</p>
    </div>
    <div class="mobile-page-header__meta">
      <span class="mobile-chip">
        <i class="bi bi-collection"></i>ทั้งหมด <%= plans.length %> รายการ
      </span>
    </div>
  </div>

  <div class="card border-0 shadow-sm mobile-list-card table-mobile-cards">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover table-sm mb-0">
        <thead class="table-light">
          <tr>
            <th scope="col">#</th>
            <th scope="col">รหัส</th>
            <th scope="col">หัวข้อ</th>
            <th scope="col">บันทึกโดย</th>
            <th scope="col">วันที่</th>
            <th scope="col">การจัดการ</th>
          </tr>
        </thead>
        <tbody>
          <% plans.forEach(p => { %>
            <tr>
              <td class="mobile-primary" data-label="ลำดับ"><%= p.ma_id %></td>
              <td data-label="รหัส"><%= p.ma_code %></td>
              <td data-label="หัวข้อ"><%= p.ma_subject %></td>
              <td data-label="บันทึกโดย"><%= p.ma_saveby %></td>
              <td data-label="วันที่"><%= thaiDate(p.ma_savedate) %></td>
              <td class="mobile-action" data-label="การจัดการ">
                <div class="mobile-inline-actions">
                <a href="/planmain/<%= p.ma_id %>/edit" class="btn btn-sm btn-outline-primary">
                  <i class="bi bi-pencil-square"></i>
                </a>
                <!-- submit POST with hidden _method so method-override turns it into DELETE -->
                <form action="/planmain/api/<%= p.ma_id %>" method="post" class="d-inline">
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('ลบรายการ?')">ลบ</button>
                </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer bg-light text-muted small text-center py-2">
        <i class="bi bi-info-circle me-1"></i>มีทั้งหมด <%= plans.length %> แผนงานหลัก
      </div>
    </div>
</div>

<%- include('../partials/footer') %>
