<%- include('../partials/header') %>
<%- include('../partials/travel-navbar', { currentPage: 'approval' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">พิจารณาคำขอไปราชการ</h3>
    <p class="text-muted mb-0"><%= item.request_no %></p>
  </div>
  <a href="/vehicle-approval/pending" class="btn btn-outline-secondary">กลับคิวอนุมัติ</a>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">เรื่อง</dt><dd class="col-sm-8"><%= item.subject %></dd>
          <dt class="col-sm-4">ผู้ขอ</dt><dd class="col-sm-8"><%= item.requester_name %> (<%= item.requester_position || '-' %>)</dd>
          <dt class="col-sm-4">กลุ่มงาน</dt><dd class="col-sm-8"><%= item.requester_group || '-' %></dd>
          <dt class="col-sm-4">สถานที่</dt><dd class="col-sm-8"><%= item.destination_text %></dd>
          <dt class="col-sm-4">วันที่ปฏิบัติงาน</dt><dd class="col-sm-8"><%= new Date(item.start_at).toLocaleDateString('th-TH', { dateStyle: 'medium' }) %></dd>
          <dt class="col-sm-4">วัตถุประสงค์</dt><dd class="col-sm-8"><%= item.purpose_text %></dd>
          <dt class="col-sm-4">วิธีเดินทาง</dt><dd class="col-sm-8"><%= item.transport_type %></dd>
          <dt class="col-sm-4">สถานะ</dt><dd class="col-sm-8"><span class="badge bg-info"><%= item.status %></span></dd>
          <dt class="col-sm-4">ความเห็นล่าสุด</dt><dd class="col-sm-8"><%= item.approval_comment || '-' %></dd>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-header bg-white"><h5 class="mb-0">ผลการพิจารณา</h5></div>
      <div class="card-body">
        <% if (item.status === 'submitted') { %>
          <form action="/vehicle-approval/travel/<%= item.id %>/approve" method="POST" class="mb-3">
            <label class="form-label">ความเห็น</label>
            <textarea class="form-control mb-2" name="approval_comment" rows="3"></textarea>

            <% if (item.vehicleRequest) { %>
              <div class="alert alert-info">
                ระบบจะอนุมัติคำขอใช้รถที่เชื่อมอยู่พร้อมกัน หากเลือกรถและคนขับในฟอร์มด้านล่าง
              </div>
              <div class="mb-3">
                <label class="form-label">เลือกรถ</label>
                <select class="form-select" name="vehicle_id">
                  <option value="">ไม่ระบุ</option>
                  <% vehicles.forEach((vehicle) => { %>
                    <option value="<%= vehicle.id %>" <%= Number(assignmentSelection.vehicle_id) === Number(vehicle.id) ? 'selected' : '' %>><%= vehicle.plate_no %> - <%= vehicle.vehicle_name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">เลือกคนขับ</label>
                <select class="form-select" name="driver_id">
                  <option value="">ไม่ระบุ</option>
                  <% drivers.forEach((driver) => { %>
                    <option value="<%= driver.id %>" <%= Number(assignmentSelection.driver_id) === Number(driver.id) ? 'selected' : '' %>><%= driver.driver_name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">หมายเหตุการมอบหมาย</label>
                <textarea class="form-control" name="assignment_note" rows="2"><%= assignmentSelection.assignment_note || '' %></textarea>
              </div>
            <% } %>

            <button type="submit" class="btn btn-success w-100">อนุมัติคำขอไปราชการ</button>
          </form>
          <form action="/vehicle-approval/travel/<%= item.id %>/reject" method="POST">
            <label class="form-label">เหตุผลไม่อนุมัติ</label>
            <textarea class="form-control mb-2" name="approval_comment" rows="3" required></textarea>
            <button type="submit" class="btn btn-outline-danger w-100">ไม่อนุมัติ</button>
          </form>
        <% } else { %>
          <p class="text-muted mb-2">คำขอนี้ถูกพิจารณาแล้ว</p>
          <div class="small text-muted"><%= item.approver_name || '-' %></div>
        <% } %>
      </div>
    </div>

    <% if (item.vehicleRequest) { %>
      <div class="card shadow-sm border-0">
        <div class="card-header bg-white"><h5 class="mb-0">คำขอใช้รถที่เชื่อมไว้</h5></div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-5">เลขที่คำขอใช้รถ</dt>
            <dd class="col-sm-7"><a href="/vehicle-approval/request/<%= item.vehicleRequest.id %>"><%= item.vehicleRequest.vehicle_request_no %></a></dd>
            <dt class="col-sm-5">สถานะ</dt>
            <dd class="col-sm-7"><span class="badge bg-<%= item.vehicleRequest.status === 'approved' ? 'success' : item.vehicleRequest.status === 'submitted' ? 'warning text-dark' : item.vehicleRequest.status === 'draft' ? 'secondary' : 'danger' %>"><%= item.vehicleRequest.status %></span></dd>
            <dt class="col-sm-5">เริ่มเดินทาง</dt>
            <dd class="col-sm-7"><%= new Date(item.vehicleRequest.trip_start_at).toLocaleDateString('th-TH', { dateStyle: 'medium' }) %></dd>
            <dt class="col-sm-5">สถานะการมอบหมาย</dt>
            <dd class="col-sm-7"><%= item.vehicleRequest.plate_no_snapshot ? 'มอบหมายแล้ว' : 'ยังไม่มอบหมาย' %></dd>
          </dl>
          <div class="d-grid gap-2 mt-3">
            <a href="/vehicle-approval/request/<%= item.vehicleRequest.id %>" class="btn btn-outline-primary">เปิดคำขอใช้รถ</a>
            <a href="/vehicle-request/<%= item.vehicleRequest.id %>" class="btn btn-outline-secondary">ดูคำขอใช้รถ</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleCommentBtn = document.getElementById('show-approval-comment');
    const commentSection = document.getElementById('approval-comment-section');
    if (toggleCommentBtn && commentSection) {
      toggleCommentBtn.addEventListener('click', () => {
        commentSection.classList.toggle('d-none');
        if (!commentSection.classList.contains('d-none')) {
          const textarea = commentSection.querySelector('textarea[name="approval_comment"]');
          if (textarea) textarea.focus();
        }
      });
    }
  });
</script>
<%- include('../partials/footer') %>
