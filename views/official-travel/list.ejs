<%- include('../partials/header') %>
<%- include('../partials/travel-navbar', { currentPage: 'travel' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">คำขอไปราชการ</h3>
    <p class="text-muted mb-0">จัดการคำขอไปราชการและเชื่อมข้อมูลไปยังปฏิทินกิจกรรม</p>
  </div>
  <div class="d-flex gap-2">
    <% if (user && (user.mClass === 'admin' || user.mClass === 'kjs')) { %>
      <a href="/official-travel/settings/running-number" class="btn btn-outline-secondary">
        <i class="bi bi-123 me-1"></i> ตั้งค่าเลขที่
      </a>
      <a href="/official-travel/report" class="btn btn-outline-primary">
        <i class="bi bi-bar-chart-line me-1"></i> รายงาน
      </a>
    <% } %>
    <a href="/official-travel/create" class="btn btn-success">
      <i class="bi bi-plus-circle me-1"></i> สร้างคำขอ
    </a>
  </div>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<% if (typeof notice !== 'undefined' && notice) { %>
  <div class="alert alert-success"><%= notice %></div>
<% } %>

<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th>เลขที่</th>
          <th>วันที่</th>
          <th>เรื่อง</th>
          <th>ผู้ขอ</th>
          <th>วันที่ปฏิบัติงาน</th>
          <th>คำขอใช้รถ</th>
          <th>สถานะ</th>
          <th class="text-end">จัดการ</th>
        </tr>
      </thead>
      <tbody>
        <% if (!items.length) { %>
          <tr>
            <td colspan="8" class="text-center py-4 text-muted">ยังไม่มีคำขอไปราชการ</td>
          </tr>
        <% } %>
        <% items.forEach((item) => { %>
          <tr>
            <td><%= item.request_no %></td>
            <td><%= new Date(item.request_date).toLocaleDateString('th-TH') %></td>
            <td>
              <div class="fw-semibold"><%= item.subject %></div>
              <small class="text-muted"><%= item.destination_text %></small>
            </td>
            <td>
              <div><%= item.requester_name %></div>
              <small class="text-muted"><%= item.requester_group || '-' %></small>
            </td>
            <td>
              <div><%= new Date(item.start_at).toLocaleDateString('th-TH', { dateStyle: 'short' }) %></div>
            </td>
            <td>
              <% if (Number(item.requires_vehicle_request) !== 1) { %>
                <span class="text-muted">ไม่ต้องใช้รถ</span>
              <% } else if (item.vehicle_request_id) { %>
                <a href="/vehicle-request/<%= item.vehicle_request_id %>" class="text-decoration-none">
                  <div class="fw-semibold"><%= item.vehicle_request_no %></div>
                  <small class="text-muted"><%= item.vehicle_request_status || '-' %></small>
                </a>
              <% } else { %>
                <div class="text-danger small mb-1">ยังไม่สร้างคำขอใช้รถ</div>
                <a href="/vehicle-request/create?travelId=<%= item.id %>" class="btn btn-sm btn-outline-primary">สร้างคำขอใช้รถ</a>
              <% } %>
            </td>
            <td>
              <% const badge = item.status === 'approved' ? 'success' : item.status === 'submitted' ? 'warning text-dark' : item.status === 'rejected' ? 'danger' : item.status === 'cancelled' ? 'secondary' : 'info'; %>
              <span class="badge bg-<%= badge %>"><%= item.status %></span>
            </td>
            <td class="text-end text-nowrap">
              <a href="/official-travel/<%= item.id %>" class="btn btn-sm btn-outline-primary">ดู</a>
              <% if (item.status !== 'cancelled') { %>
                <a href="/official-travel/<%= item.id %>/edit" class="btn btn-sm btn-outline-warning">แก้ไข</a>
              <% } %>
              <% if (user && (user.mClass === 'admin' || user.mClass === 'kjs')) { %>
                <form
                  action="/official-travel/<%= item.id %>/delete"
                  method="POST"
                  class="d-inline"
                  onsubmit="return confirm('ยืนยันลบข้อมูลทดสอบนี้ถาวร? ระบบจะลบคำขอไปราชการและคำขอใช้รถที่เชื่อมไว้ทั้งหมด');">
                  <button type="submit" class="btn btn-sm btn-outline-danger">ลบ</button>
                </form>
              <% } %>
              <a href="/official-travel/<%= item.id %>/print" class="btn btn-sm btn-outline-secondary" target="_blank">พิมพ์</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
