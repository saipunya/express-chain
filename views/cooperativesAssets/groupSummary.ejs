<%- include('../partials/header') %>

<div class="py-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">
        <i class="bi bi-people-fill me-2"></i><%= title %>
      </h1>
      <p class="text-muted small mb-0">ภาพรวมอุปกรณ์การตลาดเฉพาะกลุ่ม <%= groupDisplayName %></p>
    </div>
    <div class="d-flex gap-2">
      <a href="/cooperatives-assets/summary" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>กลับหน้าสรุปทั้งหมด
      </a>
      <a href="/#assets_all" class="btn btn-primary">
        <i class="bi bi-house-door me-1"></i>หน้าแรก
      </a>
    </div>
  </div>

  <!-- Overall Statistics for this Group -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">อุปกรณ์การตลาดทั้งหมด</div>
          <div class="display-6 fw-bold text-primary"><%= summary.total_count %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">มูลค่ารวม</div>
          <div class="display-6 fw-bold text-success"><%= Number(summary.total_value || 0).toLocaleString('th-TH') %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">ใช้งานได้</div>
          <div class="display-6 fw-bold text-success"><%= summary.working_count %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">ใช้งานไม่ได้</div>
          <div class="display-6 fw-bold text-danger"><%= summary.not_working_count %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Additional Group Information -->
  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small">จำนวนสหกรณ์ในกลุ่ม</div>
          <div class="h2 fw-bold mb-0"><%= cooperatives.length %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small">สัดส่วนใช้งานได้</div>
          <div class="h2 fw-bold mb-0 text-success">
            <%= summary.total_count ? Math.round((summary.working_count / summary.total_count) * 100) : 0 %>%
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small">มูลค่าเฉลี่ยต่อเครื่อง</div>
          <div class="h2 fw-bold mb-0 text-primary">
            <%= summary.total_count ? Math.round(summary.total_value / summary.total_count).toLocaleString('th-TH') : 0 %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Machine Types and Crops Summary -->
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white">
          <h6 class="mb-0 text-primary">
            <i class="bi bi-gear me-1"></i>ประเภทอุปกรณ์ (<%= machineTypes.length %>)
          </h6>
        </div>
        <div class="card-body">
          <div class="d-flex flex-wrap gap-1">
            <% machineTypes.forEach(type => { %>
              <span class="badge bg-light text-dark border"><%= type %></span>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white">
          <h6 class="mb-0 text-success">
            <i class="bi bi-flower1 me-1"></i>พืชผล (<%= crops.length %>)
          </h6>
        </div>
        <div class="card-body">
          <div class="d-flex flex-wrap gap-1">
            <% crops.forEach(crop => { %>
              <span class="badge bg-light text-dark border"><%= crop %></span>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Cooperatives in this Group -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white">
      <h5 class="mb-0 text-primary">
        <i class="bi bi-building me-2"></i>รายชื่อสหกรณ์ใน<%= groupDisplayName %>
      </h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>รหัสสหกรณ์</th>
              <th>ชื่อสหกรณ์</th>
              <th class="text-center">จำนวนอุปกรณ์</th>
              <th class="text-end">มูลค่ารวม</th>
              <th class="text-center">ใช้งานได้</th>
              <th class="text-center">ใช้งานไม่ได้</th>
              <th class="text-center">รายละเอียด</th>
            </tr>
          </thead>
          <tbody>
            <% cooperatives.forEach(coop => { %>
              <tr>
                <td class="fw-semibold"><%= coop.coop_code %></td>
                <td><%= coop.coop_name %></td>
                <td class="text-center">
                  <span class="badge bg-primary"><%= coop.total_count %></span>
                </td>
                <td class="text-end text-success fw-semibold">
                  <%= Number(coop.total_value || 0).toLocaleString('th-TH') %>
                </td>
                <td class="text-center">
                  <%- coop.working_count > 0 ? `<span class="badge bg-success">${coop.working_count}</span>` : '<span class="text-muted">-</span>' %>
                </td>
                <td class="text-center">
                  <%- coop.not_working_count > 0 ? `<span class="badge bg-danger">${coop.not_working_count}</span>` : '<span class="text-muted">-</span>' %>
                </td>
                <td class="text-center">
                  <a href="/cooperatives-assets/detail/<%= encodeURIComponent(coop.coop_code) %>" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye me-1"></i>ดูรายละเอียด
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- All Assets in this Group (Detailed View) -->
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
      <h5 class="mb-0 text-primary">
        <i class="bi bi-list-ul me-2"></i>รายการอุปกรณ์ทั้งหมดใน<%= groupDisplayName %>
      </h5>
      <span class="badge bg-primary"><%= assets.length %> รายการ</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>รหัสสหกรณ์</th>
              <th>ชื่อสหกรณ์</th>
              <th>ประเภทอุปกรณ์</th>
              <th>รายละเอียด</th>
              <th class="text-center">จำนวน</th>
              <th class="text-end">มูลค่า</th>
              <th class="text-center">สถานะ</th>
              <th class="text-center">พืชผล</th>
            </tr>
          </thead>
          <tbody>
            <% assets.forEach(asset => { %>
              <tr>
                <td class="fw-semibold small"><%= asset.coop_code %></td>
                <td class="small"><%= asset.coop_name || asset.active_coop_name || '-' %></td>
                <td class="small"><%= asset.machine_type || '-' %></td>
                <td class="small"><%= asset.description || '-' %></td>
                <td class="text-center small">
                  <%= asset.quantity || '1' %> <%= asset.quantity_unit || '-' %>
                </td>
                <td class="text-end text-success fw-semibold small">
                  <%= Number(asset.price_total || 0).toLocaleString('th-TH') %>
                </td>
                <td class="text-center">
                  <% if (asset.status === 'ใช้งานได้') { %>
                    <span class="badge bg-success small">ใช้งานได้</span>
                  <% } else if (asset.status === 'ใช้งานไม่ได้') { %>
                    <span class="badge bg-danger small">ใช้งานไม่ได้</span>
                  <% } else { %>
                    <span class="badge bg-secondary small"><%= asset.status || '-' %></span>
                  <% } %>
                </td>
                <td class="text-center small">
                  <span class="badge bg-light text-dark border"><%= asset.crop || '-' %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
