<%- include('partials/header.ejs') %>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" />
<script defer src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales-all.min.js"></script>
<%
  const _stats = (typeof stats !== 'undefined' && stats) ? stats : {};
  const _coopTypeSummary = (typeof coopTypeSummary !== 'undefined' && coopTypeSummary) ? coopTypeSummary : {};
  const _coopGroupStats = (typeof coopGroupStats !== 'undefined' && Array.isArray(coopGroupStats)) ? coopGroupStats : [];
  const _meetingsToday = (typeof meetingsToday !== 'undefined' && Array.isArray(meetingsToday)) ? meetingsToday : [];
  const _meetingroomTodayDate = (typeof meetingroomTodayDate !== 'undefined' && meetingroomTodayDate) ? meetingroomTodayDate : '';
  const _lastProjects = (typeof lastProjects !== 'undefined' && Array.isArray(lastProjects)) ? lastProjects : [];
  const _lastCommands = (typeof lastCommands !== 'undefined' && Array.isArray(lastCommands)) ? lastCommands : [];
  const _activity = (typeof activity !== 'undefined' && Array.isArray(activity)) ? activity : [];
  const _calendarEvents = (typeof calendarEvents !== 'undefined' && Array.isArray(calendarEvents)) ? calendarEvents : [];
  const _calendarItems = _calendarEvents.length ? _calendarEvents : _activity.map((item, index) => ({
    id: `activity-${index + 1}`,
    title: item.activity || '-',
    start: item.date_act,
    end: item.end_act || undefined,
    allDay: true,
    extendedProps: {
      sourceType: 'gitgum',
      sourceLabel: 'กิจกรรมสำนักงาน',
      dateLabel: item.date_label || null,
      timeLabel: item.act_time || null,
      place: item.place || null,
      respon: item.co_person || null,
      goto: item.co_person || null,
      detailUrl: item.detailUrl || null
    }
  }));
  const _turnoverFiscalSummary = (typeof turnoverFiscalSummary !== 'undefined' && Array.isArray(turnoverFiscalSummary)) ? turnoverFiscalSummary : [];
  const _memberSummary = (typeof memberSummary !== 'undefined' && memberSummary) ? memberSummary : {};
  const _latestYear = (typeof latestYear !== 'undefined' && latestYear) ? latestYear : '-';
  const _memberTotals = {
    coopSaman: Number((_memberSummary.coop_agri_saman || 0) + (_memberSummary.coop_non_agri_saman || 0)),
    coopSomtob: Number((_memberSummary.coop_agri_somtob || 0) + (_memberSummary.coop_non_agri_somtob || 0)),
    farmerSaman: Number(_memberSummary.farmer_group_saman || 0),
    farmerSomtob: Number(_memberSummary.farmer_group_somtob || 0)
  };
  const _turnoverRows = _turnoverFiscalSummary
    .map((row) => ({
      budYear: Number(row.tur_budyear || 0),
      months: Number(row.months_with_data || 0),
      total: Number(row.total_amount || 0),
      latestMonth: row.latest_month || '',
      latestYear: row.latest_year || ''
    }))
    .filter((row) => row.budYear)
    .sort((a, b) => b.budYear - a.budYear);
  const _currentTurnover = _turnoverRows[0] || null;
  const _previousTurnover = _currentTurnover ? _turnoverRows.find((row) => row.budYear === _currentTurnover.budYear - 1) : null;
  const _turnoverTarget = _previousTurnover ? _previousTurnover.total * 1.03 : 0;
  const _turnoverPercent = _currentTurnover && _turnoverTarget > 0 ? (_currentTurnover.total / _turnoverTarget) * 100 : 0;
  const _formatMoney = (value) => Number(value || 0).toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
%>

  <!-- Modern Dashboard -->
  <div class="container-fluid py-4 dashboard-wrapper">
    <div class="container">
      <!-- Welcome / Profile Section -->
      <div class="row g-4 align-items-stretch mb-4">
        <div class="col-lg-8">
          <div class="card border-0 shadow-lg glass-card h-100">
            <div class="card-body p-4 p-lg-5 d-flex flex-column justify-content-center">
              <h1 class="display-6 fw-bold text-gradient mb-3">
                <i class="bi bi-speedometer2 me-2"></i> แดชบอร์ด
              </h1>
              <p class="text-muted mb-4">ศูนย์รวมเมนูการทำงานและข้อมูลล่าสุด เพื่อการเข้าถึงฟีเจอร์อย่างรวดเร็ว</p>

              <!-- Quick Action Buttons (Role Based) -->
              <div class="d-flex flex-wrap gap-2">
                <% if (user && user.mClass === 'kjs') { %>
                  <a href="/chamra/" class="btn btn-outline-danger btn-action"><i class="bi bi-info-circle me-1"></i> ชำระบัญชี</a>
                <% } %>
                <% if (user && user.mClass === 'admin') { %>
                  <a href="/member" class="btn btn-warning text-dark btn-action"><i class="bi bi-people me-1"></i> จัดการสมาชิก</a>
                  <!-- add strength menu -->
                  <a href="/strength" class="btn btn-outline-primary btn-action"><i class="bi bi-shield-lock me-1"></i> จัดการความเข้มแข็ง</a>
                  <!-- จัดการ suggestion menu -->
                  <a href="/suggestion" class="btn btn-outline-info btn-action"><i class="bi bi-lightbulb me-1"></i> คำแนะนำนายทะเบียนสหกรณ์</a>
                  <!-- ผลประชุมใหญ่ -->
                  <a href="/bigmeet" class="btn btn-outline-success btn-action"><i class="bi bi-calendar-check me-1"></i> ผลประชุมใหญ่</a>
                  <!-- จำนวนสมาชิก -->
                  <a href="/addmem/list" class="btn btn-outline-secondary btn-action"><i class="bi bi-person-plus me-1"></i> จำนวนสมาชิก</a>
                <% } %>
                <a href="/gitgum/add" class="btn btn-outline-secondary btn-action"><i class="bi bi-plus-circle me-1"></i> เพิ่มกิจกรรมสำนักงาน</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Profile Card -->
        <div class="col-lg-4">
          <div class="card border-0 shadow-lg profile-card h-100 position-relative overflow-hidden">
            <div class="card-body text-center p-4 d-flex flex-column justify-content-center">
              <div class="position-relative d-inline-block mb-3">
                <img src="<%= user.m_img %>" alt="Profile" class="rounded-circle shadow profile-avatar avatar-lg">
                <span class="status-badge bg-success" title="online"></span>
              </div>
              <h4 class="fw-bold mb-1 text-dark"><i class="bi bi-person-badge me-1 text-primary"></i><%= user.fullname %></h4>
              <p class="text-muted mb-3"><i class="bi bi-award me-1"></i> <%= user.position %></p>
              <!-- for admin link only -->
              <% if (user && user.mClass === 'admin') { %>
                <a href="/auditlog" class="btn btn-primary btn-action mb-2"><i class="bi bi-speedometer2 me-1"></i> auditlog</a>
              <% } %>
              <a href="/auth/logout" class="btn btn-outline-danger w-100"><i class="bi bi-box-arrow-right me-1"></i> ออกจากระบบ</a>
            </div>
          </div>
        </div>
      </div>

       <section class="dashboard-operations-section mb-4" aria-labelledby="operationsDashboardTitle">
        <div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
          <div>
            <div class="menu-section-title mb-1">Operations</div>
            <h2 id="operationsDashboardTitle" class="h4 fw-bold mb-0">ปฏิทินงาน</h2>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <a href="/gitgum/calendar" class="btn btn-outline-success btn-sm">
              <i class="bi bi-calendar3 me-1"></i>ปฏิทินเต็ม
            </a>
          </div>
        </div>

        <div class="row g-3 align-items-stretch">
          <div class="col-12">
            <div class="card border-0 shadow-sm h-100 dashboard-home-card">
              <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between">
                <div>
                  <h3 class="h5 fw-bold mb-1"><i class="bi bi-calendar3 me-1 text-success"></i>ปฏิทินงาน</h3>
                  <div class="small text-muted">คลิกกิจกรรมในปฏิทินเพื่อดูรายละเอียด</div>
                </div>
                <span class="badge text-bg-success"><%= _calendarItems.length.toLocaleString('th-TH') %> รายการ</span>
              </div>
              <div class="card-body">
                <div id="dashboardActivitiesCalendar" class="dashboard-calendar" aria-label="ปฏิทินงาน"></div>
                <div id="dashboardActivitiesCalendarFallback" class="dashboard-home-list mt-2">
                  <% if (_calendarItems.length) { %>
                    <% _calendarItems.slice(0, 6).forEach(function(item, activityIndex) { %>
                      <%
                        const itemProps = item.extendedProps || {};
                        const actDate = item.start ? new Date(item.start) : null;
                        const actDateText = itemProps.dateLabel
                          ? itemProps.dateLabel
                          : actDate && !Number.isNaN(actDate.getTime())
                          ? actDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })
                          : String(item.start || '-').slice(0, 10);
                      %>
                      <button type="button" class="dashboard-home-list-item dashboard-activity-fallback-item text-start w-100" data-activity-index="<%= activityIndex %>">
                        <div class="fw-semibold"><%= item.title || '-' %></div>
                        <div class="small text-muted">
                          <i class="bi bi-calendar-event me-1"></i><%= actDateText %>
                          <% if (itemProps.timeLabel) { %><span class="ms-2"><i class="bi bi-clock me-1"></i><%= itemProps.timeLabel %></span><% } %>
                          <% if (itemProps.place) { %><span class="ms-2"><i class="bi bi-geo-alt me-1"></i><%= itemProps.place %></span><% } %>
                        </div>
                      </button>
                    <% }); %>
                  <% } else { %>
                    <div class="dashboard-home-empty">ยังไม่มีข้อมูลปฏิทินงาน</div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

         
        </div>
      </section>

