<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'หน้าแรกระบบ CoopChain' %></title>
    <% if (typeof themeColor !== 'undefined' && themeColor) { %>
      <meta name="theme-color" content="<%= themeColor %>" />
    <% } %>
    <% if (typeof manifestPath !== 'undefined' && manifestPath) { %>
      <link rel="manifest" href="<%= manifestPath %>" />
      <link rel="icon" href="/icon/seal.svg" />
      <link rel="apple-touch-icon" href="/icon/seal.svg" />
      <meta name="mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-capable" content="yes" />
      <meta name="apple-mobile-web-app-title" content="CoopChain" />
      <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <% } %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@200;400;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="main-dashboard-body d-flex flex-column min-vh-100 flex-grow-1">
    <main class="container-fluid main-dashboard-wrap py-3 py-lg-4 flex-grow-1">

<style>
  :root {
    --main-ink: #172033;
    --main-muted: #667085;
    --main-line: #e4e9f2;
    --main-soft: #f6f8fc;
    --main-panel: #ffffff;
    --main-navy: #142033;
    --main-green: #107f50;
    --main-teal: #147b83;
    --main-blue: #2f6fdd;
    --main-amber: #f0a020;
    --main-red: #d94b4b;
    --main-shadow: 0 14px 32px rgba(20, 32, 51, .08);
    --main-shadow-soft: 0 8px 18px rgba(20, 32, 51, .055);
  }

  .main-dashboard-body {
    background:
      linear-gradient(180deg, #f6f8fc 0, #edf2f8 34rem, #eef2f7 100%);
    color: var(--main-ink);
    font-family: 'Sarabun', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .main-dashboard-wrap {
    max-width: 1520px;
  }

  .main-dashboard-shell {
    display: grid;
    grid-template-columns: 16.5rem minmax(0, 1fr);
    gap: 1.15rem;
    min-height: calc(100vh - 2rem);
  }

  .main-sidebar {
    background: linear-gradient(180deg, #17263b 0%, #111d2e 58%, #0f1a29 100%);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, .08);
    box-shadow: 0 18px 36px rgba(20, 32, 51, .16);
    color: #dce6ef;
    padding: 1.05rem;
    position: sticky;
    top: 1rem;
    height: calc(100vh - 2rem);
    min-height: 42rem;
  }

  .main-brand {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .5rem .35rem 1.15rem;
    border-bottom: 1px solid rgba(255, 255, 255, .12);
  }

  .main-brand img {
    width: 2.85rem;
    height: 2.85rem;
    object-fit: contain;
    border-radius: 8px;
    background: #fff;
    padding: .35rem;
    box-shadow: 0 .75rem 1.4rem rgba(0, 0, 0, .16);
  }

  .main-brand-title {
    margin: 0;
    color: #fff;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .main-brand-subtitle {
    color: #a9b7c8;
    font-size: .78rem;
  }

  .main-nav {
    display: grid;
    gap: .35rem;
    margin: 1.25rem 0;
  }

  .main-nav-link {
    display: flex;
    align-items: center;
    gap: .75rem;
    border-radius: 8px;
    color: #bdcad8;
    padding: .75rem .8rem;
    text-decoration: none;
    transition: background-color .15s ease, color .15s ease, transform .15s ease;
  }

  .main-nav-link:hover,
  .main-nav-link.active {
    background: rgba(255, 255, 255, .11);
    color: #fff;
    transform: translateX(2px);
  }

  .main-nav-link i {
    width: 1.5rem;
    text-align: center;
    color: #7ed4ad;
  }

  .main-sidebar-foot {
    margin-top: auto;
    padding: .95rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, .09);
    border: 1px solid rgba(255, 255, 255, .08);
  }

  .main-content {
    min-width: 0;
  }

  .main-topbar,
  .main-panel,
  .main-stat,
  .main-login-card,
  .main-hero,
  .main-deadline-card {
    background: var(--main-panel);
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
  }

  .main-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: .95rem 1.05rem;
    margin-bottom: 1.15rem;
    backdrop-filter: blur(12px);
  }

  .main-avatar {
    width: 2.55rem;
    height: 2.55rem;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #e7f8ef, #eef7ff);
    color: var(--main-green);
    font-weight: 700;
  }

  .main-hero {
    position: relative;
    min-height: 31.2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1.35rem, 3vw, 2.1rem);
    color: #fff;
    overflow: hidden;
    box-shadow: var(--main-shadow);
    background:
      linear-gradient(90deg, rgba(12, 24, 39, .9) 0%, rgba(14, 53, 62, .7) 45%, rgba(15, 105, 78, .24) 100%),
      url('/images/coopchain-network-hero.png') center / cover no-repeat;
  }

  .main-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, .08), rgba(5, 18, 32, .2));
    pointer-events: none;
  }

  .main-hero > * {
    position: relative;
    z-index: 1;
  }

  .main-hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    width: max-content;
    border-radius: 8px;
    background: rgba(255, 255, 255, .2);
    border: 1px solid rgba(255, 255, 255, .22);
    padding: .45rem .7rem;
    color: #fff;
    font-size: .84rem;
    font-weight: 700;
  }

  .main-hero h2 {
    max-width: 43rem;
    margin: 1rem 0 .75rem;
    color: #fff;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.18;
  }

  .main-hero p {
    max-width: 38rem;
    color: rgba(255, 255, 255, .86);
  }

  .main-hero-summary {
    display: grid;
    gap: .55rem;
    max-width: 36rem;
    padding: .85rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, .12);
    border: 1px solid rgba(255, 255, 255, .16);
  }

  .main-hero-summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .85rem;
    color: rgba(255, 255, 255, .9);
    font-size: .9rem;
  }

  .main-hero-summary-row strong {
    color: #fff;
    white-space: nowrap;
  }

  .main-login-card {
    height: 100%;
    box-shadow: var(--main-shadow);
  }

  .main-login-card .form-control {
    border-radius: 8px;
    border-color: var(--main-line);
    background: #fbfcfe;
    min-height: 3rem;
  }

  .main-login-card .form-control:focus {
    border-color: rgba(22, 155, 98, .55);
    box-shadow: 0 0 0 .22rem rgba(22, 155, 98, .13);
  }

  .main-login-card .btn {
    border-radius: 8px;
    min-height: 3.05rem;
    border: 0;
    background: linear-gradient(135deg, #147b83, #107f50);
    box-shadow: 0 .7rem 1.2rem rgba(22, 155, 98, .22);
  }

  .main-login-card .btn:hover {
    filter: brightness(.97);
    transform: translateY(-1px);
  }

  .main-stat {
    position: relative;
    overflow: hidden;
    padding: 1rem;
    height: 100%;
    transition: transform .15s ease, box-shadow .15s ease;
  }

  .main-stat:hover {
    box-shadow: var(--main-shadow);
    transform: translateY(-1px);
  }

  .main-stat-icon {
    width: 2.65rem;
    height: 2.65rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 1.15rem;
  }

  .main-stat-icon.green { background: #e9f7ef; color: var(--main-green); }
  .main-stat-icon.amber { background: #fff4dc; color: #b86f00; }
  .main-stat-icon.teal { background: #e5f6f8; color: var(--main-teal); }
  .main-stat-icon.blue { background: #eef5ff; color: var(--main-blue); }
  .main-stat-icon.red { background: #fdecec; color: var(--main-red); }

  .main-turnover-card {
    background: var(--main-panel);
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
    height: 100%;
    overflow: hidden;
    padding: 1rem;
    position: relative;
  }

  .main-turnover-card::before {
    content: "";
    inset: 0 0 auto;
    height: .22rem;
    position: absolute;
    background: var(--turnover-accent, var(--main-green));
  }

  .main-turnover-card.green { --turnover-accent: var(--main-green); }
  .main-turnover-card.teal { --turnover-accent: var(--main-teal); }
  .main-turnover-card.amber { --turnover-accent: var(--main-amber); }

  .main-turnover-label {
    color: var(--main-muted);
    font-size: .85rem;
    font-weight: 700;
  }

  .main-turnover-value {
    color: var(--main-ink);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    line-height: 1.15;
    margin-top: .45rem;
    overflow-wrap: anywhere;
  }

  .main-turnover-meta {
    border-top: 1px solid var(--main-line);
    color: var(--main-muted);
    display: flex;
    flex-wrap: wrap;
    font-size: .82rem;
    gap: .45rem .85rem;
    margin-top: .9rem;
    padding-top: .75rem;
  }

  .main-bigmeet-card {
    background: var(--main-panel);
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
    height: 100%;
    padding: 1rem;
  }

  .main-bigmeet-counts {
    display: grid;
    gap: .6rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: .9rem;
  }

  .main-bigmeet-count {
    background: #f8fafc;
    border: 1px solid #edf1f6;
    border-radius: 8px;
    padding: .65rem;
  }

  .main-bigmeet-count-label {
    color: var(--main-muted);
    font-size: .74rem;
    line-height: 1.2;
  }

  .main-bigmeet-count-value {
    color: var(--main-ink);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.1;
    margin-top: .25rem;
  }

  .main-bigmeet-progress {
    background: #edf1f6;
    border-radius: 999px;
    height: .48rem;
    margin-top: .9rem;
    overflow: hidden;
  }

  .main-bigmeet-progress-bar {
    background: linear-gradient(90deg, var(--main-green), var(--main-teal));
    border-radius: inherit;
    height: 100%;
    width: var(--meeting-progress, 0%);
  }

  .main-strength-card {
    background: var(--main-panel);
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
    height: 100%;
    padding: 1rem;
  }

  .main-strength-grade-list {
    display: grid;
    gap: .55rem;
    margin-top: .85rem;
  }

  .main-strength-grade-row {
    align-items: center;
    display: grid;
    gap: .65rem;
    grid-template-columns: 4.2rem minmax(0, 1fr) 3.3rem;
  }

  .main-strength-grade-label {
    color: var(--main-muted);
    font-size: .8rem;
    font-weight: 700;
  }

  .main-strength-bar {
    background: #edf1f6;
    border-radius: 999px;
    height: .48rem;
    overflow: hidden;
  }

  .main-strength-bar-fill {
    border-radius: inherit;
    height: 100%;
    width: var(--strength-width, 0%);
  }

  .main-strength-bar-fill.grade-1 { background: var(--main-green); }
  .main-strength-bar-fill.grade-2 { background: var(--main-amber); }
  .main-strength-bar-fill.grade-3 { background: var(--main-red); }

  .main-strength-grade-value {
    color: var(--main-ink);
    font-size: .9rem;
    font-weight: 700;
    text-align: right;
  }

  .main-closing-card {
    background: var(--main-panel);
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
    height: 100%;
    padding: 1rem;
  }

  .main-closing-list {
    display: grid;
    gap: .45rem;
    margin-top: .85rem;
  }

  .main-closing-item {
    align-items: center;
    background: #f8fafc;
    border: 1px solid #edf1f6;
    border-radius: 8px;
    display: flex;
    gap: .65rem;
    justify-content: space-between;
    padding: .55rem .65rem;
  }

  .main-closing-name {
    color: var(--main-ink);
    font-size: .82rem;
    font-weight: 700;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .main-closing-date {
    color: var(--main-muted);
    flex: 0 0 auto;
    font-size: .76rem;
  }

  .main-overdue-card {
    background: #fff;
    border: 1px solid #f1d3d3;
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
    height: 100%;
    padding: 1rem;
  }

  .main-overdue-card .main-closing-item {
    background: #fff8f8;
    border-color: #f6dddd;
  }

  .main-institution-section {
    margin-top: 1.15rem;
  }

  .main-section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: .85rem;
  }

  .main-section-title h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .main-institution-card {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: 100%;
    padding: 1.05rem;
    text-align: left;
    background: #fff;
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }

  .main-institution-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: .22rem;
    background: var(--card-accent, var(--main-green));
  }

  .main-institution-card:hover {
    border-color: #a5dfe4;
    box-shadow: var(--main-shadow);
    transform: translateY(-1px);
  }

  .main-institution-card:focus-visible {
    outline: 3px solid rgba(34, 160, 107, .3);
    outline-offset: 2px;
  }

  .main-institution-label {
    color: var(--main-muted);
    font-size: .9rem;
    font-weight: 700;
  }

  .main-institution-count {
    color: var(--main-ink);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .main-institution-hint {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    color: var(--card-accent, var(--main-green));
    font-size: .82rem;
    font-weight: 700;
  }

  .main-institution-card[data-institution-type="agri"] { --card-accent: var(--main-green); }
  .main-institution-card[data-institution-type="non_agri"] { --card-accent: var(--main-teal); }
  .main-institution-card[data-institution-type="farmer"] { --card-accent: var(--main-amber); }

  .main-institution-chart-card {
    height: 100%;
    min-height: 19rem;
    padding: 1.05rem;
    background: #fff;
    border: 1px solid var(--main-line);
    border-radius: 8px;
    box-shadow: var(--main-shadow-soft);
  }

  .main-chart-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: .9rem;
  }

  .main-chart-title {
    display: flex;
    align-items: center;
    gap: .55rem;
    margin: 0;
    color: var(--main-ink);
    font-size: 1rem;
    font-weight: 700;
  }

  .main-chart-title i {
    color: var(--main-green);
  }

  .main-chart-canvas-wrap {
    position: relative;
    min-height: 13.5rem;
  }

  .main-chart-canvas-wrap canvas {
    width: 100% !important;
  }

  .main-chart-fallback {
    display: grid;
    gap: .55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .main-chart-fallback[hidden] {
    display: none;
  }

  .main-chart-fallback li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    padding: .62rem .75rem;
    border: 1px solid #edf1f6;
    border-radius: 8px;
    background: #f8fafc;
    color: var(--main-ink);
    font-size: .9rem;
    font-weight: 700;
  }

  .main-chart-fallback span {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
  }

  .main-chart-dot {
    width: .65rem;
    height: .65rem;
    border-radius: 999px;
    background: var(--dot-color, var(--main-green));
    flex: 0 0 auto;
  }

  .main-pill {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    border: 1px solid var(--main-line);
    border-radius: 8px;
    background: #fff;
    color: var(--main-muted);
    padding: .35rem .55rem;
    font-size: .82rem;
    font-weight: 700;
  }

  .main-institution-modal-table {
    font-size: .92rem;
  }

  .main-institution-modal-table th {
    background: #f8fafc;
    color: var(--main-muted);
    font-weight: 700;
    white-space: nowrap;
  }

  .main-institution-modal-table td {
    vertical-align: middle;
  }

  .main-institution-name {
    min-width: 14rem;
    color: var(--main-ink);
    font-weight: 700;
  }

  .main-system-link {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .8rem .9rem;
    border: 1px solid var(--main-line);
    border-radius: 8px;
    text-decoration: none;
    color: var(--main-ink);
    background: #fff;
    box-shadow: var(--main-shadow-soft);
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }

  .main-system-link:hover {
    color: var(--main-teal);
    border-color: #a5dfe4;
    box-shadow: 0 .55rem 1.2rem rgba(31, 42, 55, .08);
    transform: translateY(-1px);
  }

  .main-system-link i {
    width: 2.1rem;
    height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: #eef5ff;
    color: var(--main-blue);
    flex: 0 0 auto;
  }

  .main-deadline-section {
    margin-top: 1.15rem;
  }

  .main-deadline-card {
    height: 100%;
    overflow: hidden;
    box-shadow: var(--main-shadow-soft);
  }

  .main-deadline-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem;
    background: linear-gradient(180deg, #fff, #fbfcfe);
    border-bottom: 1px solid var(--main-line);
  }

  .main-deadline-title {
    display: flex;
    align-items: center;
    gap: .65rem;
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--main-ink);
  }

  .main-deadline-title i {
    width: 2.1rem;
    height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: #e9f7ef;
    color: var(--main-green);
  }

  .main-deadline-count {
    white-space: nowrap;
    font-weight: 700;
  }

  .main-deadline-body {
    padding: 1rem 1.1rem 1.1rem;
    background: #fff;
  }

  .main-deadline-group + .main-deadline-group {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #edf1f6;
  }

  .main-deadline-group-name {
    font-size: .9rem;
    font-weight: 700;
    color: var(--main-teal);
    margin-bottom: .65rem;
  }

  .main-deadline-table {
    margin-bottom: 0;
    font-size: .9rem;
    border-color: #edf1f6;
  }

  .main-deadline-table th {
    color: var(--main-muted);
    font-weight: 700;
    white-space: nowrap;
    background: #f8fafc;
    border-bottom: 0;
  }

  .main-deadline-table td {
    vertical-align: middle;
  }

  .main-deadline-name {
    min-width: 12rem;
    font-weight: 600;
    color: var(--main-ink);
  }

  .main-empty {
    border: 1px dashed #cbd5e1;
    border-radius: 8px;
    color: var(--main-muted);
    padding: 1rem;
    text-align: center;
    background: #f8fafc;
  }

  .main-download-list {
    display: grid;
    gap: .6rem;
  }

  .main-download-item {
