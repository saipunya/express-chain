                <a href="/command" class="btn btn-sm btn-outline-primary">จัดการ</a>
              </div>
              <div class="card-body">
                <% if (_lastCommands.length) { %>
                  <div class="dashboard-home-list">
                    <% _lastCommands.slice(0, 5).forEach(function(command) { %>
                      <%
                        const commandDateValue = command.com_date || command.command_date || null;
                        let commandDateText = '';
                        if (commandDateValue) {
                          const commandDate = new Date(commandDateValue);
                          commandDateText = Number.isNaN(commandDate.getTime())
                            ? String(commandDateValue).slice(0, 10)
                            : commandDate.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' });
                        }
                      %>
                      <div class="dashboard-home-list-item">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                          <div class="min-w-0">
                            <div class="fw-semibold"><%= command.com_story || '-' %></div>
                            <div class="small text-muted">
                              <% if (command.com_no) { %>
                                <span class="badge text-bg-light border me-1">เลขที่ <%= command.com_no %></span>
                              <% } %>
                              <% if (commandDateText) { %>
                                <span><i class="bi bi-calendar3 me-1"></i><%= commandDateText %></span>
                              <% } %>
                              <% if (command.com_from) { %>
                                <span class="ms-2"><i class="bi bi-building me-1"></i><%= command.com_from %></span>
                              <% } %>
                            </div>
                          </div>
                          <% if (command.com_filename && command.command_id) { %>
                            <a href="/command/download/<%= command.command_id %>" class="btn btn-sm btn-outline-primary flex-shrink-0" target="_blank" title="ดาวน์โหลดคำสั่ง">
                              <i class="bi bi-file-earmark-arrow-down"></i>
                            </a>
                          <% } %>
                        </div>
                      </div>
                    <% }); %>
                  </div>
                <% } else { %>
