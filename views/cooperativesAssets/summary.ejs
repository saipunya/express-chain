<%- include('../partials/header') %>

<div class="py-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1"><i class="bi bi-bar-chart-line me-2"></i><%= title %></h1>
      <% if (typeof selectedGroup !== 'undefined' && selectedGroup) { %>
        <p class="text-muted small mb-0">ภาพรวมอุปกรณ์การตลาดเฉพาะ<%= selectedGroup.replace('group', 'กลุ่มส่งเสริมสหกรณ์') %></p>
      <% } else { %>
        <p class="text-muted small mb-0">ภาพรวมอุปกรณ์การตลาดทุกสหกรณ์ พร้อมสรุปตามกลุ่มส่งเสริมสหกรณ์</p>
      <% } %>
    </div>
    <div class="d-flex gap-2">
      <% if (typeof selectedGroup !== 'undefined' && selectedGroup) { %>
        <a href="/cooperatives-assets/summary" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left me-1"></i>ดูทั้งหมด
        </a>
      <% } else { %>
        <a href="/cooperatives-assets" class="btn btn-outline-secondary">
          <i class="bi bi-list-ul me-1"></i>รายการทั้งหมด
        </a>
      <% } %>
      <a href="/#assets_all" class="btn btn-primary">
        <i class="bi bi-house-door me-1"></i>หน้าแรก
      </a>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">อุปกรณ์การตลาดทั้งหมด</div>
          <div class="display-6 fw-bold text-primary"><%= overall.total_count %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">มูลค่ารวม(บาท)</div>
          <div class="fw-bold fs-3 text-success"><%= Number(overall.total_value || 0).toLocaleString('th-TH') %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">ใช้งานได้(รายการ)</div>
          <div class="display-6 fw-bold text-success"><%= overall.working_count %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small mb-1">ใช้งานไม่ได้(รายการ)</div>
          <div class="display-6 fw-bold text-danger"><%= overall.not_working_count %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small">จำนวนกลุ่มส่งเสริมสหกรณ์</div>
          <div class="h2 fw-bold mb-0"><%= overall.total_groups %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small">จำนวนสหกรณ์ที่มี(แห่ง)</div>
          <div class="h2 fw-bold mb-0"><%= overall.total_cooperatives %></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="text-muted small">สัดส่วนใช้งานได้(%)</div>
          <div class="h2 fw-bold mb-0 text-success">
            <%= overall.total_count ? Math.round((overall.working_count / overall.total_count) * 100) : 0 %>%
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if (groupSummaries && groupSummaries.length > 0) { %>
    <% groupSummaries.forEach(group => { %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div>
            <h5 class="mb-0 text-primary">
              <i class="bi bi-people-fill me-2"></i><%= group.c_group %>
            </h5>
            <small class="text-muted">รวมสหกรณ์ทั้งหมดในกลุ่มนี้</small>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary"><%= group.total_count %> รายการ</span>
            <span class="badge bg-success"><%= group.working_count %> ใช้ได้(รายการ)</span>
            <span class="badge bg-danger"><%= group.not_working_count %> ใช้ไม่ได้(รายการ)</span>
            <span class="badge bg-dark"><%= Number(group.total_value || 0).toLocaleString('th-TH') %> บาท</span>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
              <thead class="table-light">
                <tr>
                  <th>รหัสสหกรณ์</th>
                  <th>ชื่อสหกรณ์</th>
                  <th class="text-center">จำนวน(รายการ)</th>
                  <th class="text-end">มูลค่ารวม(บาท)</th>
                  <th class="text-center">ใช้งานได้(รายการ)</th>
                  <th class="text-center">ใช้งานไม่ได้(รายการ)</th>
                  <th class="text-center">รายละเอียด</th>
                </tr>
              </thead>
              <tbody>
                <% group.cooperatives.forEach(coop => { %>
                  <tr>
                    <td class="fw-semibold"><%= coop.coop_code %></td>
                    <td><%= coop.coop_name %></td>
                    <td class="text-center"><span class="badge bg-primary"><%= coop.total_count %></span></td>
                    <td class="text-end text-success fw-semibold"><%= Number(coop.total_value || 0).toLocaleString('th-TH') %></td>
                    <td class="text-center">
                      <%- coop.working_count > 0 ? `<span class="badge bg-success">${coop.working_count}</span>` : '<span class="text-muted">-</span>' %>
                    </td>
                    <td class="text-center">
                      <%- coop.not_working_count > 0 ? `<span class="badge bg-danger">${coop.not_working_count}</span>` : '<span class="text-muted">-</span>' %>
                    </td>
                    <td class="text-center">
                      <a href="/cooperatives-assets/detail/<%= encodeURIComponent(coop.coop_code) %>" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-eye me-1"></i>ดูรายละเอียด
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="card border-0 shadow-sm">
      <div class="card-body text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
        <h5 class="text-muted">ไม่พบข้อมูลอุปกรณ์การตลาด</h5>
        <p class="text-muted mb-0">ยังไม่มีข้อมูลในระบบ</p>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
