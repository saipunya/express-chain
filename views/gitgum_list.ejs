<%- include('partials/header') %>

<% const totalRecords = (pagination && pagination.total) || data.length; %>
<% const currentPage = (pagination && pagination.page) || 1; %>
<% const totalPages = (pagination && pagination.totalPages) || 1; %>
<% const pageSize = (pagination && pagination.pageSize) || data.length || 0; %>
<%
  const formatThaiDate = (value) => {
    let result = '-';
    if (value) {
      const date = value instanceof Date ? value : new Date(value);
      if (!Number.isNaN(date.getTime())) {
        result = date.toLocaleDateString('th-TH', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
          timeZone: 'Asia/Bangkok'
        });
      } else {
        result = String(value).slice(0, 10);
      }
    }
    return result;
  };
%>

<div class="container py-4 gitgum-page">
  <div class="gitgum-hero shadow-sm mb-4">
    <div class="row align-items-center g-3">
      <div class="col-lg-8">
        <div class="d-flex align-items-center gap-3 mb-2">
          <div class="gitgum-hero-icon">
            <i class="bi bi-calendar2-week"></i>
          </div>
          <div>
            <p class="text-uppercase text-muted fw-semibold small mb-1 letter-spacing-1">กิจกรรมทั้งหมด</p>
            <h3 class="mb-0 fw-bold text-dark">รายการกิจกรรม</h3>
          </div>
        </div>
        <p class="text-muted mb-0">จัดการและติดตามกิจกรรมทั้งหมดได้จากหน้านี้ พร้อมดูรายละเอียดแต่ละรายการได้อย่างรวดเร็ว</p>
      </div>
      <div class="col-lg-4">
        <div class="d-flex flex-wrap justify-content-lg-end gap-2">
          <% if(user){ %>
            <a href="/gitgum/add" class="btn btn-success btn-lg shadow-sm">
              <i class="bi bi-plus-circle me-1"></i> เพิ่มรายการ
            </a>
          <% } %>
          <a href="/dashboard/" class="btn btn-outline-primary btn-lg shadow-sm">
            <i class="bi bi-house me-1"></i> กลับไปที่แดชบอร์ด
          </a>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-3">
      <div class="col-sm-6 col-xl-3">
        <div class="gitgum-stat-card">
          <span class="gitgum-stat-icon bg-primary-subtle text-primary"><i class="bi bi-collection"></i></span>
          <div>
            <div class="text-muted small">ทั้งหมด</div>
            <div class="fw-bold fs-5"><%= totalRecords %></div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="gitgum-stat-card">
          <span class="gitgum-stat-icon bg-success-subtle text-success"><i class="bi bi-files"></i></span>
          <div>
            <div class="text-muted small">ต่อหน้า</div>
            <div class="fw-bold fs-5"><%= pageSize %></div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="gitgum-stat-card">
          <span class="gitgum-stat-icon bg-warning-subtle text-warning"><i class="bi bi-layers"></i></span>
          <div>
            <div class="text-muted small">หน้าปัจจุบัน</div>
            <div class="fw-bold fs-5"><%= currentPage %> / <%= totalPages %></div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="gitgum-stat-card">
          <span class="gitgum-stat-icon bg-info-subtle text-info"><i class="bi bi-clock-history"></i></span>
          <div>
            <div class="text-muted small">สถานะ</div>
            <div class="fw-bold fs-5">พร้อมใช้งาน</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card shadow-sm border-0 gitgum-list-shell">
    <div class="card-header bg-white border-0 py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
      <div>
        <h5 class="mb-1 fw-bold">รายการกิจกรรมแบบ 2 แถว</h5>
        <div class="text-muted small">วันที่/เวลา และ กิจกรรม/สถานที่ จะถูกจัดให้อยู่เป็นกลุ่มในแต่ละรายการ</div>
      </div>
      <div class="text-muted small">
        <i class="bi bi-info-circle me-1"></i> แสดงผล <%= data.length %> รายการบนหน้านี้
      </div>
    </div>

    <div class="card-body p-3 p-md-4">
      <% if (data && data.length) { %>
        <div class="d-grid gap-3">
          <% data.forEach(gitgum => { %>
            <article class="gitgum-list-item shadow-sm">
              <div class="row g-0 align-items-stretch">
                <div class="col-lg-9">
                  <div class="gitgum-list-content">
                    <div class="gitgum-list-row">
                      <div class="gitgum-field">
                        <span class="gitgum-field-label"><i class="bi bi-calendar-event me-1"></i> วันที่</span>
                        <div class="gitgum-field-value text-dark"><%= formatThaiDate(gitgum.git_date) %></div>
                      </div>
                      <div class="gitgum-field">
                        <span class="gitgum-field-label"><i class="bi bi-clock me-1"></i> เวลา</span>
                        <div class="gitgum-field-value">
                          <span class="badge rounded-pill bg-light text-dark border px-3 py-2"><%= gitgum.git_time || '-' %></span>
                        </div>
                      </div>
                    </div>

                    <div class="gitgum-list-row gitgum-list-row-secondary">
                      <div class="gitgum-field">
                        <span class="gitgum-field-label"><i class="bi bi-stars me-1"></i> กิจกรรม</span>
                        <div class="gitgum-field-value text-primary fw-semibold text-truncate-2"><%= gitgum.git_act || '-' %></div>
                      </div>
                      <div class="gitgum-field">
                        <span class="gitgum-field-label"><i class="bi bi-geo-alt-fill me-1"></i> สถานที่</span>
                        <div class="gitgum-field-value text-muted text-truncate-2"><%= gitgum.git_place || '-' %></div>
                      </div>
                      <div class="gitgum-field">
                        <span class="gitgum-field-label"><i class="bi bi-person-badge me-1"></i> ผู้รับผิดชอบ</span>
                        <div class="gitgum-field-value text-muted text-truncate-2"><%= gitgum.git_goto || '-' %></div>
                      </div>
                    </div>
                  </div>
                </div>

                <% if(user){ %>
                <div class="col-lg-3">
                  <div class="gitgum-actions-panel h-100">
                    <div class="text-muted small fw-semibold mb-2">จัดการรายการ</div>
                    <div class="d-flex flex-wrap gap-2">
                      <button type="button"
                        class="btn btn-soft-primary btn-sm"
                        data-bs-toggle="modal"
                        data-bs-target="#gitgumDetailModal"
                        data-gitgum-title="<%= gitgum.git_act || '-' %>"
                        data-gitgum-date="<%= formatThaiDate(gitgum.git_date) %>"
                        data-gitgum-time="<%= gitgum.git_time || '-' %>"
                        data-gitgum-act="<%= gitgum.git_act || '-' %>"
                        data-gitgum-place="<%= gitgum.git_place || '-' %>"
                        data-gitgum-respon="<%= gitgum.git_respon || '-' %>"
                        data-gitgum-goto="<%= gitgum.git_goto || '-' %>"
                        data-gitgum-group="<%= gitgum.git_group || '-' %>"
                        data-gitgum-maihed="<%= gitgum.git_maihed || '-' %>"
                        data-gitgum-saveby="<%= gitgum.git_saveby || '-' %>"
                        data-gitgum-savedate="<%= formatThaiDate(gitgum.git_savedate) %>"
                        data-gitgum-view-url="/gitgum/view/<%= gitgum.git_id %>"
                        data-gitgum-edit-url="/gitgum/edit/<%= gitgum.git_id %>"
                        data-gitgum-delete-url="/gitgum/delete/<%= gitgum.git_id %>">
                        <i class="bi bi-eye me-1"></i> View
                      </button>
                      <a href="/gitgum/edit/<%= gitgum.git_id %>" class="btn btn-soft-warning btn-sm">
                        <i class="bi bi-pencil-square me-1"></i> Edit
                      </a>
                      <a href="/gitgum/delete/<%= gitgum.git_id %>" class="btn btn-soft-danger btn-sm" onclick="return confirm('ลบข้อมูล?')">
                        <i class="bi bi-trash me-1"></i> Delete
                      </a>
                    </div>
                  </div>
                </div>
                <% } %>
              </div>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center py-5">
          <div class="gitgum-empty-icon mb-3">
            <i class="bi bi-calendar-x"></i>
          </div>
          <h5 class="fw-bold mb-2">ยังไม่มีรายการกิจกรรม</h5>
          <p class="text-muted mb-3">เริ่มต้นด้วยการเพิ่มกิจกรรมใหม่ เพื่อให้รายการแสดงอยู่ที่นี่</p>
          <% if(user){ %>
            <a href="/gitgum/add" class="btn btn-success">
              <i class="bi bi-plus-circle me-1"></i> เพิ่มรายการแรก
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mt-4">
      <div class="text-muted small">
        หน้า <span class="fw-semibold"><%= pagination.page %></span> จาก <span class="fw-semibold"><%= pagination.totalPages %></span>
        · ทั้งหมด <span class="fw-semibold"><%= pagination.total %></span> รายการ
      </div>

      <nav aria-label="Gitgum pagination">
        <ul class="pagination mb-0 pagination-lg flex-wrap justify-content-center justify-content-md-end">
          <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.hasPrev ? `/gitgum/list?page=${pagination.page - 1}&pageSize=${pagination.pageSize}` : '#' %>" aria-label="ก่อนหน้า">
              <i class="bi bi-chevron-left me-1"></i> ก่อนหน้า
            </a>
          </li>

          <% for (let p = 1; p <= pagination.totalPages; p++) { %>
            <li class="page-item <%= p === pagination.page ? 'active' : '' %>">
              <a class="page-link" href="/gitgum/list?page=<%= p %>&pageSize=<%= pagination.pageSize %>"><%= p %></a>
            </li>
          <% } %>

          <li class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.hasNext ? `/gitgum/list?page=${pagination.page + 1}&pageSize=${pagination.pageSize}` : '#' %>" aria-label="ถัดไป">
              ถัดไป <i class="bi bi-chevron-right ms-1"></i>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  <% } %>
</div>

<div class="modal fade" id="gitgumDetailModal" tabindex="-1" aria-labelledby="gitgumDetailModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-gradient-success text-white border-0">
        <div>
          <p class="small text-white-50 text-uppercase fw-semibold mb-1">รายละเอียดกิจกรรม</p>
          <h5 class="modal-title fw-bold mb-0" id="gitgumDetailModalLabel">-</h5>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body bg-white">
        <div class="p-3 p-md-4 rounded-4 bg-light border mb-4">
          <div class="d-flex align-items-start gap-3">
            <div class="gitgum-hero-icon flex-shrink-0">
              <i class="bi bi-calendar2-event"></i>
            </div>
            <div class="min-w-0">
              <div class="text-muted small mb-1">กิจกรรม</div>
              <div class="fw-bold fs-5 text-dark text-truncate" data-modal-field="activityTitle">-</div>
              <div class="text-muted small mt-1">
                <span class="me-3"><i class="bi bi-calendar-event me-1"></i><span data-modal-field="date">-</span></span>
                <span><i class="bi bi-clock me-1"></i><span data-modal-field="time">-</span></span>
              </div>
            </div>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-md-6">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-geo-alt-fill me-1"></i> สถานที่</div>
              <div class="fw-semibold text-dark" data-modal-field="place">-</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-person-badge me-1"></i> ผู้รับผิดชอบ</div>
              <div class="fw-semibold text-dark" data-modal-field="respon">-</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-person-check me-1"></i> ผู้ไป/ผู้เกี่ยวข้อง</div>
              <div class="fw-semibold text-dark" data-modal-field="goto">-</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-people me-1"></i> กลุ่ม/หน่วยงาน</div>
              <div class="fw-semibold text-dark" data-modal-field="group">-</div>
            </div>
          </div>
          <div class="col-12">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-journal-text me-1"></i> หมายเหตุ</div>
              <div class="fw-semibold text-dark" data-modal-field="maihed">-</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-pencil-square me-1"></i> บันทึกโดย</div>
              <div class="fw-semibold text-dark" data-modal-field="saveby">-</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 rounded-4 border h-100">
              <div class="text-muted small fw-semibold mb-1"><i class="bi bi-calendar-check me-1"></i> วันที่บันทึก</div>
              <div class="fw-semibold text-dark" data-modal-field="savedate">-</div>
            </div>
          </div>
        </div>
      </div>

      <div class="modal-footer bg-light border-0">
        <a href="#" class="btn btn-outline-primary" data-modal-action="view-full" target="_blank" rel="noopener">
          <i class="bi bi-box-arrow-up-right me-1"></i> เปิดหน้ารายละเอียดเต็ม
        </a>
        <% if(user){ %>
          <a href="#" class="btn btn-warning text-white" data-modal-action="edit">
            <i class="bi bi-pencil-square me-1"></i> แก้ไข
          </a>
          <a href="#" class="btn btn-danger" data-modal-action="delete" onclick="return confirm('ลบข้อมูล?')">
            <i class="bi bi-trash me-1"></i> ลบ
          </a>
        <% } %>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ปิด</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var modal = document.getElementById('gitgumDetailModal');
    if (!modal) return;

    modal.addEventListener('show.bs.modal', function (event) {
      var button = event.relatedTarget;
      if (!button) return;

      var title = button.getAttribute('data-gitgum-title') || '-';
      var fields = {
        activityTitle: button.getAttribute('data-gitgum-act') || '-',
        date: button.getAttribute('data-gitgum-date') || '-',
        time: button.getAttribute('data-gitgum-time') || '-',
        place: button.getAttribute('data-gitgum-place') || '-',
        respon: button.getAttribute('data-gitgum-respon') || '-',
        goto: button.getAttribute('data-gitgum-goto') || '-',
        group: button.getAttribute('data-gitgum-group') || '-',
        maihed: button.getAttribute('data-gitgum-maihed') || '-',
        saveby: button.getAttribute('data-gitgum-saveby') || '-',
        savedate: button.getAttribute('data-gitgum-savedate') || '-'
      };

      var titleEl = modal.querySelector('#gitgumDetailModalLabel');
      if (titleEl) titleEl.textContent = title;

      Object.keys(fields).forEach(function (key) {
        var el = modal.querySelector('[data-modal-field="' + key + '"]');
        if (el) el.textContent = fields[key];
      });

      var viewUrl = button.getAttribute('data-gitgum-view-url') || '#';
      var editUrl = button.getAttribute('data-gitgum-edit-url') || '#';
      var deleteUrl = button.getAttribute('data-gitgum-delete-url') || '#';

      var viewLink = modal.querySelector('[data-modal-action="view-full"]');
      if (viewLink) viewLink.setAttribute('href', viewUrl);

      var editLink = modal.querySelector('[data-modal-action="edit"]');
      if (editLink) editLink.setAttribute('href', editUrl);

      var deleteLink = modal.querySelector('[data-modal-action="delete"]');
      if (deleteLink) deleteLink.setAttribute('href', deleteUrl);
    });
  });
</script>

<%- include('partials/footer') %>