<%- include('partials/header') %>

<div class="container mt-4">
  <h3 class="mb-4">➕ เพิ่มกิจกรรม</h3>

  <form action="/gitgum/add" method="POST" class="row g-3">
    <div class="col-md-4">
      <label for="git_date" class="form-label">วันที่</label>
      <input type="date" class="form-control" id="git_date" name="git_date" required />
    </div>

    <div class="col-md-4">
      <label for="git_time" class="form-label">เวลา</label>
      <input type="time" class="form-control" id="git_time" name="git_time" required />
    </div>

    <div class="col-md-12">
      <label for="git_act" class="form-label">กิจกรรม</label>
      <input type="text" class="form-control" id="git_act" name="git_act" placeholder="เช่น ประชุมคณะทำงาน..." required />
    </div>

    <div class="col-md-6">
      <label for="git_place" class="form-label">สถานที่</label>
      <input type="text" class="form-control" id="git_place" name="git_place" placeholder="สถานที่จัดกิจกรรม" />
    </div>

    <div class="col-md-6">
      <label for="git_goto" class="form-label">ผู้รับผิดชอบ/ผู้ไป</label>
      <input type="text" class="form-control" id="git_goto" name="git_goto" placeholder="ผู้ที่ต้องไป/รับผิดชอบ" />
    </div>

    <div class="col-md-6">
      <label for="git_respon" class="form-label">ผู้รับผิดชอบหลัก</label>
      <input type="text" class="form-control" id="git_respon" name="git_respon" placeholder="ชื่อผู้รับผิดชอบหลัก" />
    </div>

    <div class="col-md-6">
      <label for="git_group" class="form-label">กลุ่ม/หน่วยงาน</label>
      <input type="text" class="form-control" id="git_group" name="git_group" placeholder="กลุ่ม/แผนก" />
    </div>

    <div class="col-md-12">
      <label for="git_maihed" class="form-label">หมายเหตุ</label>
      <textarea class="form-control" id="git_maihed" name="git_maihed" rows="3" placeholder="ข้อมูลเพิ่มเติม/หมายเหตุ"></textarea>
    </div>

    <!-- Hidden meta fields -->
    <input type="hidden" name="git_saveby" value="<%= (user && user.fullname) ? user.fullname : 'guest' %>" />
    <input type="hidden" name="git_savedate" value="<%= new Date().toISOString().slice(0,19).replace('T',' ') %>" />

    <div class="col-12 d-flex gap-2">
      <button type="submit" class="btn btn-success">บันทึก</button>
      <a href="/gitgum/list" class="btn btn-secondary">ย้อนกลับ</a>
    </div>
  </form>
</div>

<!-- แสดงข้อมูลล่าสุด -->
<% if (recentData && recentData.length > 0) { %>
<div class="container mt-5">
  <div class="card">
    <div class="card-header bg-info text-white">
      <h5 class="mb-0">📋 ข้อมูลที่บันทึกล่าสุด (<%= recentData.length %> รายการ)</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>วันที่</th>
              <th>เวลา</th>
              <th>กิจกรรม</th>
              <th>สถานที่</th>
              <th>ผู้เข้าร่วม</th>
              <th>ผู้รับผิดชอบ</th>
           
              <% if(user){ %>
              <th>จัดการ</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% recentData.forEach(item => { %>
              <tr>
                <% const date = new Date(item.git_date); %>
                <% const options = { year: 'numeric', month: 'short', day: 'numeric' }; %>
                <% const thaiDate = date.toLocaleDateString('th-TH', options); %>
                <td><%= thaiDate %></td>
                <td><%= item.git_time %></td>
                <td>
                  <div class="fw-semibold"><%= item.git_act %></div>
                  <% if (item.git_maihed) { %>
                    <small class="text-muted"><%= item.git_maihed %></small>
                  <% } %>
                </td>
                <td><%= item.git_place || '-' %></td>
                <td><%= item.git_goto || '-' %></td>
                <td><%= item.git_respon || '-' %></td>
                <td>
                  <small class="text-muted">
                    <%= item.git_saveby %>
                    <br><%= new Date(item.git_savedate).toLocaleString('th-TH', { hour: '2-digit', minute: '2-digit' }) %>
                  </small>
                </td>
                <% if(user){ %>
                <td class="text-center text-nowrap">
                  <div class="btn-group btn-group-sm" role="group">
                    <a href="/gitgum/view/<%= item.git_id %>" class="btn btn-outline-info" title="ดูรายละเอียด">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/gitgum/edit/<%= item.git_id %>" class="btn btn-outline-warning" title="แก้ไข">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/gitgum/delete/<%= item.git_id %>" class="btn btn-outline-danger" title="ลบ" onclick="return confirm('ต้องการลบกิจกรรมนี้?')">
                      <i class="bi bi-trash"></i>
                    </a>
                  </div>
                </td>
                <% } %>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card-footer">
      <a href="/gitgum/list" class="btn btn-outline-primary btn-sm">ดูทั้งหมด</a>
      <a href="/gitgum/calendar" class="btn btn-outline-info btn-sm">ดูปฏิทิน</a>
    </div>
  </div>
</div>
<% } %>

<%- include('partials/footer') %>

