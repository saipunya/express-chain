<!-- include header -->
<%- include('../header.ejs', { title: title }) %>
<style>
  .promo-codes-page {
    background: linear-gradient(180deg, #f8fafc 0%, #eef4ff 100%);
    min-height: 100vh;
    padding: 40px 0 56px;
  }

  .promo-codes-shell {
    max-width: 1280px;
    margin: 0 auto;
  }

  .promo-codes-topbar {
    background: rgba(255,255,255,0.96);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
    margin-bottom: 24px;
  }

  .promo-codes-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    background: #eff6ff;
    color: #2563eb;
    font-size: 0.92rem;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .promo-codes-title {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #0f172a;
    line-height: 1.08;
    margin-bottom: 10px;
    letter-spacing: -0.03em;
  }

  .promo-codes-desc {
    color: #64748b;
    margin-bottom: 0;
    line-height: 1.7;
    max-width: 820px;
  }

  .promo-codes-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .promo-codes-nav .btn,
  .promo-codes-action-btn,
  .promo-codes-clear-btn {
    border-radius: 12px;
    padding: 10px 14px;
    font-weight: 600;
    border-width: 1.5px;
  }

  .promo-scope-card,
  .promo-panel-card,
  .promo-table-card {
    border: none;
    border-radius: 24px;
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
    overflow: hidden;
  }

  .promo-scope-card .card-body,
  .promo-panel-card .card-body,
  .promo-table-card .card-body {
    padding: 20px;
  }

  .promo-scope-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #eff6ff;
    color: #1d4ed8;
    font-weight: 700;
    margin-bottom: 10px;
  }

  .promo-scope-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 4px;
  }

  .promo-scope-subtitle {
    color: #64748b;
    margin-bottom: 0;
  }

  .promo-filter-box {
    display: grid;
    gap: 12px;
  }

  .promo-filter-label {
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .promo-filter-help {
    color: #64748b;
    font-size: 0.9rem;
  }

  .promo-stat-card {
    border: none;
    border-radius: 22px;
    padding: 18px 16px;
    height: 100%;
    background: #fff;
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
    position: relative;
    overflow: hidden;
  }

  .promo-stat-card::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.12;
    pointer-events: none;
  }

  .promo-stat-total::before { background: linear-gradient(135deg, #2563eb, #60a5fa); }
  .promo-stat-used::before { background: linear-gradient(135deg, #7c3aed, #a78bfa); }
  .promo-stat-remaining::before { background: linear-gradient(135deg, #16a34a, #4ade80); }
  .promo-stat-expired::before { background: linear-gradient(135deg, #ef4444, #fda4af); }

  .promo-stat-inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .promo-stat-label {
    font-size: 0.88rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 10px;
  }

  .promo-stat-value {
    font-size: clamp(1.7rem, 4vw, 2.35rem);
    font-weight: 800;
    line-height: 1;
    color: #0f172a;
    margin-bottom: 8px;
  }

  .promo-stat-foot {
    font-size: 0.9rem;
    color: #64748b;
  }

  .promo-grid-note {
    color: #64748b;
    font-size: 0.92rem;
  }

  .promo-table {
    margin-bottom: 0;
  }

  .promo-table thead th {
    background: #f8fafc;
    color: #475569;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-bottom: 1px solid #e2e8f0;
    padding: 14px 16px;
    white-space: nowrap;
  }

  .promo-table tbody td {
    padding: 14px 16px;
    vertical-align: middle;
    border-color: #eef2f7;
    color: #0f172a;
    font-size: 0.95rem;
  }

  .promo-table tbody tr:hover {
    background: #f8fbff;
  }

  .promo-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.9rem;
    color: #2563eb;
    background: #eff6ff;
    border-radius: 10px;
    padding: 5px 10px;
    display: inline-block;
  }

  .promo-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 7px 12px;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .promo-status-unused {
    background: #dcfce7;
    color: #15803d;
  }

  .promo-status-drawn {
    background: #ede9fe;
    color: #6d28d9;
  }

  .promo-status-claimed {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .promo-status-declined {
    background: #fee2e2;
    color: #b91c1c;
  }

  .promo-status-expired {
    background: #e2e8f0;
    color: #334155;
  }

  .promo-muted {
    color: #94a3b8;
  }

  .promo-empty {
    padding: 36px 16px !important;
    color: #64748b !important;
    font-size: 0.98rem;
  }

  .promo-action-stack {
    display: grid;
    gap: 8px;
    min-width: 160px;
  }

  .promo-mini-summary {
    display: grid;
    gap: 8px;
  }

  .promo-mini-summary .badge {
    justify-self: start;
  }

  .promo-generate-btn {
    border-radius: 14px;
    font-weight: 700;
    min-height: 50px;
  }

  .promo-clear-btn {
    min-height: 50px;
  }

  @media (max-width: 767.98px) {
    .promo-codes-page {
      padding: 24px 0 36px;
    }

    .promo-codes-topbar {
      padding: 18px;
      border-radius: 18px;
    }

    .promo-scope-card .card-body,
    .promo-panel-card .card-body,
    .promo-table-card .card-body {
      padding: 16px;
    }
  }
</style>

<div class="promo-codes-page">
  <div class="container promo-codes-shell">
    <% const codesSafe = Array.isArray(codes) ? codes : []; %>
    <% const storesSafe = Array.isArray(stores) ? stores : []; %>
    <% const campaignsSafe = Array.isArray(campaigns) ? campaigns : []; %>
    <% const summarySafe = summary || {}; %>
    <% const selectedStoreObj = selectedStore || (selectedStoreId ? storesSafe.find(s => Number(s.id) === Number(selectedStoreId)) : null); %>
    <% const selectedCampaignObj = selectedCampaign || (selectedCampaignId ? campaignsSafe.find(c => Number(c.id) === Number(selectedCampaignId)) : null); %>
    <% const showExpiredSafe = Boolean(showExpired); %>
    <% const canClear = Boolean(selectedStoreId || selectedCampaignId); %>
    <% const clearScopeLabel = selectedCampaignObj
      ? selectedCampaignObj.name + (selectedStoreObj ? ' / ' + selectedStoreObj.name : '')
      : selectedStoreObj
        ? selectedStoreObj.name
        : 'ทั้งหมด'; %>
    <% const scopeStoreIdValue = selectedStoreId || (selectedCampaignObj ? selectedCampaignObj.store_id : ''); %>

    <div class="promo-codes-topbar">
      <div class="d-flex flex-column flex-xl-row justify-content-between align-items-start gap-3">
        <div>
          <div class="promo-codes-badge">
            <span>🔑</span>
            <span>Promotion Code Manager</span>
          </div>
          <h1 class="promo-codes-title"><%= title %></h1>
          <p class="promo-codes-desc">
            จัดการโค้ดโปรโมชั่นแบบแยกตามสโตร์และแคมเปญ พร้อมสรุปจำนวนโค้ดทั้งหมด ใช้งานแล้ว และคงเหลือในหน้าจอเดียว
          </p>
        </div>

        <div class="promo-codes-nav">
          <% if (promotionAdmin) { %>
            <span class="btn btn-light btn-sm disabled">
              <%= promotionAdmin.display_name || promotionAdmin.username %> (<%= promotionAdmin.role %>)
            </span>
          <% } %>
          <% if (promotionAdmin && promotionAdmin.role === 'super_admin') { %>
            <a href="/promotion/admin/users" class="btn btn-outline-primary btn-sm">Admin Users</a>
            <a href="/promotion/admin/stores" class="btn btn-outline-primary btn-sm">Stores</a>
          <% } %>
          <a href="/promotion/admin" class="btn btn-outline-secondary btn-sm">← Back</a>
          <a href="/promotion/admin/logout" class="btn btn-outline-danger btn-sm">Logout</a>
        </div>
      </div>
    </div>

    <% if (locals && locals.flash) { %>
      <div class="alert alert-<%= locals.flash.type || 'info' %> rounded-3 mb-3">
        <%= locals.flash.message %>
      </div>
    <% } %>

    <div class="card promo-scope-card mb-4">
      <div class="card-body">
        <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 align-items-start">
          <div>
            <div class="promo-scope-chip">Scope Overview</div>
            <div class="promo-scope-title">
              <%= selectedCampaignObj ? 'แคมเปญที่เลือก' : 'โค้ดทั้งหมดใน scope ปัจจุบัน' %>
            </div>
            <p class="promo-scope-subtitle">
              <% if (selectedCampaignObj) { %>
                <%= selectedCampaignObj.name %>
              <% } else if (selectedStoreObj) { %>
                <%= selectedStoreObj.name %>
              <% } else { %>
                แสดงข้อมูลรวมทุกสโตร์
              <% } %>
            </p>
          </div>

          <form method="GET" action="/promotion/admin/codes" class="row g-2 align-items-end flex-grow-1" style="max-width: 760px;">
            <div class="col-md-5">
              <label class="promo-filter-label">Filter Store</label>
              <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
                <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
                <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
              <% } else { %>
                <select class="form-select" name="store_id">
                  <option value="">ทั้งหมด</option>
                  <% storesSafe.forEach(s => { %>
                    <option value="<%= s.id %>" <%= Number(selectedStoreId) === Number(s.id) ? 'selected' : '' %>>
                      <%= s.name %> (<%= s.store_code || '-' %>)
                    </option>
                  <% }) %>
                </select>
              <% } %>
            </div>
            <div class="col-md-5">
              <label class="promo-filter-label">Filter Campaign</label>
              <select class="form-select" name="campaign_id">
                <option value="">ทั้งหมด</option>
                <% campaignsSafe.forEach(c => { %>
                  <option value="<%= c.id %>" <%= Number(selectedCampaignId) === Number(c.id) ? 'selected' : '' %>>
                    <%= c.name %> (<%= c.campaign_code || '-' %>)
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-2 d-grid">
              <button class="btn btn-outline-primary">Apply</button>
            </div>
            <div class="col-12 d-flex flex-wrap gap-2 align-items-center">
              <% if (showExpiredSafe) { %>
                <a href="/promotion/admin/codes<%= selectedStoreId ? `?store_id=${selectedStoreId}` : '' %><%= selectedCampaignId ? `${selectedStoreId ? '&' : '?'}campaign_id=${selectedCampaignId}` : '' %>" class="btn btn-outline-secondary btn-sm">
                  Hide expired
                </a>
              <% } else { %>
                <a href="/promotion/admin/codes<%= selectedStoreId ? `?store_id=${selectedStoreId}` : '' %><%= selectedCampaignId ? `${selectedStoreId ? '&' : '?'}campaign_id=${selectedCampaignId}` : '' %>&show_expired=1" class="btn btn-outline-secondary btn-sm">
                  Show expired
                </a>
              <% } %>
              <span class="promo-filter-help">ค่าเริ่มต้นจะซ่อน expired เพื่อให้เห็นผลล้างโค้ดชัดขึ้น</span>
            </div>
            <div class="col-12">
              <div class="d-flex flex-wrap gap-2">
                <% if (selectedStoreObj) { %>
                  <span class="badge text-bg-primary">Store: <%= selectedStoreObj.name %> (<%= selectedStoreObj.store_code || '-' %>)</span>
                <% } else { %>
                  <span class="badge text-bg-primary">Store: ทั้งหมด</span>
                <% } %>
                <% if (selectedCampaignObj) { %>
                  <span class="badge text-bg-info">Campaign: <%= selectedCampaignObj.name %></span>
                <% } else { %>
                  <span class="badge text-bg-info">Campaign: ทั้งหมด</span>
                <% } %>
                <a href="/promotion/admin/codes" class="badge text-bg-light text-decoration-none">Reset filter</a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6 col-xl-3">
        <div class="promo-stat-card promo-stat-total">
          <div class="promo-stat-inner">
            <div class="promo-stat-label">Total</div>
            <div class="promo-stat-value"><%= summarySafe.total || 0 %></div>
            <div class="promo-stat-foot">โค้ดทั้งหมด</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="promo-stat-card promo-stat-used">
          <div class="promo-stat-inner">
            <div class="promo-stat-label">Used</div>
            <div class="promo-stat-value"><%= summarySafe.used || 0 %></div>
            <div class="promo-stat-foot">โค้ดที่ถูกใช้งานแล้ว</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="promo-stat-card promo-stat-remaining">
          <div class="promo-stat-inner">
            <div class="promo-stat-label">Remaining</div>
            <div class="promo-stat-value"><%= summarySafe.unused || 0 %></div>
            <div class="promo-stat-foot">ยังไม่ถูกใช้</div>
          </div>
        </div>
      </div>
      <div class="col-6 col-xl-3">
        <div class="promo-stat-card promo-stat-expired">
          <div class="promo-stat-inner">
            <div class="promo-stat-label">Expired</div>
            <div class="promo-stat-value"><%= summarySafe.expired || 0 %></div>
            <div class="promo-stat-foot">หมดอายุแล้ว</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4 mb-4">
      <div class="col-lg-5">
        <div class="card promo-panel-card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
              <div>
                <h5 class="fw-bold mb-1">⚡ Generate Codes</h5>
                <div class="promo-grid-note">สร้างโค้ดใหม่ตามสโตร์และแคมเปญที่เลือก</div>
              </div>
              <span class="badge text-bg-light">Current scope: <%= clearScopeLabel %></span>
            </div>

            <form method="POST" action="/promotion/admin/codes/generate" class="mb-3">
              <div class="promo-filter-box">
                <div>
                  <label class="promo-filter-label">Store</label>
                  <% if (promotionAdmin && promotionAdmin.role === 'coop_admin') { %>
                    <input type="hidden" name="store_id" value="<%= storesSafe[0] ? storesSafe[0].id : '' %>">
                    <input type="text" class="form-control" value="<%= storesSafe[0] ? storesSafe[0].name : '-' %>" readonly>
                  <% } else { %>
                    <select class="form-select" name="store_id" required>
                      <option value="">เลือกสาขา</option>
                      <% storesSafe.forEach(s => { %>
                        <option value="<%= s.id %>" <%= Number(selectedStoreId) === Number(s.id) ? 'selected' : '' %>>
                          <%= s.name %> (<%= s.store_code || '-' %>)
                        </option>
                      <% }) %>
                    </select>
                  <% } %>
                </div>

                <div>
                  <label class="promo-filter-label">Campaign</label>
                  <select class="form-select" name="campaign_id">
                    <option value="">ทั้งหมด</option>
                    <% campaignsSafe.forEach(c => { %>
                      <option value="<%= c.id %>" <%= Number(selectedCampaignId) === Number(c.id) ? 'selected' : '' %>>
                        <%= c.name %> (<%= c.campaign_code || '-' %>)
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div>
                  <label class="promo-filter-label">Quantity</label>
                  <input type="number" name="quantity" class="form-control" value="100" min="1" max="50000">
                </div>

                <button class="btn btn-primary promo-generate-btn w-100">
                  🚀 Generate Now
                </button>
              </div>
            </form>

            <hr class="my-4">

            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
              <div>
                <h6 class="fw-bold mb-1">🧹 Clear unused / expired codes</h6>
                <div class="promo-grid-note">
                  ลบเฉพาะโค้ดสถานะ <code>unused</code> และ <code>expired</code> ของ scope ที่เลือก เพื่อไม่กระทบประวัติการใช้งาน
                </div>
              </div>
            </div>

            <form method="POST" action="/promotion/admin/codes/clear"
                  onsubmit="return confirm('ยืนยันลบโค้ด unused/expired ของ <%= clearScopeLabel %> ใช่หรือไม่?');">
              <input type="hidden" name="store_id" value="<%= scopeStoreIdValue || '' %>">
              <input type="hidden" name="campaign_id" value="<%= selectedCampaignId || '' %>">
              <button class="btn btn-outline-danger promo-clear-btn w-100 <%= canClear ? '' : 'disabled' %>" <%= canClear ? '' : 'disabled' %>>
                Clear unused / expired codes
              </button>
              <% if (!canClear) { %>
                <div class="promo-filter-help mt-2">
                  กรุณาเลือกสาขาหรือแคมเปญก่อนจึงจะล้างโค้ดได้
                </div>
              <% } %>
            </form>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <% if (newCodes && newCodes.length) { %>
          <div class="card promo-panel-card h-100">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                  <h5 class="fw-bold mb-1">🔥 New Codes</h5>
                  <div class="promo-grid-note"><%= newCodes.length %> codes created</div>
                </div>
                <button id="copyCodesBtn" class="btn btn-outline-primary btn-sm">
                  Copy All
                </button>
              </div>

              <div class="table-responsive">
                <table class="table table-bordered mb-0">
                  <tbody>
                    <% newCodes.forEach(nc => { %>
                      <tr class="bg-light">
                        <td><code><%= nc.code %></code></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% } else { %>
          <div class="card promo-panel-card h-100">
            <div class="card-body d-flex align-items-center justify-content-center text-center">
              <div>
                <div class="fw-bold mb-1">No new codes yet</div>
                <div class="promo-grid-note">สร้างโค้ดใหม่แล้วรายการล่าสุดจะแสดงที่นี่</div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <div class="card promo-table-card">
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table promo-table table-hover mb-0">
            <thead>
              <tr>
                <th>Code</th>
                <th>Store</th>
                <th>Campaign</th>
                <th>Status</th>
                <th>Expire</th>
              </tr>
            </thead>
            <tbody>
              <% if (codesSafe.length) { %>
                <% codesSafe.forEach(c => { %>
                  <tr>
                    <td><span class="promo-code"><%= c.code %></span></td>
                    <td>
                      <div class="fw-semibold"><%= c.store_name || '-' %></div>
                      <div class="promo-grid-note"><%= c.store_code || '-' %></div>
                    </td>
                    <td>
                      <div class="fw-semibold"><%= c.campaign_name || '-' %></div>
                    </td>
                    <td>
                      <span class="promo-status promo-status-<%= c.status || 'unused' %>">
                        <%= c.status || 'unused' %>
                      </span>
                    </td>
                    <td><%= c.expires_at ? new Date(c.expires_at).toLocaleDateString() : '-' %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="text-center promo-empty">
                    ยังไม่พบโค้ดใน scope ที่เลือก
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const copyBtn = document.getElementById('copyCodesBtn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      const codes = Array.from(document.querySelectorAll('code'))
        .map(el => el.innerText)
        .join('\n');

      navigator.clipboard.writeText(codes).then(() => {
        copyBtn.innerText = 'Copied!';
        setTimeout(() => copyBtn.innerText = 'Copy All', 2000);
      });
    });
  }
</script>

<%- include('../footer.ejs') %>
