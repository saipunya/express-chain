<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4 gap-2 flex-wrap">
  <div>
    <h3 class="mb-1"><%= title %></h3>
    <p class="text-muted mb-0">บันทึกใบขออนุญาตใช้รถส่วนกลาง</p>
  </div>
  <a href="/vehicle-request" class="btn btn-outline-secondary">ย้อนกลับ</a>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<form action="<%= formAction %>" method="POST" class="card shadow-sm border-0">
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-3">
        <label class="form-label">เลขที่คำขอใช้รถ</label>
        <input type="text" class="form-control" name="vehicle_request_no" value="<%= item.vehicle_request_no || '' %>" readonly>
      </div>
      <div class="col-md-3">
        <label class="form-label">วันที่คำขอ</label>
        <input type="date" class="form-control" name="request_date" value="<%= item.request_date || '' %>" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">เรียน</label>
        <input type="text" class="form-control" name="learn_to" value="<%= item.learn_to || '' %>">
      </div>
      <div class="col-md-12">
        <label class="form-label">อ้างอิงคำขอไปราชการ</label>
        <select class="form-select" name="travel_request_id" required>
          <option value="">เลือกคำขอไปราชการ</option>
          <% travelOptions.forEach((option) => { %>
            <option value="<%= option.id %>" <%= Number(item.travel_request_id) === Number(option.id) ? 'selected' : '' %>>
              <%= option.request_no %> - <%= option.subject %> - <%= option.requester_name %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">ผู้ขอใช้รถ</label>
        <input type="text" class="form-control" name="requester_name" value="<%= item.requester_name || '' %>" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">ตำแหน่ง</label>
        <input type="text" class="form-control" name="requester_position" value="<%= item.requester_position || '' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">จำนวนผู้โดยสาร</label>
        <input type="number" min="1" class="form-control" name="passenger_count" value="<%= item.passenger_count || 1 %>" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">ปลายทาง</label>
        <input type="text" class="form-control" name="destination_text" value="<%= item.destination_text || '' %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">เริ่มใช้รถ</label>
        <input type="datetime-local" class="form-control" name="trip_start_at" value="<%= item.trip_start_at || '' %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">สิ้นสุดการใช้รถ</label>
        <input type="datetime-local" class="form-control" name="trip_end_at" value="<%= item.trip_end_at || '' %>" required>
      </div>
      <div class="col-md-12">
        <label class="form-label">ภารกิจ / เหตุผล</label>
        <textarea class="form-control" name="mission_text" rows="4" required><%= item.mission_text || '' %></textarea>
      </div>
    </div>
  </div>
  <div class="card-footer bg-white d-flex gap-2 justify-content-end">
    <button type="submit" class="btn btn-success"><%= submitLabel %></button>
  </div>
</form>

<%- include('../partials/footer') %>