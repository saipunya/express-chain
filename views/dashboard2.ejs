<%- include('partials/header.ejs') %>

<div class="container py-4">
  <div class="row g-4 align-items-stretch mb-4">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex align-items-start gap-3">
            <div class="rounded bg-success-subtle text-success d-inline-flex align-items-center justify-content-center flex-shrink-0" style="width: 3rem; height: 3rem;">
              <i class="bi bi-building fs-4"></i>
            </div>
            <div>
              <h1 class="h3 fw-bold mb-2">แดชบอร์ดสมาชิกสถาบัน</h1>
              <p class="text-muted mb-0">รวมเมนูสำหรับสหกรณ์และกลุ่มเกษตรกร</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="fw-semibold mb-1"><%= user.fullname || user.username %></div>
          <div class="text-muted small mb-1">ชื่อผู้ใช้: <%= user ? (user.username || '-') : '-' %></div>
          <div class="text-muted small mb-3"><%= user.position || '-' %></div>
          <a href="/auth/logout" class="btn btn-outline-danger w-100">
            <i class="bi bi-box-arrow-right me-1"></i>ออกจากระบบ
          </a>
          <% if (user && (user.username || user.m_user)) { %>
            <a href="/allCoop/profile/<%= user.username || user.m_user %>" class="btn btn-primary w-100 mt-2">
              <i class="bi bi-building me-1"></i>ดูข้อมูลสถาบันของฉัน
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 py-3">
      <h2 class="h5 mb-0">เมนูใช้งาน</h2>
    </div>
    <div class="card-body p-4">
      <div class="row g-3">
        <div class="col-md-4">
          <a href="/chamra" class="text-decoration-none">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-success mb-2"><i class="bi bi-cash-coin fs-4"></i></div>
              <div class="fw-semibold text-dark">ผลการชำระบัญชี</div>
              <div class="text-muted small">ตรวจสอบข้อมูลที่เกี่ยวข้องกับสถาบัน</div>
            </div>
          </a>
        </div>
        <div class="col-md-4">
          <a href="/meetingroom" class="text-decoration-none">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-primary mb-2"><i class="bi bi-calendar-week fs-4"></i></div>
              <div class="fw-semibold text-dark">ห้องประชุม</div>
              <div class="text-muted small">ดูข้อมูลและการใช้งานห้องประชุม</div>
            </div>
          </a>
        </div>
        <div class="col-md-4">
          <a href="/" class="text-decoration-none">
            <div class="border rounded-3 p-3 h-100">
              <div class="text-secondary mb-2"><i class="bi bi-house-door fs-4"></i></div>
              <div class="fw-semibold text-dark">หน้าแรก</div>
              <div class="text-muted small">กลับไปยังหน้าหลักของระบบ</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
