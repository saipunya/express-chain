<%- include('../partials/header.ejs') %>

<% const isAdmin = (user && (user.mClass === 'pbt' || user.mClass === 'admin')); %>
<% function canDelete(meeting) {
  if (!user) return false;
  if (isAdmin) return true;
  return meeting.mee_saveby === user.fullname || meeting.mee_saveby === user.username || meeting.mee_saveby === user.name;
} %>
<%
  function parseLocalDate(value) {
    if (!value) return null;
    if (value instanceof Date) return new Date(value.getFullYear(), value.getMonth(), value.getDate());
    const match = String(value).match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (match) return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));
    const dt = new Date(value);
    if (isNaN(dt)) return null;
    return new Date(dt.getFullYear(), dt.getMonth(), dt.getDate());
  }
  function dateKey(value) {
    const dt = parseLocalDate(value);
    if (!dt) return '';
    const year = dt.getFullYear();
    const month = String(dt.getMonth() + 1).padStart(2, '0');
    const day = String(dt.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }
  function formatDate(d) {
    const dt = parseLocalDate(d);
    if (!dt) return '';
    return dt.toLocaleDateString('th-TH', { year:'numeric', month:'short', day:'numeric' });
  }
%>
<%
  const todayStart = new Date();
  todayStart.setHours(0,0,0,0);
  const upcomingLimit = new Date(todayStart);
  upcomingLimit.setDate(upcomingLimit.getDate() + 30);
  const sevenDayLimit = new Date(todayStart);
  sevenDayLimit.setDate(sevenDayLimit.getDate() + 7);
  const todayKey = dateKey(todayStart);
  const upcomingMeetings = (meetings || [])
    .filter(m => {
      if (!m.mee_date) return false;
      const d = parseLocalDate(m.mee_date);
      if (!d) return false;
      return d >= todayStart && d <= upcomingLimit;
    })
    .sort((a, b) => {
      const diff = parseLocalDate(a.mee_date) - parseLocalDate(b.mee_date);
      if (diff !== 0) return diff;
      return (a.mee_time || '').localeCompare(b.mee_time || '');
    });
  const todayMeetings = (meetings || []).filter(m => dateKey(m.mee_date) === todayKey).length;
  const next7Meetings = upcomingMeetings.filter(m => {
    const d = parseLocalDate(m.mee_date);
    return d && d >= todayStart && d <= sevenDayLimit;
  }).length;
  const totalMeetings = (meetings || []).length;
  const upcomingRangeText = `${formatDate(todayStart)} - ${formatDate(upcomingLimit)}`;
%>

<div class="meetingroom-wrapper py-3 py-md-4">
  <div class="container">
    <!-- Page header with enhanced visual -->
    <div class="page-header-card card border-0 shadow-sm mb-4">
      <div class="card-body p-3 p-md-4 page-header-surface">
        <div class="page-header-top d-flex flex-column flex-xl-row align-items-xl-center justify-content-between gap-4">
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-3 mb-3">
              <div class="icon-box">
                <i class="bi bi-calendar-week fs-3 text-primary"></i>
              </div>
              <div>
                <p class="eyebrow mb-1">Meeting Room</p>
                <h1 class="page-title mb-1">ตารางการใช้ห้องประชุม</h1>
                <p class="text-muted mb-0">ดูภาพรวมการจองช่วงถัดไปแบบอ่านง่าย และกดดูรายละเอียดได้ทันที</p>
              </div>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2">
              <span class="pill-badge pill-badge--success">
                <i class="bi bi-calendar-check"></i>
                แสดงตั้งแต่วันนี้เป็นต้นไป
              </span>
              <span class="pill-badge pill-badge--soft">
                <i class="bi bi-shield-lock"></i>
                แก้ไข: เฉพาะผู้ดูแล | ลบ: ผู้ดูแลและเจ้าของการจอง
              </span>
            </div>
          </div>

          <div class="header-actions">
            <div class="header-stat">
              <span>วันนี้</span>
              <strong><%= todayMeetings %></strong>
            </div>
            <div class="header-stat">
              <span>7 วัน</span>
              <strong><%= next7Meetings %></strong>
            </div>
            <div class="header-stat">
              <span>ทั้งหมด</span>
              <strong><%= totalMeetings %></strong>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-end">
              <button id="btnPrint" class="btn btn-outline-secondary btn-action">
                <i class="bi bi-printer"></i>
                <span class="d-none d-md-inline">พิมพ์</span>
              </button>
              <button id="btnCsv" class="btn btn-outline-success btn-action">
                <i class="bi bi-file-earmark-spreadsheet"></i>
                <span class="d-none d-md-inline">ส่งออก</span>
              </button>
              <% if (user) { %>
                <a href="/meetingroom/create" class="btn btn-primary btn-action">
                  <i class="bi bi-plus-circle"></i>
                  <span class="d-none d-sm-inline">เพิ่มการจอง</span>
                </a>
              <% } %>
              <a href="/dashboard" class="btn btn-outline-primary btn-action d-none d-md-inline-flex">
                <i class="bi bi-speedometer2"></i>แดชบอร์ด
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Enhanced Calendar View -->
    <div class="card border-0 shadow-sm d-print-none d-none d-md-block">
      <div class="card-body p-0">
        <!-- Calendar View -->
        <div class="calendar-container p-4">
          <!-- Calendar Navigation -->
          <div class="calendar-head d-flex justify-content-between align-items-center mb-4 gap-3 flex-wrap">
            <button id="prevMonth" type="button" class="btn calendar-nav-btn">
              <i class="bi bi-chevron-left"></i>
            </button>
            <div class="text-center flex-grow-1">
              <p class="text-muted small mb-1">ตารางการจองห้องประชุม</p>
              <h4 id="currentMonth" class="mb-0 fw-bold text-primary"></h4>
              <small id="currentYear" class="text-muted"></small>
            </div>
            <button id="nextMonth" type="button" class="btn calendar-nav-btn">
              <i class="bi bi-chevron-right"></i>
            </button>
          </div>

          <!-- Calendar Grid -->
          <div class="calendar-grid">
            <!-- Weekday Headers -->
            <div class="calendar-weekdays">
              <div class="weekday-header weekday-sunday">อา</div>
              <div class="weekday-header weekday-monday">จ</div>
              <div class="weekday-header weekday-tuesday">อ</div>
              <div class="weekday-header weekday-wednesday">พ</div>
              <div class="weekday-header weekday-thursday">พฤ</div>
              <div class="weekday-header weekday-friday">ศ</div>
              <div class="weekday-header weekday-saturday">ส</div>
            </div>
            
            <!-- Calendar Days -->
            <div id="calendarDays" class="calendar-days">
              <!-- Days will be generated by JavaScript -->
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Upcoming 30 days list -->
    <div class="card border-0 shadow-sm d-print-none">
      <div class="card-body p-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
          <div>
            <p class="section-label mb-1">รายการใน 30 วันข้างหน้า</p>
            <h5 class="section-title mb-0">ช่วงวันที่ <span class="text-primary"><%= upcomingRangeText %></span></h5>
          </div>
          <span class="pill-badge pill-badge--info">
            <i class="bi bi-calendar-week me-1"></i>
            <%= upcomingMeetings.length %> รายการ
          </span>
        </div>

        <% if (upcomingMeetings.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
            <p class="mb-0">ยังไม่มีการจองในช่วง 30 วันข้างหน้า</p>
          </div>
        <% } else { %>
          <div class="upcoming-list" data-preview-limit="8">
            <% upcomingMeetings.forEach((m) => { 
              const meetingDate = parseLocalDate(m.mee_date);
              const isoDate = dateKey(m.mee_date);
              const isToday = isoDate === todayKey;
              const day = meetingDate.getDate();
              const monthLabel = meetingDate.toLocaleDateString('th-TH', { month: 'short' });
              const weekdayLabel = meetingDate.toLocaleDateString('th-TH', { weekday: 'short' });
              const currentYear = meetingDate.getFullYear();
            %>
              <div class="upcoming-item">
                <div class="upcoming-timeline">
                  <span class="timeline-dot"></span>
                  <span class="timeline-line"></span>
                </div>
                <div class="upcoming-card <%= isToday ? 'upcoming-card--today' : '' %>">
                  <div class="upcoming-date">
                    <div class="upcoming-date__day"><%= day %></div>
                    <div class="upcoming-date__meta">
                      <span><%= monthLabel %> <%= currentYear+543 %></span>
                      <small><%= weekdayLabel %></small>
                    </div>
                  </div>
                  <div class="upcoming-body">
                    <div class="upcoming-body__top">
                      <span class="time-chip"><i class="bi bi-clock me-1"></i><%= m.mee_time %></span>
                      <h6 class="mb-0 flex-grow-1"><%= m.mee_subject %></h6>
                    </div>
                    <div class="upcoming-body__meta">
                      <span>
                        <i class="bi bi-house me-1"></i>
                        <%= m.mee_room %></span>
                      <span><i class="bi bi-person me-1"></i><%= m.mee_respon %></span>
                    </div>
                  </div>
                  <div class="upcoming-actions">
                    <button type="button" class="btn btn-sm btn-outline-primary btn-detail"
                      data-id="<%= m.mee_id %>"
                      data-date="<%= isoDate %>"
                      data-date-display="<%= formatDate(m.mee_date) %>"
                      data-time="<%= m.mee_time %>"
                      data-subject="<%- (m.mee_subject || '').replace(/"/g,'&quot;') %>"
                      data-room="<%- (m.mee_room || '').replace(/"/g,'&quot;') %>"
                      data-respon="<%- (m.mee_respon || '').replace(/"/g,'&quot;') %>"
                      data-saveby="<%- (m.mee_saveby || '').replace(/"/g,'&quot;') %>"
                      data-savedate="<%= dateKey(m.mee_savedate) %>"
                      data-savedate-display="<%= formatDate(m.mee_savedate) %>"
                      data-bs-toggle="modal" data-bs-target="#detailModal">
                      <i class="bi bi-eye"></i>
                    </button>
                    <% if (canDelete(m)) { %>
                      <button type="button" class="btn btn-sm btn-outline-danger btn-delete"
                        data-id="<%= m.mee_id %>"
                        data-subject="<%- (m.mee_subject || '').replace(/"/g,'&quot;') %>">
                        <i class="bi bi-trash"></i>
                      </button>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
          <% if (upcomingMeetings.length > 8) { %>
            <div class="meeting-list-toggle-wrap d-md-none mt-3 pt-3 border-top">
              <button type="button" class="btn btn-sm btn-outline-primary rounded-pill meeting-list-toggle" data-expand-label="ดูรายการเพิ่มเติม" data-collapse-label="ซ่อนรายการ">
                <i class="bi bi-chevron-down me-1"></i>ดูรายการเพิ่มเติม
              </button>
              <span class="meeting-list-toggle-meta text-muted small">แสดง 8 จาก <%= upcomingMeetings.length %> รายการ</span>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>

    <!-- Print-only table (always shows all data) -->
    <div class="d-none d-print-block">
      <h3 class="print-title text-center mb-3">ตารางการใช้ห้องประชุม</h3>
      <table class="table table-bordered table-sm">
        <thead>
          <tr>
            <th style="width:60px;">#</th>
            <th style="width:120px;">วันที่</th>
            <th style="width:120px;">เวลา</th>
            <th>เรื่อง</th>
            <th style="width:160px;">ห้อง</th>
            <th style="width:180px;">ผู้รับผิดชอบ</th>
          </tr>
        </thead>
        <tbody>
          <% (meetings || []).forEach(m => { %>
            <tr>
              <td><%= m.mee_id %></td>
              <td><%= formatDate(m.mee_date) %></td>
              <td><%= m.mee_time %></td>
              <td style="word-break:break-word; overflow-wrap:anywhere;"><%= m.mee_subject %></td>
              <td><%= m.mee_room %></td>
              <td><%= m.mee_respon %></td>
            </tr>
          <% }) %>
          <% if (!meetings || meetings.length === 0) { %>
            <tr><td colspan="6" class="text-center">ไม่มีข้อมูล</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Enhanced Detail Modal -->
    <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
          <div class="modal-header bg-primary bg-opacity-10 border-0 pb-3">
            <h5 class="modal-title fw-bold">
              <i class="bi bi-info-circle-fill text-primary me-2"></i>รายละเอียดการใช้ห้องประชุม
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4">
            <div class="row g-3">
              <div class="col-12">
                <div class="info-item p-3 bg-light rounded-3">
                  <label class="small text-muted mb-1 d-block">
                    <i class="bi bi-journal-text me-1"></i>เรื่อง
                  </label>
                  <div class="fw-semibold fs-5" id="md-subject"></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="info-item p-3 bg-light rounded-3">
                  <label class="small text-muted mb-1 d-block">
                    <i class="bi bi-calendar-event me-1"></i>วันที่และเวลา
                  </label>
                  <div class="fw-semibold" id="md-datetime"></div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="info-item p-3 bg-light rounded-3">
                  <label class="small text-muted mb-1 d-block">
                    <i class="bi bi-geo-alt-fill me-1"></i>ห้อง
                  </label>
                  <div class="fw-semibold" id="md-room"></div>
                </div>
              </div>
              <div class="col-12">
                <div class="info-item p-3 bg-light rounded-3">
                  <label class="small text-muted mb-1 d-block">
                    <i class="bi bi-person-fill me-1"></i>ผู้รับผิดชอบ
                  </label>
                  <div class="fw-semibold" id="md-respon"></div>
                </div>
              </div>
              <div class="col-12">
                <div class="d-flex align-items-center gap-2 text-muted small pt-2 border-top">
                  <i class="bi bi-pencil-square"></i>
                  <span>บันทึกโดย <strong class="text-dark" id="md-saveby"></strong></span>
                  <span>•</span>
                  <span id="md-savedate"></span>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer border-0 bg-light">
            <% if (isAdmin) { %>
              <a id="md-edit" href="#" class="btn btn-primary">
                <i class="bi bi-pencil-square me-1"></i>แก้ไข
              </a>
            <% } %>
            <form id="md-delete-form" method="POST" class="d-inline" onsubmit="return confirm('ยืนยันการลบรายการนี้?')">
              <button type="submit" class="btn btn-outline-danger" id="md-delete-btn" style="display: none;">
                <i class="bi bi-trash me-1"></i>ลบ
              </button>
            </form>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
              <i class="bi bi-x-circle me-1"></i>ปิด
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
// Calendar functionality
(function() {
  // Meeting data from server
  const meetings = <%- JSON.stringify(meetings || []) %>;
  const currentUser = <%- user ? JSON.stringify({
    fullname: user.fullname,
    username: user.username,
    name: user.name,
    mClass: user.mClass
  }) : 'null' %>;
  
  // Current date state
  let currentDate = new Date();
  let currentMonth = currentDate.getMonth();
  let currentYear = currentDate.getFullYear();
  
  // Day colors
  const dayColors = {
    0: { bg: 'bg-sunday', name: 'อาทิตย์' },
    1: { bg: 'bg-monday', name: 'จันทร์' },
    2: { bg: 'bg-tuesday', name: 'อังคาร' },
    3: { bg: 'bg-wednesday', name: 'พุธ' },
    4: { bg: 'bg-thursday', name: 'พฤหัสบดี' },
    5: { bg: 'bg-friday', name: 'ศุกร์' },
    6: { bg: 'bg-saturday', name: 'เสาร์' }
  };

  function parseLocalDate(value) {
    if (!value) return null;
    if (value instanceof Date) {
      return new Date(value.getFullYear(), value.getMonth(), value.getDate());
    }
    const match = String(value).match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (match) {
      return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));
    }
    const dt = new Date(value);
    if (Number.isNaN(dt.getTime())) return null;
    return new Date(dt.getFullYear(), dt.getMonth(), dt.getDate());
  }

  function dateKey(value) {
    const dt = parseLocalDate(value);
    if (!dt) return '';
    const year = dt.getFullYear();
    const month = String(dt.getMonth() + 1).padStart(2, '0');
    const day = String(dt.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }
  
  // Group meetings by date
  function groupMeetingsByDate() {
    const meetingsByDate = {};
    meetings.forEach(meeting => {
      if (meeting.mee_date) {
        const date = dateKey(meeting.mee_date);
        if (!meetingsByDate[date]) {
          meetingsByDate[date] = [];
        }
        meetingsByDate[date].push(meeting);
      }
    });
    return meetingsByDate;
  }
  
  // Format date for display
  function formatDate(date) {
    try {
      const dt = parseLocalDate(date);
      if (!dt) return '';
      return dt.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch(e) {
      return '';
    }
  }
  
  // Render calendar
  function renderCalendar() {
    const firstDay = new Date(currentYear, currentMonth, 1);
    const lastDay = new Date(currentYear, currentMonth + 1, 0);
    const prevLastDay = new Date(currentYear, currentMonth, 0);
    
    const firstDayOfWeek = firstDay.getDay();
    const lastDateOfMonth = lastDay.getDate();
    const prevLastDate = prevLastDay.getDate();
    
    // Update month/year display
    const monthNames = ['มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน', 
                       'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'];
    document.getElementById('currentMonth').textContent = monthNames[currentMonth];
    document.getElementById('currentYear').textContent = currentYear + 543; // Buddhist year
    
    const meetingsByDate = groupMeetingsByDate();
    const today = dateKey(new Date());
    
    let calendarHTML = '';
    
    // Previous month days
    for (let i = firstDayOfWeek; i > 0; i--) {
      const day = prevLastDate - i + 1;
      calendarHTML += createDayHTML(day, 'prev-month', null, false);
    }
    
    // Current month days
    for (let day = 1; day <= lastDateOfMonth; day++) {
      const dateStr = dateKey(new Date(currentYear, currentMonth, day));
      const isToday = dateStr === today;
      const dayMeetings = meetingsByDate[dateStr] || [];
      calendarHTML += createDayHTML(day, 'current-month', dayMeetings, isToday);
    }
    
    // Next month days
    const totalCells = firstDayOfWeek + lastDateOfMonth;
    const nextMonthDays = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
    for (let day = 1; day <= nextMonthDays; day++) {
      calendarHTML += createDayHTML(day, 'next-month', null, false);
    }
    
    document.getElementById('calendarDays').innerHTML = calendarHTML;
    bindMeetingItems();
    bindDetailButtons();
  }
  
  // Create HTML for a day
  function createDayHTML(day, monthType, meetings, isToday) {
    const date = new Date(currentYear, currentMonth, day);
    const dayOfWeek = date.getDay();
    const dayColor = dayColors[dayOfWeek];
    const dateStr = dateKey(date);
    
    let classes = 'calendar-day';
    if (monthType === 'prev-month' || monthType === 'next-month') {
      classes += ' calendar-day--muted';
    }
    if (isToday) {
      classes += ' calendar-day--today';
    }
    
    let meetingHTML = '';
    if (meetings && meetings.length > 0) {
      meetingHTML = '<div class="meetings-list mt-2">';
      meetings.slice(0, 3).forEach(meeting => {
        meetingHTML += `
          <button type="button" class="meeting-item" 
                  data-meeting-id="${meeting.mee_id}"
                  data-date="${dateStr}"
                  data-date-display="${formatDate(meeting.mee_date)}"
                  data-time="${meeting.mee_time}"
                  data-subject="${(meeting.mee_subject || '').replace(/"/g, '&quot;')}"
                  data-room="${(meeting.mee_room || '').replace(/"/g, '&quot;')}"
                  data-respon="${(meeting.mee_respon || '').replace(/"/g, '&quot;')}"
                  data-saveby="${(meeting.mee_saveby || '').replace(/"/g, '&quot;')}"
                  data-savedate="${dateKey(meeting.mee_savedate)}"
                  data-savedate-display="${formatDate(meeting.mee_savedate)}"
                  data-bs-toggle="modal" data-bs-target="#detailModal">
            <span class="meeting-time">${meeting.mee_time}</span>
            <span class="meeting-subject text-truncate">${meeting.mee_subject}</span>
          </button>
        `;
      });
      if (meetings.length > 3) {
        meetingHTML += `<div class="text-muted small text-center">+${meetings.length - 3} เพิ่มเติม</div>`;
      }
      meetingHTML += '</div>';
    }
    
    return `
      <div class="${classes}" data-date="${dateStr}">
        <div class="calendar-day__head">
          <div class="day-number ${dayColor.bg}">
            <span>${day}</span>
          </div>
          ${isToday ? '<span class="badge badge-today">วันนี้</span>' : ''}
        </div>
        ${meetingHTML}
      </div>
    `;
  }
  
  function changeMonth(delta) {
    currentMonth += delta;
    if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    } else if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    }
    renderCalendar();
  }
  
  function populateModal(data) {
    document.getElementById('md-subject').textContent = data.subject || '';
    document.getElementById('md-datetime').textContent = `${data.dateDisplay || ''} ${data.time || ''}`.trim();
    document.getElementById('md-room').textContent = data.room || '';
    document.getElementById('md-respon').textContent = data.respon || '';
    document.getElementById('md-saveby').textContent = data.saveby || '';
    document.getElementById('md-savedate').textContent = data.savedateDisplay || '';
    
    const editBtn = document.getElementById('md-edit');
    const deleteBtn = document.getElementById('md-delete-btn');
    const deleteForm = document.getElementById('md-delete-form');
    const meetingId = data.meetingId || data.id;
    const canCurrentUserDelete = currentUser && (
      currentUser.mClass === 'admin' ||
      currentUser.mClass === 'pbt' ||
      currentUser.fullname === data.saveby ||
      currentUser.username === data.saveby ||
      currentUser.name === data.saveby
    );
    
    if (editBtn && meetingId) {
      editBtn.href = `/meetingroom/edit/${meetingId}`;
    }
    
    if (deleteBtn && deleteForm && meetingId) {
      deleteBtn.style.display = canCurrentUserDelete ? 'inline-block' : 'none';
      deleteForm.action = `/meetingroom/delete/${meetingId}`;
    }
  }

  function bindMeetingItems() {
    document.querySelectorAll('.meeting-item').forEach(item => {
      item.addEventListener('click', function() {
        populateModal(this.dataset);
      });
    });
  }

  function bindDetailButtons() {
    document.querySelectorAll('.btn-detail').forEach(btn => {
      btn.addEventListener('click', function() {
        populateModal(this.dataset);
      });
    });
  }
  
  // Initialize calendar
  const prevBtn = document.getElementById('prevMonth');
  const nextBtn = document.getElementById('nextMonth');
  if (prevBtn && nextBtn) {
    prevBtn.addEventListener('click', () => changeMonth(-1));
    nextBtn.addEventListener('click', () => changeMonth(1));
  }
  renderCalendar();
  
  // Existing modal and delete functionality
  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', function(event) {
      event.preventDefault();
      event.stopImmediatePropagation();
      if (confirm('ยืนยันการลบรายการนี้?')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/meetingroom/delete/${this.dataset.id}`;
        document.body.appendChild(form);
        form.submit();
      }
    });
  });
  
  // Print functionality
  document.getElementById('btnPrint').addEventListener('click', () => {
    window.print();
  });
  
  // CSV export functionality
  document.getElementById('btnCsv').addEventListener('click', () => {
    const csvContent = "data:text/csv;charset=utf-8," 
      + "วันที่,เวลา,เรื่อง,ห้อง,ผู้รับผิดชอบ,ผู้บันทึก,วันที่บันทึก\n"
      + meetings.map(m => 
        `"${formatDate(m.mee_date)}","${m.mee_time}","${m.mee_subject}","${m.mee_room}","${m.mee_respon}","${m.mee_saveby}","${formatDate(m.mee_savedate)}"`
      ).join("\n");
    
    const encodedUri = encodeURI(csvContent);
    const link = document.createElement("a");
    link.setAttribute("href", encodedUri);
    link.setAttribute("download", `meetingroom_${dateKey(new Date())}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });
})();
</script>

