<%- include('../partials/header', { title: 'โครงการ' }) %>
<% const canManage = user && (user.mClass=='admin' || user.mClass=='pbt'); %>

<style>
  :root {
    --primary: #0f766e;
    --primary-dark: #115e59;
    --light-bg: #f8fafc;
    --surface: #ffffff;
    --border-color: #e5e7eb;
    --text-main: #0f172a;
    --text-muted: #64748b;
  }

  .project-card .project-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .project-card .project-main {
    flex: 1;
    min-width: 0;
  }

  .page-header {
    background: var(--light-bg);
    color: var(--text-main);
    padding: 2rem 0 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .search-wrapper {
    margin-bottom: 1.25rem;
  }

  .search-card {
    background: var(--surface);
    border-radius: 0.95rem;
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
    padding: 1.25rem;
    border: 1px solid var(--border-color);
  }

  .search-input {
    background: #ffffff;
    border: 1px solid var(--border-color);
    border-radius: 0.8rem;
    padding: 0.75rem 1rem;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  .search-input:focus {
    background: white;
    border-color: var(--primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.12);
  }

  .btn-primary-action {
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 0.8rem;
    padding: 0.75rem 1.5rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-primary-action:hover {
    background: var(--primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 6px 14px rgba(15, 118, 110, 0.14);
    color: white;
  }

  .project-card {
    background: var(--surface);
    border-radius: 0.95rem;
    border: 1px solid var(--border-color);
    padding: 1.25rem;
    height: 100%;
    transition: all 0.3s ease;
    overflow: hidden;
    position: relative;
  }

  .project-card:hover {
    border-color: rgba(15, 118, 110, 0.25);
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
    transform: translateY(-2px);
  }

  .year-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #ecfdf5;
    color: var(--primary-dark);
    font-size: 0.75rem;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    font-weight: 600;
  }

  .project-icon {
    width: 56px;
    height: 56px;
    background: #f1f5f9;
    color: var(--primary);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .project-no {
    background: var(--light-bg);
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    border-radius: 0.5rem;
    font-weight: 500;
    display: inline-block;
    margin-top: 0.5rem;
  }

  .project-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-main);
    line-height: 1.5;
    margin: 1rem 0 1.25rem 0;
    white-space: normal;
    overflow: visible;
    word-break: break-word;
  }

  .project-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .project-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-color);
  }

  .btn-view {
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 0.65rem;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
    flex-grow: 1;
  }

  .btn-view:hover {
    background: var(--primary-dark);
    color: white;
    text-decoration: none;
  }

  .dropdown-toggle::after {
    display: none;
  }

  .dropdown-item {
    font-size: 0.9rem;
    padding: 0.6rem 1rem;
  }

  .dropdown-item:hover {
    background: var(--light-bg);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--light-bg);
    border-radius: 1rem;
    border: 1px dashed var(--border-color);
  }

  .empty-icon {
    font-size: 3rem;
    color: #cbd5e1;
    margin-bottom: 1rem;
  }

  .empty-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.5rem;
  }

  .empty-text {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .results-info {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .results-info strong {
    color: var(--text-main);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 1rem 0 1rem;
      margin-bottom: 1rem;
    }

    .search-wrapper {
      margin-bottom: 1rem;
    }

    .search-card {
      padding: 1rem;
      border-radius: 1rem;
    }

    .project-card .project-row {
      gap: 0.85rem;
    }

    .project-card {
      padding: 1rem;
      border-radius: 1rem;
    }

    .project-title {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .year-badge {
      font-size: 0.7rem;
      padding: 0.3rem 0.6rem;
    }

    .project-actions {
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .project-actions .btn,
    .project-actions .dropdown {
      flex: 1 1 auto;
    }

    .project-actions .dropdown .btn {
      width: 100%;
    }
  }
</style>

<!-- Header -->
<div class="page-header">
  <div class="container">
    <div class="mobile-page-header mb-0">
      <div>
        <h1 class="mobile-page-header__title">โครงการ</h1>
        <p class="mobile-page-header__subtitle">ค้นหาและเปิดดูเอกสารโครงการได้รวดเร็วขึ้นบนมือถือและหน้าจอขนาดเล็ก</p>
      </div>
      <div class="mobile-page-header__meta">
        <span class="mobile-chip"><i class="bi bi-folder2-open"></i><%= (pagination && pagination.total) ? pagination.total : ((projects && projects.length) ? projects.length : 0) %> รายการ</span>
      </div>
    </div>
  </div>
</div>

<div class="container">
  <!-- Search & Filter -->
  <div class="search-wrapper">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="search-card">
          <form id="project-search-form"
                class="d-flex flex-column flex-md-row gap-2"
                method="GET"
                action="/project">
            <input type="hidden" name="page" value="1">
            <div class="position-relative flex-grow-1">
              <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
              <input id="project-search-input"
                     type="text"
                     class="form-control search-input ps-5"
                     name="search"
                     placeholder="ค้นหาชื่อโครงการ..."
                     value="<%= search || '' %>">
            </div>
            <select class="form-select" name="pageSize" style="max-width: 150px;">
              <% [12, 24, 48].forEach(size => { %>
                <option value="<%= size %>" <%= pagination && pagination.pageSize === size ? 'selected' : '' %>><%= size %>/หน้า</option>
              <% }) %>
            </select>
            <button class="btn btn-primary-action" type="submit">ค้นหา</button>
            <% if(search) { %>
              <a href="/project" class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="ล้างการค้นหา">
                <i class="bi bi-x-lg"></i>
              </a>
            <% } %>
            <% if (canManage) { %>
              <a href="/project/create" class="btn btn-primary-action">
                <i class="bi bi-plus-lg me-2"></i>เพิ่มโครงการ
              </a>
            <% } %>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Results Info -->
  <div id="project-results-info" class="results-info">
    <i class="bi bi-folder2-open me-2"></i>
    พบทั้งหมด <strong><%= (pagination && pagination.total) ? pagination.total : ((projects && projects.length) ? projects.length : 0) %></strong> รายการ
    <% if (pagination) { %>
      <span class="ms-2">หน้า <strong><%= pagination.page %></strong> / <strong><%= pagination.totalPages %></strong></span>
    <% } %>
  </div>

  <!-- Project Grid -->
  <div id="project-grid" class="row g-3">
    <% if (projects && projects.length) { %>
      <% projects.forEach(p => { %>
        <div class="col-12">
          <div class="project-card">
            <div class="year-badge">ปี <%= p.pro_year %></div>

            <div class="project-row">
              <div class="project-icon">
                <i class="bi bi-folder-check"></i>
              </div>

              <div class="project-main">
                <% const thaiDate = new Date(p.pro_date).toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' }); %>
                <div class="project-meta">
                  <i class="bi bi-calendar-event me-1"></i><%= thaiDate %>
                </div>

                <div class="project-no">เลขที่ <%= p.pro_no %></div>

                <h5 class="project-title">
                  <%= p.pro_story %>
                </h5>

                <div class="project-actions">
                  <% if (user) { %>
                    <a href="/project/download/<%= p.pro_id %>" class="btn btn-view" target="_blank">
                      <i class="bi bi-file-earmark-pdf me-1"></i>เปิดดู
                    </a>
                  <% } else { %>
                    <a href="/auth/login" class="btn btn-view">
                      <i class="bi bi-lock-fill me-1"></i>เข้าสู่ระบบ
                    </a>
                  <% } %>

                  <% if (canManage) { %>
                    <div class="dropdown">
                      <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown" title="เพิ่มเติม">
                        <i class="bi bi-three-dots"></i>
                      </button>
                      <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li><a class="dropdown-item" href="/project/edit/<%= p.pro_id %>">
                          <i class="bi bi-pencil me-2 text-warning"></i>แก้ไข
                        </a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                          <form action="/project/delete/<%= p.pro_id %>" method="POST" onsubmit="return confirm('ต้องการลบรายการนี้หรือไม่?');">
                            <button class="dropdown-item text-danger" type="submit">
                              <i class="bi bi-trash me-2"></i>ลบ
                            </button>
                          </form>
                        </li>
                      </ul>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12">
        <div class="empty-state">
          <div class="empty-icon">
            <i class="bi bi-inbox"></i>
          </div>
          <div class="empty-title">ไม่พบข้อมูลโครงการ</div>
          <p class="empty-text">ลองเปลี่ยนคำค้นหา หรือ<% if(canManage) { %> <a href="/project/create">เพิ่มโครงการใหม่</a><% } %></p>
        </div>
      </div>
    <% } %>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
    <% const baseQuery = (extra = {}) => {
         const params = new URLSearchParams();
         if (search) params.set('search', search);
         if (pagination.pageSize) params.set('pageSize', pagination.pageSize);
         Object.keys(extra).forEach(key => params.set(key, extra[key]));
         return '?' + params.toString();
       }; %>
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mt-4">
      <div class="text-muted small">แสดง <%= projects.length %> รายการจากทั้งหมด <%= pagination.total %> รายการ</div>
      <nav aria-label="Project pagination">
        <ul class="pagination pagination-sm mb-0 flex-wrap">
          <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.page === 1 ? '#' : baseQuery({ page: 1 }) %>">&laquo;</a>
          </li>
          <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.hasPrev ? baseQuery({ page: pagination.page - 1 }) : '#' %>">&lsaquo;</a>
          </li>
          <% const windowSize = 5;
             let start = Math.max(1, pagination.page - Math.floor(windowSize / 2));
             let end = Math.min(pagination.totalPages, start + windowSize - 1);
             if (end - start + 1 < windowSize) start = Math.max(1, end - windowSize + 1);
             for (let pageNumber = start; pageNumber <= end; pageNumber++) { %>
            <li class="page-item <%= pageNumber === pagination.page ? 'active' : '' %>">
              <a class="page-link" href="<%= baseQuery({ page: pageNumber }) %>"><%= pageNumber %></a>
            </li>
          <% } %>
          <li class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.hasNext ? baseQuery({ page: pagination.page + 1 }) : '#' %>">&rsaquo;</a>
          </li>
          <li class="page-item <%= pagination.page === pagination.totalPages ? 'disabled' : '' %>">
            <a class="page-link" href="<%= pagination.page === pagination.totalPages ? '#' : baseQuery({ page: pagination.totalPages }) %>">&raquo;</a>
          </li>
        </ul>
      </nav>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
