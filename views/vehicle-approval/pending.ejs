<%- include('../partials/header') %>
<%- include('../partials/travel-navbar', { currentPage: 'approval' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
  <div>
    <h3 class="mb-1">คิวอนุมัติคำขอ</h3>
    <p class="text-muted mb-0">ตรวจสอบคำขอไปราชการและคำขอใช้รถที่รอการพิจารณา</p>
  </div>
</div>

<% if (warning) { %>
  <div class="alert alert-warning"><%= warning %></div>
<% } %>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <h5 class="mb-0">คำขอไปราชการรออนุมัติ</h5>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>เลขที่</th>
              <th>เรื่อง</th>
              <th>ผู้ขอ</th>
              <th class="text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (!travelItems.length) { %>
              <tr><td colspan="4" class="text-center py-4 text-muted">ไม่มีคำขอไปราชการรออนุมัติ</td></tr>
            <% } %>
            <% travelItems.forEach((item) => { %>
              <tr>
                <td><%= item.request_no %></td>
                <td>
                  <div class="fw-semibold"><%= item.subject %></div>
                  <small class="text-muted"><%= item.destination_text %></small>
                </td>
                <td><%= item.requester_name %></td>
                <td class="text-end"><a href="/vehicle-approval/travel/<%= item.id %>" class="btn btn-sm btn-outline-primary">พิจารณา</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <h5 class="mb-0">คำขอใช้รถรออนุมัติ/มอบหมาย</h5>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>เลขที่</th>
              <th>ปลายทาง</th>
              <th>ผู้ขอ</th>
              <th class="text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (!vehicleItems.length) { %>
              <tr><td colspan="4" class="text-center py-4 text-muted">ไม่มีคำขอใช้รถที่รออนุมัติหรือมอบหมาย</td></tr>
            <% } %>
            <% vehicleItems.forEach((item) => { %>
              <tr>
                <td>
                  <div class="fw-semibold"><%= item.travel_request_no || item.vehicle_request_no %></div>
                  <small class="text-muted"><%= item.status %></small>
                </td>
                <td><%= item.destination_text %></td>
                <td><%= item.requester_name %></td>
                <td class="text-end"><a href="/vehicle-approval/request/<%= item.id %>" class="btn btn-sm btn-outline-primary">พิจารณา</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0 mt-4">
  <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
    <div>
      <h5 class="mb-0">สถานะรถ 7 วันข้างหน้า</h5>
      <div class="small text-muted">
        <% if (availabilityStart && availabilityEnd) { %>
          ช่วง <%= new Date(availabilityStart).toLocaleDateString('th-TH', { dateStyle: 'medium', timeZone: 'Asia/Bangkok' }) %> ถึง <%= new Date(availabilityEnd).toLocaleDateString('th-TH', { dateStyle: 'medium', timeZone: 'Asia/Bangkok' }) %>
        <% } else { %>
          แสดงสถานะรถที่มีการมอบหมายในช่วง 7 วันถัดไป
        <% } %>
      </div>
    </div>
    <span class="badge bg-primary"><%= vehicleAvailability.length %> คัน</span>
  </div>
  <div class="table-responsive">
    <table class="table table-bordered mb-0 align-middle">
      <thead class="table-light">
        <tr>
          <th style="min-width: 160px; position: sticky; left: 0; background: #f8f9fa; z-index: 2;">วันที่</th>
          <% (vehicleAvailability || []).forEach((vehicle) => { %>
            <th class="text-center" style="min-width: 170px;">
              <div class="fw-semibold"><%= vehicle.plate_no %></div>
              <div class="small text-muted"><%= vehicle.vehicle_name || '-' %></div>
            </th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% if (!(availabilityMatrix || []).length) { %>
          <tr>
            <td colspan="<%= (vehicleAvailability || []).length + 1 %>" class="text-center py-4 text-muted">ยังไม่มีข้อมูลรถในช่วง 7 วันข้างหน้า</td>
          </tr>
        <% } %>
        <% (availabilityMatrix || []).forEach((row) => { %>
          <tr>
            <th class="table-light" style="position: sticky; left: 0; z-index: 1;"><%= row.date_label %></th>
            <% (row.cells || []).forEach((cell) => { %>
              <td class="align-top">
                <% if (cell.available) { %>
                  <div class="badge bg-success mb-2">ว่าง</div>
                <% } else { %>
                  <div class="badge bg-danger mb-2">ไม่ว่าง</div>
                  <% cell.assignments.forEach((assignment) => { %>
                    <div class="mb-2 p-2 rounded border bg-light">
                      <div class="fw-semibold"><%= assignment.vehicle_request_no %></div>
                      <div class="small text-muted">
                        <%= new Date(assignment.trip_start_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Bangkok' }) %>
                        ถึง
                        <%= new Date(assignment.trip_end_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Bangkok' }) %>
                      </div>
                      <div class="small">คนขับ: <%= assignment.driver_name || '-' %></div>
                    </div>
                  <% }) %>
                <% } %>
              </td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
