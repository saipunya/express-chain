<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/random-names.css">
  </head>
  <body>
    <main class="random-page">
      <div class="container py-4 py-lg-5">
        <div class="random-auth-panel mx-auto">
          <div class="random-auth-icon">
            <i class="bi bi-shield-lock-fill"></i>
          </div>
          <h1 class="random-title">เข้าสู่หน้าจัดการรางวัล</h1>
          <p class="random-subtitle">กรอกรหัสผ่านเพื่อแก้ไขหรือลบรายชื่อผู้ได้รับรางวัล</p>

          <% if (error) { %>
            <div class="alert alert-danger random-import-status" role="alert">
              <i class="bi bi-exclamation-triangle-fill"></i>
              <span><%= error %></span>
            </div>
          <% } %>

          <form action="/random-names/admin/login" method="post" class="random-auth-form">
            <div>
              <label for="adminPassword" class="form-label">รหัสผ่าน</label>
              <input id="adminPassword" type="password" name="password" class="form-control form-control-lg" inputmode="numeric" autocomplete="current-password" required autofocus>
            </div>
            <button type="submit" class="btn random-action-btn random-submit-btn">
              <i class="bi bi-unlock-fill"></i>
              <span>เข้าสู่ระบบ</span>
            </button>
            <a href="/random-names/play" class="btn random-cancel-btn">กลับหน้าสุ่ม</a>
          </form>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </body>
</html>
