<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>พิมพ์คำขอไปราชการ</title>
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Sarabun', 'TH SarabunPSK', 'TH Sarabun New', Arial, sans-serif;
      margin: 0;
      padding: 24px;
      background: #fff;
      color: #111;
    }
    .print-sheet {
      max-width: 900px;
      margin: 0 auto;
      padding: 24px;
      box-sizing: border-box;
    }
    .document-header {
      text-align: center;
      margin-bottom: 20px;
    }
    .document-header h1 {
      margin: 0;
      font-size: 28px;
      letter-spacing: 0.05em;
    }
    .meta-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 24px;
    }
    .meta-table td {
      padding: 8px 6px;
      vertical-align: top;
      border-bottom: 1px dotted #999;
    }
    .meta-table .label {
      width: 120px;
      font-weight: 700;
      white-space: nowrap;
    }
    .section-title {
      font-size: 16px;
      font-weight: 700;
      margin: 20px 0 8px;
    }
    .signature-block {
      margin-top: 48px;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
    }
    .signature-area {
      min-width: 320px;
      text-align: center;
    }
    .no-print {
      margin-bottom: 24px;
      text-align: right;
    }
    @media print {
      .no-print { display: none; }
      body { padding: 0; }
      .print-sheet { box-shadow: none; padding: 0; }
    }
  </style>
</head>
<body>
  <div class="print-sheet">
    <div class="no-print">
      <button onclick="window.print()">พิมพ์</button>
    </div>

    <div class="document-header">
      <h1 style="font-size:32px;margin-bottom:8px;">บันทึกข้อความ</h1>
    </div>
    <% function thaiDate(dateStr) {
      if (!dateStr) return '-';
      const d = new Date(dateStr);
      if (isNaN(d)) return '-';
      const months = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
      return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear() + 543}`;
    } %>
    <table class="meta-table">
      <tr>
        <td class="label">ส่วนราชการ</td>
        <td colspan="3"><%= item.department_name || 'สำนักงาน/กลุ่มงาน/หน่วยงาน' %></td>
      </tr>
      <tr>
        <td class="label">ที่</td>
        <td style="width:180px"><%= item.request_no || '-' %></td>
        <td class="label">วันที่</td>
        <td><%= thaiDate(item.request_date) %></td>
      </tr>
      <tr>
        <td class="label">เรื่อง</td>
        <td colspan="3"><%= item.subject || 'ขออนุญาตไปราชการ' %></td>
      </tr>
      <tr>
        <td class="label">เรียน</td>
        <td colspan="3"><%= item.learn_to || '-' %></td>
      </tr>
    </table>

    <div style="margin-bottom: 24px; font-size: 16px; line-height: 2.1;">
      <span>ข้าพเจ้า <strong><%= item.requester_name || '-' %></strong> ตำแหน่ง <strong><%= item.requester_position || '-' %></strong> กลุ่มงาน <strong><%= item.requester_group || '-' %></strong></span>
      <span>มีความประสงค์ขออนุญาตไปราชการเพื่อ <strong><%= item.purpose_text || '-' %></strong></span><br>
      <span>สถานที่ <strong><%= item.destination_text || '-' %></strong></span>
      <span>ในวันที่ <strong><%= item.start_at ? thaiDate(item.start_at) : '-' %></strong></span>
      <% if (item.end_at && item.end_at !== item.start_at) { %>
        <span>ถึงวันที่ <strong><%= thaiDate(item.end_at) %></strong></span>
      <% } %>
      <span>วิธีเดินทาง <strong><%= item.transport_type || '-' %> <%= item.transport_other_text || '' %></strong></span>
    </div>

    <div>
      <div class="section-title">ผู้ร่วมเดินทาง</div>
      <% if (item.companions && item.companions.length > 0) { %>
        <ol>
          <% item.companions.forEach((companion) => { %>
            <li><%= companion.companion_name %> (<%= companion.companion_position || '-' %>)</li>
          <% }) %>
        </ol>
      <% } else { %>
        <div style="margin-left: 24px;">-</div>
      <% } %>
    </div>

    <% const hasEstimatedCosts = item.transport_type === 'official_vehicle' || Number(item.estimated_allowance) > 0 || Number(item.estimated_lodging) > 0 || Number(item.estimated_fuel) > 0; %>
    <% if (hasEstimatedCosts) { %>
      <div style="margin: 16px 0 24px;">
        <div class="section-title">ประมาณการค่าใช้จ่าย</div>
        <table style="width:100%; border-collapse:collapse; font-size:16px; line-height:2;">
          <tr>
            <td style="width: 50%; padding: 4px 0;">ค่าเบี้ยเลี้ยง (บาท)</td>
            <td style="padding: 4px 0; border-bottom: 1px dotted #999;"><strong><%= item.estimated_allowance ?? '-' %></strong></td>
          </tr>
          <tr>
            <td style="padding: 4px 0;">ค่าที่พัก (บาท)</td>
            <td style="padding: 4px 0; border-bottom: 1px dotted #999;"><strong><%= item.estimated_lodging ?? '-' %></strong></td>
          </tr>
          <tr>
            <td style="padding: 4px 0;">ค่าพาหนะ/น้ำมันเชื้อเพลิง (บาท)</td>
            <td style="padding: 4px 0; border-bottom: 1px dotted #999;"><strong><%= item.estimated_fuel ?? '-' %></strong></td>
          </tr>
        </table>
      </div>
    <% } %>

    <div class="signature-block">
      <div class="signature-area">
        <div style="margin-bottom: 48px;">&nbsp;</div>
        <div>ลงชื่อ....................................................</div>
        <div>(<%= item.requester_name || '-' %>)</div>
        <div style="margin-top: 4px;">ตำแหน่ง....................................................</div>
      </div>
    </div>
  </div>
</body>
</html>
